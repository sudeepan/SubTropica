   (* == FILL IN: sp[pi,pj] -> value for every independent external invariant == *)
   kinematicRules = {(*  e.g.  sp[p3, p3] -> s  *)};
   (Set @@ #) & /@ kinematicRules;
   toSP[expr_] := expr /. Power[mom_, 2] /; ! FreeQ[mom, Alternatives @@ Join[atomicLoops, atomicExt]] :> sp[Expand[mom]];
   lrDir = FileNameJoin[{$TemporaryDirectory, "fam_lr"}];
   If[DirectoryQ[lrDir], DeleteDirectory[lrDir, DeleteContents -> True]];
