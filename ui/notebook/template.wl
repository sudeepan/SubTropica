   (* m = the DE matrix dI/dx = m.I from your IBP reduction *)
   FuchsianQ[m, x]    (* test the current form *)
   Fuchsify[m, x]     (* reduce to Fuchsian form; then Normalize/Balance to eps-form -- see Examples/ *)
