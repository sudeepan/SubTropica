(* ::Text:: *)
(*SubTropica does not perform IBP reduction, but the k-space propagators of your graph can be obtained directly from the edge/node lists via STGetLoopsProps. The cell below builds a Mathematica Graph from edges, routes loop momenta through the spanning tree + chords, and returns the list of inverse propagators q_i^2 - m_i^2 in loop+external-momentum form.*)


stMaxVertex = Max[Flatten[edges[[All, 1]]]];
stExtLegs = Table[UndirectedEdge[nodes[[i, 1]], stMaxVertex + i], {i, Length[nodes]}];
stGraph = Graph[
	DeleteDuplicates[Join[Flatten[edges[[All, 1]]], stMaxVertex + Range[Length[nodes]]]],
	Join[UndirectedEdge @@@ edges[[All, 1]], stExtLegs]];
{loopMomenta, propagators} = STGetLoopsProps[stGraph];
propagators = propagators /. Table[mm[i] -> edges[[i, 2]]^2, {i, Length[edges]}];
Print["Loop momenta: ", loopMomenta];
Print["Propagators (routed): ", propagators];


