STToPySecDec::pythonfail = "Python script failed (exit code `1`): `2`.";

Options[STToPySecDec] = {
	"Order"              -> 0,
	"Accuracy"           -> 1*^-4,
	"MaxEval"            -> 10^7,
	"KinematicPoint"     -> {},
	"Verbose"            -> False,
	"ContourDeformation" -> True,
	"CacheDirectory"     -> Automatic,
	"Normalization"      -> Automatic,
	"Dimension"          -> 4 - 2 eps,
	"Exponents"          -> Automatic,
	"LoopMomenta"        -> Automatic,
	"Substitutions"      -> {},
	"Integrator"         -> "Qmc",  (* "Qmc", "Disteval", or "Vegas" *)
	"MaxTime"            -> Automatic   (* wall-clock cap on the Python subprocess (signal.alarm + subprocess.run timeout).  Automatic = 3600 s; pass an integer (seconds) to override; Infinity disables. *)
};

STToPySecDec[g:{_List, _List}, opts:OptionsPattern[]] :=
	stPySecDecFromGraph[g, FilterRules[{opts}, Options[STToPySecDec]]];

STToPySecDec[props_List, opts:OptionsPattern[]] :=
	stPySecDecFromPropagators[props, FilterRules[{opts}, Options[STToPySecDec]]];

stMmaExprToPython[0] := "0";
stMmaExprToPython[0.] := "0";
stMmaExprToPython[n_Integer] := ToString[n];
stMmaExprToPython[n_Rational] := "Rational(" <> ToString[Numerator[n]] <> "," <> ToString[Denominator[n]] <> ")";
stMmaExprToPython[n_Real] := ToString[CForm[n]];
stMmaExprToPython[expr_] := Module[{e, s},
	(* Pre-flatten arbitrary-arity Subscript[head, integers...] -> head_with_digits
	   so 6+-leg Mandelstams like Subscript[s, 1, 2, 3] become s123 instead of
	   leaking through as the literal "Subscript[s, 1, 2, 3]" string (which
	   then fails Symbol[]/sympy parsing on the pySecDec side). *)
	e = expr //. Subscript[h_Symbol, args__Integer] :>
		Symbol[SymbolName[h] <> StringJoin[ToString /@ {args}]];
	s = ToString[e, InputForm];
	s = StringReplace[s, {
		(* The 2-arg Subscript[s, i, j] form is now redundant after the //. above
		   but keep it for safety against any expr that bypasses pre-flattening. *)
		RegularExpression["Subscript\\[m,\\s*(\\d+)\\]"] :> "m$1",
		RegularExpression["Subscript\\[M,\\s*(\\d+)\\]"] :> "M$1",
		RegularExpression["Subscript\\[s,\\s*(\\d+),\\s*(\\d+)\\]"] :> "s$1$2",
		RegularExpression["Subscript\\[p,\\s*(\\d+)\\]"] :> "p$1",
		RegularExpression["l\\[(\\d+)\\]"] :> "l$1",
		RegularExpression["p\\[(\\d+)\\]"] :> "p$1",
		RegularExpression["q\\[(\\d+)\\]"] :> "q$1",
		RegularExpression["k\\[(\\d+)\\]"] :> "k$1",
		RegularExpression["M\\[(\\d+)\\]"] :> "M$1",
		RegularExpression["m\\[(\\d+)\\]"] :> "m$1",
		"Sqrt[" ~~ x:Shortest[__] ~~ "]" :> "sqrt(" <> x <> ")",
		"^" -> "**"
	}];
	(* Second pass: convert Mathematica function-call notation Gamma[...] ->
	   gamma(...) AFTER ^ -> ** so that any powers inside the argument are
	   already in Python syntax.  pySecDec's SymPy parser knows `gamma` but
	   treats `Gamma` as a plain Symbol, causing "'Symbol' is not subscriptable". *)
	s = StringReplace[s,
		"Gamma[" ~~ x:Shortest[__] ~~ "]" :> "gamma(" <> x <> ")"
	];
	s
];

(* Short, readable cache-dir suffix per Dimension expression, so different
   D values keep separate compiled packages instead of thrashing each other.
   D0 - 2 eps (integer/rational D0) -> "D4m2e", "D6m2e", "D11d2m2e"; any
   other expression -> 6-hex-char hash.  Must be a deterministic function
   of dim; Hash of the canonicalized Python string keeps it context-stable. *)
stDimDirTag[dim_] := Module[{D0, residual},
	D0 = dim /. eps -> 0;
	residual = dim - D0;
	Which[
		residual === -2*eps && IntegerQ[D0] && D0 >= 0,
			"D" <> ToString[D0] <> "m2e",
		residual === -2*eps && MatchQ[D0, _Rational] && D0 > 0,
			"D" <> ToString[Numerator[D0]] <> "d" <> ToString[Denominator[D0]] <> "m2e",
		True,
			"D" <> IntegerString[Hash[stMmaExprToPython[dim], "SHA256"], 16, 6]
	]
];

stPySecDecFromGraph[{edges_, nodes_}, opts:OptionsPattern[STToPySecDec]] :=
Module[{nEdges, nExt, nVerts, edgePairs, edgeMasses, nodeVerts, nodeMasses,
	internalLines, externalLines, replacementRules, genKin, nLoops,
	realParamSymbols, realParamNames, massSqExprs, kinRules, integralData,
	order, dim, contDef, normalization, nNu, powers, exponents},

	nEdges = Length[edges];
	nExt = Length[nodes];
	edgePairs = edges[[All, 1]];
	edgeMasses = edges[[All, 2]];
	nodeVerts = nodes[[All, 1]];
	nodeMasses = nodes[[All, 2]];
	nVerts = Length[Union[Flatten[edgePairs]]];
	nLoops = 1 + nEdges - nVerts;

	exponents = OptionValue["Exponents"];
	powers = If[exponents === Automatic, ConstantArray[1, nEdges], exponents];
	nNu = Total[powers];
	order = OptionValue["Order"];
	dim = OptionValue["Dimension"];
	contDef = OptionValue["ContourDeformation"];
	normalization = OptionValue["Normalization"];

	internalLines = Table[
		"{\"mass\": \"" <> stMmaExprToPython[edgeMasses[[i]]] <>
		"\", \"vertices\": [" <> ToString[edgePairs[[i, 1]]] <> ", " <> ToString[edgePairs[[i, 2]]] <> "]}",
		{i, nEdges}
	];

	externalLines = Table[
		"{\"momentum\": \"p" <> ToString[i] <> "\", \"vertex\": " <> ToString[nodeVerts[[i]]] <> "}",
		{i, nExt}
	];

	genKin = GenerateKinematics[nExt];

	(* Express external invariants as squared quantities.
	   Node mass M means p^2 = M^2. For Euclidean, p^2 < 0, so we need
	   the squared quantity as the parameter (not M itself).
	   - Node mass 0 \[RightArrow] p^2 = 0 (no parameter)
	   - Node mass Sqrt[s] \[RightArrow] p^2 = s (parameter is s)
	   - Node mass M that is ALSO an internal edge mass \[RightArrow] bake
	     p^2 = M^2 directly into the replacement rules (no new parameter),
	     so pySecDec's sector decomposition sees the factored F at compile
	     time. Otherwise a generic coefficient (m^2 - msq) would vanish
	     only at the special shared-mass point, and the pre-compiled
	     integrand would miss the second \[CurlyEpsilon]-pole.
	   - Node mass M otherwise \[RightArrow] introduce MM as parameter *)
	Module[{extInvariants, kinRulesSquared, mandelstans},
		extInvariants = Table[
			Module[{nm = nodeMasses[[i]], sq},
				sq = Expand[nm^2];
				Which[
					sq === 0, 0,
					MatchQ[sq, _Symbol], sq,
					stIsSharedMassLeg[{edges, nodes}, i] =!= None, sq,
					True, Symbol[StringReplace[stMmaExprToPython[nm], "**" -> ""] <> "sq"]
				]
			],
		{i, nExt}];

		(* Subscript[M,i] \[RightArrow] Sqrt[extInvariant_i] so that Subscript[M,i]^2 \[RightArrow] extInvariant_i *)
		kinRulesSquared = Table[
			Subscript[M, i] -> If[extInvariants[[i]] === 0, 0, Sqrt[extInvariants[[i]]]],
		{i, nExt}];

		replacementRules = Table[
			Module[{lhs, rhs, pi, pj, lhsStr, rhsStr},
				lhs = genKin[[r, 1]];
				rhs = genKin[[r, 2]] /. kinRulesSquared // Expand;
				pi = lhs[[1]] /. Subscript[p, k_] :> k;
				pj = lhs[[2]] /. Subscript[p, k_] :> k;
				lhsStr = "p" <> ToString[pi] <> "*p" <> ToString[pj];
				rhsStr = stMmaExprToPython[rhs];
				"('" <> lhsStr <> "', '" <> rhsStr <> "')"
			],
			{r, Length[genKin]}
		];

		mandelstans = Cases[genKin[[All, 2]] /. kinRulesSquared, Subscript[s, __], {0, Infinity}]
			// DeleteDuplicates;

		(* Flatten all subscripts/indexed symbols to plain symbols for KinematicPoint matching *)
		flattenSym[sym_] := Symbol[stMmaExprToPython[sym]];
		realParamSymbols = Join[
			Cases[edgeMasses, _Symbol | _[_Integer], {0, Infinity}] // DeleteDuplicates,
			(* Skip non-atomic extInvariants entries (e.g. shared-mass m^2): the
			   internal mass symbol itself is already picked up from edgeMasses
			   above, and feeding m^2 would create a bogus Python parameter. *)
			Select[extInvariants, # =!= 0 && !NumericQ[#] && MatchQ[#, _Symbol | _[_Integer]] &] // DeleteDuplicates,
			mandelstans
		] // DeleteDuplicates;
		realParamSymbols = flattenSym /@ realParamSymbols;
	];

	realParamNames = ToString /@ realParamSymbols;

	Module[{ilStr, elStr, defaultPwStr, dimPy},
		ilStr = "[" <> StringRiffle[internalLines, ", "] <> "]";
		elStr = "[" <> StringRiffle[externalLines, ", "] <> "]";
		dimPy = "'" <> stMmaExprToPython[dim] <> "'";
		defaultPwStr = "[" <> StringRiffle[ConstantArray["1", nEdges], ", "] <> "]";
		pyIntegralBlock =
"        il_raw = " <> ilStr <> "
        internal_lines = [[d['mass'], d['vertices']] for d in il_raw]
        el_raw = " <> elStr <> "
        external_lines = [[d['momentum'], d['vertex']] for d in el_raw]

        li = LoopIntegralFromGraph(
            internal_lines=internal_lines,
            external_lines=external_lines,
            replacement_rules=replacement_rules,
            dimensionality=" <> dimPy <> ",
            powerlist=powerlist if powerlist != " <> defaultPwStr <> " else []
        )";
	];

	integralData = <|
		"pyIntegralBlock" -> pyIntegralBlock,
		"replacementRules" -> replacementRules,
		"realParamSymbols" -> realParamSymbols,
		"realParamNames" -> realParamNames,
		"nLoops" -> nLoops,
		"nNu" -> nNu,
		"powers" -> powers,
		"order" -> order,
		"contourDeformation" -> contDef,
		"normalization" -> normalization,
		"nEdges" -> nEdges,
		(* Raw Dimension expression; feeds both the cache-key hash and the
		   on-disk directory suffix so different D values don't collide.
		   Kept as a symbolic expression (not a string) so stDimDirTag can
		   pattern-match the canonical "D0 - 2 eps" form without context
		   round-tripping through ToExpression. *)
		"dimension" -> dim,
		(* topology hash: the extra "sharedMassLegs" entry encodes which
		   external-leg node masses coincide with an internal-edge mass.
		   Changing this changes the pySecDec replacement rules at compile
		   time, so it must be part of the cache key (v1.0.297). *)
		"topology" -> {edgePairs, Sort[edgeMasses /. x_Symbol :> "sym"],
		               nodeMasses /. x_Symbol :> "sym", nodeVerts, powers,
		               normalization, order, contDef,
		               "sharedMassLegs", stSharedMassLegs[{edges, nodes}][[2]]},
		"name" -> Quiet[Check[
			(* Use the 2-arg signature so external masses get aligned to
			   sorted vertex IDs.  The 4-arg signature requires the caller
			   to pre-align extMasses to n0reordered; passing Sort[nodeVerts]
			   without permuting nodeMasses (the old pattern here) produced
			   wrong canonical CNIs for entries with unsorted nodes lists,
			   leading to pySecDec cache-key collisions where two distinct
			   integrals (e.g. 2-mass-easy vs 2-mass-hard box) mapped to
			   the same cache directory. *)
			computeNickelIndex[edges, nodes],
			None]]
	|>;

	stPySecDecEvaluate[integralData, opts]
];

stPySecDecFromPropagators[propagators_List, opts:OptionsPattern[STToPySecDec]] :=
Module[{props, loops, extMom, nExt, nLoops, exponents, powers, nNu,
	order, dim, contDef, normalization, propStrs, loopStrs, extStrs,
	genKin, kinRules, replacementRules, realParamSymbols, realParamNames,
	allSymbols, integralData, userSubs, massSqExprs, dotCanon},

	(* Canonicalize scalar products: p*q, p CenterDot q, and p.q all become Times.
	   pySecDec's propagator parser expects Times-form (e.g., "2*l*p").  Warn on
	   Dot chains with arity > 2, which degrade to iterated Times.  HoldPattern
	   is required around Dot patterns because Dot's Flat attribute defeats
	   naive `Dot[a__]` matching. *)
	If[!FreeQ[propagators, HoldPattern[Dot[_, _, _, ___]]],
		Message[STSymanzik::badDot,
			FirstCase[propagators, d_Dot /; Length[d] > 2, None, Infinity]]];
	dotCanon = {CenterDot[a_, b_] :> a b, HoldPattern[Dot[a__]] :> Times[a]};

	props = propagators /. Subscript[a_, b__] :> a[b] /. dotCanon;

	loops = If[OptionValue["LoopMomenta"] === Automatic,
		props // Variables // Cases[#, l[_]] & // Sort,
		OptionValue["LoopMomenta"] /. Subscript[a_, b__] :> a[b]
	];
	(* v1.0.422: accept any _Symbol[_Integer] momentum name (p, q, k, ...)
	   as external, not just p[_].  Loop momenta (usually l[_]) are the
	   complement.  Previously only p[_] matched, so users writing props
	   in terms of q[i] (the convention in SubTropica's paper examples)
	   got an empty extMom list and kinematic logic silently failed.

	   v1.0.435: exclude the conventional mass-symbol letters {m, mm, M, MM}
	   so an internal-mass factor like m[1]^2 inside a propagator doesn't
	   get mis-classified as an external momentum (which then synthesised
	   a fake "m3" nth-leg name and emitted bogus replacement_rules that
	   FORM rejected with "Undeclared variable M1"). *)
	extMom = Complement[
		Cases[Variables[props], x:_Symbol[_Integer] /;
			!MemberQ[{"m", "mm", "M", "MM"}, SymbolName[Head[x]]]],
		loops] // Sort;
	nExt = Length[extMom] + 1;
	nLoops = Length[loops];

	exponents = OptionValue["Exponents"];
	powers = If[exponents === Automatic, ConstantArray[1, Length[props]], exponents];
	nNu = Total[powers];
	order = OptionValue["Order"];
	dim = OptionValue["Dimension"];
	contDef = OptionValue["ContourDeformation"];
	normalization = OptionValue["Normalization"];
	(* Accept kinematics from both "Substitutions" (STToPySecDec's direct
	   option) and "KinematicPoint" (STNIntegrate/STVerify forward subs
	   here after resolving via stResolveEulerSubstitutions).  Users
	   calling STToPySecDec directly use "Substitutions"; callers through
	   STNIntegrate route them via "KinematicPoint". *)
	userSubs = Module[{s, k},
		s = OptionValue["Substitutions"];
		k = OptionValue["KinematicPoint"];
		If[!ListQ[s], s = {}];
		If[!ListQ[k], k = {}];
		Join[s, k] /. Subscript[a_, b__] :> a[b] /. dotCanon];

	(* v1.0.422: un-flatten momenta back to indexed form.  STVerify's
	   subs normalizer flattens q[1] -> q1, which doesn't match the
	   indexed extMom[[i]] used in the Cases patterns below.  Map every
	   flat pi/qi/ki symbol in userSubs back to its indexed form so the
	   lookup succeeds. *)
	Module[{unflattenRules},
		unflattenRules = Cases[Join[extMom, loops],
			h_[i_Integer] :> (Symbol[SymbolName[h] <> ToString[i]] -> h[i])];
		If[unflattenRules =!= {},
			userSubs = userSubs //. unflattenRules]];

	(* v1.0.435: bake internal-mass substitutions into the propagator
	   expressions before they reach pySecDec.  Without this, a propagator
	   like l1^2 - m[1]^2 is shipped as the string 'l1**2 - m1**2' and
	   FORM errors with "Undeclared variable m1" because internal masses
	   are not declared as external_momenta or real_parameters.  We apply
	   *only* rules whose LHS is an internal-mass letter (m or mm, either
	   atomic or indexed); external masses / Mandelstams / scalar-products
	   continue to flow through replacement_rules. *)
	Module[{internalMassSubs, isInternalMassLhs, massUnflattenRules,
			propMasses, propAtomicMasses, propToCanonical,
			massLetters = {"m", "mm"}},
		(* Collect mass-indexed symbols that actually appear in the props
		   (e.g. {m[1], mm[1], mm[2]}), then build unflatten rules
		   m1 -> m[1], mm2 -> mm[2], ... so user-supplied flat keys
		   (from stNormalizeSubstitutions) can match the indexed props. *)
		propMasses = Cases[Variables[props],
			h_[i_Integer] /; MemberQ[massLetters, SymbolName[h]]];
		massUnflattenRules = (
			Symbol[SymbolName[Head[#]] <> ToString[#[[1]]]] -> #) & /@
				DeleteDuplicates[propMasses];
		If[massUnflattenRules =!= {},
			userSubs = userSubs //. massUnflattenRules];

		(* v1.0.438: atomic mass symbols in props get the same
		   canonicalisation as sub LHSes, via stNormalizeSubLHS.  This
		   covers both the bare "mm" -> "m" fold AND the indexed "mm1"
		   -> "m1" fold (atomic), so props and subs end up in the same
		   flat symbol space.  Mandelstam / momentum / "bare" kinds are
		   skipped \[LongDash] we only rewrite for internal-mass kinds. *)
		propToCanonical = Module[{candidates = Cases[Variables[props], _Symbol]},
			DeleteCases[
				Map[
					Module[{cn = Quiet[stNormalizeSubLHS[#]]},
						If[cn =!= $Failed && ListQ[cn] && Length[cn] == 2 &&
								MemberQ[{"intmass", "intmasssq"}, cn[[2]]] &&
								cn[[1]] =!= #,
							# -> cn[[1]],
							Nothing]] &,
					candidates],
				Nothing]];
		If[propToCanonical =!= {},
			props = props /. propToCanonical];

		isInternalMassLhs[lhs_] := Which[
			MatchQ[lhs, _Symbol],
				(* Accept atomic mass-letter-only symbols AND mi / mmi
				   flat forms produced by stNormalizeSubLHS. *)
				MemberQ[massLetters, SymbolName[lhs]] ||
				StringMatchQ[SymbolName[lhs], RegularExpression["^m\\d+$"]],
			MatchQ[lhs, _Symbol[_Integer]],
				MemberQ[massLetters, SymbolName[Head[lhs]]],
			True, False];
		internalMassSubs = Cases[userSubs,
			rule_Rule /; isInternalMassLhs[rule[[1]]]];
		If[internalMassSubs =!= {},
			props = props /. internalMassSubs]];

	propStrs = stMmaExprToPython /@ (Expand /@ props);
	loopStrs = stMmaExprToPython /@ loops;
	extStrs = stMmaExprToPython /@ extMom;

	(* v1.0.423: synthesize name for the implicit nth external momentum
	   (momentum-conservation: p_n = -sum(p_i, i<n)).  pySecDec wants
	   all nExt external momenta listed in external_momenta even if
	   the propagators only reference nExt - 1 of them directly.  Use
	   the same letter prefix as the user's existing extMom (q, p, k).
	   Also build a concrete-momenta version of genKin so replacement
	   rules reference the user's actual momentum names rather than
	   GenerateKinematics's abstract Subscript[p, i] labels. *)
	Module[{letter, synName, extMomFull, extStrsFull, pToExtRule, genKinConcrete},
		letter = If[Length[extMom] > 0, SymbolName[Head[extMom[[1]]]], "p"];
		synName = Symbol[letter][Length[extMom] + 1];
		extMomFull = Append[extMom, synName];
		extStrsFull = Append[extStrs, letter <> ToString[Length[extMom] + 1]];
		pToExtRule = Table[Subscript[p, i] -> extMomFull[[i]], {i, nExt}];

		genKin = GenerateKinematics[nExt];
		genKinConcrete = genKin /. pToExtRule;
		kinRules = {};
		Do[
			Module[{msub = Cases[userSubs, Rule[extMom[[i]]^2, v_] :> v]},
				If[Length[msub] > 0,
					AppendTo[kinRules, Subscript[M, i] -> Sqrt[msub[[1]]]]]
			],
		{i, Length[extMom]}];

		(* v1.0.438: bind M_nExt for the synthesized nth leg via momentum
		   conservation: q_n = -Sum(q_i, i<n) so q_n^2 = Sum_{i,j<n} q_i*q_j
		   (Expand'd form).  Evaluate against userSubs (already dotCanon'd
		   into Times/Power form) and add to kinRules if the result is
		   numeric; otherwise leave M_nExt symbolic (user may have passed
		   only internal masses and no external invariants, in which case
		   this integral is not fully determined and pySecDec will fail
		   with a clearer "missing realParam" error downstream). *)
		Module[{synSq},
			synSq = Expand[Total[extMom]^2] /. userSubs;
			If[NumericQ[synSq],
				AppendTo[kinRules, Subscript[M, nExt] -> Sqrt[synSq]]]];

		(* v1.0.446: bind Mandelstam invariants s_{i,j,...} that appear in
		   genKin's RHS (output of GenerateKinematics[nExt]).  GenerateKinematics
		   expresses every scalar product q_i\[CenterDot]q_j in a cyclic basis of
		   s-variables + M_i^2; without these s-rules the replacement_rules
		   handed to pySecDec retain symbolic s12, s23, ... which FORM then
		   rejects with "Undeclared variable s_ij".  Compute each s-invariant
		   from user's q-subs via
		      s_{i_1,...,i_k} = (sum_l q_{i_l})^2 = sum_{l,m} q_{i_l}\[CenterDot]q_{i_m}
		   using extMomFull (which includes the synthesised nth leg q_nExt
		   defined by momentum conservation) so indices up to nExt resolve. *)
		Module[{sSyms, sRules, synMomSubs},
			(* extMomFull[[nExt]] is the synthesised leg; it = -Sum(extMom[1..nExt-1])
			   by momentum conservation.  Substitute, then re-Expand, so
			   any resulting (sum q_i)^2 piece blows up into q_i^2 + 2 q_i q_j
			   form that userSubs can match. *)
			synMomSubs = {extMomFull[[nExt]] -> -Total[extMom]};
			sSyms = DeleteDuplicates @ Cases[genKinConcrete[[All, 2]],
				Subscript[s, __Integer], Infinity];
			sRules = Map[
				Function[ssym,
					Module[{indices = List @@ Rest[ssym], v},
						v = Expand[Expand[(Total[extMomFull[[indices]]])^2] /.
						      synMomSubs] /. userSubs;
						If[NumericQ[v], ssym -> v, Nothing]]],
				sSyms];
			kinRules = Join[kinRules, sRules]];

		replacementRules = Table[
			Module[{lhs, rhs, lhsStr, rhsStr, pi, pj},
				(* lhs is Subscript[p, i]\[CenterDot]Subscript[p, j] in abstract
				   form; extract the indices so we can emit names that match
				   the user's external momentum convention. *)
				lhs = genKin[[r, 1]];
				pi = lhs[[1]] /. Subscript[p, k_] :> k;
				pj = lhs[[2]] /. Subscript[p, k_] :> k;
				rhs = genKinConcrete[[r, 2]] /. kinRules //. userSubs;
				lhsStr = extStrsFull[[pi]] <> "*" <> extStrsFull[[pj]];
				rhsStr = stMmaExprToPython[rhs // Expand];
				"('" <> lhsStr <> "', '" <> rhsStr <> "')"
			],
			{r, Length[genKin]}
		];

		(* Use the extended list (including the synthesized momentum) for
		   external_momenta so pySecDec sees every external leg referenced
		   in replacement_rules. *)
		extStrs = extStrsFull;

		allSymbols = Join[Variables[props],
			Variables[genKinConcrete[[All, 2]] /. kinRules //. userSubs]];
		realParamSymbols = Select[allSymbols,
			FreeQ[Join[loops, extMomFull, {eps}], #] && MatchQ[#, _Symbol] &
		] // DeleteDuplicates // Sort;
		realParamNames = stMmaExprToPython /@ realParamSymbols;
	];

	Module[{prStr, lmStr, emStr, defaultPwStr, dimPy, pyIntegralBlock},
		prStr = "[" <> StringRiffle["'" <> # <> "'" & /@ propStrs, ", "] <> "]";
		lmStr = "[" <> StringRiffle["'" <> # <> "'" & /@ loopStrs, ", "] <> "]";
		emStr = "[" <> StringRiffle["'" <> # <> "'" & /@ extStrs, ", "] <> "]";
		dimPy = "'" <> stMmaExprToPython[dim] <> "'";
		defaultPwStr = "[" <> StringRiffle[ConstantArray["1", Length[props]], ", "] <> "]";
		pyIntegralBlock =
"        li = LoopIntegralFromPropagators(
            propagators=" <> prStr <> ",
            loop_momenta=" <> lmStr <> ",
            external_momenta=" <> emStr <> ",
            replacement_rules=replacement_rules,
            dimensionality=" <> dimPy <> ",
            powerlist=powerlist if powerlist != " <> defaultPwStr <> " else []
        )";

		integralData = <|
			"pyIntegralBlock" -> pyIntegralBlock,
			"replacementRules" -> replacementRules,
			"realParamSymbols" -> realParamSymbols,
			"realParamNames" -> realParamNames,
			"nLoops" -> nLoops,
			"nNu" -> nNu,
			"powers" -> powers,
			"order" -> order,
			"contourDeformation" -> contDef,
			"normalization" -> normalization,
			"nEdges" -> Length[props],
			"dimension" -> dim,
			(* v1.0.449: include replacementRules in the topology hash key.
			   Previously the cache was keyed only on props/loops/exts/powers/
			   normalization/order/contDef, so two runs with the SAME topology
			   but DIFFERENT kinematic substitutions (e.g. Euclidean vs
			   physical-cut points) silently reused the first-run's .so file
			   with baked-in replacement_rules.  All non-first runs returned
			   stale numerical answers.  Folding replacementRules into the
			   hash forces a rebuild whenever kinematic values change. *)
			"topology" -> {Sort[propStrs], loopStrs, extStrs, powers,
			               normalization, order, contDef, replacementRules}
		|>;
	];

	stPySecDecEvaluate[integralData, opts]
];

stBuildPySecDecScript[integralData_Association, soPath_String, pkgDir_String, pkgName_String,
	kinValues_List, epsrel_, maxeval_, verbose_, integrator_String:"Qmc",
	maxTimeSec_:3600] :=
Module[{script, prefStr, orderStr, rpStr, contStr, rrStr, pwStr, kinDict, evalBlock,
	timeoutStr},

	(* Python literal for the timeout value: integer seconds, or None to
	   disable.  None makes signal.alarm a no-op (skipped via if-guard
	   below) and subprocess.run(timeout=None) wait forever.  Values
	   above ~2^31 (e.g. MaxTime->10^17 used as "effectively infinite")
	   would overflow signal.alarm's C int, so we collapse them to None. *)
	timeoutStr = If[maxTimeSec === Infinity || !NumericQ[maxTimeSec] ||
			N[maxTimeSec] >= 2^31 - 1,
		"None", ToString[Round[maxTimeSec]]];

	orderStr = ToString[integralData["order"]];
	rpStr = "[" <> StringRiffle["'" <> # <> "'" & /@ integralData["realParamNames"], ", "] <> "]";
	contStr = If[integralData["contourDeformation"], "True", "False"];
	pwStr = "[" <> StringRiffle[ToString /@ integralData["powers"], ", "] <> "]";

	prefStr = Switch[integralData["normalization"],
		Automatic, "'exp(" <> ToString[integralData["nLoops"]] <> "*eps*EulerGamma)'",
		1, "'1'",
		_, "'" <> stMmaExprToPython[integralData["normalization"]] <> "'"
	];

	rrStr = "[" <> StringRiffle[integralData["replacementRules"], ", "] <> "]";

	(* Build parameter dict string for Disteval: {"name1": val1, ...} *)
	kinDict = "{" <> StringRiffle[
		MapThread["'" <> #1 <> "': " <> ToString[CForm[#2]] &,
			{integralData["realParamNames"], kinValues}], ", "] <> "}";

	(* Integrator-specific evaluation block *)
	evalBlock = Switch[integrator,
		"Disteval",
"    # Compile disteval if needed
    import pySecDecContrib
    contrib_dir = pySecDecContrib.dirname
    disteval_json = os.path.join(PKG_DIR, PKG_NAME, 'disteval', PKG_NAME + '.json')
    disteval_so = os.path.join(PKG_DIR, PKG_NAME, 'disteval', PKG_NAME + '_' + PKG_NAME + '.so')
    if not os.path.exists(disteval_so):
        if VERBOSE: print('pySecDec: compiling disteval...', file=sys.stderr, flush=True)
        int_dir = os.path.join(PKG_DIR, PKG_NAME, PKG_NAME + '_' + PKG_NAME)
        import glob
        for f in glob.glob(os.path.join(int_dir, 'distsrc', 'sector_*.cpp')):
            ofile = f.replace('.cpp', '.o')
            r = subprocess.run(['c++', '-c', '-o', ofile, '-fPIC', '-std=c++17', '-O3',
                '-funsafe-math-optimizations', '-I', os.path.join(contrib_dir, 'disteval'), f],
                capture_output=True, text=True, timeout=300)
            if r.returncode != 0:
                print(f'disteval compile failed: {f}', file=sys.stderr)
                print(r.stderr[:500], file=sys.stderr)
                sys.exit(2)
        # builtin
        r = subprocess.run(['c++', '-c', '-o', os.path.join(int_dir, 'distsrc', 'builtin.o'),
            '-fPIC', '-std=c++17', '-O3', '-funsafe-math-optimizations',
            '-I', os.path.join(contrib_dir, 'disteval'),
            os.path.join(contrib_dir, 'disteval', 'builtin.cpp')],
            capture_output=True, text=True, timeout=120)
        if r.returncode != 0:
            print('disteval builtin compile failed', file=sys.stderr)
            sys.exit(2)
        # link sector .so
        sector_objs = sorted(glob.glob(os.path.join(int_dir, 'distsrc', 'sector_*.o')))
        dest_dir = os.path.join(int_dir, 'disteval')
        os.makedirs(dest_dir, exist_ok=True)
        r = subprocess.run(['c++', '-shared', '-o',
            os.path.join(dest_dir, PKG_NAME + '_' + PKG_NAME + '.so')] + sector_objs,
            capture_output=True, text=True, timeout=120)
        if r.returncode != 0:
            print('disteval link failed', file=sys.stderr)
            sys.exit(2)
        # link builtin .so
        r = subprocess.run(['c++', '-shared', '-o', os.path.join(dest_dir, 'builtin.so'),
            os.path.join(int_dir, 'distsrc', 'builtin.o')],
            capture_output=True, text=True, timeout=60)
        if r.returncode != 0:
            print('disteval builtin link failed', file=sys.stderr)
            sys.exit(2)
        # copy .so and .json to top-level disteval dir (where integral.json lives)
        import shutil
        top_disteval = os.path.join(PKG_DIR, PKG_NAME, 'disteval')
        for f in glob.glob(os.path.join(dest_dir, '*.so')) + glob.glob(os.path.join(dest_dir, '*.json')):
            shutil.copy2(f, top_disteval)

    if VERBOSE: print('pySecDec: evaluating (Disteval)...', file=sys.stderr, flush=True)
    top_json = os.path.join(PKG_DIR, PKG_NAME, 'disteval', PKG_NAME + '.json')
    from pySecDec.integral_interface import DistevalLibrary
    lib = DistevalLibrary(top_json)
    result_str = lib(parameters=" <> kinDict <> ", epsrel=EPSREL, epsabs=1e-10, format='mathematica')
    # Parse Disteval's mathematica format: split value and plusminus terms
    import re
    val_terms, err_terms = [], []
    for line in result_str.split('\\n'):
        line = line.strip()
        if not line or line in ('{', '}', '(', ')'): continue
        if '*plusminus' in line:
            err_terms.append(line.replace('*plusminus', ''))
        elif 'eps' in line:
            val_terms.append(line)
    val_str = ' '.join(val_terms).replace('*10^', '*^').replace('*I', ' I')
    err_str = ' '.join(err_terms).replace('*10^', '*^').replace('*I', ' I')
    # Wrap in Mathematica Normal[SeriesData[...]] -like format
    print('PYSECDEC_RESULT:' + json.dumps({'value': val_str, 'error': err_str}))",

		"Vegas",
