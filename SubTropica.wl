Begin["`Private`"];

(* Silent autocompletion install on package load:
   Write OptionValues/*.m files so the Mathematica frontend offers
   option-value dropdowns for STIntegrate and STSymanzik.
   Fails silently if the directory is read-only (macOS SIP). *)
Quiet @ Module[{dir, file, stream, optData, lines},
    dir = FileNameJoin[{$InstallationDirectory,
        "SystemFiles", "Components", "AutoCompletionData", "Main", "OptionValues"}];
    If[DirectoryQ[dir],
        Do[
            optData = $STAutocompletionData[funcName];
            lines = Table[
                " " <> k <> " -> {" <> StringRiffle[optData[k], ", "] <> "}",
                {k, Keys[optData]}
            ];
            file = FileNameJoin[{dir, funcName <> ".m"}];
            stream = OpenWrite[file];
            If[Head[stream] === OutputStream,
                WriteString[stream, "{\n" <> StringRiffle[lines, ",\n"] <> "\n}\n"];
                Close[stream];
            ];
        , {funcName, Keys[$STAutocompletionData]}];
    ];
];

(* ---- Bare-symbol option-key coercion ----

   The Mathematica frontend's autocompletion writes options as bare symbols
   ( Order -> 0 ) but SubTropica's Options[] use string keys ( "Order" -> 0 ).
   Without coercion, a bare-symbol form silently uses the default value
   instead of the user's, because OptionsPattern[] captures the pair but
   OptionValue["Order"] only sees the string key.

   For each public entry point in $stPublicFnsForOptCoercion, we PrependTo[
   DownValues[fn], ...] a guard that intercepts any call carrying a bare-
   symbol option whose name matches a string key in Options[fn], rewrites
   those keys to their string form, and recurses.  Calls without bare-symbol
   options skip the guard and fall through to the original definitions.
   Functions whose Options[] are bare-symbol-keyed (e.g. ConfigureSubTropica)
   are no-ops (no string keys to match against). *)

stHasNormalizableOpts[args_List, defaults_List] :=
    Module[{stringKeys = Cases[defaults, Rule[k_String, _] :> k]},
        AnyTrue[args, MatchQ[#, Rule[s_Symbol, _] /; MemberQ[stringKeys, SymbolName[s]]] &]
    ];

stNormalizeOptKeys[args_List, defaults_List] :=
    Module[{stringKeys = Cases[defaults, Rule[k_String, _] :> k]},
        args /. HoldPattern[Rule[s_Symbol, v_]] /; MemberQ[stringKeys, SymbolName[s]] :>
            Rule[SymbolName[s], v]
    ];

(* Use Symbol["SubTropica`name"] to ensure we hit the PUBLIC symbols
   (created by BeginPackage), not freshly-created Private` symbols. *)
$stPublicFnsForOptCoercion = Symbol["SubTropica`" <> #] & /@
    {"STIntegrate", "STNIntegrate", "STVerify", "STSymanzik",
     "STToPySecDec", "ConfigureSubTropica"};

Do[With[{fn = symb},
    Module[{defs, rule},
        defs = Options[fn];
        (* With substitutes fn textually into HoldPattern, so the LHS literally
           references the public symbol \[LongDash] Module would leave a renamed local. *)
        rule = HoldPattern[fn[args___]] /; stHasNormalizableOpts[{args}, defs] :>
            fn @@ stNormalizeOptKeys[{args}, defs];
        DownValues[fn] = Prepend[DownValues[fn], rule]
    ]
], {symb, $stPublicFnsForOptCoercion}];


End[];

On[General::shdw];
(* EndPackage[] triggers a SetFunctionInformation FE packet that the front
   end cannot process (~3700 public symbols). Suppress FE communication
   just for the EndPackage[] call by temporarily nulling $FrontEnd. *)
Block[{$FrontEnd = Null},
  Quiet[EndPackage[], {FrontEndObject::notavail}]];

(* Eager kernel-pool kickoff (master kernel, notebook front end only).
   Schedules stSetupKernelImpl[$ProcessorCount - 1] as a background
   SessionSubmit task so the parallel pool comes up while the user's
   subsequent evaluation (typing, reading library files, composing
   diagrams) runs.  By the time the first STIntegrate triggers
   STSetupKernel, the pool is usually already warm and the wrapper just
   TaskWaits on the (likely-already-finished) handle.

   Restricted to $Notebooks because SessionSubmit's evaluator only
   progresses during master-kernel idle time.  In a wolframscript /
   batch run, the master kernel goes straight from Get to STIntegrate
   with no yield, so the eager task only starts when TaskWait blocks
   \[LongDash] which makes the launch sequential AND adds 1\[Dash]2 s
   of scheduling overhead.  In a notebook, idle time between user
   evaluations gives the task a real async window.

   Suppressed when:
     - loading on a subkernel (Global`$STSubkernelMode);
     - the user opted out via SubTropica`$STEagerKernelPool = False;
     - the machine has < 2 cores (no usable subkernels);
     - or the front end is absent ($Notebooks === False). *)
If[!TrueQ[Global`$STSubkernelMode] &&
    TrueQ[SubTropica`$STEagerKernelPool] &&
    TrueQ[$Notebooks] &&
    $ProcessorCount >= 2,
    Quiet[
        SubTropica`$STEagerLaunchTask =
            SessionSubmit[
                SubTropica`stSetupKernelImpl[Max[1, $ProcessorCount - 1]]]]];
