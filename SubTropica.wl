(* Detect whether any face of problem `id` has no valid LR order.
   Used by the MethodPolysAndPairs -> "Fast" -> "Standard" fallback. *)
stAnyFaceNOLR[id_String] := Module[{dirs},
    dirs = STListDirectoriesNP2[id];
    If[Length[dirs] === 0, Return[False]];
    AnyTrue[dirs,
        With[{f = #[[3]] <> "/bestOrder.m"},
            !FileExistsQ[f] || !FreeQ[Get[f], NOLR]
        ] &
    ]
];


Clear[STEvaluateGraph]

(* Shared variable for monitoring *)
$STCurrentIntegrand = None;
$STCurrentOrder = None;

(* Helper function to read active jobs from files *)
STReadActiveJobs[] := Module[{files, jobs},
    If[!DirectoryQ[$STJobTrackingDir], Return[<||>]];
    files = FileNames["kernel_*.m", $STJobTrackingDir];
    jobs = <||>;
    Do[
        Quiet[
            With[{data = Get[file]},
                If[AssociationQ[data],
                    jobs[FileBaseName[file]] = data;
                ];
            ]
        ];
    , {file, files}];
    jobs
]

(* Helper function to find the slowest completed job *)
STFindSlowestJob[] := Module[{files, jobs, slowest},
    If[!DirectoryQ[$STJobTrackingDir], Return[None]];
    files = FileNames["completed_*.m", $STJobTrackingDir];
    If[Length[files] == 0, Return[None]];
    
    jobs = {};
    Do[
        Quiet[
            With[{data = Get[file]},
                If[AssociationQ[data],
                    AppendTo[jobs, data];
                ];
            ]
        ];
    , {file, files}];
    
    If[Length[jobs] == 0, Return[None]];
    
    slowest = First @ MaximalBy[jobs, #["Duration"] &];
    slowest
]

