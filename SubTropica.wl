(*Graph Functions *)


(*Lorentz rules and exterior algebra:*)
Clear[Wedge,d,CenterDot];
SetAttributes[CenterDot,Orderless];
CenterDot/:CenterDot[x_+y_,z_]:=CenterDot[x,z]+CenterDot[y,z];
CenterDot/:CenterDot[c_*x_,y_]:=c CenterDot[x,y]/;NumericQ[c];
CenterDot/:CenterDot[0,y_]:=0;
Protect[CenterDot];
wedgerules[arg_]:=arg//.wedge1//.wedge2;
wedge1={
Wedge[u___,x_+y_,z___]:>Wedge[u,x,z]+Wedge[u,y,z],
Wedge[x___, (scalar_ :1)Wedge[y__],z___]:> scalar Wedge[x,y,z],
Wedge[x___,scalar_ d[z_],y___]:>scalar Wedge[x,d[z],y],
Wedge[u___,x_,z___]:>x Wedge[u,z]/;FreeQ[x,d[_]],
Wedge[d[x_]]:>d[x]
};
wedge2={
Wedge[u___,x_,y_,z___]:>-Wedge[u,y,x,z]/;Not@OrderedQ[{x,y}],
Wedge[u___,x_,y___,x_,z___]:>0
};
d/:d[x_+y_]:=d[x]+d[y];
d/:d[x_ d[y_]]:=Wedge[d[x],d[y]];
d/:d[(x_:1) Wedge[y__]]:=Wedge[d[x],y];
d/:d[d[x__]]:=0;
Applyd[vars_]:={
d[x_]:>((Sum[D[x,vars[[i]]]d[vars[[i]]],{i,1,Length[vars]}]))
};
Applyd[exp_,vars_]:=exp//.Applyd[vars]//.wedge1//.wedge2;
(*Graph utilities:*)
<<"GraphUtilities`";
(*Generate kinematics in the cyclic basis:*)
Clear[GenerateKinematics];
GenerateKinematics[nParticles_]:=
If[nParticles==2,{Subscript[p, 1]\[CenterDot]Subscript[p, 1]->Subscript[M, 1]^2,Subscript[p, 1]\[CenterDot]Subscript[p, 2]->-Subscript[M, 1]^2,Subscript[p, 2]\[CenterDot]Subscript[p, 2]->Subscript[M, 1]^2},Module[{out},
n=nParticles;
ppMatrix=Table[If[i==j,Subscript[M, i]^2,(Subscript[s, Sequence@@Sort[{i,j}]]-Subscript[M, i]^2-Subscript[M, j]^2)/2],{i,n},{j,n}];
cyclicBasis=Flatten[Table[Subscript[s, Sequence@@Sort[Mod[Range[a,a+l],n,1]]],{l,1,n/2-1},{a,If[l==n/2-1,n/2,n]}]];
sRelations=Flatten[Table[Subscript[s, Sequence@@Sort[Mod[Range[a,a+l],n,1]]]==Sum[ppMatrix[[b,c]],{b,Mod[Range[a,a+l],n,1]},{c,Mod[Range[a,a+l],n,1]}],{l,1,n/2-1},{a,If[l==n/2-1,n/2,n]}]];
momentumConservation=Table[Sum[ppMatrix[[i,j]],{j,n}]==0,{i,n}];
solution=Solve[
Join[momentumConservation,sRelations]
,Complement[Variables[ppMatrix],cyclicBasis,Table[Subscript[M, i],{i,n}]]][[1]];
substitutions=Flatten[Table[Subscript[p, i]\[CenterDot]Subscript[p, j]->ppMatrix[[i,j]]/.solution//Factor,{i,n},{j,n}]];
out=substitutions
]
];
(*Feynman diagrammatic:*)
FeynmanDraw:=Module[{edgelist,edgelist2,extnodes,posnodes,nodes0,edgelist3,vertices,ivertices,reordering,intmasses,allEdges,nodes1,edgelistfinal,edges,nodes,en},
edgelist=GraphUtilities`GraphEdit[][[2,2]];
edgelist2=Partition[ToExpression[StringReplace[ToString[edgelist],"->"-> ","]],2];
extnodes=Select[Tally[Flatten[edgelist2]],#[[2]]==1&]//Transpose//First;
posnodes=(Position[edgelist2,#][[1]]&/@extnodes)/.{{x_,1}->{x,2},{x_,2}->{x,1}};
nodes0=Sort[Table[Part[edgelist2,posnodes[[n,1]],posnodes[[n,2]]],{n,1,Length[extnodes]}]];
edgelist3=Sort/@Delete[edgelist2,List/@(posnodes//Transpose//First)];
vertices=edgelist3//Flatten//DeleteDuplicates;
ivertices=Complement[vertices,nodes0];
nodes1=nodes0//DeleteDuplicates;
reordering=Join[Table[nodes1[[i]]->i,{i,1,Length[nodes1]}],Table[ivertices[[i]]->i+Length[nodes1],{i,1,Length[ivertices]}]];
edgelistfinal=Sort/@(edgelist3/.reordering);
edges=Table[{edgelistfinal[[i]],Subscript[m, i](*^2*)},{i,1,Length[edgelistfinal]}];
nodes=Table[{Part[nodes0/.reordering,i],Subscript[M, i]},{i,1,Length[nodes0]}];
en={edges,nodes};
FeynPlot[en]//Echo;
Return[en];
];
ContractEdge[edgenode_,edgein_]:=Module[{edgect,edgelist,posedgect,newedges,newnodes,edges0,edges,nodes},
edges0=edgenode[[1]]; nodes=edgenode[[2]];
edges={Sort/@Transpose[edges0][[1]],Transpose[edges0][[2]]}//Transpose; (*sorts them correctly*);
edgelist=Sort/@edges[[All,1]];
If[Depth[edgein]==2,
edgect=Sort[edgein];posedgect=(Position[edgelist,edgect]//Flatten)[[1]];,
edgect={Sort[edgein[[1]]],edgein[[2]]};posedgect=(Position[edges,edgect]//Flatten)[[1]];];
newedges=Delete[edges,posedgect]//.{{x_,edgelist[[posedgect,2]]}->{x,edgelist[[posedgect,1]]},{edgelist[[posedgect,2]],x_}->{edgelist[[posedgect,1]],x}};
newnodes=nodes/.{{edgelist[[posedgect,2]],x_}->{edgelist[[posedgect,1]],x}};
{newedges,newnodes}];
ContractSingle[edgenode_]:=Table[ContractEdge[edgenode,edgenode[[1,j]]],{j,1,Length[edgenode[[1]]]}];
Contractions[edgenode_]:=Module[{contractions,j,max,inter1,inter2},
max=Length[edgenode[[1]]];
For[j=0;contractions[0]={edgenode},j<=max,j++,
inter1=Table[ContractSingle[contractions[j][[i]]],{i,1,contractions[j]//Length}]//Flatten[#,1]&;
inter2=Select[DeleteTadpoles/@inter1,OneVertexIrreducibleQ[#]&&NotContactQ[#]&];
contractions[j+1]=inter2];
Table[contractions[j],{j,0,max}]//Flatten[#,1]&//DeleteDuplicates
];

(*Subtopologies:*)
NLoops[edgesnodes_]:=(1+Length[edgesnodes[[1]]]-Length[Join[edgesnodes[[1]][[All,1]],edgesnodes[[1]][[All,1]]]//Flatten//DeleteDuplicates//Sort]);
NVertexCut[edgenode_]:= Module[{edges},
edges=Transpose[edgenode[[1]]][[1]]//Quiet;
If[SameQ[edges,{}[[1]]]//Quiet,0,
edgelist=#[[1]]\[UndirectedEdge]#[[2]]&/@edges;
FindVertexCut[edgelist]//Length]];
OneVertexIrreducibleQ[edgenode_]:=Module[{edgelist,edges,NVertexCut},
edges=Transpose[edgenode[[1]]][[1]]//Quiet;
NVertexCut=If[SameQ[edges,{}[[1]]]//Quiet,0, edgelist=#[[1]]\[UndirectedEdge]#[[2]]&/@edges;FindVertexCut[edgelist]//Length];
If[NVertexCut>1,True,If[VertexCount[edgelist]>2,False,If[Length[DeleteDuplicates[Transpose[edgenode[[2]]][[1]]]]===1,False,True]]]];

(*SetAttributes[ReflectionQ,Orderless];*)
ReflectionQ[d1_,d2_]:=Module[{sym},sym=Symmetry[d1,d2]; If[SameQ[Length[sym],2],If[SameQ[sym[[2]],{}],True,False],False]];

NoTadpoleQ[edgenode_]:=If[SameQ[Select[edgenode[[1]],SameQ[#[[1,1]],#[[1,2]]]&],{}],True,False];
NotContactQ[edgenode_]:=If[SameQ[edgenode[[1]],{}],False,True];
DeleteTadpoles[edgenode_]:=Module[{edges},edges=edgenode[[1]];{Select[edges,UnsameQ[#[[1,1]],#[[1,2]]]&],edgenode[[2]]} ];
ContractionsNontrivial[edgenode_]:=ContractionsNontrivial[edgenode]=Select[DeleteTadpoles/@Contractions[edgenode],OneVertexIrreducibleQ[#]&&NotContactQ[#]&];

(*Subtopologies functions with reflection:*)
ContractionsR[edgenode_]:=Module[{contractions,j,max,inter1,inter2,inter3,out},
max=Length[edgenode[[1]]];
For[j=0;out=0;contractions[0]={edgenode},j<max&&out==0,j++,
inter1=Table[ContractSingle[contractions[j][[i]]],{i,1,contractions[j]//Length}]//Flatten[#,1]&;
inter2=Select[DeleteTadpoles/@inter1,OneVertexIrreducibleQ[#]&&NotContactQ[#]&];
If[SameQ[inter2,{}],out=1,
inter3=Transpose[Tally[inter2,ReflectionQ]][[1]];
	contractions[j+1]=inter3]];
Table[contractions[a],{a,0,j-out}]//Flatten[#,1]&//DeleteDuplicates
];

Subtopologies[edgenode_,Reflections_:False]:=Subtopologies[edgenode,Reflections]=Monitor[
If[SameQ[Reflections,False],
DeleteDuplicates[{{SortBy[#[[1]],Length],#[[-1]]}&/@(#[[1]]),#[[-1]]}&/@Contractions[edgenode]],
DeleteDuplicates[{{SortBy[#[[1]],Length],#[[-1]]}&/@(#[[1]]),#[[-1]]}&/@ContractionsR[edgenode]]
]
,"Constructing subtopologies..."];

(*Diagram display:*)
FeynPlot[x_]:=FeynPlot[x[[1]],x[[2]]];
FeynPlot[edgesin_,nodesin_]:=Module[
{ContactQ,edges,nodes,edgelist,vertices,intmasses,extmasses,vmax,
 masslesspos,vmasslesspos,allEdges,multiplicity,graph0,edgelistgraph,
 masslessedges,massiveInternalEdges,graph},
ContactQ=SameQ[edgesin,{}];(*True if it's a contact diagram*);
If[ContactQ, {edges={},nodes=nodesin},(*checks the trivial case of contact diagrams*)
If[Length[Part[Flatten/@edgesin,1]]==3,{edges=edgesin,nodes=nodesin}, {nodes=edgesin,edges=nodesin}](*corrects arguments if they were swapped by mistake*);];
edgelist=Sort/@(#[[1]]&/@edges);
vertices=If[ContactQ,{1},Sort[DeleteDuplicates[Flatten[edgelist]]]];
intmasses=#[[2]]&/@edges;
extmasses=#[[2]]&/@nodes;
vmax=vertices[[-1]];
masslesspos=Position[Join[intmasses,extmasses],0]//Flatten;
vmasslesspos=(Position[extmasses,0]//Flatten)+vmax;
allEdges=Join[#[[1]]\[UndirectedEdge]#[[2]]&/@edgelist,#[[1]]\[DirectedEdge]#[[2]]&/@Table[{vmax+v,nodes[[v,1]]},{v,Length[nodes]}]];
multiplicity=Sort[Transpose[Tally[allEdges]][[2]]][[-1]];
graph0=EdgeTaggedGraph[Join[vertices,Range[vmax+1,vmax+Length[nodes]]],allEdges];
edgelistgraph=EdgeList[graph0];
masslessedges=Part[edgelistgraph,masslesspos];
massiveInternalEdges=DeleteCases[edgelistgraph,Alternatives@@Join[masslessedges,edgelistgraph[[-Length[nodes];; -1]]]];
graph = EdgeTaggedGraph[
   Join[vertices, Style[#, Transparent] & /@ Range[vmax + 1, vmax + Length[nodes]]],
   allEdges,
   EdgeWeight -> Thread[edgelistgraph -> (Style[#, Black, Background -> White] & /@ Join[intmasses, extmasses])],
   VertexWeight -> Join[vertices, Subscript[p, #] & /@ Range[Length[nodes]]]
];
GraphPlot[
  graph,
  EdgeLabels -> Thread[Complement[edgelistgraph, masslessedges] -> "EdgeWeight"],
  VertexLabels -> Thread[VertexList[graph0] -> "VertexWeight"],
  MultiedgeStyle -> 0.22*(multiplicity - 1),
  PlotTheme -> "Scientific",
  PlotRangePadding -> Scaled[0.2],
  GraphLat -> "SpringElectricalEmbedding",
  EdgeStyle -> Merge[
    {
      Thread[masslessedges -> Directive[Dashed, Thick]],
      Thread[massiveInternalEdges -> Directive[Thick]],
      Thread[edgelistgraph[[-Length[nodes];; -1]] -> Directive[Thick, Arrowheads[{{Medium, 0.23}}]]]
    },
    If[Length[#] > 1, Directive @@ #, First[#]] &
  ] // Normal
]
];
FeynPlot[edgesin_,nodesin_,edgelabels_,edgespecial_]:=Module[
{ContactQ,edges,nodes,edgelist,vertices,intmasses,extmasses,vmax,
 masslesspos,vmasslesspos,allEdges,multiplicity,graph0,edgelistgraph,
 masslessedges,massiveInternalEdges,graph},
ContactQ=SameQ[edgesin,{}];(*True if it's a contact diagram*);
If[ContactQ, {edges={},nodes=nodesin},(*checks the trivial case of contact diagrams*)
If[Length[Part[Flatten/@edgesin,1]]==3,{edges=edgesin,nodes=nodesin}, {nodes=edgesin,edges=nodesin}](*corrects arguments if they were swapped by mistake*);];
edgelist=Sort/@(#[[1]]&/@edges);
vertices=If[ContactQ,{1},Sort[DeleteDuplicates[Flatten[edgelist]]]];
intmasses=#[[2]]&/@edges;
extmasses=#[[2]]&/@nodes;
vmax=vertices[[-1]];
masslesspos=Position[Join[intmasses,extmasses],0]//Flatten;
vmasslesspos=(Position[extmasses,0]//Flatten)+vmax;
allEdges=Join[#[[1]]\[UndirectedEdge]#[[2]]&/@edgelist,#[[1]]\[DirectedEdge]#[[2]]&/@Table[{vmax+v,nodes[[v,1]]},{v,Length[nodes]}]];
multiplicity=Sort[Transpose[Tally[allEdges]][[2]]][[-1]];
graph0=EdgeTaggedGraph[Join[vertices,Range[vmax+1,vmax+Length[nodes]]],allEdges];
edgelistgraph=EdgeList[graph0];
masslessedges=Part[edgelistgraph,masslesspos];
massiveInternalEdges=DeleteCases[edgelistgraph,Alternatives@@Join[masslessedges,edgelistgraph[[-Length[nodes];; -1]]]];
graph=EdgeTaggedGraph[Join[vertices,Style[#,Transparent]&/@Range[vmax+1,vmax+Length[nodes]]],allEdges,EdgeWeight->Thread[edgelistgraph->(Style[#,Black,Background->White]&/@Join[edgelabels,Table[0,nodes//Length]])],VertexWeight->Join[vertices,Subscript[p, #]&/@Range[nodes//Length]]];
GraphPlot[graph,
  EdgeLabels -> Thread[Complement[edgelistgraph, edgelistgraph[[-Length[nodes];;-1]]] -> "EdgeWeight"],
  VertexLabels -> Thread[VertexList[graph0] -> "VertexWeight"],
  MultiedgeStyle -> 0.22*(multiplicity - 1),
  PlotTheme -> "Scientific",
  PlotRangePadding -> Scaled[0.2],
  GraphLat -> "SpringElectricalEmbedding",
  EdgeStyle -> Merge[
    {
      Thread[masslessedges -> Directive[Dashed, Thick]],
      Thread[massiveInternalEdges -> Directive[Thick]],
      Thread[edgelistgraph[[-Length[nodes];; -1]] -> Directive[Thick, Arrowheads[{{Medium, 0.23}}]]],
      Thread[Part[edgelistgraph, #] & /@ edgespecial -> Directive[Black, Thick]]
    },
    If[Length[#] > 1, Directive @@ #, First[#]] &
  ] // Normal
]
];

Options[FeynmanPlot]={EdgesLabel->{},HighlightedEdges->{},"LabelInternalEdges"->False};
FeynmanPlot[diag_,opts:OptionsPattern[]]:=Module[{EdgesLabeL,HighlighteD,labelInternal,effectiveLabels},
{EdgesLabeL,HighlighteD,labelInternal}=OptionValue[{EdgesLabel,HighlightedEdges,"LabelInternalEdges"}];
(* Resolve which edge labels to use:
   - explicit EdgesLabel always wins;
   - "LabelInternalEdges"->True auto-numbers by position in the edge list;
   - non-empty HighlightedEdges also auto-numbers (existing behaviour);
   - otherwise no labels. *)
effectiveLabels=Which[
    !SameQ[EdgesLabeL,{}],            EdgesLabeL,
    TrueQ[labelInternal],             Range[Length[diag[[1]]]],
    !SameQ[HighlighteD,{}],           Range[Length[diag[[1]]]],
    True,                             {}
];
If[SameQ[effectiveLabels,{}]&&SameQ[HighlighteD,{}],
    FeynPlot[diag[[1]],diag[[-1]]],
    FeynPlot[diag[[1]],diag[[-1]],effectiveLabels,HighlighteD]
]
];
basis[n_]:=GenerateKinematics[n]/.Subscript[M, i_]:>Sqrt[Subscript[M, i]]
basis[1]:={Subscript[p, i_]\[CenterDot]Subscript[p, i_]->Global`s}
basis[2]:={Subscript[p, 1]\[CenterDot]Subscript[p, 1]->Subscript[M, 1],Subscript[p, 1]\[CenterDot]Subscript[p, 2]->-Subscript[M, 1],Subscript[p, 2]\[CenterDot]Subscript[p, 2]->Subscript[M, 1]}
debug=False;

(*STSymanzikGraph[edges,nodes,numerator] translates from the loop momentum Feynman integral 1/\[Pi]^(LD/2)\[Integral]d^DEq N(Subscript[q, e])\!\(
\*SubsuperscriptBox[\(\[Product]\), \(v = 1\), \(V\)]\(
\*SuperscriptBox[\(\[Delta]\), \(D\)]\((
\*SubscriptBox[\(p\), \(v\)] + 
\*SubsuperscriptBox[\(\[Sum]\), \(e = 1\), \(E\)]
\*SubscriptBox[\(\[Eta]\), \(ve\)]
\*SubscriptBox[\(q\), \(e\)])\)/\(
\*SubsuperscriptBox[\(\[Product]\), \(e = 1\), \(E\)]\((
\*SuperscriptBox[
SubscriptBox[\(q\), \(e\)], \(2\)] - 
\*SuperscriptBox[
SubscriptBox[\(m\), \(e\)], \(2\)] + \[ImaginaryI]\[Epsilon])\)\ into\ the\ parametric\ form\ \[CapitalGamma]\((g)\)\(\[Integral]\((d^E\[Alpha])\)/\((GL\((1)\))\)\[CapitalNu]/\((U^\(uF^f\))\)\)\)\)\) *)
STSymanzikGraph[edges__List,nodes__List,numerator_:1,dimension_:dim]:=Block[{vertices,EE,n,V,LL,dd,P,L,detL,expand,\[Beta]Edges,U,F,degq,deg\[CapitalNu],num,monomials,\[CapitalNu],terms,\[CapitalNu]mon,e,\[Mu]p,\[Mu]Unique,degMon,\[CapitalNu]monCoeff},
vertices=Sort[DeleteDuplicates[Flatten[edges]]];
EE=Length[edges];
n=Length[nodes];
V=Length[vertices];
noLoop=LL=1+EE-V;
dd=EE-LL d/2; 
If[vertices!=Range[V]\[Or]Complement[nodes,vertices]!={},
"Too much Pina colada eh?! You provided incorrect arguments... the police is on their way!" // Print;
Abort[];
];
P=ConstantArray[0,{V}];
Do[P[[nodes[[i]]]]+=Subscript[p, i],{i,n}];
L=ConstantArray[0,{V,V}];
Do[{v1,v2}=edges[[e]];L[[v1,v1]]+=1/Subscript[\[Alpha], e];L[[v2,v2]]+=1/Subscript[\[Alpha], e];L[[v1,v2]]-=1/Subscript[\[Alpha], e];L[[v2,v1]]-=1/Subscript[\[Alpha], e];,{e,EE}];
(* V==1 (tadpole / vacuum-like): reduced Laplacian is empty, Kirchhoff poly = 1 by convention. *)
detL:=If[V==1,1,Det[L[[Range[V-1],Range[V-1]]]]];
Subscript[detL, i_,j_]:=If[V==1,0,If[i!=V\[And]j!=V,If[V==2,1,(-1)^(i+j) Det[L[[Complement[Range[V-1],{i}],Complement[Range[V-1],{j}]]]]],0]];
SetAttributes[CenterDot,Orderless];
SetAttributes[\[Eta],Orderless];
expand={(a_+b_)\[CenterDot]x_:>a\[CenterDot]x+b\[CenterDot]x,x_\[CenterDot](a_+b_):>x\[CenterDot]a+x\[CenterDot]b,a_\[CenterDot]0:>0};
\[Beta]Edges=DeleteDuplicates[Cases[Variables[numerator],Subscript[q, _][_]]/.Subscript[q, e_][\[Mu]_]:>e];
If[debug,Echo[\[Beta]Edges,"\[Beta]Edges = "]];
U = Expand[ Product[Subscript[\[Alpha], e], {e, 1, EE}] * detL ];
F0 = Expand[
  Product[Subscript[\[Alpha], e], {e, 1, EE}] *
    Sum[
      Sum[
        P[[i]]\[CenterDot]P[[j]] *
          Piecewise[{
            {2 Subscript[detL, i,j], i < j},
            {   Subscript[detL, i,i], i == j}
          }, 0]
      , {j, 1, V - 1}]
    , {i, 1, V - 1}]
]//.expand;
F1 = I * Expand[
  Product[Subscript[\[Alpha], e], {e, 1, EE}] *
    Sum[
      Sum[
        ( P[[i]]\[CenterDot]Subscript[\[Beta], e] / Subscript[\[Alpha], e] ) *
          (Subscript[detL, i,edges[[e, 2]]] - Subscript[detL, i,edges[[e, 1]]])
      , {e, \[Beta]Edges}]
    , {i, 1, V - 1}]
]//.expand;
F2 = -(1/4) * Expand[
  Product[Subscript[\[Alpha], e], {e, 1, EE}] *
    Sum[
      Sum[
        ( Subscript[\[Beta], e]\[CenterDot]Subscript[\[Beta], f] / (Subscript[\[Alpha], e] Subscript[\[Alpha], f]) ) *
          Piecewise[{
            {
              2 * Sum[
                    Sum[
                      (-1)^(ii + jj) * Subscript[detL, edges[[e, ii]],edges[[f, jj]]]
                    , {jj, 1, 2}]
                  , {ii, 1, 2}],
              e < f
            },
            {
              Subscript[detL, edges[[e, 1]],edges[[e, 1]]] 
              - 2 Subscript[detL, edges[[e, 1]], edges[[e, 2]]] 
              +   Subscript[detL, edges[[e, 2]], edges[[e, 2]]]
              - Subscript[\[Alpha], e] detL,
              e == f
            }
          }, 0]
      , {f, \[Beta]Edges}]
    , {e, \[Beta]Edges}]
];
Subscript[F, 0] = F0;
Subscript[F, 1] = F1;
Subscript[F, 2] = F2;
degq[expr_]:=Max[Cases[CoefficientRules[expr/.{Subscript[q, e_][\[Mu]_]:>Subscript[q, e]},Table[Subscript[q, e],{e,EE}]],v_?VectorQ:>Total[v],2]]; 
deg\[CapitalNu]=degq[numerator];
num=Expand[numerator];
monomials=If[num[[0]]===Plus,List@@num,{num}];
\[CapitalNu]=0;
Do[
terms={mon}//.{a_ Subscript[q, e_][\[Mu]_]:>Sequence@@{a,Subscript[q, e][\[Mu]]},Subscript[q, e_][\[Mu]_]^p_:>Sequence@@Table[Subscript[q, e][\[Mu]],{i,p}],a_ Subscript[q, e_][\[Mu]_]^p_:>Sequence@@Join[{a},Table[Subscript[q, e][\[Mu]],{i,p}]]};
If[debug,Echo[terms,"terms = "];];
\[CapitalNu]mon=1;
Do[
If[MatchQ[term,Subscript[q, _][_]],
{e,\[Mu]p}=term/.{Subscript[q, e_][\[Mu]_]:>{e,\[Mu]}};
If[debug,Echo[{e,\[Mu]p},"{e,\[Mu]p} = "];];
\[Mu]Unique=Unique[\[Mu]];
\[CapitalNu]mon=Expand[D[\[CapitalNu]mon,Subscript[\[Beta], e]]+I D[(Subscript[F, 1]+Subscript[F, 2])/UU/.{a_\[CenterDot]b_:>a[\[Mu]Unique]b[\[Mu]Unique]},Subscript[\[Beta], e]]\[CapitalNu]mon]//.{1[\[Nu]_]a_[\[Nu]_]:>a[\[Mu]p]}/.{1[\[Nu]_]:>\[Eta][\[Nu],\[Mu]p]};
If[debug,Echo[\[CapitalNu]mon,"\[CapitalNu]mon = "];];
,
\[CapitalNu]mon=term \[CapitalNu]mon;];
,{term,terms}];
\[CapitalNu]mon=Expand[\[CapitalNu]mon/.{Subscript[\[Beta], e_][\[Mu]_]:>0}]//.{\[Eta][\[Mu]_,\[Mu]_]:>d,\[Eta][\[Mu]_,\[Nu]_]^2:>d,\[Eta][\[Mu]_,\[Rho]_]\[Eta][\[Rho]_,\[Nu]_]:>\[Eta][\[Mu],\[Nu]],\[Eta][\[Mu]_,\[Nu]_]a_[\[Mu]_]:>a[\[Nu]],a_[\[Mu]_]b_[\[Mu]_]:>a\[CenterDot]b,a_[\[Mu]_]^2:>a\[CenterDot]a};
degMon=degq[mon];
If[debug,Echo[degMon,"degMon = "];];
\[CapitalNu]monCoeff=CoefficientList[UU^degMon \[CapitalNu]mon,UU];
\[CapitalNu]+=\!\(
\*SubsuperscriptBox[\(\[Sum]\), \(l = 0\), \(\[LeftFloor]degMon/2\[RightFloor]\)]\(
\*SuperscriptBox[\(I\), \(-l\)] FunctionExpand[
\*FractionBox[\(Gamma[dd - l]\), \(Gamma[dd - \[LeftFloor]deg\[CapitalNu]/2\[RightFloor]]\)]] \[CapitalNu]monCoeff[\([l + 1]\)] 
\*SuperscriptBox[\(UU\), \(deg\[CapitalNu] - degMon\)] 
\*SuperscriptBox[\(FF\), \(\(l\)\(\ \)\)]\)\);
,{mon,monomials}];
SavedLeePomeransky=Gamma[dimension/2]/Gamma[((LL+1)dimension)/2-EE] ((U)+(Subscript[F, 0]-U \!\(
\*SubsuperscriptBox[\(\[Sum]\), \(e = 1\), \(EE\)]\(
\*SubscriptBox[\(m\), \(e\)] 
\*SubscriptBox[\(\[Alpha]\), \(e\)]\)\)))^(-(dimension/2));
data=Expand[{U,Subscript[F, 0]-U \!\(
\*SubsuperscriptBox[\(\[Sum]\), \(e = 1\), \(EE\)]\(
\*SubscriptBox[\(m\), \(e\)] 
\*SubscriptBox[\(\[Alpha]\), \(e\)]\)\),\[CapitalNu],d/2-dd+deg\[CapitalNu],dd,dd-\[LeftFloor]deg\[CapitalNu]/2\[RightFloor]}]/.d:>dimension;
Return[
(* Feynman branch: use (-F)^aF in the denominator. See normalization.tex Eq. 6. *)
{data[[1]],data[[2]]//.UU->data[[1]],Gamma[data[[-1]]](*/I^LL*)*Wedge@@(d/@Variables[data[[1]]])(*/GL[1]*)*data[[3]]/(data[[1]]^data[[4]] (-(data[[2]]//.UU->data[[1]]))^data[[5]])}
];
];

(*Combining with SOFIA: *)
debugMG=False;
tadpole[msq_,dim_]:=-Gamma[1-dim/2] msq^(dim/2-1)
(*syntax patches:*)
relabel[list_]:=Module[{vals,rules},
vals=DeleteDuplicates@Flatten[list,Infinity];
rules=Thread[vals->Range@Length@vals];
list/. rules]
findMapping[list1_List,list2_List]:=Module[{flat1,flat2,pairs,mapping},flat1=Flatten[list1];
flat2=Flatten[list2];
pairs=Thread[flat1->flat2];
mapping=(*Association@*)DeleteDuplicates[pairs];
mapping];
(*Reorder external nodes to match the planar boundary (outer face) ordering.
  This ensures that the F polynomial has sign-definite kinematic
  coefficients, which is required for the tropical geometry integration
  algorithm to find valid linear reduction orders.
  For non-planar graphs, returns the original ordering unchanged.*)
STEvaluateGraph::nonplanar="The input graph is non-planar. The F polynomial may have mixed-sign kinematic coefficients, which can prevent tropical integration from finding valid linear reduction orders.";
planarBoundaryOrdering[edges_List,nodes_List]:=Module[
{graph,faces,outerFace,orderedNodes,pos},
If[Length[nodes]<=2,Return[nodes]];
graph=Graph[UndirectedEdge@@@edges];
If[!PlanarGraphQ[graph],Message[STEvaluateGraph::nonplanar];Return[nodes]];
faces=PlanarFaceList[graph];
outerFace=SelectFirst[faces,ContainsAll[#,nodes]&];
If[MissingQ[outerFace],outerFace=First@MaximalBy[faces,Length]];
orderedNodes=DeleteDuplicates[Select[outerFace,MemberQ[nodes,#]&]];
If[Length[orderedNodes]!=Length[nodes],Return[nodes]];
pos=FirstPosition[orderedNodes,First[nodes],{1}][[1]];
RotateLeft[orderedNodes,pos-1]
];
(*Compute Mandelstam variable remapping from boundary ordering back to user ordering.
  When planarBoundaryOrdering permutes the external nodes, the Mandelstam variables
  s12, s23, ... in the computation refer to different physical channels than the
  user's input convention.  This function returns substitution rules that map
  the boundary-convention variables back to user-convention expressions, e.g.
  {s23 -> -(s12+s23)} for the double box with boundary order {1,2,4,3}.
  Returns {} if no remapping is needed.*)
toSOFIA={};
homogeneizeKin2[arg_]:=arg//.Subscript[s, a___]:>ToExpression["s"<>StringJoin[ToString/@{a}]]//.Subscript[M, i_]:>ToExpression["MM"<>ToString[i]]//.Subscript[m, i_]:>ToExpression["mm"<>ToString[i]]//.M:>MM//.m:>mm;

Options[SOFIASymanzik]={
TopSectorOnly->True,
numerator->1,
dimension->dim,
RunSOFIA->False,
SOLVERBOUND->100,
Normalization->(*1*)Automatic,
Gauge->{Global`x1->1}
};
SOFIASymanzik[diagram_,opts:OptionsPattern[]]:=Module[{listSym,out,tempDiagram,\[Alpha]Replacements,topSectorOnlyVal,numVal,dimVal,runSOFIAVal,solverBoundVal,subs,listPlot,kinReplacements,shifts,nodes1,nodes2,cv,UUU,FFF,GGG,listUF,finalRep,normalization,gauge,saveCV={}},
(*Extract Options*)
topSectorOnlyVal=OptionValue[{SOFIASymanzik,opts},TopSectorOnly];
numVal=OptionValue[{SOFIASymanzik,opts},numerator];
dimVal=OptionValue[{SOFIASymanzik,opts},dimension];
runSOFIAVal=OptionValue[{SOFIASymanzik,opts},RunSOFIA];
solverBoundVal=OptionValue[{SOFIASymanzik,opts},SOLVERBOUND];
normalization=OptionValue[{SOFIASymanzik,opts},Normalization];
gauge=OptionValue[{SOFIASymanzik,opts},Gauge];

(*Build Final Replacements (m_i,M_i->actual masses)*)
finalRep=(Thread[Join[Table[Subscript[m,ii],{ii,Length[#1[[1]]]}],Table[Subscript[M,ii],{ii,Length[#1[[-1]]]}]]->Flatten[#1]]&[#1])&/@Table[Join[{((#[[-1]]&/@#)&/@(#[[1]]&/@#))[[ii]]},{((#[[-1]]&/@#)&/@(#[[-1]]&/@#))[[ii]]}],{ii,Length[#]}]&[{diagram}];
If[debugMG,Echo[finalRep,"finalRep = "]];
(*Build Temp Diagram with Symbolic Masses*)
tempDiagram=Table[Join[{({Table[{Flatten[#1,1][[ii]][[1]],Subscript[m,ii]},{ii,Length[Flatten[#1,1]]}]&[(#[[1]]&/@#)]})[[ii]]},{(({#[[1]],Subscript[M,Flatten[Position[diagram[[2]],#]][[1]]]}&/@#)&/@(#[[-1]]&/@#))[[ii]]}],{ii,Length[#]}]&[{diagram}][[1]];
If[debugMG,Echo[tempDiagram,"tempDiagram = "]];
If[debugMG,Echo[DeleteDuplicates[Flatten[tempDiagram-diagram//.finalRep]]=={0},"equivalent? "]];
(*Get Subtopologies*)
subs=If[SameQ[topSectorOnlyVal,True],{tempDiagram},Subtopologies[tempDiagram]];
If[debugMG,Echo[subs,"subs = "]];
listPlot=FeynmanPlot[#]&/@(subs/. Flatten[finalRep]);
(*Build Kinematic Replacements for Each Subtopology*)
kinReplacements=(Thread[Join[Table[Subscript[m,ii],{ii,Length[#1[[1]]]}],Table[Subscript[M,ii],{ii,Length[#1[[-1]]]}]]->Flatten[#1]]&[#1])&/@Table[Join[{((#[[-1]]&/@#)&/@(#[[1]]&/@#))[[ii]]},{((#[[-1]]&/@#)&/@(#[[-1]]&/@#))[[ii]]}],{ii,Length[#]}]&[subs];
(*Build Alpha Replacements*)
\[Alpha]Replacements=(Thread[Table[Subscript[m,ii],{ii,Length[#1[[1]]]}]->Flatten[#1]]&[#1])&/@Table[{((#[[-1]]&/@#)&/@(#[[1]]&/@#))[[ii]]},{ii,Length[#]}]&[subs]//.Subscript[m,i_]:>Subscript[\[Alpha],i];
If[debugMG,Echo[kinReplacements,"kinReplacements = "]];
If[debugMG,Echo[\[Alpha]Replacements,"\[Alpha]Replacements = "]];
(*Compute Symanzik Polynomials - use planar boundary ordering for sign-definite F*)
If[SameQ[topSectorOnlyVal,True],
(*Top-sector only: skip relabeling, pass original edges/nodes directly*)
Module[{edgesRaw,nodesRaw,nodesAll},
edgesRaw=(#[[1]]&/@#)&/@(#[[1]]&/@#)&@subs//First;
nodesAll=(#[[1]]&/@#)&/@(#[[-1]]&/@#)&@subs//First;  (* full list, with duplicates for co-vertex legs *)
nodesRaw=DeleteDuplicates[nodesAll];
nodes2=planarBoundaryOrdering[edgesRaw,nodesRaw];
nodes1=nodesAll;  (* keep duplicates so PositionIndex merges co-vertex momenta *)
If[debugMG,Echo[{nodesRaw,nodes2},"planarBoundaryOrdering: {nodesUser,nodesBoundary} = "]];
(* No mass permutation needed for the top-sector path.
   STSymanzikGraph receives nodesAll (original vertex order) and assigns
   momentum p_i to vertex nodesAll[[i]].  The finalRep already maps
   M_i -> mass of user-node i (original order), matching exactly.
   The boundary ordering (nodes2) is used only for planarBoundaryOrdering
   of the Kirchhoff matrix inside STSymanzikGraph; it does NOT relabel
   the external momenta.  A massPerm here would incorrectly reassign
   M_3 <-> M_4 etc., producing a wrong F polynomial for graphs where
   boundary order != original order (e.g., the 4-point box). *)
listSym={STSymanzikGraph[edgesRaw,nodesAll,numVal,dimVal]};
(*Compute Momentum Shifts - with co-vertex legs handled directly by STSymanzikGraph,
  shifts are identity (each p_i maps to itself). *)
shifts={Table[Subscript[p, i] -> Subscript[p, i], {i, Length[nodesAll]}]};
];
,
(*Subtopology path: use relabel as before*)
listSym=(STSymanzikGraph[relabel[#[[1]]],nodes2=planarBoundaryOrdering[relabel[#[[1]]],DeleteDuplicates[nodes1=(#[[2]]/. findMapping[#[[1]],relabel[#[[1]]]])]],numVal,dimVal]&/@Table[Join[{((#[[1]]&/@#)&/@(#[[1]]&/@#))[[ii]]},{((#[[1]]&/@#)&/@(#[[-1]]&/@#))[[ii]]}],{ii,Length[#]}]&[subs]);
(*Compute Momentum Shifts*)
shifts=(Normal[PositionIndex[relabel[#[[2]]]]]&/@Table[Join[{((#[[1]]&/@#)&/@(#[[1]]&/@#))[[ii]]},{((#[[1]]&/@#)&/@(#[[-1]]&/@#))[[ii]]}],{ii,Length[#]}]&[subs])/. Rule[a_,b_]:>Rule[Subscript[p,a],Plus@@(Subscript[p,#]&/@b)];
];
(*Main*)
out=QuietEcho@Table[Echo[If[!FreeQ[#[[-1]],Det]||With[{stFeval=Quiet[listSym[[ii]][[2]]/. shifts[[ii]]/. kinReplacements[[ii]]/. \[Alpha]Replacements[[ii]]/. finalRep//.toSOFIA//First//Simplify],stEElocal=Length[Union[Cases[listSym[[ii]][[1]],Subscript[\[Alpha],_],Infinity]]]},SameQ[stFeval,0]&&!SameQ[Simplify[(stEElocal-noLoop dimVal/2)/.eps->0],0]],(*Vanishing Diagram*)cv[ii]={};
{"This diagram vanishes in dim-reg (e.g., has no scale). We skip it.",{}},
(*Non-Vanishing Diagram*)
saveCV=cv[ii]=Echo[homogeneizeKin2[Flatten[basis[Length[Variables[shifts[[ii]][[All,2]]]]]/. kinReplacements[[ii]]/. finalRep]],"Kinematics ="];
UUU[ii]=Echo[listSym[[ii]][[1]]/. shifts[[ii]]/. kinReplacements[[ii]]/. \[Alpha]Replacements[[ii]]/. finalRep//.toSOFIA//.Subscript[\[Alpha],i_]:>ToExpression["x"<>ToString[i]]//.cv[ii]//Factor//First//homogeneizeKin2,"U ="];
FFF[ii]=With[{stFraw=listSym[[ii]][[2]]/. shifts[[ii]]/. kinReplacements[[ii]]/. \[Alpha]Replacements[[ii]]//.cv[ii]/. finalRep//.Subscript[\[Alpha],i_]:>ToExpression["x"<>ToString[i]]//.toSOFIA//.cv[ii]},Echo[If[SameQ[stFraw//Simplify,0],0,stFraw//Factor//First//homogeneizeKin2],"F ="]];
#]&[
{listSym[[ii]][[-1]]/. shifts[[ii]]/. kinReplacements[[ii]]/. \[Alpha]Replacements[[ii]]/. finalRep//.toSOFIA//.If[ListQ[cv[ii]],cv[ii],{}]//.A_^B_:>A^Factor[B]//.Gamma[A_]:>Gamma[Factor[A]]//.{0^(power_ /; SameQ[Simplify[power/.eps->0],0]):>($STLastVacuumPeriod = True; 1)}//homogeneizeKin2,
If[TrueQ[runSOFIAVal],SOFIA[(subs/. Flatten[finalRep])[[ii]],ShowPossiblyDegenerate->False,SolverBound->solverBoundVal,IncludeSubtopologies->False]//QuietEcho,Nothing]}/. Flatten[basis[Length[Variables[shifts[[ii]][[All,2]]]]]/. kinReplacements[[ii]]/. finalRep]],
{listPlot[[ii]]}],{ii,If[TrueQ[topSectorOnlyVal],1,Length[listPlot]]}];
(*Build U/F List*)listUF=Table[{UUU[ii],FFF[ii]},{ii,If[TrueQ[topSectorOnlyVal],1,Length[listPlot]]}];

(*Updated Lee-Pomeransky (TODO: for now, only records that for the last diagram processed; for use in SubTropica it is enough to record top sector LP only.):*)
SavedLeePomeransky = homogeneizeKin2[If[SameQ[normalization,Automatic],Exp[noLoop eps EulerGamma],normalization] SavedLeePomeransky/. finalRep//.saveCV//.Subscript[\[Alpha],i_]:>ToExpression["x"<>ToString[i]]//.Gamma[A_]:>Gamma[Factor[A]]];

(*Final output*)
homogeneizeKin2[If[SameQ[normalization,Automatic],Exp[noLoop eps EulerGamma],normalization] out//.Subscript[\[Alpha],i_]:>ToExpression["x"<>ToString[i]]//.A_^B_:>Expand[A]^B//.gauge//.Wedge[___]:>1]
];


Options[STGenerateIntegrand]=Options[SOFIASymanzik];

Clear[STGenerateIntegrand]
Options[STGenerateIntegrand] = {
    "TopSectorOnly" -> True,
    "Numerator" -> 1,
    "Dimension" -> 4 - 2*eps,
    "RunSOFIA" -> False,
    "SolverBound" -> 100,
    "Normalization" -> (*1*)Automatic,
    "Gauge" -> {},
    "Substitutions" -> {},
    "Representation" -> "Schwinger"(*"LeePomeransky"*)
};

STGenerateIntegrand[g_, opts:OptionsPattern[]] := Module[
  {raw, factors, xvars, prefactor, integrand, massvars},
  
  raw =
   Flatten[SOFIASymanzik[g, 
    TopSectorOnly -> OptionValue["TopSectorOnly"],
    numerator -> OptionValue["Numerator"],
    dimension -> OptionValue["Dimension"],
    RunSOFIA -> OptionValue["RunSOFIA"],
    SOLVERBOUND -> OptionValue["SolverBound"],
    Normalization -> OptionValue["Normalization"],
    Gauge -> OptionValue["Gauge"]
  ]][[1]];
  
  If[SameQ[OptionValue["Representation"],"Schwinger"],
  (*Schwinger:*)
    raw = raw//.OptionValue["Substitutions"]/.A_^B_:>Factor[A]^B,
    If[SameQ[OptionValue["Representation"],"LeePomeransky"],
  (*Lee-Pomeransky:*)
    raw = (SavedLeePomeransky//.OptionValue["Substitutions"]/.A_^B_:>Factor[A]^B)[[1]],
    Message[STGenerateIntegrand::unknownrepresentation];
    Abort[];
    ]
  ];
  
  factors = Cases[raw * dummy, _];
  xvars = Union@Cases[raw, s_Symbol /; StringStartsQ[SymbolName[s], "x"], Infinity];
  prefactor = Times @@ DeleteCases[
    Select[factors, FreeQ[#, Alternatives @@ xvars] &], dummy];
  integrand = Times @@ factors / (dummy * prefactor);

  (* Schwinger parametrization normalization: the standard formula includes
     (-1)^{nu_tot} = (-1)^{nEdges} (for unit propagator powers) from
     1/D^nu = (-1)^nu/Gamma(nu) * int dx x^{nu-1} e^{xD}.
     SOFIA's output omits this factor.  It is +1 for even nEdges (bubble,
     box, spectacles) and -1 for odd nEdges (triangle, pentagon).
     nEdges is extracted from the graph (not from xvars, which may still
     include the gauge-fixed variable). *)
  Module[{nEdges = If[MatchQ[g, {_List, _List}], Length[g[[1]]], Length[xvars]]},
    prefactor = (-1)^nEdges * prefactor];
  massvars = DeleteCases[
    Union@Cases[integrand, _Symbol, Infinity],
    Alternatives @@ Join[xvars, {eps}]];

  (* Check that the F polynomial has not vanished after substitutions *)
  If[Not[FreeQ[prefactor, 0^_]],
    (* Distinguish vacuum period (0^O(eps)) from truly scaleless (0^nonzero) *)
    Module[{zeroPowers = Cases[prefactor, 0^p_ :> p, Infinity]},
      If[AllTrue[zeroPowers, SameQ[Simplify[# /. eps -> 0], 0] &],
        (* All 0^_ powers vanish at eps=0: vacuum period \[LongDash] replace 0^O(eps) -> 1 *)
        Message[STGenerateIntegrand::vacuumPeriod];
        $STLastVacuumPeriod = True;
        prefactor = prefactor /. {0^(p_ /; SameQ[Simplify[p /. eps -> 0], 0]) :> 1};
      ,
        Message[STGenerateIntegrand::zeroF]; Return[0];
      ];
    ];
  ];

  {prefactor, (Times@@xvars)integrand, xvars, massvars}
]


STGenerateIntegrand::unknownrepresentation = "You passed an invalid representation to STGenerateIntegrand[]. The valid options are: Schwinger or LeePomeransky.";
STGenerateIntegrand::zeroF = "The F (second Symanzik) polynomial vanishes after applying the kinematic substitutions. The integral is scaleless.";
STGenerateIntegrand::vacuumPeriod = "The F polynomial vanishes but the superficial degree of divergence is zero (vacuum period). Replacing 0^O(\[Epsilon]) \[Rule] 1 and proceeding with U polynomial only.";


