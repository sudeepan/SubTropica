import datetime as _review_dt
import re as _review_re
import hashlib as _review_hashlib

_extracted_cache = [None]  # lazy-loaded extracted_integrals.json

_REJECT_LINE_RE = _review_re.compile(r'^\\s*-\\s+(\\S+)\\s+(.+?)\\s+L=(\\d+)\\s+legs=(\\d+)\\s*$')

def review_detect_style(raw):
    head = raw[:512]
    has_loose = '\": ' in head
    if has_loose:
        return 'python'
    has_tight = '\":\"' in head or '\":[' in head or '\":{' in head
    has_escaped = '\\\\/' in head
    if has_tight or has_escaped:
        return 'wolfram'
    return 'python'

def review_dumps_wolfram(data):
    s = json.dumps(data, indent='\\t', separators=(',', ':'), ensure_ascii=False)
    return s.replace('/', '\\\\/')

def review_dumps_python(data):
    return json.dumps(data, indent='\\t', ensure_ascii=False)

def review_serialize(data, original_raw):
    if review_detect_style(original_raw) == 'wolfram':
        return review_dumps_wolfram(data)
    return review_dumps_python(data)

def review_atomic_write(path, contents):
    tmp = path + '.tmp'
    d = os.path.dirname(path)
    if d and not os.path.isdir(d):
        os.makedirs(d)
    with open(tmp, 'w', encoding='utf-8') as f:
        f.write(contents)
        f.flush()
        os.fsync(f.fileno())
    os.rename(tmp, path)

def review_safe_path(rel):
    # Reject paths that escape LIBRARY_BUNDLED_DIR via .. or absolute paths.
    if not rel or not isinstance(rel, str):
        return None
    base = os.path.abspath(LIBRARY_BUNDLED_DIR)
    full = os.path.abspath(os.path.join(base, rel))
    if not full.startswith(base + os.sep) and full != base:
        return None
    return full

def review_invalidate_library_cache():
    _library_cache[1] = 0

# \[HorizontalLine]\[HorizontalLine] Waitlist helpers \[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]\[HorizontalLine]
# ui/waitlist.json lists {topoKey, configKey} pairs that are hidden from
# the public UI until promoted in review mode. The waitlist is owned by
# the frontend (generated by scripts/mark_new_records.py), but the review
# endpoints keep it consistent when entries are verified, moved, or
# deleted so public visibility tracks review state without a rebuild.

def review_waitlist_path():
    return os.path.join(UI_DIR, 'waitlist.json')

def review_waitlist_config_from_path(rel_path):
    # 'topo_dir/cfg_dir/entry.json' \[RightArrow] (topo_key, cfg_key) where both use
    # '|' instead of '_' as separators (matching CNickelIndex convention).
    if not rel_path or not isinstance(rel_path, str):
        return None
    parts = rel_path.split('/')
    if len(parts) < 2 or not parts[0] or not parts[1]:
        return None
    return (parts[0].replace('_', '|'), parts[1].replace('_', '|'))

def review_waitlist_load():
    path = review_waitlist_path()
    if not os.path.isfile(path):
        return None
    try:
        with open(path, 'r', encoding='utf-8') as f:
            return json.load(f)
    except Exception:
        return None

def review_waitlist_save(data):
    path = review_waitlist_path()
    review_atomic_write(path, json.dumps(data, indent=2, ensure_ascii=False))

def review_waitlist_contains(topo_key, config_key):
    data = review_waitlist_load()
    if not data:
        return False
    for c in data.get('configs', []):
        if c.get('topoKey') == topo_key and c.get('configKey') == config_key:
            return True
    return False

def review_remove_from_waitlist(topo_key, config_key):
    data = review_waitlist_load()
    if not data:
        return False
    configs = data.get('configs', [])
    new_configs = [c for c in configs
                   if not (c.get('topoKey') == topo_key
                           and c.get('configKey') == config_key)]
    if len(new_configs) == len(configs):
        return False
    data['configs'] = new_configs
    review_waitlist_save(data)
    return True

def review_add_to_waitlist(topo_key, config_key):
    data = review_waitlist_load()
    if data is None:
        data = {'mode': 'manual', 'configs': []}
    configs = data.get('configs', [])
    for c in configs:
        if c.get('topoKey') == topo_key and c.get('configKey') == config_key:
            return False
    configs.append({'topoKey': topo_key, 'configKey': config_key})
    data['configs'] = configs
    review_waitlist_save(data)
    return True

def review_load_extracted():
    if _extracted_cache[0] is not None:
        return _extracted_cache[0]
    if not os.path.isfile(REVIEW_EXTRACTED_JSON):
        _extracted_cache[0] = []
        return []
    try:
        with open(REVIEW_EXTRACTED_JSON, 'r', encoding='utf-8') as f:
            data = json.load(f)
        _extracted_cache[0] = data if isinstance(data, list) else []
    except Exception:
        _extracted_cache[0] = []
    return _extracted_cache[0]

def review_parse_rejects_log():
    if not os.path.isfile(REVIEW_REJECTS_LOG):
        return []
    entries = []
    with open(REVIEW_REJECTS_LOG, 'r', encoding='utf-8') as f:
        for line in f:
            m = _REJECT_LINE_RE.match(line)
            if not m:
                continue
            arxiv_id, family, loops, legs = m.groups()
            entries.append({
                'id': arxiv_id.strip() + '::' + family.strip(),
                'arxivId': arxiv_id.strip(),
                'familyName': family.strip(),
                'loops': int(loops),
                'legs': int(legs),
            })
    return entries

def review_find_extracted_family(arxiv_id, family_name, loops, legs):
    '''Return the matching family dict from extracted_integrals.json,
    tie-breaking on loops+legs for ambiguous family-name collisions.'''
    candidates = []
    for paper in review_load_extracted():
        if paper.get('arxiv_id') != arxiv_id:
            continue
        for fam in paper.get('families', []):
            fn = fam.get('family_name') or fam.get('name') or ''
            if fn == family_name:
                candidates.append((paper, fam))
    if not candidates:
        return None
    if len(candidates) == 1:
        return candidates[0]
    tiebroken = [c for c in candidates
                 if c[1].get('loops') == loops and c[1].get('legs') == legs]
    if len(tiebroken) == 1:
        return tiebroken[0]
    return None

def review_load_rejects_state():
    if not os.path.isfile(REVIEW_REJECTS_STATE):
        return {}
    try:
        with open(REVIEW_REJECTS_STATE, 'r', encoding='utf-8') as f:
            data = json.load(f)
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}

def review_save_rejects_state(state):
    review_atomic_write(REVIEW_REJECTS_STATE, json.dumps(state, indent='\\t', ensure_ascii=False))

def review_today_iso():
    return _review_dt.date.today().isoformat()

def review_walk_pairs_queue(filter_mode):
    '''Walk library-bundled/ and yield one descriptor per Records[] entry.
    filter_mode is 'pending' (only unverified), 'all', or 'verified'.

    Each item carries loops/legs/props from topology.json so the frontend
    can offer client-side filter chips.'''
    out = []
    base = LIBRARY_BUNDLED_DIR
    if not os.path.isdir(base):
        return out
    topo_meta_cache = {}  # topoKey -> (loops, legs, props) tuple
    for topo in sorted(os.listdir(base)):
        topo_dir = os.path.join(base, topo)
        if not os.path.isdir(topo_dir):
            continue
        # Load topology.json once per topology dir for loops/legs/props
        if topo not in topo_meta_cache:
            tj = os.path.join(topo_dir, 'topology.json')
            loops_v, legs_v, props_v = 0, 0, 0
            if os.path.isfile(tj):
                try:
                    with open(tj, 'r', encoding='utf-8') as f:
                        td = json.load(f)
                    loops_v = td.get('Loops', 0)
                    legs_v = td.get('Legs', 0)
                    props_v = td.get('Propagators', 0)
                except Exception:
                    pass
            topo_meta_cache[topo] = (loops_v, legs_v, props_v)
        loops_v, legs_v, props_v = topo_meta_cache[topo]
        for cfg in sorted(os.listdir(topo_dir)):
            cfg_dir = os.path.join(topo_dir, cfg)
            if not os.path.isdir(cfg_dir):
                continue
            ef = os.path.join(cfg_dir, 'entry.json')
            if not os.path.isfile(ef):
                continue
            try:
                with open(ef, 'r', encoding='utf-8') as f:
                    entry = json.load(f)
            except Exception:
                continue
            rel = os.path.relpath(ef, base)
            cni = entry.get('CNickelIndex', '')
            ms = entry.get('MassScales', 0)
            fc = entry.get('FunctionClass', '')
            names = entry.get('Names', [])
            for idx, rec in enumerate(entry.get('Records', [])):
                ver = bool(rec.get('verified'))
                if filter_mode == 'pending' and ver:
                    continue
                if filter_mode == 'verified' and not ver:
                    continue
                out.append({
                    'path': rel.replace(os.sep, '/'),
                    'topoKey': topo,
                    'configKey': cfg,
                    'cNickel': cni,
                    'loops': loops_v,
                    'legs': legs_v,
                    'props': props_v,
                    'massScales': ms,
                    'functionClass': fc,
                    'names': names,
                    'recordIndex': idx,
                    'recordId': rec.get('recordId', ''),
                    'reference': rec.get('reference', ''),
                    'authors': rec.get('authors', ''),
                    'description': rec.get('description', ''),
                    'verified': ver,
                    'verifiedAt': rec.get('verifiedAt', ''),
                })
    return out

def review_rejects_queue(filter_mode):
    state = review_load_rejects_state()
    out = []
    for e in review_parse_rejects_log():
        key = e['id']
        st = state.get(key, {'status': 'pending'})
        status = st.get('status', 'pending')
        if filter_mode == 'pending' and status != 'pending':
            continue
        if filter_mode == 'resolved' and status == 'pending':
            continue
        match = review_find_extracted_family(
            e['arxivId'], e['familyName'], e['loops'], e['legs'])
        candidate = None
        if match:
            paper, fam = match
            candidate = {
                'title': paper.get('title', ''),
                'authors': paper.get('authors', ''),
                'year': paper.get('year'),
                'propagators': fam.get('propagators', []),
                'edges': fam.get('edges', []),
                'extVerts': fam.get('ext_verts', []),
                'edgeMasses': fam.get('edge_masses', []),
                'externalMomenta': fam.get('external_momenta', []),
                'kinematics': fam.get('kinematics', {}),
                'massConfig': fam.get('mass_config', ''),
                'functionClass': fam.get('function_class', ''),
                'dimScheme': fam.get('dim_scheme', ''),
                'epsilonOrder': fam.get('epsilon_order', ''),
                'computationLevel': fam.get('computation_level', ''),
                'location': fam.get('location', ''),
                'description': fam.get('description', ''),
            }
        e2 = dict(e)
        e2['status'] = status
        e2['acceptedAs'] = st.get('acceptedAs', '')
        e2['candidate'] = candidate
        # Parse the human-readable reason from the log section headers
        # (done lazily in UI \[LongDash] here we just include the raw match).
        out.append(e2)
    return out


def build_library_json():
    \"\"\"Walk LIBRARY_BUNDLED_DIR and LIBRARY_LOCAL_DIR, merge, and return JSON.
    Caches the result and rebuilds only if any file changed.\"\"\"
    try:
        latest = 0
        for lib_root in [LIBRARY_BUNDLED_DIR, LIBRARY_LOCAL_DIR]:
            if not os.path.isdir(lib_root):
                continue
            for root, dirs, files in os.walk(lib_root):
                for f in files:
                    mt = os.path.getmtime(os.path.join(root, f))
                    if mt > latest:
                        latest = mt
        if _library_cache[0] and latest <= _library_cache[1]:
            return _library_cache[0]

        topologies = {}
        topo_count = 0
        config_count = 0
        for lib_root in [LIBRARY_BUNDLED_DIR, LIBRARY_LOCAL_DIR]:
            if not os.path.isdir(lib_root):
                continue
            for topo_name in sorted(os.listdir(lib_root)):
                topo_dir = os.path.join(lib_root, topo_name)
                if not os.path.isdir(topo_dir):
                    continue
                topo_file = os.path.join(topo_dir, 'topology.json')
                if not os.path.isfile(topo_file):
                    continue
                try:
                    with open(topo_file, 'r', encoding='utf-8') as f:
                        topo_data = json.load(f)
                except Exception:
                    continue
                nickel = topo_data.get('NickelIndex', topo_name.replace('_', '|'))
                # Merge into existing topology if already seen
                if nickel not in topologies:
                    topologies[nickel] = {
                        'name': topo_data.get('Name', ''),
                        # PrimaryName is the curated UI-facing label (Tier-1
                        # canonical name from data/topology_names.json,
                        # synced to topology.json by apply_diagram_names.py).
                        # The UI's title fallback chain is
                        # `topo.primaryName || topo.name || topo.Name || key`,
                        # so omitting primaryName here makes the UI fall back
                        # to the raw `name` (which for I-family entries is
                        # the paper's $I^{**}_{a,b,c}$ LaTeX, not the
                        # descriptive label). Emit it now to stay in sync
                        # with scripts/_build_library_json.py.
                        'primaryName': topo_data.get('PrimaryName', ''),
                        'loops': topo_data.get('Loops', 0),
                        'legs': topo_data.get('Legs', 0),
                        'props': topo_data.get('Propagators', 0),
                        'loopediaURL': topo_data.get('LoopediaURL', ''),
                        'configs': {}
                    }
                    topo_count += 1
                configs = topologies[nickel]['configs']
                for cfg_name in sorted(os.listdir(topo_dir)):
                    cfg_dir = os.path.join(topo_dir, cfg_name)
                    if not os.path.isdir(cfg_dir):
                        continue
                    entry_file = os.path.join(cfg_dir, 'entry.json')
                    if not os.path.isfile(entry_file):
                        continue
                    try:
                        with open(entry_file, 'r', encoding='utf-8') as f:
                            entry = json.load(f)
                    except Exception:
                        continue
                    cni = entry.get('CNickelIndex', '')
                    mass_key = cni.split(':')[1] if ':' in cni else ''.join('0' if c != '|' else '|' for c in cni)
                    if mass_key in configs:
                        # Merge results from user library into existing config
                        existing_results = configs[mass_key].get('Results', configs[mass_key].get('results', []))
                        new_results = entry.get('Results', entry.get('results', []))
                        existing_results.extend(new_results)
                        if 'Results' in configs[mass_key]:
                            configs[mass_key]['Results'] = existing_results
                        else:
                            configs[mass_key]['results'] = existing_results
                    else:
                        configs[mass_key] = entry
                    config_count += 1
        result = json.dumps({
            'topologies': topologies,
            '_meta': {
                'topologyCount': topo_count,
                'configCount': config_count,
                'sourceDir': 'library-bundled'
            }
        })
        _library_cache[0] = result
        _library_cache[1] = latest
        return result
    except Exception as e:
        return json.dumps({'topologies': {}, '_meta': {'error': str(e)}})

def call_mma(action, body):
    rid = next_id()
    rp = os.path.join(IPC_DIR, rid + '.request')
    sp = os.path.join(IPC_DIR, rid + '.response')
    with open(rp, 'w', encoding='utf-8') as f:
        json.dump({'id': rid, 'action': action, 'body': body}, f)
    for _ in range(300):
        if os.path.exists(sp):
            time.sleep(0.02)
            try:
                with open(sp, 'r', encoding='utf-8') as f:
                    r = f.read()
                os.remove(sp)
                try: os.remove(rp)
                except: pass
                return r
            except: pass
        time.sleep(0.1)
    try: os.remove(rp)
    except: pass
    return json.dumps({'status':'error','error':'Mathematica timeout'})

class H(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        p = self.path.split('?')[0]
        if p == '/api/ping':
            kf = os.path.join(IPC_DIR, 'kernels.json')
            df = os.path.join(IPC_DIR, 'deps.json')
            nk = 0; deps = {}
            try:
                with open(kf, 'r') as f:
                    nk = json.loads(f.read()).get('kernels', 0)
            except: pass
            try:
                with open(df, 'r') as f:
                    deps = json.loads(f.read())
            except: pass
            self._ok('application/json', json.dumps({'status':'alive','kernels':nk,'deps':deps}))
        elif p == '/api/verify_result':
            vf = os.path.join(IPC_DIR, 'verify_result.json')
            if os.path.isfile(vf):
                try:
                    with open(vf, 'r', encoding='utf-8') as f:
                        self._ok('application/json', f.read())
                except:
                    self._ok('application/json', '{\"status\":\"pending\"}')
            else:
                self._ok('application/json', '{\"status\":\"pending\"}')
        elif p == '/api/progress':
            pf = os.path.join(IPC_DIR, 'progress.log')
            try:
                with open(pf, 'r', encoding='utf-8') as f:
                    lines = f.read()
                self._ok('application/json', json.dumps({'status':'ok','log':lines}))
            except:
                self._ok('application/json', '{\"status\":\"ok\",\"log\":\"\"}')
        elif p == '/api/progress_jsonl':
            # Axis 11: byte-offset tailing. Client passes ?since=<offset>;
            # we return only the tail past that point plus the new total
            # size. On truncation (client offset > current size) we reset.
            pf = os.path.join(IPC_DIR, 'progress.jsonl')
            qs = self.path.split('?', 1)[1] if '?' in self.path else ''
            since = 0
            for part in qs.split('&'):
                if part.startswith('since='):
                    try: since = int(part.split('=', 1)[1])
                    except: since = 0
            try:
                size = os.path.getsize(pf)
                # File shrank (new run truncated it) -- reset client offset.
                if since > size: since = 0
                if since >= size:
                    tail = ''
                else:
                    with open(pf, 'rb') as f:
                        f.seek(since)
                        tail = f.read(size - since).decode('utf-8', 'replace')
                self._ok('application/json',
                    json.dumps({'status':'ok','jsonl':tail,'size':size,'since':since}))
            except:
                self._ok('application/json',
                    '{\"status\":\"ok\",\"jsonl\":\"\",\"size\":0,\"since\":0}')
        elif p == '/api/result':
            rf = os.path.join(IPC_DIR, 'result.json')
            if os.path.exists(rf):
                try:
                    with open(rf, 'r', encoding='utf-8') as f:
                        r = f.read()
                    self._ok('application/json', r)
                except:
                    self._ok('application/json', '{\"status\":\"pending\"}')
            else:
                self._ok('application/json', '{\"status\":\"pending\"}')
        elif p == '/api/stage':
            sf = os.path.join(IPC_DIR, 'stage.json')
            if os.path.exists(sf):
                try:
                    with open(sf, 'r', encoding='utf-8') as f:
                        r = f.read()
                    import json as _json
                    d = _json.loads(r)
                    jtd = d.get('JobTrackingDir', '')
                    if jtd and os.path.isdir(jtd):
                        completed = len([f for f in os.listdir(jtd) if f.startswith('completed_kernel_')])
                        d['JobsCompleted'] = completed
                    self._ok('application/json', _json.dumps(d))
                except:
                    self._ok('application/json', '{\"Stage\":\"Unknown\"}')
            else:
                self._ok('application/json', '{}')
        elif p == '/api/favorites':
            try:
                with open(FAV_FILE, 'r', encoding='utf-8') as f:
                    self._ok('application/json', f.read())
            except:
                self._ok('application/json', '[]')
        elif p == '/api/config_favorites':
            try:
                with open(CONFIG_FAV_FILE, 'r', encoding='utf-8') as f:
                    self._ok('application/json', f.read())
            except:
                self._ok('application/json', '[]')
        elif p == '/api/symanzik_tex':
            sf = os.path.join(IPC_DIR, 'symanzik_tex.json')
            if os.path.exists(sf):
                try:
                    with open(sf, 'r', encoding='utf-8') as f:
                        r = f.read()
                    self._ok('application/json', r)
                except:
                    self._ok('application/json', '{\"tex\":\"\"}')
            else:
                self._ok('application/json', '{\"tex\":\"\"}')
        elif p == '/api/library':
            self._ok('application/json', build_library_json())
        elif p == '/api/review/queue':
            from urllib.parse import parse_qs, urlparse
            q = parse_qs(urlparse(self.path).query)
            qtype = (q.get('type', ['pairs'])[0] or 'pairs').lower()
            qfilter = (q.get('filter', ['pending'])[0] or 'pending').lower()
            try:
                if qtype == 'rejects':
                    items = review_rejects_queue(qfilter)
                else:
                    items = review_walk_pairs_queue(qfilter)
                body = json.dumps({'status': 'ok', 'type': qtype,
                                   'filter': qfilter, 'items': items},
                                  ensure_ascii=False)
                self._ok('application/json', body)
            except Exception as e:
                self._ok('application/json',
                         json.dumps({'status': 'error', 'error': str(e)}))
        elif p == '/api/review/entry':
            from urllib.parse import parse_qs, urlparse
            q = parse_qs(urlparse(self.path).query)
            rel = q.get('path', [''])[0]
            full = review_safe_path(rel)
            if not full or not os.path.isfile(full):
                self._ok('application/json',
                         json.dumps({'status': 'error', 'error': 'not found'}))
            else:
                try:
                    with open(full, 'r', encoding='utf-8') as f:
                        raw = f.read()
                    entry = json.loads(raw)
                    self._ok('application/json',
                             json.dumps({'status': 'ok', 'entry': entry}))
                except Exception as e:
                    self._ok('application/json',
                             json.dumps({'status': 'error', 'error': str(e)}))
        elif p == '/api/review/name_suggestions':
