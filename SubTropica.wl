];


Clear[STEvaluateEulerMaple];
STEvaluateEulerMaple[ integrand_ , xvars_ , coeffs_ , order_:0 , mode_:"All", startOrder_:1,trDataGiven_:{},forceUs_:{}]:=Module[
	{
	expansions, result, combined
	}
	,
	(* Computing expansion in subtraction formulae *)
	expansions=STExpandIntegral[integrand,xvars,coeffs,{eps},trDataGiven,forceUs];
	(* STExpandIntegral[integrand_,vars_,coeffs_,regulators_:{eps},trDataGiven_:{}] *)
	
	(* Evaluating subtraction formulae *)
	(*killMapleProcesses[];*)
	If[Not[(mode==="NoOrders")||(mode==="Read")],
		STClearDirectories["euler"]
	];
	
	
	result=STEvaluateSubtractionNPMaple[expansions, order, xvars, coeffs, "euler", mode, startOrder];
	(***********************************************************)
	(* To add: Check we were successfull, otherwise try again *)
	(***********************************************************)

	(* To add: If asked, reduce to fibration basis *)
	result
];


Clear[STEvaluateFeynmanMaple];
STEvaluateFeynmanMaple[loops_, props_ , kinematics_, dim_,  order_:0 , mode_:"All", startOrder_:1]:=Module[
	{
	dummyDim,
	expansions, result, combined, xvars, coeffs, integrand, L, eF, eU, prefactor,polePref
	}
	,
	
	(* Assembling Parametric Integrand *)
	{{dummyDim,\[Nu],L,eF,eU,xvars},{prefactor,integrand}}=STGetIntegrandData[dim,loops,props,Table[1,{p,props}],kinematics];
	integrand=integrand/.xvars[[-1]]->1;
	If[(prefactor/.Gamma->Identity/.eps->0)<= 0,polePref=1,polePref=0];
	
	coeffs=Join[kinematics[[;;,2]]//Variables,props//Cases[#,mm[_],\[Infinity]]&];
	xvars=xvars[[;;-2]];
	STDeclarePositiveVariables[xvars];
	STDeclarePositiveVariables[coeffs];
	
	(* Computing expansion in subtraction formulae *)
	Print["-----------------"];
	Print["Computing Subtractions+NP"];
	expansions=STExpandIntegral[ integrand,xvars,coeffs,{eps}];
	Print["-----------------"];
	
	(* Clean-Up *)
	(*killMapleProcesses[];*)
	If[Not[(mode==="NoOrders")||(mode==="Read")],
		STClearDirectories["euler"]
	];
	
	(* Evaluating subtraction formulae *)
	result=STEvaluateSubtractionNPMaple[expansions, order+polePref, xvars, coeffs, "euler", mode, startOrder];
	
	
	(***********************************************************)
	(* To add: Check we were successfull, otherwise try again *)
	(***********************************************************)
	
	(* To add: If asked, reduce to fibration basis *)
	{Gamma[Length[props]-(dim-2 eps) Length[loops]/2//Expand],result}
];


Clear[STEvaluateFeynmanG];
STEvaluateFeynmanG[graph_ , kinematics_, dim_,  order_:0 , mode_:"All", startOrder_:1]:=Module[
	{
	loops,props,dummyDim,
	expansions, result, combined, xvars, coeffs, integrand, L, eF, eU, prefactor,polePref
	}
	,
	
	(* Assembling Parametric Integrand *)
	Quiet[{loops,props}=graph//STtoMyGraph//STGetPropagators];
	(* STGetPropagators returns -(q^2-m^2); negate to q^2-m^2 for STSymanzik *)
	props=-props-mm/@Range[props//Length];
	{{dummyDim,\[Nu],L,eF,eU,xvars},{prefactor,integrand}}=STGetIntegrandData[dim,loops,props,Table[1,{p,props}],kinematics];
	If[(prefactor/.Gamma->Identity/.eps->0)<= 0,polePref=1,polePref=0];
	integrand=integrand/.xvars[[-1]]->1;
	
	coeffs=Join[kinematics[[;;,2]]//Variables,props//Cases[#,mm[_],\[Infinity]]&];
	xvars=xvars[[;;-2]];
	STDeclarePositiveVariables[xvars,coeffs];
	
	(* Computing expansion in subtraction formulae *)
	expansions=STExpandIntegral[ integrand,xvars,coeffs,{eps}];
	
	(* Clean-Up *)
	(*killMapleProcesses[];*)
	If[Not[(mode==="NoOrders")||(mode==="Read")],
		STClearDirectories["euler"]
	];
	
	(* Evaluating subtraction formulae *)
	result=STEvaluateSubtractionNPMaple[expansions, order+polePref, xvars, coeffs, "euler", mode, startOrder];
		
	(***********************************************************)
	(* To add: Check we were successfull, otherwise try again *)
	(***********************************************************)
	
	(* To add: If asked, reduce to fibration basis *)
	{prefactor, result}
];


