(* Return all face directories contributing to problem id, as a list of triples {face id, eps-order, face directory }*)
STListDirectoriesNP[id_:"NP"]:=Module[
{NPfilenames,stringReplacerFunction,NPfilenamesEpsOrders},
(* names of all face/order directories that contribute to this NP-id *)
	NPfilenames=FileNames["integrands/"<>id<>"*"<>"/*"];
	Clear[stringReplacerFunction];
	stringReplacerFunction[string_]:=
		{
		(* face identifier *)
		StringReplace[string, {"ord_" ~~ ___ ~~"_face"-> "_face"}],
		(* eps-order *)
		StringReplace[string, {___ ~~ "ord_" ~~ a___ ~~"_face"~~ ___ :> a}],
		(* original string *)
		string		
		};
	NPfilenamesEpsOrders=stringReplacerFunction /@ NPfilenames;
	NPfilenamesEpsOrders//Return;
]


(* Return all face directories contributing to problem id, as a list of triples {face id, eps-order, face directory }*)
