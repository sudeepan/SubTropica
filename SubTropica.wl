        feynmanAnalyzeTopology[edgePairs_List] := Module[
          {edgelist2 = edgePairs,
           extnodes, extPositions, partnerPositions, nodes0,
           extEdgeRows, edgelist3, vertices, nodes1, ivertices,
           reordering, edgelistfinal, nedges, nlegs, nloops},

          If[Length[edgelist2] == 0,
            Return[<|
              "edgelistfinal" -> {}, "nodes0" -> {},
              "nodes0reordered" -> {}, "vertices" -> {},
              "reordering" -> {}, "nIntEdges" -> 0,
              "nExtLegs" -> 0, "nVertices" -> 0, "nLoops" -> 0|>]
          ];

          extnodes = Select[Tally[Flatten[edgelist2]],
                            #[[2]] == 1 &][[All, 1]];

          If[Length[extnodes] == 0,
            edgelist3 = Sort /@ edgelist2;
            vertices = edgelist3 // Flatten // DeleteDuplicates;
            reordering = Thread[vertices -> Range[Length[vertices]]];
            edgelistfinal = Sort /@ (edgelist3 /. reordering);
            nedges = Length[edgelistfinal];
            nloops = nedges - Length[vertices] + 1;
            Return[<|
              "edgelistfinal" -> edgelistfinal, "nodes0" -> {},
              "nodes0reordered" -> {}, "vertices" -> vertices,
              "reordering" -> reordering, "nIntEdges" -> nedges,
              "nExtLegs" -> 0, "nVertices" -> Length[vertices],
              "nLoops" -> nloops|>]
          ];

          extPositions = Position[edgelist2, #][[1]] & /@ extnodes;
          partnerPositions = extPositions /. {
            {r_, 1} -> {r, 2}, {r_, 2} -> {r, 1}};
          nodes0 = Extract[edgelist2, partnerPositions]; (* preserve JS order \[LongDash] no Sort *)

          extEdgeRows = extPositions[[All, 1]];
          edgelist3 = Sort /@ Delete[edgelist2, List /@ extEdgeRows];

          vertices = edgelist3 // Flatten // DeleteDuplicates;
          nodes1 = DeleteDuplicates[nodes0];
          ivertices = Complement[vertices, nodes1];

          reordering = Join[
            Thread[nodes1 -> Range[Length[nodes1]]],
            Thread[ivertices -> Range[
              Length[nodes1] + 1, Length[nodes1] + Length[ivertices]]]
          ];

          edgelistfinal = Sort /@ (edgelist3 /. reordering);
          nedges = Length[edgelistfinal];
          nlegs = Length[nodes0];
          nloops = nedges - Length[vertices] + 1;

          <|"edgelistfinal" -> edgelistfinal,
            "nodes0" -> nodes0,
            "nodes0reordered" -> (nodes0 /. reordering),
            "vertices" -> vertices,
            "reordering" -> reordering,
            "nIntEdges" -> nedges,
            "nExtLegs" -> nlegs,
            "nVertices" -> Length[vertices],
            "nLoops" -> nloops|>
        ];

        (* buildFeynmanPreview: uses actual mass values and EdgesLabel *)
        buildFeynmanPreview[edgePairs_List, intMasses_List, extMasses_List,
                            plotOpts_List, imgSize_: 300] :=
          Module[{an, pEdges, pNodes, pDiag, nE},
            an = feynmanAnalyzeTopology[edgePairs];
            nE = an["nIntEdges"];
            If[nE == 0 && an["nExtLegs"] == 0,
              Return[Graphics[
                {Text[Style["(no diagram)", Gray, Italic, 11]]},
                ImageSize -> imgSize]]
            ];
            pEdges = Table[
              {an["edgelistfinal"][[i]],
               If[i <= Length[intMasses], intMasses[[i]], 0]},
              {i, nE}];
            pNodes = Table[
              {an["nodes0reordered"][[i]],
               If[i <= Length[extMasses], extMasses[[i]], 0]},
              {i, an["nExtLegs"]}];
            pDiag = {pEdges, pNodes};
            Check[
              Show[FeynmanPlot[pDiag,
                     EdgesLabel -> Range[nE],
                     Sequence @@ plotOpts],
                   ImageSize -> imgSize],
              Graphics[
                {Text[Style["(Preview unavailable)", Gray, Italic]]},
                ImageSize -> imgSize]
            ]
          ];

      )  (* end Initialization *)
    ],  (* end DynamicModule *)

    WindowTitle -> FromCharacterCode[16^^1F3DD] <> "SubTropica"
  ];

  (* ============================================================= *)
  (* Post-dialog: call STEvaluate                                    *)
  (* ============================================================= *)
  If[result === $Canceled, Return[$Failed]];

  edges = result["edges"];
  nodes = result["nodes"];
  allOpts = KeyDrop[result, {"edges", "nodes"}];

  STEvaluate[{edges, nodes},
    Sequence @@ Normal[allOpts]
  ]
]*)


