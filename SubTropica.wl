	*)
	mapleCommand=mapleCommand<>"exit;";
	
	(*mapleCommand//Print;*)
	
	(* Write in hyperInt/mathMaplecoms directory *)
	mapleCommandFile="hyperInt/mathMaplecoms/mapleCommandFile.mpl";
