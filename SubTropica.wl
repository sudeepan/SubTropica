Needs["GraphUtilities`"]

(* Draw a graph: draw first external vertices, then internal edges, then external legs *)
STfixGraph[g_]:=g//System`EdgeList//DeleteCases[#,e_\[UndirectedEdge]e_]&//System`Graph[#,EdgeLabels->"Index",VertexLabels->"Index"]&;
Clear[STdrawGraph];
STDrawGraph[]:=Module[{gr},
gr=("Graph"/.GraphEdit[][[2]])//System`Graph;
STfixGraph[System`Graph[(gr//System`EdgeList//DeleteCases[#,a_ \[UndirectedEdge] a_]&)/.DirectedEdge-> UndirectedEdge,VertexLabels->Automatic,EdgeLabels->"Index"]]
]

(* Convert graph notations from/to Mathematica & Subtropica*)
STtoMyGraph[matGraph_]:=Module[{vertices,edges},
{matGraph//System`VertexList,matGraph//System`EdgeList}
]

(* Simplify the labelling of vertices and edges *)
STRelabelG[graph_]:=Block[{verts,toVerts},
verts=Range[graph[[1]]//Length];
toVerts=Table[graph[[1,i]]-> verts[[i]],{i,1,graph[[1]]//Length}];
{verts,graph[[2]]/.toVerts}
]
STtoMatGraph[myGraph_]:=Graph@@myGraph

STtoMatGraph[myGraph_]:=Graph@@myGraph


Clear[STgetExternalVertices];
STgetExternalVertices[graph_]:=Module[{flatVerts},
	flatVerts=graph[[2]]/.UndirectedEdge-> List//Flatten;
	Cases[flatVerts,v_/;Count[flatVerts,v]===1]
]

STgetMomenta[graph_,externalVertices_:Automatic]:=Module[
{vertices,extVertices,innerVertices,
extMomenta,intMomenta,momenta,
equations,momentumL,momentumR,sol
},
	vertices=graph[[1]];
	extVertices=If[externalVertices===Automatic,STgetExternalVertices[graph],externalVertices];
	If[extVertices==={},
		Message[STgetMomenta::noext];
		Print["[SubTropica] Warning: no external vertices detected. If the graph has external legs with degree > 1, pass them explicitly via STgetMomenta[graph, {v1,v2,...}] or STGetPropagators[graph, masses, {v1,v2,...}]."]];
	innerVertices=Complement[vertices,extVertices];
	extMomenta=p/@extVertices;
	momenta=Table[q[i],{i,1,graph[[2]]//Length}];
	equations=Table[
	(Total[q/@Flatten[Position[graph[[2]],_\[UndirectedEdge]v]]]==Total[q/@Flatten[Position[graph[[2]],v\[UndirectedEdge]_]]])/.q[Null]->0
	,
	{v,innerVertices}];
	equations=Join[
		equations,
		Table[
			momentumL=q[(Position[graph[[2]],_\[UndirectedEdge]v]//Flatten)]/.{ q[{}]-> 0,q[{a__}]:> q[a]};
			momentumR=q[(Position[graph[[2]],v\[UndirectedEdge]_]//Flatten)]/.{ q[{}]-> 0,q[{a__}]:> q[a]};
			momentumL==p[v]+momentumR
		,{v,extVertices}]
	];
	sol=Solve[equations,Cases[equations,p[_]|q[_]]//DeleteDuplicates//Sort]//First//Quiet;
	Table[i->( q[i]/.sol),{i,1,graph[[2]]//Length}]
]
STgetMomenta::noext="No external vertices detected. The degree-1 heuristic failed for this graph topology.";

Clear[STGetPropagators];
STGetPropagators[graph_,masses_:{mm[_]-> 0},externalVertices_:Automatic]:=Module[{momenta=STgetMomenta[graph,externalVertices],props,loops},
props=DeleteCases[Table[-(i/.momenta)^2 +( mm[i]/.masses),{i,1,graph[[2]]//Length}]//Factor,v_/;Count[v,q[_],\[Infinity]]===0];
loops=Cases[props,q[_],\[Infinity]]//DeleteDuplicates//Sort;
{loops,props}
]
Clear[STgetUF];
STgetUF[graph_,kinematics_:{p[_]->1,mm[_]->0},externalVertices_:Automatic]:=Module[{loops,props,massRules,extMom,nExt,massSubs,subs},
massRules=Cases[kinematics/.Rule-> tRule,tRule[mm[_],_]]/.tRule-> Rule ;
{loops,props}=STGetPropagators[graph,massRules,externalVertices];
(* STGetPropagators returns -(q^2-m^2) convention; negate to q^2-m^2 for STSymanzik *)
props=-props;
(* Build mass rules: map M[i]^2 to p[i]^2 values from kinematics *)
extMom = Complement[Cases[Variables[props], p[_]], loops] // Sort;
nExt = Length[extMom] + 1;
massSubs = Join[
	Table[M[i]^2 -> (extMom[[i]]^2 /. kinematics), {i, Length[extMom]}],
	{M[nExt]^2 -> (Expand[(-Total[extMom])^2] //. kinematics)}
];
subs = Join[kinematics, massSubs];
(* STSymanzik "UF" mode returns physical signs: U > 0, F \[LessEqual] 0 (Euclidean) *)
STSymanzik[props, "Substitutions" -> subs, "LoopMomenta" -> loops, "Output" -> "UF"]
]

SThowManyEdge[g_,edge_,ray_]:=Module[{multipleEdgesPos},
multipleEdgesPos=Position[System`EdgeList[g],edge|Reverse[edge]]//Flatten;
If[(Intersection[Position[ray,-1]//Flatten,multipleEdgesPos]//Length)>1,{multipleEdgesPos//First,Intersection[Position[ray,-1]//Flatten,multipleEdgesPos]//Length},multipleEdgesPos//First]
]

Clear[STdrawSubGraphs];STdrawSubGraphs[graph_,rays_,method_:Automatic]:=Module[{edge},Table[HighlightGraph[graph,
Table[
edge=System`EdgeList[graph][[i]];
{Labeled[edge,SThowManyEdge[graph,edge,ray]],Style[edge,Red,Thick]},
{i,Position[ray,-1]//Flatten}]
],{ray,rays}]//Map[GraphPlot[#,Method->method,VertexLabels->None]&,#]&]


STGetLoopsProps[graph_]:=Module[
{
loops,props
}
	,
	Quiet[{loops,props}=graph//STtoMyGraph//STGetPropagators;];
	(* Negate: STGetPropagators returns -(q^2-m^2); convert to q^2-m^2 for STSymanzik *)
	{loops,-props-mm/@Range[props//Length]}
];


