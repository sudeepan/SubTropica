  [self.v loadHTMLString:loadHTML baseURL:nil];
  [self.w setContentView:self.v];[self.w makeKeyAndOrderFront:nil];
  [NSApp activateIgnoringOtherApps:YES];
  dispatch_after(dispatch_time(DISPATCH_TIME_NOW,(int64_t)(.5*NSEC_PER_SEC)),dispatch_get_main_queue(),^{[self p];});
}
-(void)p{[self.v loadRequest:[NSURLRequest requestWithURL:[NSURL URLWithString:self.u] cachePolicy:NSURLRequestReloadIgnoringLocalCacheData timeoutInterval:3]];}
-(void)webView:(WKWebView*)wv didFailProvisionalNavigation:(WKNavigation*)n withError:(NSError*)e{
  if(self.r<50){self.r++;dispatch_after(dispatch_time(DISPATCH_TIME_NOW,(int64_t)(.3*NSEC_PER_SEC)),dispatch_get_main_queue(),^{[self p];});}
}
-(void)webView:(WKWebView*)wv decidePolicyForNavigationAction:(WKNavigationAction*)a decisionHandler:(void(^)(WKNavigationActionPolicy))dh{
  NSURL*url=a.request.URL;
  if(a.navigationType==WKNavigationTypeLinkActivated&&url&&![url.host isEqualToString:@\"127.0.0.1\"]){
    [[NSWorkspace sharedWorkspace]openURL:url];
    dh(WKNavigationActionPolicyCancel);
    return;
  }
  dh(WKNavigationActionPolicyAllow);
}
-(void)webView:(WKWebView*)wv didFinishNavigation:(WKNavigation*)nav{
}
-(void)userContentController:(WKUserContentController*)uc didReceiveScriptMessage:(WKScriptMessage*)msg{
  if([msg.name isEqualToString:@\"resize\"]){
    CGFloat ch=[msg.body doubleValue];
    if(ch>100){
      CGFloat th=ch+28+24;
      CGFloat sh=[[NSScreen mainScreen]visibleFrame].size.height;
      if(th>sh*0.93)th=sh*0.93;
      if(th<400)th=400;
      NSRect f=self.w.frame;
      CGFloat dh=th-f.size.height;
      if(fabs(dh)>4){f.origin.y-=dh;f.size.height=th;
        [self.w setFrame:f display:YES animate:YES];}
    }
  }
}
-(void)windowWillClose:(NSNotification*)n{[NSApp terminate:nil];}
-(BOOL)applicationShouldTerminateAfterLastWindowClosed:(NSApplication*)a{return YES;}
