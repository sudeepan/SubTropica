                if dest_exists:
                    with open(new_full, 'r', encoding='utf-8') as f:
                        dest_raw = f.read()
                    dest = json.loads(dest_raw)
                    # Merge: append moved records (dedup by recordId)
                    existing_ids = {r.get('recordId') for r in dest.get('Records', [])}
                    dest.setdefault('Records', []).extend(
                        [r for r in moved_records if r.get('recordId') not in existing_ids])
                    # Merge References
                    existing_refs = set(dest.get('References', []))
                    for r in moved_records:
                        ref = r.get('reference', '')
                        if ref and ref not in existing_refs:
                            dest.setdefault('References', []).append(ref)
                            existing_refs.add(ref)
                else:
                    dest_raw = ''
                    dest = dict(new_entry)
                    dest['Records'] = list(moved_records)
                    # Regenerate References from the records' reference fields
                    refs = []
                    seen = set()
                    for r in moved_records:
                        ref = r.get('reference', '')
                        if ref and ref not in seen:
                            refs.append(ref)
                            seen.add(ref)
                    dest['References'] = refs
                if drop_results:
