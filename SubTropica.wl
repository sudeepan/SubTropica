(*Ask Polymake to compute STtropicalData*)


Clear[STpolyToMath]
STpolyToMath[""]:={};
STpolyToMath[stringMat_]:=Module[{temp},
temp=stringMat//StringReplace[#,{"{"-> "","}"->""}]&;(* for the cones*)
temp=temp//StringReplace[#,{"\n"-> "},{suffix", " " -> ","}]&;
temp=temp<>"}";
temp = temp//StringReplace[#,",{suffix}"-> "}"]&//StringReplace[#,"suffix"-> ""]&;
ToExpression["{{"<>temp ]
];


Clear[STtropicalData];STtropicalData[polyOriginalNames_,varsOriginalNames_,timeConstraint_:3, QuietQ_:True]:=
If[Length[varsOriginalNames]>1,
	STtropicalDataOLD[polyOriginalNames,varsOriginalNames,timeConstraint,QuietQ]
,
	Module[{var=varsOriginalNames[[1]], poly=polyOriginalNames},
		<|
			"equations" -> If[Length[CoefficientRules[poly,varsOriginalNames]]>1, {}, {Exponent[poly,var], 1}],
			"rays" -> {{-1},{1}},
			"facets" -> {{Exponent[poly,var,Min], 1}, {Exponent[poly,var,Max], -1}},
			"vertices" -> Map[Join[{1},#]&, CoefficientRules[poly,varsOriginalNames][[;;,1]]]
		|>
	]
];


Clear[STtropicalDataOLD];STtropicalDataOLD[polyOriginalNames_,varsOriginalNames_,timeConstraint_:3, QuietQ_:True]:=Module[
{
poly,factors, polyString,vars,varsString,data,transposed,mac2PIDD,matrix,
vectors,variables,toVector,file,basisRels,fileNameInput,
fileNameOutput,Polyscript,Poltput,string,mac2ExitStatus,
currentTime,startTime,timeElapsed,maxTime=timeConstraint,
abortedQ,messageFunction,permutation,assData,facets,
rays,cones,refinement,
polyInd,
projString,preambleString,dummyDepString
},
	If[stRequireTool["polymake"] === $Failed, Return[$Failed]];
	(* Ensure the scratch directory exists -- paclet installs no longer ship a
	   pre-populated mathPolycoms/, so we create it on demand in CWD. *)
	Quiet @ CreateDirectory["mathPolycoms", CreateIntermediateDirectories -> True];
	If[QuietQ,messageFunction=noPrint,messageFunction=Print];

	fileNameInput="mathPolycoms/poly.pl";
	fileNameOutput="mathPolycoms/STtropicalData.txt";
	Polyscript="mathPolycoms/tropFast.pl";
	Poltput= "mathPolycoms/Poltput.pl";

	(* Polymake wants variable to be called x_0,x_1,x_2... *)
	vars=Table["x_"<>ToString[i-1],{i,1,varsOriginalNames//Length}];
	
	(* Load polymake applications *)
	preambleString="use application \"polytope\";\n";
	
	(* One-dimensional polynomials are a different class in polymake. To avoid complication, we introduce a dummy variable x_1 *)
	(* We fix this by adding a dummy dependence, then project the polytope on x_1 = 0 *)
	(* If we have multiple polynomials depending on different variables, polymake's "newton" will yield polytopes in different spaces *)
	(* we fix this by adding a dummy dependence *)
	(* To do: one-dimensional case still doesn't work *)
	If[Length[vars]===1,
		varsString="local_var_names<Polynomial>(qw(x_0 x_1));\n";
		projString="declare $projectQ=1;\n";
		dummyDepString="+0*x1";
		,
		varsString=vars//ToString //StringReplace[#,{"{"-> "local_var_names<Polynomial>(qw(","}"-> "))","\n"-> "",","-> " "}]&;
		varsString=varsString<>";\n";
		projString="declare $projectQ=0;\n\n";
		dummyDepString=StringJoin[Sequence@@Table["+0*"<>ToString[v],{v,vars}]];
	];
	
	(* We build a list of factors as strings *)
	factors=(polyOriginalNames/.Table[varsOriginalNames[[i]]-> vars[[i]],{i,1,vars//Length}])//Factor;
	If[Head[factors]===Plus,factors={factors},factors=List@@factors];
	factors=(#//InputForm//ToString//StringReplace[#,"\""-> ""]&)&/@factors;
	(* Add dummy dependences*)
	factors=(#<>dummyDepString)&/@factors;
		
	polyString="# Computing the Newton polytope(s)\n\n";
	(* We compute the first polytope and if necessary the others *)
	polyInd=1;
	poly=factors[[polyInd]];
	(* Declare polynomial, compute its Newton polytope, if necessary project it *)
	polyString=polyString<>("declare $poly"<>ToString[polyInd]<>" = new Polynomial('"<>poly<>"');\n");
	polyString=polyString<>("declare $p"<>ToString[polyInd]<>" = newton($poly"<>ToString[polyInd]<>");\n");
	polyString=polyString<>("$p"<>ToString[polyInd]<>"= projection($p"<>ToString[polyInd]<>", [2], revert=> true) if ($projectQ == 1);\n");
	polyString=polyString<>("declare $p=$p1;\n\n");

	If[Length[vars]>1,
		Do[	
			poly=factors[[polyInd]];
			(* Declare polynomial, compute its Newton polytope, if necessary project it *)
			polyString=polyString<>("declare $poly"<>ToString[polyInd]<>" = new Polynomial('"<>poly<>"');\n");
			polyString=polyString<>("declare $p"<>ToString[polyInd]<>" = newton($poly"<>ToString[polyInd]<>");\n");
			polyString=polyString<>("$p"<>ToString[polyInd]<>"= projection($p"<>ToString[polyInd]<>", [2], revert=> true) if ($projectQ == 1);\n");
			polyString=polyString<>("$p=minkowski_sum($p,$p"<>ToString[polyInd]<>");\n\n");
			,
			{polyInd,2,factors//Length}
		];
	];
	
	(* OLD VERSION (fixed file paths, not parallel-safe)
	(* Joining strings poly.pl *)
	string=preambleString<>varsString<>projString<>polyString;
	If[FileExistsQ["mathPolycoms/poly.pl"],DeleteFile["mathPolycoms/poly.pl"]];
	file=OpenWrite["mathPolycoms/poly.pl"];
	WriteString[file,string];

	(*Launch Poly and wait a max of time maxTime*)
	If[FileExistsQ["mathPolycoms/output.pl"],DeleteFile["mathPolycoms/output.pl"]];

	messageFunction["Poly launched, I will wait for at most ", maxTime, " seconds"];
	startTime= AbsoluteTime[];
	If[maxTime===\[Infinity],
	mac2ExitStatus=Run[$PolymakeCommand<>" --script "<>Polyscript];
	,
	mac2ExitStatus=Run[$PolymakeCommand<>" --script "<>Polyscript];
	];
	Print["polymake exit status:" , mac2ExitStatus];
	If[Not[FileExistsQ["mathPolycoms/output.pl"]],Print["couldn't find output.pl"]; Return[$Failed]];

	data=STpolyToMath/@ToExpression[ReadString["mathPolycoms/output.pl"]];
	--- END OLD VERSION *)

	(* NEW VERSION: self-contained polymake script with unique file names to avoid
	   race conditions when multiple parallel sub-kernels call this function. *)
	Module[{uid, scriptFile, outputFile, fanString},
	uid = ToString[$KernelID] <> "_" <> ToString[Unique["trop"]];
	scriptFile = FileNameJoin[{Directory[], "mathPolycoms", "tropScript_" <> uid <> ".pl"}];
	outputFile = FileNameJoin[{Directory[], "mathPolycoms", "output_" <> uid <> ".pl"}];

	fanString =
		"use application \"fan\";\n" <>
		"declare $fn = normal_fan($p);\n" <>
		"declare $fs = $p-> FACETS;\n\n" <>
		"open(FH, '>', \"" <> outputFile <> "\");\n" <>
		"print FH '{';\n" <>
		"print FH '\"';\n" <>
		"print FH $fs;\n" <>
		"print FH '\",'; \n" <>
		"print FH '\"';\n" <>
		"print FH $p->VERTICES;\n" <>
		"print FH '\",\"';\n" <>
		"print FH $fn -> MAXIMAL_CONES;\n" <>
		"print FH '\",\"';\n" <>
		"print FH $p->AFFINE_HULL;\n" <>
		"print FH '\"';\n" <>
		"print FH '}';\n" <>
		"close(FH);\n";

	string = preambleString <> varsString <> projString <> polyString <> fanString;
	If[FileExistsQ[scriptFile], DeleteFile[scriptFile]];
	If[FileExistsQ[outputFile], DeleteFile[outputFile]];
	file = OpenWrite[scriptFile];
	WriteString[file, string];
	Close[file];

	messageFunction["Poly launched, I will wait for at most ", maxTime, " seconds"];
	startTime = AbsoluteTime[];
	mac2ExitStatus = Run[$PolymakeCommand <> " --script " <> scriptFile];
	Print["polymake exit status:", mac2ExitStatus];
	Quiet[DeleteFile[scriptFile]];
	If[Not[FileExistsQ[outputFile]], Print["couldn't find output file"]; Return[$Failed]];

	data = STpolyToMath /@ ToExpression[ReadString[outputFile]];
	Quiet[DeleteFile[outputFile]];
	];
	cones=data[[-2,;;,1,;;]]/.v_/;IntegerQ[v]:> v+1;
	rays=-data[[1,;;,2;;]];
	(*vertices are given as a list with no wrapper, so if  add output  have to update the -3 index*)
	
	assData=<|"equations"-> data[[-1]],"rays"-> rays,"facets"-> data[[1]],"vertices" -> data[[2]]|>;
	Return[assData];
];


(*  Concurrent tropical data pre-computation.
   Each gauge gets a fully self-contained polymake script (absolute output path
   baked in).  All scripts are launched as shell background jobs in a single
   RunProcess[bash] call, which blocks until every polymake process has finished.
   WaitForProcess is NOT (!!) used; it does not block reliably in wolframscript mode. *)

(* Build a self-contained polymake script for one polynomial; write it to disk.
   Returns {scriptFile, outputFile}; both absolute paths. *)
Clear[STtropicalDataBuildScript];
STtropicalDataBuildScript[polyOriginalNames_, varsOriginalNames_, tag_String] := Module[
    {vars, varsString, projString, dummyDepString, preambleString,
     polyString, fanString, poly, polyInd, factors, fullString, file,
     scriptFile, outputFile, workDir},

    workDir    = Directory[];
    (* Ensure the scratch dir exists.  On a fresh CWD this function is the
       first polymake-script writer (called from STTropicalDataPrecompute
       before any of the older STtropicalData* functions that create it),
       so without this guard the three OpenWrite/WriteString/Close calls
       below emit noopen / strml / Close::stream for the first 3 scripts. *)
    Quiet @ CreateDirectory[FileNameJoin[{workDir, "mathPolycoms"}],
                            CreateIntermediateDirectories -> True];
    scriptFile = FileNameJoin[{workDir, "mathPolycoms", "tropScript_" <> tag <> ".pl"}];
    outputFile = FileNameJoin[{workDir, "mathPolycoms", "output_"    <> tag <> ".pl"}];

    vars = Table["x_" <> ToString[i-1], {i, 1, Length[varsOriginalNames]}];

    preambleString = "use application \"polytope\";\nuse application \"fan\";\n";

    If[Length[vars] === 1,
        varsString     = "local_var_names<Polynomial>(qw(x_0 x_1));\n";
        projString     = "declare $projectQ=1;\n";
        dummyDepString = "+0*x1";
    ,
        varsString = vars // ToString // StringReplace[#,
            {"{"-> "local_var_names<Polynomial>(qw(", "}"-> "))", "\n"-> "", ","-> " "}]&;
        varsString     = varsString <> ";\n";
        projString     = "declare $projectQ=0;\n\n";
        dummyDepString = StringJoin[Sequence @@ Table["+0*" <> ToString[v], {v, vars}]];
    ];

    factors = (polyOriginalNames /. Table[varsOriginalNames[[i]] -> vars[[i]],
                   {i, 1, Length[vars]}]) // Factor;
    If[Head[factors] === Plus, factors = {factors}, factors = List @@ factors];
    factors = (# // InputForm // ToString // StringReplace[#, "\"" -> ""]&) & /@ factors;
    factors = (# <> dummyDepString) & /@ factors;

    polyString = "# Computing the Newton polytope(s)\n\n";
    polyInd = 1;
    poly    = factors[[polyInd]];
    polyString = polyString <> ("declare $poly" <> ToString[polyInd] <> " = new Polynomial('" <> poly <> "');\n");
    polyString = polyString <> ("declare $p"    <> ToString[polyInd] <> " = newton($poly" <> ToString[polyInd] <> ");\n");
    polyString = polyString <> ("$p"            <> ToString[polyInd] <> "= projection($p" <> ToString[polyInd] <> ", [2], revert=> true) if ($projectQ == 1);\n");
    polyString = polyString <> ("declare $p=$p1;\n\n");

    If[Length[vars] > 1,
        Do[
            poly = factors[[polyInd]];
            polyString = polyString <> ("declare $poly" <> ToString[polyInd] <> " = new Polynomial('" <> poly <> "');\n");
            polyString = polyString <> ("declare $p"    <> ToString[polyInd] <> " = newton($poly" <> ToString[polyInd] <> ");\n");
            polyString = polyString <> ("$p"            <> ToString[polyInd] <> "= projection($p" <> ToString[polyInd] <> ", [2], revert=> true) if ($projectQ == 1);\n");
            polyString = polyString <> ("$p=minkowski_sum($p,$p" <> ToString[polyInd] <> ");\n\n");
        , {polyInd, 2, Length[factors]}];
    ];

    (* Inline the fan computation; output path is an absolute literal in the script *)
    fanString =
        "declare $fn = normal_fan($p);\n" <>
        "declare $fs = $p-> FACETS;\n\n" <>
        "open(FH, '>', \"" <> outputFile <> "\");\n" <>
        "print FH '{';\n" <>
        "print FH '\"';\n" <>
        "print FH $fs;\n" <>
        "print FH '\",'; \n" <>
        "print FH '\"';\n" <>
        "print FH $p->VERTICES;\n" <>
        "print FH '\",\"';\n" <>
        "print FH $fn -> MAXIMAL_CONES;\n" <>
        "print FH '\",\"';\n" <>
        "print FH $p->AFFINE_HULL;\n" <>
        "print FH '\"';\n" <>
        "print FH '}';\n" <>
        "close(FH);\n";

    fullString = preambleString <> varsString <> projString <> polyString <> fanString;

    If[FileExistsQ[scriptFile], DeleteFile[scriptFile]];
    If[FileExistsQ[outputFile], DeleteFile[outputFile]];
    file = OpenWrite[scriptFile];
    WriteString[file, fullString];
    Close[file];

    {scriptFile, outputFile}
];

(*  Pre-compute tropical data for all integrands concurrently.
   Builds one polymake script per cache-miss integrand, then runs them all as
   shell background jobs in one RunProcess[bash] call (true concurrency, reliable
   blocking; WaitForProcess does not block in wolframscript mode). *)
Clear[STTropicalDataPrecompute];
STTropicalDataPrecompute[allIntegrands_, vb_:False] := Module[
    {i, pref, integrand, xvars, coeffs, mons, pols, polsNoCoeffs,
     cacheKey, toCompute, scripts, shellCmd, workDir, data, cones, rays},

    workDir = Directory[];

    (* step 1: identify cache misses *)
    toCompute = {};
    Do[
        {pref, integrand, xvars, coeffs} = allIntegrands[[i]];
        If[xvars === {}, Continue[]];  (* trivial: no Feynman parameters to polymake *)
        {mons, pols} = STtoMonPols[integrand, xvars];
        polsNoCoeffs = STforgetCoeffs[#, xvars]& /@ pols[[1]];
        polsNoCoeffs = DeleteCases[polsNoCoeffs, 1];
        cacheKey     = {Times @@ polsNoCoeffs, xvars};
        If[!KeyExistsQ[$STTropicalDataCache, cacheKey],
            AppendTo[toCompute, {Times @@ polsNoCoeffs, xvars, cacheKey, "trop" <> ToString[i]}]
        ];
    , {i, Length[allIntegrands]}];

    If[Length[toCompute] === 0,
        If[vb, Print["  [OPT] Tropical data: all ", Length[allIntegrands],
                     " integrand(s) already cached."]];
        Return[];
    ];

    If[vb, Print["  [OPT] Tropical data: building ", Length[toCompute],
                 " polymake script(s) and launching concurrently..."]];

    (* step 2: write all scripts, collect {cacheKey, scriptFile, outputFile} *)
    scripts = Table[
        With[{poly = toCompute[[i, 1]], vars = toCompute[[i, 2]],
              ck   = toCompute[[i, 3]], tag  = toCompute[[i, 4]]},
            {sf, of} = STtropicalDataBuildScript[poly, vars, tag];
            {ck, sf, of}
        ]
    , {i, Length[toCompute]}];

    (* step 3: launch polymake jobs in batches capped by PolymakeConcurrencyFraction.
       maxJobs = floor(fraction * $ProcessorCount), minimum 1.
        use StartProcess instead of RunProcess so that on Mathematica
       Abort[] we can kill the bash process and all its polymake children cleanly. *)
    With[{maxJobs = Max[1, Floor[$PolymakeConcurrencyFraction * $ProcessorCount]],
          nScripts = Length[scripts]},
        If[vb, Print["  [OPT] Tropical data: launching ", nScripts,
                     " polymake job(s) in batches of ", maxJobs,
                     " (", $PolymakeConcurrencyFraction * 100, "% of ", $ProcessorCount, " cores)."]];
        Do[
            With[{batch = scripts[[bStart ;; Min[bStart + maxJobs - 1, nScripts]]]},
                shellCmd = StringJoin[
                    Table["\"" <> $PolymakeCommand <> "\" --script \"" <> batch[[j, 2]] <> "\" &\n",
                          {j, Length[batch]}]
                ] <> "wait\n";
                $STPolymakeProcess = StartProcess[{"/bin/bash", "-c", shellCmd},
                                                  ProcessDirectory -> workDir];
                CheckAbort[
                    (* Poll until the batch finishes ; reliable in notebook and wolframscript *)
                    While[ProcessStatus[$STPolymakeProcess] === "Running", Pause[0.2]];
                    ,
                    (* Abort handler: kill all polymake children, then the bash wrapper *)
                    With[{pid = ToString[ProcessID[$STPolymakeProcess]]},
                        RunProcess[{"/bin/bash", "-c",
                            "pkill -TERM -P " <> pid <> "; kill -TERM " <> pid}];
                        Pause[0.5];
                    ];
                    KillProcess[$STPolymakeProcess];
                    $STPolymakeProcess = None;
                    Abort[]
                ];
                KillProcess[$STPolymakeProcess];  (* reap the finished bash process *)
                $STPolymakeProcess = None;
            ];
        , {bStart, 1, nScripts, maxJobs}];
    ];

    (* step 4: parse outputs and populate cache; clean up temp files *)
    Do[
        {cacheKey, sf, of} = scripts[[i]];
        Quiet[DeleteFile[sf]];
        If[FileExistsQ[of],
            data    = STpolyToMath /@ ToExpression[ReadString[of]];
            Quiet[DeleteFile[of]];
            cones   = data[[-2, ;;, 1, ;;]] /. v_ /; IntegerQ[v] :> v + 1;
            rays    = -data[[1, ;;, 2;;]];
            $STTropicalDataCache[cacheKey] = <|
                "equations" -> data[[-1]], "rays" -> rays,
                "facets" -> data[[1]], "vertices" -> data[[2]]|>;
        ,
            If[vb, Print["  [OPT] polymake failed for script ", sf]];
        ];
    , {i, Length[scripts]}];

    If[vb, Print["  [OPT] Tropical data: all polymake calls complete."]];
];


