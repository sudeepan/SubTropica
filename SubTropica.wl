Options[STEvaluateGraph] = Join[
    {
        "Order" -> Automatic,            (* Output order in eps: Automatic = through eps^0 (finite part); n = through eps^n *)
        "StopAt" -> Automatic,
        "StartAt" -> None,
        "Gauge" -> Automatic,
        "IncludeGauges" -> All,
        "Verbose" -> False,
        "ShowTimings" -> True,
        "ShowIntegrands" -> False,
        "SaveSlowestIntegrand" -> False,
        "SaveAllIntegrands" -> False,
        "SetProblemID" -> Automatic,
        "Parallelization" -> All,
        "KernelsAvailable" -> $ProcessorCount - 1,
        "SimplifyOutput" -> Simplify,
        "Heuristic" -> "LeafCountLinear",
        "ScanScoreInterval" -> {1, 3},
        "ScoreInParallel" -> All,
        "TimeUpperBound" -> 10^17,
        "MemoryPercentCutOff" -> None,
        "ScoringMemoryFraction" -> 0.5,  (*  fraction of available RAM budgeted for parallel gauge scoring *)
        "SetupInParallel"       -> Automatic, (*  Automatic = all gauges in one parallel batch (original behaviour); 1 = serial on main kernel only; n > 1 = n sequential parallel batches *)
        "ClearCachesPerIntegrand" -> False, (*  if True, each sub-kernel clears HyperInt memoization caches
                                              immediately after finishing one integrand, reducing peak memory at the
                                              cost of losing cache reuse across counter-terms on the same kernel *)
        "ClearCachesMemoryThreshold" -> Infinity, (*  integer in GB; when set, each sub-kernel flushes HyperInt
                                              memoization caches after an integrand if MemoryInUse[] exceeds the
                                              threshold. Infinity disables. Middle ground between always-flush
                                              (ClearCachesPerIntegrand -> True) and never-flush (default). *)
        "Integrator"              -> "HyperIntica",  (* "HyperIntica" (default, Mathematica), "HyperInt" (Maple via SThyperIntMaple), or "HyperFLINT" (C++/FLINT CLI via STHyperFlint) *)
        "CleanOutput"             -> False,  (* If True, apply CleanZeroInf[] to the final result *)
        "SelectFaces"             -> All,    (* Face-selective integration; see Options[STEvaluateEulerIntegral] for full syntax *)
        "ReuseExistingResults"    -> True,   (* Skip faces that already have result.m + successQ.m on disk *)
        "UIComms"                 -> None,   (* Structured progress reporting for SubTropica UI *)
        "ContourHandling"         -> "Abort", (* "Abort" = abort on undetermined contour direction; "Continue" = leave Hlog[Infinity,...] unevaluated *)
        FindRoots                 -> Automatic,   (* B17 (was True since v1.0.398): "Automatic" runs the gauge-scoring phase with FindRoots -> False first; if every gauge returns NOLR, retries with FindRoots -> True (which factors univariate quadratic+ polynomials into linear roots, introducing Wm[i]/Wp[i] algebraic letters via HyperIntica's LinearFactors). The retry handles equal-mass / unequal-mass bubbles, sunrise triangles, and other clustered-mass graphs that False aborts on. Explicit True forces always-FindRoots; explicit False skips entirely. Parallel integration: each subkernel Block-scopes $HyperAlgebraicLetterCounter/Table with JobIndex*$STFindRootsJobStride; the aggregator unions per-subkernel tables. Set $STFindRootsParallelSafe = False to opt out to the legacy serial path. *)
        "AutoRationalize"         -> False,  (* When True, try the M1/M2/M3 rationalization dispatcher (single/double Cheng-Wu, FKV, Kallen, BoxFKV) before falling through to the normal pipeline.  Off by default because the dispatcher may pick a substitution for cases the normal pipeline already handles correctly, producing a DIFFERENTLY-parameterized (FKV-variable) result.  Users who want unlocks should set this True explicitly. *)
        "MethodLR"                -> "Lungo",  (* "Lungo" (default, OLD algorithm: discriminant/resultant + global dedup) or "Espresso" *)
        "MethodPolysAndPairs"     -> "Fast",   (* "Fast" (default) = extract polys directly from STtoCoeffMonPols; "Standard" = sum renormalized integrands per eps-order and call STpreparePolysAndPairs *)
        "LROrderBackend"          -> "HyperIntica",  (* "HyperIntica" (default, in-process Mma STFasterFubini2) or "HyperFLINT" (C++ HF find_lr_orders via stDispatchFubini2).  HF requires FindRoots -> False.  Tie-break-equivalent orders to Mma on 22/26 of a real-face sweep (Phase \[Beta].3 validation); 4/26 pick a different valid LR order but all are mathematically equivalent (Fubini guarantees integration-order independence). *)
        "ScoreProgress"           -> False  (* When True, print per-gauge LR status and wall time as each (sub)kernel finishes *)
    },
    Options[STGenerateIntegrand]
];


(* Whole-integration FindRoots -> Automatic cascade was previously here
   (B17 / v1.0.398-era).  Removed in v1.1.8.10: the cascade now runs at
   per-face granularity inside the LR-search dispatchers
   (stDispatchFubini2, STEspressoFubini), which is finer-grained and lets
   the integrator side run with $HyperIntroduceAlgebraicLetters = True
   (per design choice (ii)(a)) regardless of which leg of the per-face
   cascade succeeded.  The whole-integration retry was too coarse: it
   only escalated when STEvaluateGraph::nolr fired (every gauge NOLR at
   LR-search time), missing the common case where LR succeeds on the
   post-expansion factored polynomials but the integrator hits a deg-2
   Schwinger-dependent factor and refuses via the parity guard. *)

STEvaluateGraph[g_, opts : OptionsPattern[]] :=
Catch[
Module[{
    pref, integrand, xvars, coeffs, expansion,
    verbose, showTimings, showIntegrands,
    saveSlowestIntegrand, saveAllIntegrands,
    problemId, monitorDisplay, slowestJob, result,
    numberOfVars, problemIds, scores, bestGauge, heuristicValue,
    allIntegrands, allExpansions,
    var,
    outputOrder, poleGamma, effectiveOrder, scanScoreInterval,
    scoreInParallel, timeUpperBound,
    memPercentCutOff, scoringMemoryFraction, setupInParallel, scoreProgress,
    findRootsValue, frOrig, methodLRValue, methodPolysAndPairs, mppOrig, lrBackendValue,
    frLegs, chosenFrLeg, frPass,
    includeGauges, gaugesToConsider, invalidGauges, bestGaugeIdx,
    stopAt, startAt, resumeFrom,
    uiComms, isScanPath,
    lrRawExpr, lrPolysAndPairs, lrBestOrder, lrScore
},
    uiComms = OptionValue["UIComms"];
    isScanPath = (OptionValue["Gauge"] === Automatic && OptionValue["Representation"] === "Schwinger");
    stSetUIStage[uiComms, "Initializing", 1];

    STSetupKernel[OptionValue["KernelsAvailable"]];

    $STContourHandling = OptionValue["ContourHandling"];
    DistributeDefinitions[$STContourHandling];

    verbose = OptionValue["Verbose"];
    heuristicValue = OptionValue["Heuristic"];
    showTimings = OptionValue["ShowTimings"];
    showIntegrands = OptionValue["ShowIntegrands"];
    saveSlowestIntegrand = OptionValue["SaveSlowestIntegrand"];
    saveAllIntegrands = OptionValue["SaveAllIntegrands"];
    problemId = If[OptionValue["SetProblemID"] === Automatic,
        ToString[Unique[SubTropicaID]],
        (* Explicit SetProblemID: extend with an 8-char content hash of
           {graph spec, Substitutions, Dimension} so different colorings or
           mass configurations of the same nominal problem don't silently
           share `integrands/<id>*` per-face caches. The UI's handleIntegrate
           passes SetProblemID equal to the sanitized topology nickel
           (e.g. "e12_e2_e_"), which is identical across every coloring
           \[LongDash] without the hash, ReuseExistingResults -> True returns cached
           result.m files from whichever coloring was integrated first.
           Caches from before this hash extension stay on disk; they are
           simply not matched by the new id wildcard. *)
        Module[{cacheKey, cacheHash},
            cacheKey = {g, Sort @ OptionValue["Substitutions"],
                        OptionValue["Dimension"]};
            cacheHash = StringTake[
                IntegerString[Hash[cacheKey, "MD5"], 16, 8], -8];
            ToString[OptionValue["SetProblemID"]] <> "_" <> cacheHash]];
    outputOrder = OptionValue["Order"];
    outputOrder = If[outputOrder === Automatic, 0, outputOrder];
    poleGamma = 0; effectiveOrder = outputOrder;  (* resolved later when prefactor is known *)
    scanScoreInterval = OptionValue["ScanScoreInterval"];
    scoreInParallel = OptionValue["ScoreInParallel"];
    timeUpperBound = OptionValue["TimeUpperBound"];
    memPercentCutOff = OptionValue["MemoryPercentCutOff"];
    scoringMemoryFraction = Clip[OptionValue["ScoringMemoryFraction"], {0.01, 1.0}];
    scoreProgress         = TrueQ[OptionValue["ScoreProgress"]];
    findRootsValue        = OptionValue[FindRoots];
    frOrig                = findRootsValue;  (* preserved across the FR cascade for the post-LR escalation guard *)
    methodLRValue         = OptionValue["MethodLR"];
    methodPolysAndPairs   = OptionValue["MethodPolysAndPairs"];
    setupInParallel       = OptionValue["SetupInParallel"];
    includeGauges = OptionValue["IncludeGauges"];
    stopAt        = OptionValue["StopAt"];
    startAt       = OptionValue["StartAt"];

    (* Phase \[Beta].3: LR-order-search backend.  "HyperFLINT" routes every
       stDispatchFubini2 call site through HF's C++ find_lr_orders op;
       "HyperIntica" (default) keeps the in-process Mma STFasterFubini2
       path.  As of Phase 7-vii, HF's find_lr_orders accepts deg-2
       polys when FindRoots=True (the integrator allocates Wm/Wp at
       integration time), so the two compose cleanly without
       downgrade. *)
    lrBackendValue = OptionValue["LROrderBackend"];
    $STLROrderBackend   = lrBackendValue;
    $STHFFallbackCount  = 0;
    $STHFFallbackWarned = False;
    If[Length[Kernels[]] > 0,
        (* Propagate the backend selection to every subkernel so
           ParallelMap-dispatched stDispatchFubini2 calls hit the same
           path.  DistributeDefinitions on a bare OwnValue-only global
           doesn't always copy (it holds the symbol but the lookup for
           distribution misses).  Use an explicit ParallelEvaluate so
           every subkernel's `$STLROrderBackend` matches the main
           kernel's.  Counters are main-kernel-only; subkernel
           fallbacks are best-effort (may be undercounted). *)
        With[{bk = lrBackendValue},
            ParallelEvaluate[$STLROrderBackend = bk]]];

    (* When FindRoots is active:
         - $NoAlgebraicRootsContributions = False   (no silent zeroing)
         - $HyperIntroduceAlgebraicLetters = True   (LinearFactors[] introduces Wm[i]/Wp[i]
           fresh letters for each deg-2 factor; metadata in $HyperAlgebraicLetterTable)
         - ClearAlgebraicLetters[]                  (reset counter+table every run)
       The FindRoots mechanism lives entirely on the HyperIntica (in-process)
       side \[LongDash] it modifies `LinearFactors[]` to mint Wm/Wp letters, which the
       HyperIntica integrator then carries through symbolically.  The HyperInt
       (Maple) backend has no such hook: Maple sees the raw integrand, does
       its own polynomial factoring, and emits its native `Root(poly, var)`
       syntax in the output, which SubTropica's string parser can't round-
       trip.  So `Integrator -> "HyperInt"` + `FindRoots -> True` is an
       incompatible combination \[LongDash] warn loudly and stop.  (The Maple side's
       STformatHyperIntMapleOut also guards against `Root(` in the returned
       string for belt-and-suspenders safety.) *)
    If[findRootsValue === True && OptionValue["Integrator"] === "HyperInt",
        Message[STEvaluateGraph::findRootsHyperInt];
        Return[$Failed]];

    (* FindRoots resolution under per-face cascade:
         - True or Automatic: arm $HyperIntroduceAlgebraicLetters so the
           integrator can mint Wm/Wp letters when a face's LR search escalated
           to True. (Automatic \[DoubleRightArrow] True per design choice (ii)(a): letters armed
           globally, faces that don't need them simply don't trigger them.)
         - False: integrator must not introduce letters; reset the flag
           explicitly (it is sticky across runs). *)
    If[findRootsValue =!= False,
        $NoAlgebraicRootsContributions = False;
        $HyperIntroduceAlgebraicLetters = True;
        ClearAlgebraicLetters[];
        If[Length[Kernels[]] > 0, ParallelEvaluate[ClearAlgebraicLetters[]]];
        $stRootSubstitutions = {}
    ,
        $HyperIntroduceAlgebraicLetters = False;
        ClearAlgebraicLetters[];
        If[Length[Kernels[]] > 0, ParallelEvaluate[ClearAlgebraicLetters[]]];
        $stRootSubstitutions = {}
    ];
    resumeFrom    = None;

    (* - Resume from checkpoint *)
    If[startAt =!= None,
        With[{ck = STLoadCheckpoint[ToString[startAt]]},
            If[ck === $Failed,
                Print["[SubTropica] Checkpoint \"", startAt, "\" not found. Running from scratch."],
                If[TrueQ[ck["ScanningPath"]],
                    (* Scanning-path "AfterExpansion" checkpoint: restore all-gauge state, skip build step *)
                    Echo[ck["ProblemID"], "Resuming from checkpoint:"];
                    Print["  Previously stopped at: ", ck["StopAt"]];
                    pref             = ck["Pref"];
                    integrand        = ck["Integrand"];
                    xvars            = ck["XVars"];
                    coeffs           = ck["Coeffs"];
                    allIntegrands    = ck["AllIntegrands"];
                    allExpansions    = ck["AllExpansions"];
                    gaugesToConsider = ck["GaugesToConsider"];
                    problemIds       = ck["ProblemIDs"];
                    effectiveOrder   = ck["OrderValue"];
                    outputOrder      = Lookup[ck, "OutputOrder", 0];
                    problemId        = ck["ProblemID"];
                    resumeFrom       = ck["StopAt"],
                    (* Non-scanning checkpoint: delegate to STEvaluateEulerIntegral
                       (it will print its own "Resuming from checkpoint:" echo) *)
                    Return[STEvaluateEulerIntegral[
                        {ck["Pref"], ck["Integrand"], ck["XVars"], ck["Coeffs"]},
                        "StartAt" -> ToString[startAt],
                        FilterRules[{opts}, Options[STEvaluateEulerIntegral]]
                    ]]
                ]
            ]
        ]
    ];

    Echo[problemId, "Problem ID:"];

    (* Early scaleless check: if STGenerateIntegrand returns 0, the integral
       vanishes in dimensional regularization \[LongDash] skip all gauge scanning.
       Use $Aborted as the CheckAbort sentinel so a downstream Abort[] (e.g.
       STSymanzikGraph's bad-input guard) is not silently conflated with a
       genuine scaleless 0. *)
    Module[{scalelessTest},
      scalelessTest = Quiet[CheckAbort[
        STGenerateIntegrand[g, "Gauge" -> {},
          FilterRules[DeleteCases[{opts}, "Gauge" -> _], Options[STGenerateIntegrand]]],
        $Aborted]];
      If[scalelessTest === $Aborted,
        stSetUIStage[uiComms, "Complete", 10];
        Return[$Failed]];
      If[scalelessTest === 0,
        Print["[SubTropica] Scaleless integral \[LongDash] vanishes in dimensional regularization."];
        stSetUIStage[uiComms, "Complete", 10];
        (* Populate $integrationResult so STSaveResult / STSubmitResult
           work on scaleless graphs the same as on non-trivial ones. *)
        Module[{sclessNickel, sclessSeries},
          sclessNickel = Quiet @ Check[
            computeNickelIndex[g[[1, All, 1]], g[[2, All, 1]],
              g[[1, All, 2]], g[[2, All, 2]]], ""];
          sclessSeries = SeriesData[eps, 0, {}, 0, outputOrder + 1, 1];
          $integrationResult = <|
            "uiResult" -> <|
              "nickelIndex"  -> sclessNickel,
              "Dimension"    -> ToString[OptionValue["Dimension"], InputForm],
              "Order"        -> outputOrder,
              "propExponents"-> Table[1, {Length[g[[1]]]}],
              "Substitutions"-> "",
              "edges"        -> g[[1]],
              "nodes"        -> g[[2]]
            |>,
            "result" -> sclessSeries
          |>;
          Return[sclessSeries]]];
      (* Trivial-integrand short-circuit: if the ungauged integrand has \[LessEqual] 1
         Schwinger variable, the Feynman/Schwinger projective integral reduces to
         pref \[Times] (integrand with the single \[Alpha] gauge-fixed to 1). Examples: the
         massive tadpole e0|:01| (one self-loop, one \[Alpha]). No tropical / NP /
         subtraction pipeline is needed (and those paths don't handle empty
         xvars \[LongDash] Det[{}], trData["rays"]={}, etc.). *)
      If[ListQ[scalelessTest] && Length[scalelessTest] === 4 &&
         Length[scalelessTest[[3]]] <= 1,
        Module[{trivPref, trivInt, trivVars, trivGauged, trivResult, trivNickel, trivOrderN},
          {trivPref, trivInt, trivVars} = scalelessTest[[{1, 2, 3}]];
          trivGauged = If[trivVars === {}, trivInt, trivInt /. trivVars[[1]] -> 1];
          trivOrderN = If[ListQ[outputOrder], Max[outputOrder], outputOrder];
          trivResult = Series[trivPref * trivGauged, {eps, 0, trivOrderN}];
          Print["[SubTropica] Trivial Schwinger integral (", Length[trivVars],
                " variable", If[Length[trivVars] == 1, "", "s"],
                ") \[LongDash] pref \[Times] gauge-fixed integrand."];
          trivNickel = Quiet @ Check[
            computeNickelIndex[g[[1, All, 1]], g[[2, All, 1]],
              g[[1, All, 2]], g[[2, All, 2]]], ""];
          $integrationResult = <|
            "uiResult" -> <|
              "nickelIndex"  -> trivNickel,
              "Dimension"    -> ToString[OptionValue["Dimension"], InputForm],
              "Order"        -> outputOrder,
              "propExponents"-> Table[1, {Length[g[[1]]]}],
              "Substitutions"-> "",
              "edges"        -> g[[1]],
              "nodes"        -> g[[2]]
            |>,
            "result" -> trivResult
          |>;
          stSetUIStage[uiComms, "Complete", 10];
          Return[trivResult]]]];

    (* Auto-rationalization hook. Fires only when FindRoots -> True and the
       user is on the default Automatic-gauge / Schwinger path. Probes the
       ungauged integrand with a one-shot LR scan (FindRoots -> True); if the
       best ordering exists only over an algebraic extension OR the scorer
       fails with a multivariate quadratic in F, tries a catalog of rational
       changes of variables: single/double Cheng-Wu (M1/M2) and kinematic
       substitutions FKV/Kallen (M3).  Accepts a candidate only when the
       transformed integrand is LR over Q.  On success, delegates based on
       candidate type:
         - CW: STEvaluateEulerIntegral on the hand-built non-projective
           tuple (currently no live CW candidates pass strict, but the
           path is here for future work);
         - Kinematic: recursive STEvaluateGraph with "Substitutions" and
           FindRoots -> False (the latter breaks hook re-entry AND is
           safe because strict acceptance already verified LR over Q).
       On no-candidate or no-rationalization-found, falls through to the
       normal pipeline so the existing FindRoots/root-factoring path is
       still exercised. *)
    If[TrueQ[findRootsValue] && TrueQ[OptionValue["AutoRationalize"]] &&
       OptionValue["Gauge"] === Automatic &&
       OptionValue["Representation"] === "Schwinger",
      Module[{probeTuple, autoResult},
        probeTuple = Quiet[CheckAbort[
          STGenerateIntegrand[g, "Gauge" -> {},
            FilterRules[DeleteCases[{opts}, "Gauge" -> _], Options[STGenerateIntegrand]]],
          $Failed]];
        If[ListQ[probeTuple] && Length[probeTuple] === 4,
          autoResult = Quiet @ Check[
            ANAutoRationalize[g, probeTuple, "Verbose" -> verbose],
            $Failed];
          Which[
            AssociationQ[autoResult] && KeyExistsQ[autoResult, "Tuple"],
              Print["[SubTropica] Auto-rationalization applied: ", autoResult["Label"]];
              Module[{autoRes, nickel, efl, n0r, intm, extm,
                      isKin = Lookup[autoResult, "Type", "CW"] === "Kinematic"},
                autoRes = If[isKin,
                  (* Kinematic winner: recursive STEvaluateGraph with the
                     substitution rule(s).  autoResult["Rule"] is always a
                     LIST of substitution rules (FKV/Kallen return a list
                     of one; BoxFKV returns a list of two).  Break hook
                     re-entry by passing FindRoots -> False (strict
                     acceptance guarantees LR over Q, so no root-finding
                     is required anyway). *)
                  STEvaluateGraph[g,
                    "Substitutions"    -> autoResult["Rule"],
                    "Order"            -> outputOrder,
                    FindRoots          -> False,
                    "AutoRationalize"  -> False,
                    "Verbose"          -> verbose,
                    "ShowTimings"      -> showTimings,
                    FilterRules[
                      DeleteCases[{opts},
                        ("Order" -> _) | (FindRoots -> _) | ("Verbose" -> _) |
                        ("ShowTimings" -> _) | ("Substitutions" -> _) |
                        ("AutoRationalize" -> _)],
                      Options[STEvaluateGraph]]],
                  (* CW winner: hand-built tuple through STEvaluateEulerIntegral. *)
                  STEvaluateEulerIntegral[autoResult["Tuple"],
                    "Order"       -> outputOrder,
                    "ScanGauges"  -> Automatic,
                    "Verbose"     -> verbose,
                    "ShowTimings" -> showTimings,
                    FilterRules[
                      DeleteCases[{opts},
                        ("Order" -> _) | ("ScanGauges" -> _) | ("Verbose" -> _) |
                        ("ShowTimings" -> _) | ("Gauge" -> _) |
                        ("Representation" -> _) | ("Substitutions" -> _)],
                      Options[STEvaluateEulerIntegral]]]];
                efl    = g[[1, All, 1]];
                n0r    = g[[2, All, 1]];
                intm   = g[[1, All, 2]];
                extm   = g[[2, All, 2]];
                nickel = Quiet @ Check[computeNickelIndex[efl, n0r, intm, extm], ""];
                $integrationResult = <|
                  "uiResult" -> <|
                    "nickelIndex"  -> nickel,
                    "Dimension"    -> ToString[OptionValue["Dimension"], InputForm],
                    "Order"        -> outputOrder,
                    "propExponents"-> Table[1, {Length[efl]}],
                    "Substitutions"-> autoResult["Label"],
                    "edges"        -> g[[1]],
                    "nodes"        -> g[[2]]
                  |>,
                  "result" -> autoRes
                |>;
                stSetUIStage[uiComms, "Complete", 10];
                Return[autoRes]
              ],
            AssociationQ[autoResult] &&
                autoResult["Reason"] === "NoRationalizationFound",
              If[verbose,
                Print["[SubTropica] Auto-rationalization tried ",
                  Length[autoResult["TriedCandidates"]],
                  " candidate(s); none produced an integrand LR over Q. ",
                  "Falling through to normal pipeline."]],
            True, Null   (* None, NoCandidates, $Failed: fall through silently *)
          ]
        ]
      ]
    ];

    If[saveSlowestIntegrand =!= False && !showIntegrands,
        showIntegrands = True;
        Print["Note: Enabling ShowIntegrands for SaveSlowestIntegrand tracking."];
    ];
    
    monitorDisplay = If[showIntegrands,
        Dynamic[
            Module[{jobs, longestRunning, currentTime = AbsoluteTime[], elapsed},
                jobs = STReadActiveJobs[];
                If[AssociationQ[jobs] && Length[jobs] > 0,
                    longestRunning = First @ MinimalBy[Values[jobs], #["StartTime"] &];
                    elapsed = currentTime - longestRunning["StartTime"];
                    Column[{
                        Style[Row[{"Slowest active job: ", Round[elapsed, 0.1], " sec"}], Bold, Darker[Red]],
                        Row[{"Face: ", longestRunning["Face"]}],
                        Row[{"Counter term ID: ", longestRunning["CtId"]}],
                        Row[{"Integrand: ", longestRunning["Integrand"]}],
                        Row[{"Order: ", longestRunning["Order"]}],
                        Row[{"Active kernels: ", Length[jobs]}]
                    }],
                    "Waiting for jobs to start..."
                ]
            ],
            UpdateInterval -> 1.0
        ],
        "Working on integration..."
    ];
    
    result = timed[conditionalEchoTiming[

        If[OptionValue["Gauge"] === Automatic && OptionValue["Representation"] === "Schwinger",

            stUpdateUIComms[uiComms, "StageCount", 10];
            numberOfVars = Length[g[[1]]];

            gaugesToConsider = If[includeGauges === All,
                Range[numberOfVars],
                Select[includeGauges, IntegerQ[#] && 1 <= # <= numberOfVars &]
            ];
            
            If[includeGauges =!= All,
                invalidGauges = Complement[includeGauges, gaugesToConsider];
                If[Length[invalidGauges] > 0,
                    Message[STEvaluateGraph::invalidgauges, numberOfVars, invalidGauges];
                ];
            ];
            
            If[Length[gaugesToConsider] == 0,
                Message[STEvaluateGraph::nogauges, numberOfVars];
                Abort[];
            ];
            
            If[verbose,
                Print["Considering gauges: ", gaugesToConsider, " (out of ", numberOfVars, " total)"];
            ];
            
            problemIds = Table[
                ToString[problemId] <> "_x" <> ToString[idx],
                {idx, gaugesToConsider}  
            ];
            
            If[$STOverwritePreviousDirectories =!= False && resumeFrom === None, Quiet@STClearDirectories[problemId]];

            If[stopAt === "AfterBuildingIntegrand",
                {pref, integrand, xvars, coeffs} = STGenerateIntegrand[g, "Gauge" -> {},
                    FilterRules[DeleteCases[{opts}, "Gauge" -> _], Options[STGenerateIntegrand]]];
                STSaveCheckpoint[problemId, <|
                    "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                    "XVars" -> xvars, "Coeffs" -> coeffs, "Expansion" -> None,
                    "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt, "Timestamp" -> DateString[]|>];
                Return[{pref, integrand/(Times@@xvars), xvars, coeffs}]
            ];

            (* If Gauge -> {} with AfterMinimalLRCheck, automatically promote to OneShot *)
            If[stopAt === "AfterMinimalLRCheck" && OptionValue["Gauge"] === {},
                stopAt = "AfterMinimalLRCheckOneShot"
            ];

            If[stopAt === "AfterMinimalLRCheckOneShot",
                Module[{xvarsAll, rawExpr, expsWithEps, polysAndPairs, bestOrder, score, gaugeVar},
                    {pref, integrand, xvarsAll, coeffs} = STGenerateIntegrand[g, "Gauge" -> {},
                        FilterRules[DeleteCases[{opts}, "Gauge" -> _], Options[STGenerateIntegrand]]];
                    rawExpr = STtoCoeffMonPols[integrand, xvarsAll];
                    expsWithEps = Position[rawExpr//Last//Last, v_/;(v/.eps->0) <= 0, 1]//Flatten;
                    polysAndPairs = (rawExpr//Last//First)[[expsWithEps]];
                    If[polysAndPairs === {} || xvarsAll === {},
                        (* Trivially LR  - pick first variable as gauge *)
                        Return[<|
                            "GaugeResults" -> {<|"Gauge" -> First[xvarsAll], "IsLR" -> True, "Order" -> Rest[xvarsAll]|>},
                            "AnyLR" -> True,
                            "LRGauges" -> {First[xvarsAll]}|>]
                    ];
                    Module[{espResult},
                      espResult = Quiet[If[methodLRValue === "Lungo",
                          stDispatchFubini2[
                              {Join[polysAndPairs, xvarsAll]},
                              xvarsAll, Heuristic -> heuristicValue, FindRoots -> findRootsValue],
                          If[methodLRValue === "AnTropica",
                          STFubiniAT2[
                              {Join[polysAndPairs, xvarsAll]},
                              xvarsAll, ScreeningLR -> True, Heuristic -> heuristicValue, FindRoots -> findRootsValue],
                          STEspressoFubini2[
                              {Join[polysAndPairs, xvarsAll]},
                              xvarsAll, ScreeningLR -> True, Heuristic -> heuristicValue, FindRoots -> findRootsValue]]
                      ]];
                      If[findRootsValue =!= False, {bestOrder, score} = espResult[[1]], {bestOrder, score} = espResult];
                    ];
                    If[bestOrder === NOLR,
                        Return[<|
                            "GaugeResults" -> {},
                            "AnyLR" -> False,
                            "LRGauges" -> {}|>],
                        gaugeVar = Last[bestOrder];
                        Return[<|
                            "GaugeResults" -> {<|"Gauge" -> gaugeVar, "IsLR" -> True, "Order" -> Most[bestOrder]|>},
                            "AnyLR" -> True,
                            "LRGauges" -> {gaugeVar}|>]
                    ]
                ]
            ];

            If[stopAt === "AfterMinimalLRCheck",
                Module[{xvarsAll, gaugeOpt, gaugesToCheck, checkOneGauge, gaugeResults, lrGauges, gi},

                    (* Get all variables from a no-gauge call *)
                    {pref, integrand, xvarsAll, coeffs} = STGenerateIntegrand[g, "Gauge" -> {},
                        FilterRules[DeleteCases[{opts}, "Gauge" -> _], Options[STGenerateIntegrand]]];

                    numberOfVars = Length[xvarsAll];
                    gaugeOpt = OptionValue["Gauge"];

                    (* Determine which gauges to check *)
                    If[gaugeOpt === Automatic,
                        gaugesToCheck = If[includeGauges === All,
                            Range[numberOfVars],
                            Select[includeGauges, IntegerQ[#] && 1 <= # <= numberOfVars &]
                        ],
                        (* Single explicit gauge: extract the variable index *)
                        gaugesToCheck = {Position[xvarsAll, Keys[gaugeOpt][[1]]][[1, 1]]}
                    ];

                    (* Per-gauge check function *)
                    checkOneGauge[gi_Integer] := Module[{xv, rawExpr, expsWithEps, polysAndPairs, bestOrder, score},
                        xv = Delete[xvarsAll, gi];
                        rawExpr = STtoCoeffMonPols[(integrand /. xvarsAll[[gi]] -> 1), xv];
                        expsWithEps = Position[rawExpr//Last//Last, v_/;(v/.eps->0) <= 0, 1]//Flatten;
                        polysAndPairs = (rawExpr//Last//First)[[expsWithEps]];
                        If[polysAndPairs === {} || xv === {},
                            Return[<|"Gauge" -> xvarsAll[[gi]], "IsLR" -> True, "Order" -> xv|>]
                        ];
                        Module[{espResult},
                          espResult = Quiet[If[methodLRValue === "Lungo",
                              stDispatchFubini2[
                                  {Join[polysAndPairs, xv]},
                                  xv, Heuristic -> heuristicValue, FindRoots -> findRootsValue],
                              If[methodLRValue === "AnTropica",
                              STFubiniAT2[
                                  {Join[polysAndPairs, xv]},
                                  xv, Heuristic -> heuristicValue, FindRoots -> findRootsValue],
                              STEspressoFubini2[
                                  {Join[polysAndPairs, xv]},
                                  xv, Heuristic -> heuristicValue, FindRoots -> findRootsValue]]
                          ]];
                          If[findRootsValue =!= False, {bestOrder, score} = espResult[[1]], {bestOrder, score} = espResult];
                        ];
                        <|"Gauge" -> xvarsAll[[gi]],
                          "IsLR" -> (bestOrder =!= NOLR),
                          "Order" -> If[bestOrder === NOLR, {}, bestOrder]|>
                    ];

                    (* Parallel with early stop: submit all, collect via WaitNext, break on first LR *)
                    If[Length[gaugesToCheck] > 1 && Length[Kernels[]] > 0,
                        DistributeDefinitions[checkOneGauge, xvarsAll, integrand, heuristicValue, findRootsValue, methodLRValue,
                            STFasterFubini2, STFasterFubini, STFubiniLR, ppqIntersection];
                        Module[{submissions, tmp},
                            submissions = Table[
                                ParallelSubmit[{gi}, checkOneGauge[gi]],
                                {gi, gaugesToCheck}];
                            gaugeResults = {};
                            While[submissions =!= {},
                                tmp = WaitNext[submissions];
                                AppendTo[gaugeResults, tmp[[1]]];
                                submissions = tmp[[-1]];
                                If[Last[gaugeResults]["IsLR"], Break[]]
                            ];
                            (* Drain any remaining submissions after early stop *)
                            If[submissions =!= {}, Quiet[WaitAll[submissions]]]
                        ],
                        gaugeResults = Map[checkOneGauge, gaugesToCheck]
                    ];

                    lrGauges = Select[gaugeResults, #["IsLR"] &][[All, "Gauge"]];

                    Return[<|
                        "GaugeResults" -> gaugeResults,
                        "AnyLR" -> (Length[lrGauges] > 0),
                        "LRGauges" -> lrGauges
                    |>]
                ]
            ];

            conditionalEchoTiming[

                If[resumeFrom =!= "AfterExpansion",
                allIntegrands = {};
                allExpansions = {};

                (* OPT step 1: generate all integrands (fast, no polymake) *)
                stSetUIStage[uiComms, "BuildingIntegrands", 2];
                runQuiet[
                    Do[
                        var = Symbol["x" <> ToString[idx]];

                        {pref, integrand, xvars, coeffs} =
                            STGenerateIntegrand[g, "Gauge" -> {var -> 1},
                                FilterRules[DeleteCases[{opts}, "Gauge" -> _],
                                    Options[STGenerateIntegrand]]];

                        AppendTo[allIntegrands, {pref, integrand, xvars, coeffs}];

                    , {idx, gaugesToConsider}]
                , verbose];

                (* Resolve pole degree of the Gamma prefactor (same for all gauges) and effective integration depth *)
                If[Length[allIntegrands] > 0,
                    poleGamma     = Max[0, -STleadingLaurentOrder[allIntegrands[[1, 1]], eps]];
                    effectiveOrder = poleGamma + outputOrder];

                (* OPT step 2: launch all polymake calls concurrently, populate cache *)
                stSetUIStage[uiComms, "TropicalPrecomputation", 3];
                STTropicalDataPrecompute[allIntegrands, vb];

                (* OPT step 3: expand all integrands in parallel.
                   Look up pre-computed tropical data from the main-kernel cache and
                   pass it as trDataGiven; sub-kernels skip the polymake call entirely. *)
                stSetUIStage[uiComms, "ExpandingIntegrands", 4];
                allTrData = Table[
                    Module[{integrand2, xvars2, mons2, pols2, polsNoCoeffs2, cacheKey2},
                        {pref, integrand2, xvars2, coeffs} = allIntegrands[[i]];
                        {mons2, pols2} = STtoMonPols[integrand2, xvars2];
                        polsNoCoeffs2 = DeleteCases[STforgetCoeffs[#, xvars2]& /@ pols2[[1]], 1];
                        cacheKey2 = {Times @@ polsNoCoeffs2, xvars2};
                        If[KeyExistsQ[$STTropicalDataCache, cacheKey2],
                            $STTropicalDataCache[cacheKey2], {}]
                    ]
                , {i, Length[gaugesToConsider]}];

                DistributeDefinitions[allIntegrands, allTrData];

                allExpansions = runQuiet[
                    Quiet[
                        ParallelTable[
                            STExpandIntegral[
                                allIntegrands[[i, 2]], allIntegrands[[i, 3]],
                                allIntegrands[[i, 4]], {eps}, allTrData[[i]]]
                        , {i, Length[gaugesToConsider]}],
                        {FrontEndObject::notavail}]
                , verbose];
                ]; (* end If[resumeFrom =!= "AfterExpansion"]: steps 1-3 skipped on resume *)

            , showTimings, "Time taken to expand the integrands:"];

            (* Abort early if expansion failed (automatic gauge SCAN PATH) *)
            If[allExpansions === $Aborted || MemberQ[Flatten[{allExpansions}], $Aborted],
                Message[STEvaluateEulerIntegral::expansionfailed]; Return[$Aborted]];

            If[stopAt === "AfterExpansion",
                STSaveCheckpoint[problemId, <|
                    "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                    "XVars" -> xvars, "Coeffs" -> coeffs,
                    "AllIntegrands" -> allIntegrands, "AllExpansions" -> allExpansions,
                    "GaugesToConsider" -> gaugesToConsider, "ProblemIDs" -> problemIds,
                    "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt,
                    "ScanningPath" -> True, "Timestamp" -> DateString[]|>];
                Return[<|"CheckpointID" -> problemId, "Result" -> allExpansions|>]
            ];

            (* FindRoots -> Automatic cascade: run the entire gauge-scoring
               pass with FindRoots -> False; if every gauge NOLRs, retry the
               whole pass with FindRoots -> True.  Resolves Automatic to a
               single FindRoots value before any integrator call begins, so
               Integrator -> "HyperInt" never receives Wm/Wp letters from a
               gauge that needed True unless every gauge needs True (in which
               case the post-cascade guard below kills the run with the
               findRootsHyperInt message). *)
            mppOrig = methodPolysAndPairs;
            frLegs  = If[findRootsValue === Automatic, {False, True}, {findRootsValue}];
            chosenFrLeg = First[frLegs];
            Do[
                chosenFrLeg = frPass;
                methodPolysAndPairs = mppOrig;  (* fresh Fast/Standard for new FR leg *)

            (* NOLR fallback: rerun setup+scoring with "Standard" if "Fast" yielded all-NOLR.
               On pass 1 all-NOLR + Fast, loop runs pass 2 with Standard; the existing NOLR
               abort below fires only if pass 2 also fails. *)
            Do[
            conditionalEchoTiming[
                stSetUIStage[uiComms, "SettingUpDirectories", 5];
                (* Always: recreate sector directories from allExpansions.
                   When SetupInParallel -> 1, run serially on the main kernel with no
                   DistributeDefinitions overhead.  For n > 1 we split into n sequential
                   chunks and distribute only one slice at a time to limit peak memory. *)
                Module[{nv, numChunks, chunkSize, chunks, sip = setupInParallel, ov = effectiveOrder},
                    nv = Length[gaugesToConsider];
                    (* 2026-04-30: Bug #3 fix. KernelsAvailable<=1 closes
                       the SubTropica subkernel pool, but downstream
                       ParallelDo can auto-launch fresh kernels lacking
                       SubTropica` definitions, leaving the gauge
                       directories empty. Force the serial-setup branch
                       below by treating sip as if it were 1 whenever
                       the user requested no parallel pool. *)
                    If[NumericQ[$STRequestedKernelCount] && $STRequestedKernelCount <= 1,
                        sip = 1
                    ];
                    If[sip === 1,
                        (* Serial path: main kernel only, no subkernel traffic *)
                        runQuiet[
                            Do[
                                Quiet@STsetupDirectoryExpansion[allExpansions[[k]], ov,
                                    allIntegrands[[k, 3]], allIntegrands[[k, 4]], problemIds[[k]],
                                    "MethodPolysAndPairs" -> methodPolysAndPairs]
                            , {k, nv}]
                        , verbose],
                        (* Parallel path *)
                        numChunks = Which[
                            sip === Automatic,        1,
                            IntegerQ[sip] && sip > 1, Min[sip, nv],
                            True,                     1];
                        chunkSize = Ceiling[nv / numChunks];
                        chunks    = Partition[Range[nv], UpTo[chunkSize]];
                        (* STsetupDirectoryExpansion is a static SubTropica`
                           function, populated on subkernels by the parallel
                           Get inside stSetupKernelImpl.  Per-call distribute
                           was redundant; removed. *)
                        Do[
                            With[{
                                ci    = chunks[[c]],
                                ce    = allExpansions[[chunks[[c]]]],
                                cint  = allIntegrands[[chunks[[c]]]],
                                cpids = problemIds[[chunks[[c]]]]
                            },
                                DistributeDefinitions[ce, cint, cpids, ov, methodPolysAndPairs];
                                runQuiet[
                                    ParallelDo[
                                        Quiet@STsetupDirectoryExpansion[ce[[k]], ov,
                                            cint[[k, 3]], cint[[k, 4]], cpids[[k]],
                                            "MethodPolysAndPairs" -> methodPolysAndPairs]
                                    , {k, Length[ci]}]
                                , verbose];
                                ParallelEvaluate[ClearSystemCache[]];
                            ]
                        , {c, numChunks}]
                    ]
                ];

            , showTimings, "Time taken to set up the integrand directories:"];

            stSetUIStage[uiComms, "ScoringGauges", 6];
            PrintTemporary["Working on gauge scorings..."];
            PrintTemporary["Considering gauges: ", gaugesToConsider];
            PrintTemporary["Scanning faces in interval: ", scanScoreInterval];
            PrintTemporary["Time limit per gauge: ", If[SameQ[timeUpperBound,10^17],"The age of the Universe",timeUpperBound], If[SameQ[timeUpperBound,10^17],"."," seconds"]];
            If[memPercentCutOff =!= None && 0 < memPercentCutOff < 1,
                PrintTemporary["Memory cutoff per gauge: ", memPercentCutOff * 100, "% of available"]
            ];
            
            (* Optimization: disable history on sub-kernels before scoring *)
            If[verbose, Print["Disabling history on sub-kernels for scoring step..."]];
            ParallelEvaluate[$HistoryLength = 0];
            
            (* Scoring section with memory constraint *)
            scores =  conditionalEchoTiming[With[{
                tub = timeUpperBound,
                hv = heuristicValue,
                frv = chosenFrLeg,
                mlr = methodLRValue,
                ssi = scanScoreInterval,
                pids = problemIds,
                nv = Length[gaugesToConsider],
                gtc = gaugesToConsider,
                sipValue = scoreInParallel,
                mpc = memPercentCutOff,
                vb = verbose,
                scp = scoreProgress
            },
                Module[{numChunks, chunkSize, chunks, results, chunkIdx, useParallel},
                    
                    numChunks = Which[
                        sipValue === All || sipValue === True || sipValue === 1,
                            (*  auto-size the parallel batch based on available memory.
                               budgetMB = scoringMemoryFraction * availMB is the RAM "envelope" for
                               parallel scoring.  perGaugeMB is derived from the actual ByteCount
                               of allIntegrands, so the estimate adapts to diagram complexity.
                               numChunks is the resulting number of sequential rounds. *)
                            Module[{availMB, budgetMB, safeWidth},
                                availMB   = MemoryAvailable[] / 1024^2;
                                budgetMB  = scoringMemoryFraction * availMB;
                                safeWidth = Max[1, Floor[budgetMB / 512]];
                                If[vb, Print["  [OPT] MemAvail: ", Round[availMB], " MB  |  ",
                                             "scoring budget: ", Round[scoringMemoryFraction * 100],
                                             "% (", Round[budgetMB], " MB)  |  ",
                                             "safe parallel width: ", safeWidth, " gauge(s)"]];
                                Ceiling[nv / safeWidth]
                            ],
                        IntegerQ[sipValue] && sipValue > 0,
                            Min[sipValue, nv],
                        sipValue === False,
                            nv,
                        True,
                            1
                    ];
                    
                    (* 2026-04-30: Bug #3 fix. When the user runs with
                       KernelsAvailable<=1, STSetupKernel closes the pool,
                       but Mma's ParallelEvaluate (e.g. line 16307,
                       $HistoryLength = 0) auto-launches a fresh
                       $ProcessorCount-wide pool that lacks SubTropica
                       definitions. The downstream parallel scoring then
                       runs STfindLinearlyReducibleOrders2 on those
                       definitionless subkernels, getting 0 for every
                       gauge and leading to a silent integrate-phase
                       no-op. Check the INTENDED count
                       ($STRequestedKernelCount, set by stSetupKernelImpl)
                       rather than Length[Kernels[]] (which may have
                       grown via auto-launch); force serial when the
                       user asked for serial. *)
                    If[NumericQ[$STRequestedKernelCount] && $STRequestedKernelCount <= 1,
                        numChunks = nv
                    ];
                    useParallel = numChunks < nv;
                    (* DistributeDefinitions of the LR-search helper functions
                       was previously fired here on every STIntegrate call.
                       Those are static SubTropica` definitions; they're
                       already loaded on every subkernel by the parallel Get
                       inside stSetupKernelImpl.  Re-broadcasting them per
                       call costs \[Tilde]1\[Dash]3 s on a 13-subkernel pool
                       depending on $ppqMemo growth.  Removed; relying on
                       parallel Get to populate subkernels at launch and on
                       the per-script `STResetKernelCaches[]` to clear
                       caches between integrations. *)

                    chunkSize = Ceiling[nv / numChunks];
                    chunks = Partition[Range[nv], UpTo[chunkSize]];

                    If[vb,
                        Print["  Scoring ", nv, " gauges (", gtc, ") in ", Length[chunks], 
                              " chunk(s) of size ~", chunkSize,
                              If[useParallel, " (parallel)", " (serial)"]]
                    ];
                    
                    results = {};
                    Do[
                        If[vb && Length[chunks] > 1, 
                            Print["    Processing chunk ", chunkIdx, "/", Length[chunks], 
                                  " (gauge indices ", gtc[[First[chunks[[chunkIdx]]]]], 
                                  "-", gtc[[Last[chunks[[chunkIdx]]]]], ")"]
                        ];
                        
                        If[useParallel,
                            Module[{evalObjs, remaining, result, proc, chunkScores},
                                evalObjs = Table[
                                    With[{pidx = pids[[idx]], gidx = idx},
                                        ParallelSubmit[
                                            Module[{memLimit, score, dt},
                                                memLimit = If[NumericQ[mpc] && 0 < mpc < 1,
                                                    Floor[mpc * MemoryAvailable[]],
                                                    Infinity
                                                ];
                                                {dt, score} = AbsoluteTiming[
                                                    Block[{Print = (Null &)},
                                                        If[memLimit === Infinity,
                                                            TimeConstrained[
                                                                STfindLinearlyReducibleOrders2[pidx,
                                                                    Heuristic -> hv,
                                                                    FindRoots -> frv,
                                                                    "MethodLR" -> mlr,
                                                                    "ScanGauges" -> True,
                                                                    "ScanScoreInterval" -> ssi
                                                                ] // Quiet,
                                                                tub,
                                                                10^500
                                                            ],
                                                            MemoryConstrained[
                                                                TimeConstrained[
                                                                    STfindLinearlyReducibleOrders2[pidx,
                                                                        Heuristic -> hv,
                                                                        FindRoots -> frv,
                                                                        "MethodLR" -> mlr,
                                                                        "ScanGauges" -> True,
                                                                        "ScanScoreInterval" -> ssi
                                                                    ] // Quiet,
                                                                    tub,
                                                                    10^500
                                                                ],
                                                                memLimit,
                                                                10^501
                                                            ]
                                                        ]
                                                    ]
                                                ];
                                                {gidx, score, dt}
                                            ]
                                        ]
                                    ],
                                    {idx, chunks[[chunkIdx]]}
                                ];
                                chunkScores = ConstantArray[Null, Length[chunks[[chunkIdx]]]];
                                remaining = evalObjs;
                                While[remaining =!= {},
                                    {result, proc, remaining} = WaitNext[remaining];
                                    chunkScores[[Position[chunks[[chunkIdx]], result[[1]]][[1, 1]]]] = result[[2]];
                                    If[scp, WriteString["stdout",
                                        ToString[gtc[[result[[1]]]]] <> " -> " <>
                                        Which[result[[2]] === Infinity, "non-LR",
                                              result[[2]] >= 10^400, "timeout",
                                              True, "LR (score "<>ToString[result[[2]]]<>")"] <>
                                        "  ("<>ToString[NumberForm[result[[3]], {4, 2}]]<>" s)\n"]]
                                ];
                                AppendTo[results, chunkScores]
                            ],
                            Module[{chunkScores},
                                chunkScores = {};
                                Do[
                                    Module[{memLimit, score, dt},
                                        memLimit = If[NumericQ[mpc] && 0 < mpc < 1,
                                            Floor[mpc * MemoryAvailable[]],
                                            Infinity
                                        ];
                                        {dt, score} = AbsoluteTiming[
                                            Block[{Print = (Null &)},
                                                If[memLimit === Infinity,
                                                    TimeConstrained[
                                                        STfindLinearlyReducibleOrders2[pids[[idx]],
                                                            Heuristic -> hv,
                                                            FindRoots -> frv,
                                                            "MethodLR" -> mlr,
                                                            "ScanGauges" -> True,
                                                            "ScanScoreInterval" -> ssi
                                                        ] // Quiet,
                                                        tub,
                                                        10^500
                                                    ],
                                                    MemoryConstrained[
                                                        TimeConstrained[
                                                            STfindLinearlyReducibleOrders2[pids[[idx]],
                                                                Heuristic -> hv,
                                                                FindRoots -> frv,
                                                                "MethodLR" -> mlr,
                                                                "ScanGauges" -> True,
                                                                "ScanScoreInterval" -> ssi
                                                            ] // Quiet,
                                                            tub,
                                                            10^500
                                                        ],
                                                        memLimit,
                                                        10^501
                                                    ]
                                                ]
                                            ]
                                        ];
                                        AppendTo[chunkScores, score];
                                        If[scp, WriteString["stdout",
                                            ToString[gtc[[idx]]] <> " -> " <>
                                            Which[score === Infinity, "non-LR",
                                                  score >= 10^400, "timeout",
                                                  True, "LR (score "<>ToString[score]<>")"] <>
                                            "  ("<>ToString[NumberForm[dt, {4, 2}]]<>" s)\n"]]
                                    ],
                                    {idx, chunks[[chunkIdx]]}
                                ];
                                AppendTo[results, chunkScores]
                            ]
                        ];

                        If[Length[chunks] > 1 && chunkIdx < Length[chunks],
                            ClearSystemCache[];
                            If[useParallel, ParallelEvaluate[ClearSystemCache[]]];
                        ];
                        
                        , {chunkIdx, Length[chunks]}
                    ];
                    
                    Flatten[results]
                ]
            ], showTimings, "Time taken to set up the gauge:"];
            
            (* Optimization: clear sub-kernel memory after scoring step *)
            If[verbose, Print["Clearing sub-kernel caches after scoring step..."]];
            ParallelEvaluate[ClearSystemCache[]];
            
            (* Restore history length on sub-kernels if needed for later stages *)
            (* Setting to 1 is a reasonable default that allows some history without excessive memory use *)
            ParallelEvaluate[$HistoryLength = 1];
            
            Do[
                If[scores[[idx]] === 10^500, 
                    Message[STEvaluateGraph::timeout, gaugesToConsider[[idx]]] 
                ];
                If[scores[[idx]] === 10^501, 
                    Message[STEvaluateGraph::membound, gaugesToConsider[[idx]]]
                ];
                , {idx, Length[scores]}
            ];
            
            scores = scores /. (10^501 -> 10^500);

            If[pass === 1 && methodPolysAndPairs === "Fast" && AllTrue[scores, # === Infinity &],
                Print["[NOLR fallback] No linearly-reducible order found for any gauge across all epsilon orders \[LongDash] truncating to the requested Order..."];
                methodPolysAndPairs = "Standard";
                Quiet@STClearDirectories[problemId];
                ,
                Break[]
            ];
            , {pass, 1, 2}];

                (* If FR cascade has another leg to try and current pass scored
                   all NOLR, advance to the next FR leg. *)
                If[chosenFrLeg =!= Last[frLegs] && AllTrue[scores, # === Infinity &],
                    Continue[]];
                Break[];
            , {frPass, frLegs}];
            findRootsValue = chosenFrLeg;  (* resolve Automatic to whichever leg was used *)

            (* Post-cascade guard: if Automatic resolved to True but the user
               requested Integrator -> "HyperInt", abort with the
               findRootsHyperInt message rather than feeding Wm/Wp letters
               to a Maple integrator that can't roundtrip Root(...). *)
            If[chosenFrLeg === True && OptionValue["Integrator"] === "HyperInt",
                Message[STEvaluateGraph::findRootsHyperInt];
                Throw[$Failed, "stEvalGraphExit"];
            ];

            (* v1.0.420: Throw[$Failed, ...] to the Catch at the top of
               STEvaluateGraph so callers (STIntegrate, test harnesses)
               get a structured failure value instead of an uncatchable
               kernel Abort.  Triggers on genuinely non-LR topologies
               like the equal-mass 2-loop sunrise (elliptic); also on
               numerator combinations that spuriously hit NOLR. *)
            If[AllTrue[scores, # === Infinity &],
                Message[STEvaluateGraph::nolr];
                Throw[$Failed, "stEvalGraphExit"];
            ];

            If[AllTrue[scores, (# >= 10^500 || # === Infinity) &],
                Message[STEvaluateGraph::timebound];
                Throw[$Failed, "stEvalGraphExit"];
            ];

            bestGaugeIdx = Position[scores, Min[Select[scores, # < 10^500 &]]][[1, 1]];
            bestGauge = gaugesToConsider[[bestGaugeIdx]];
            problemId = problemIds[[bestGaugeIdx]];

            {pref, integrand, xvars, coeffs} = allIntegrands[[bestGaugeIdx]];
            expansion = allExpansions[[bestGaugeIdx]];
            Echo[{pref, integrand/(Times@@xvars), xvars, coeffs}, "Parametric integrand:"];

            Echo[scores /. 10^500 -> "\!\(\*SuperscriptBox[\(10\), \(500\)]\)", "Picking the gauge x" <> ToString[bestGauge] <>
                " from candidates x" <> StringJoin[Riffle[ToString /@ gaugesToConsider, ", x"]] <>
                ", scores"];

            (* Axis-5 decision record: machine-readable counterpart of the
               Echo above, captured by the UI as a distinct "Kernel decision"
               row. No-op when UIComms isn't set (notebook / headless). *)
            STEmitDecision["gaugeSelected", <|
                "bestGauge" -> bestGauge,
                "candidates" -> gaugesToConsider,
                "scores" -> (scores /. s_ /; NumericQ[s] && s >= 10^500 :> "Infinity"),
                "bestScore" ->
                    With[{sc = scores[[bestGaugeIdx]]},
                        If[NumericQ[sc] && sc < 10^500, sc, "Infinity"]]
            |>];

            (*  delete losing gauge directories immediately after the winner is known.
               This frees disk space and evicts their pages from the OS cache, reducing memory
               pressure on the subsequent STLaunchHyperIntica parallel integration step.
               STsetupDirectoryExpansion appends "_cnt" to the problem id (e.g. "ID_x1_1"),
               so we glob with pid<>"_*" to catch all expansion terms.
               The trailing underscore in the glob prevents x1 from accidentally matching x10/x11/\[Ellipsis] *)
            Module[{loserPids, matches},
                loserPids = Delete[problemIds, bestGaugeIdx];
                If[Length[loserPids] > 0,
                    If[vb, Print["  [OPT] Deleting ", Length[loserPids],
                                 " losing gauge director(ies) to free memory..."]];
                    Do[
                        matches = FileNames["integrands/" <> pid <> "_*"];
                        Quiet[DeleteDirectory[#, DeleteContents -> True]] & /@ matches;
                    , {pid, loserPids}];
                ];
            ];

            stSetUIStage[uiComms, "FindingLinearOrders", 7];
            (* Optimization: skip faces that already have bestOrder.m from scoring step *)
            Monitor[
                runQuietTimed[
                    STfindLinearlyReducibleOrders2[problemId,
                        Heuristic -> heuristicValue,
                        FindRoots -> findRootsValue,
                        "MethodLR" -> methodLRValue,
                        "ScanGauges" -> False,
                        "SkipExistingOrders" -> True,
                        "UIComms" -> uiComms
                    ],
                    verbose,
                    showTimings,
                    "Time taken to find the linear orderings:"
                ],
                "Working on linear orders..."
            ];

            ForgetProportionalPolynomialsQ[];
            STEchoLinearOrders[problemId];

            (* FindRoots False -> True per-face escalation: gauge scoring
               only sampled ScanScoreInterval={1,3} faces, so a gauge that
               passed under False at sample-time may still NOLR on a
               non-sampled face during the full post-bestGauge LR search.
               When that happens AND the user requested Automatic AND the
               gauge cascade picked False, retry the NOLR faces with
               FindRoots -> True (algebraic-letter alphabet allowed) \[LongDash]
               keeping the False-success faces' orders untouched.
               Integrator -> "HyperInt" cannot consume Wm/Wp letters, so
               the escalation aborts cleanly with the standard
               findRootsHyperInt message in that case. *)
            If[chosenFrLeg === False && frOrig === Automatic && stAnyFaceNOLR[problemId],
                Print["[FR fallback] Some face NOLR with FindRoots -> False after gauge x", bestGauge, " selection; escalating laggard faces to True."];
                If[OptionValue["Integrator"] === "HyperInt",
                    Message[STEvaluateGraph::findRootsHyperInt];
                    Throw[$Failed, "stEvalGraphExit"]];
                findRootsValue = True;
                chosenFrLeg    = True;
                $NoAlgebraicRootsContributions  = False;
                $HyperIntroduceAlgebraicLetters = True;
                ClearAlgebraicLetters[];
                If[Length[Kernels[]] > 0, ParallelEvaluate[ClearAlgebraicLetters[]]];
                $stRootSubstitutions = {};
                Monitor[
                    runQuietTimed[
                        STfindLinearlyReducibleOrders2[problemId,
                            Heuristic -> heuristicValue,
                            FindRoots -> True,
                            "MethodLR" -> methodLRValue,
                            "ScanGauges" -> False,
                            "SkipExistingOrders" -> True,
                            "UIComms" -> uiComms
                        ],
                        verbose, showTimings, "Time taken to find the linear orderings (FR -> True fallback):"
                    ],
                    "Working on linear orders (FR -> True fallback)..."
                ];
                ForgetProportionalPolynomialsQ[];
                STEchoLinearOrders[problemId];
            ];

            (* MethodPolysAndPairs: "Fast" -> "Standard" fallback if simple LR hit NOLR *)
            If[methodPolysAndPairs === "Fast" && stAnyFaceNOLR[problemId],
                Print["[NOLR fallback] No linearly-reducible order found for all epsilon orders \[LongDash] truncating to the requested Order..."];
                methodPolysAndPairs = "Standard";
                Quiet@STClearDirectories[problemId];
                runQuiet[
                    STsetupDirectoryExpansion[expansion, effectiveOrder, xvars, coeffs, problemId,
                        "MethodPolysAndPairs" -> "Standard"],
                    verbose
                ];
                Monitor[
                    runQuietTimed[
                        STfindLinearlyReducibleOrders2[problemId,
                            Heuristic -> heuristicValue,
                            FindRoots -> findRootsValue,
                            "MethodLR" -> methodLRValue,
                            "ScanGauges" -> False,
                            "UIComms" -> uiComms
                        ],
                        verbose, showTimings, "Time taken to find the linear orderings (fallback):"
                    ],
                    "Working on linear orders (fallback)..."
                ];
                ForgetProportionalPolynomialsQ[];
                STEchoLinearOrders[problemId];
            ];

            If[stopAt === "AfterLinearOrder",
                STSaveCheckpoint[problemId, <|
                    "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                    "XVars" -> xvars, "Coeffs" -> coeffs, "Expansion" -> expansion,
                    "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt, "Timestamp" -> DateString[]|>];
                Return[<|"CheckpointID" -> problemId, "Result" -> ordersTEMP|>]
            ];

        ,
            (* Non-automatic gauge case *)
            stUpdateUIComms[uiComms, "StageCount", 7];

            (* Resolve FindRoots -> Automatic to False at the top of the
               explicit-gauge branch so the LR search runs in pure
               whole-pass-False mode (no per-face cascade mixing).  If any
               face NOLRs after this pass, the post-LR escalation block
               below retries the whole LR search under True. *)
            If[findRootsValue === Automatic,
                findRootsValue = False;
                chosenFrLeg    = False
            ];

            (* Early LR check  - generate integrand and return before expansion/directories *)
            If[stopAt === "AfterMinimalLRCheck" || stopAt === "AfterMinimalLRCheckOneShot",
                {pref, integrand, xvars, coeffs} =
                    STGenerateIntegrand[g,
                        FilterRules[{opts}, Options[STGenerateIntegrand]]];
                lrRawExpr = STtoCoeffMonPols[integrand, xvars];
                lrExpsWithEps = Position[lrRawExpr//Last//Last, v_/;(v/.eps->0) <= 0, 1]//Flatten;
                lrPolysAndPairs = (lrRawExpr//Last//First)[[lrExpsWithEps]];
                If[lrPolysAndPairs === {} || xvars === {},
                    lrBestOrder = xvars,
                    {lrBestOrder, lrScore} = Quiet[
                        If[methodLRValue === "Lungo",
                            stDispatchFubini2[
                                {Join[lrPolysAndPairs, xvars]},
                                xvars, Heuristic -> heuristicValue],
                            If[methodLRValue === "AnTropica",
                            STFubiniAT2[
                                {Join[lrPolysAndPairs, xvars]},
                                xvars, Heuristic -> heuristicValue],
                            STEspressoFubini2[
                                {Join[lrPolysAndPairs, xvars]},
                                xvars, Heuristic -> heuristicValue]]
                        ]]
                ];
                Return[<|"GaugeResults" -> {<|"Gauge" -> OptionValue["Gauge"],
                            "IsLR" -> (lrBestOrder =!= NOLR),
                            "Order" -> If[lrBestOrder === NOLR, {}, lrBestOrder]|>},
                         "AnyLR" -> (lrBestOrder =!= NOLR),
                         "LRGauges" -> If[lrBestOrder =!= NOLR, {OptionValue["Gauge"]}, {}]|>]
            ];

            conditionalEchoTiming[
                {pref, integrand, xvars, coeffs} =
                    STGenerateIntegrand[g,
                        FilterRules[{opts}, Options[STGenerateIntegrand]]];
                Echo[{pref, integrand/(Times@@xvars), xvars, coeffs}, "Parametric integrand:"];

                (* Resolve pole degree of the Gamma prefactor and effective integration depth *)
                poleGamma     = Max[0, -STleadingLaurentOrder[pref, eps]];
                effectiveOrder = poleGamma + outputOrder;

                If[stopAt =!= "AfterBuildingIntegrand",
                    stSetUIStage[uiComms, "ExpandingIntegrands", 2];
                    expansion = runQuiet[STExpandIntegral[integrand, xvars, coeffs], verbose];
                    stSetUIStage[uiComms, "SettingUpDirectories", 3];
                    If[$STOverwritePreviousDirectories =!= False, Quiet@STClearDirectories[problemId]];
                    runQuiet[
                        STsetupDirectoryExpansion[expansion, effectiveOrder,
                            xvars, coeffs, problemId,
                            "MethodPolysAndPairs" -> methodPolysAndPairs],
                        verbose
                    ]
                ];

            , showTimings, "Time taken to set up the integrands and directories:"];

            (* 2026-03-31: abort early if expansion failed (non-automatic gauge SCAN PATH) *)
            If[expansion === $Aborted,
                Message[STEvaluateEulerIntegral::expansionfailed]; Return[$Aborted]];

            If[stopAt === "AfterBuildingIntegrand",
                STSaveCheckpoint[problemId, <|
                    "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                    "XVars" -> xvars, "Coeffs" -> coeffs, "Expansion" -> None,
                    "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt, "Timestamp" -> DateString[]|>];
                Return[{pref, integrand/(Times@@xvars), xvars, coeffs}]
            ];

            If[stopAt === "AfterExpansion",
                STSaveCheckpoint[problemId, <|
                    "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                    "XVars" -> xvars, "Coeffs" -> coeffs, "Expansion" -> expansion,
                    "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt, "Timestamp" -> DateString[]|>];
                Return[<|"CheckpointID" -> problemId, "Result" -> expansion|>]
            ];

            If[saveAllIntegrands =!= False,
                Put[
                    <|
                        "ProblemID" -> problemId,
                        "Prefactor" -> pref,
                        "Integrand" -> integrand,
                        "XVars" -> xvars,
                        "Coefficients" -> coeffs,
                        "Expansion" -> expansion,
                        "Order" -> effectiveOrder,
                        "Timestamp" -> DateString[],
                        "Graph" -> g
                    |>,
                    saveAllIntegrands
                ];
                Print["All integrands saved to: ", saveAllIntegrands];
            ];

            stSetUIStage[uiComms, "FindingLinearOrders", 4];
            (* Non-scan LR search: STfindLinearlyReducibleOrders2 (ScanGauges
               -> False) Abort[]s the moment a face is NOLR (SubTropica.wl
               ~14861), which would unwind PAST the "Fast" -> "Standard" and
               FindRoots escalations below.  The gauge-SCAN path never hits
               this because its scoring step runs with ScanGauges -> True
               (Return[Infinity], no abort) and flips to "Standard" before the
               post-bestGauge search.  When the user PINS a gauge there is no
               such scoring step, so trap the abort here and mirror the scan
               behaviour: if we are still on the "Fast" poly-and-pairs
               extraction, rebuild under "Standard" and retry.  A genuine NOLR
               under "Standard" (or a user-forced "Standard") re-aborts as
               before, preserving the hard stop on truly non-LR gauges. *)
            If[CheckAbort[
                   Monitor[
                       runQuietTimed[
                           STfindLinearlyReducibleOrders2[problemId,
                               Heuristic -> heuristicValue,
                               FindRoots -> findRootsValue,
                               "MethodLR" -> methodLRValue,
                               "UIComms" -> uiComms],
                           verbose,
                           showTimings,
                           "Time taken to find the linear orderings:"
                       ],
                       "Working on linear orders..."
                   ];
                   False,
                   True
               ],
                (* The pinned gauge NOLR'd under the current (extraction,
                   FindRoots) combo.  The same Abort would unwind past BOTH the
                   "Fast" -> "Standard" (18669) and FindRoots False -> True
                   (18640) escalations, and the hexagon-class case needs BOTH
                   (Standard extraction AND algebraic letters).  Mirror the
                   gauge-scan recovery by escalating to the maximal permitted
                   combo in one retry: "Standard" extraction, plus FindRoots ->
                   True when the user permits algebraic letters (FindRoots =!=
                   False).  If already at that combo it is a genuine NOLR, so
                   re-Abort to preserve the hard stop on truly non-LR gauges. *)
                If[methodPolysAndPairs === "Standard" &&
                       (frOrig === False || findRootsValue === True),
                    Abort[]];
                methodPolysAndPairs = "Standard";
                If[frOrig =!= False && findRootsValue =!= True,
                    findRootsValue = True; chosenFrLeg = True;
                    $NoAlgebraicRootsContributions  = False;
                    $HyperIntroduceAlgebraicLetters = True;
                    ClearAlgebraicLetters[];
                    If[Length[Kernels[]] > 0, ParallelEvaluate[ClearAlgebraicLetters[]]];
                    $stRootSubstitutions = {}];
                Print["[NOLR fallback] No linearly-reducible order for the pinned gauge under the initial settings \[LongDash] retrying with MethodPolysAndPairs -> \"Standard\"",
                    If[findRootsValue === True, " and FindRoots -> True", ""], "..."];
                Quiet@STClearDirectories[problemId];
                runQuiet[
                    STsetupDirectoryExpansion[expansion, effectiveOrder, xvars, coeffs, problemId,
                        "MethodPolysAndPairs" -> "Standard"],
                    verbose
                ];
                Monitor[
                    runQuietTimed[
                        STfindLinearlyReducibleOrders2[problemId,
                            Heuristic -> heuristicValue,
                            FindRoots -> findRootsValue,
                            "MethodLR" -> methodLRValue,
                            "UIComms" -> uiComms],
                        verbose,
                        showTimings,
                        "Time taken to find the linear orderings (Standard/FindRoots fallback):"
                    ],
                    "Working on linear orders (Standard/FindRoots fallback)..."
                ];
            ];

            ForgetProportionalPolynomialsQ[];
            STEchoLinearOrders[problemId];

            (* FindRoots False -> True whole-pass escalation (explicit-
               gauge branch).  Symmetric to the gauge-scanning branch
               escalation: if user gave Automatic, the False-pass LR
               search above NOLR'd on at least one face, retry the
               whole pass with True (algebraic-letter alphabet).
               Integrator -> "HyperInt" cannot consume Wm/Wp letters,
               so the escalation aborts cleanly with the standard
               findRootsHyperInt message. *)
            If[chosenFrLeg === False && frOrig === Automatic && stAnyFaceNOLR[problemId],
                Print["[FR fallback] Some face NOLR with FindRoots -> False on user-supplied gauge ", OptionValue["Gauge"], "; escalating laggard faces to True."];
                If[OptionValue["Integrator"] === "HyperInt",
                    Message[STEvaluateGraph::findRootsHyperInt];
                    Throw[$Failed, "stEvalGraphExit"]];
                findRootsValue = True;
                chosenFrLeg    = True;
                $NoAlgebraicRootsContributions  = False;
                $HyperIntroduceAlgebraicLetters = True;
                ClearAlgebraicLetters[];
                If[Length[Kernels[]] > 0, ParallelEvaluate[ClearAlgebraicLetters[]]];
                $stRootSubstitutions = {};
                Monitor[
                    runQuietTimed[
                        STfindLinearlyReducibleOrders2[problemId,
                            Heuristic -> heuristicValue,
                            FindRoots -> True,
                            "MethodLR" -> methodLRValue,
                            "SkipExistingOrders" -> True,
                            "UIComms" -> uiComms],
                        verbose, showTimings, "Time taken to find the linear orderings (FR -> True fallback):"
                    ],
                    "Working on linear orders (FR -> True fallback)..."
                ];
                ForgetProportionalPolynomialsQ[];
                STEchoLinearOrders[problemId];
            ];

            (* MethodPolysAndPairs: "Fast" -> "Standard" fallback if simple LR hit NOLR *)
            If[methodPolysAndPairs === "Fast" && stAnyFaceNOLR[problemId],
                Print["[NOLR fallback] No linearly-reducible order found for all epsilon orders \[LongDash] truncating to the requested Order..."];
                methodPolysAndPairs = "Standard";
                Quiet@STClearDirectories[problemId];
                runQuiet[
                    STsetupDirectoryExpansion[expansion, effectiveOrder, xvars, coeffs, problemId,
                        "MethodPolysAndPairs" -> "Standard"],
                    verbose
                ];
                Monitor[
                    runQuietTimed[
                        STfindLinearlyReducibleOrders2[problemId,
                            Heuristic -> heuristicValue,
                            FindRoots -> findRootsValue,
                            "MethodLR" -> methodLRValue,
                            "UIComms" -> uiComms],
                        verbose, showTimings, "Time taken to find the linear orderings (fallback):"
                    ],
                    "Working on linear orders (fallback)..."
                ];
                ForgetProportionalPolynomialsQ[];
                STEchoLinearOrders[problemId];
            ];

            If[stopAt === "AfterLinearOrder",
                STSaveCheckpoint[problemId, <|
                    "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                    "XVars" -> xvars, "Coeffs" -> coeffs, "Expansion" -> expansion,
                    "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt, "Timestamp" -> DateString[]|>];
                Return[<|"CheckpointID" -> problemId, "Result" -> ordersTEMP|>]
            ];
        ];

        stSetUIStage[uiComms, "SettingUpKernels", If[isScanPath, 8, 5]];
        conditionalEchoTiming[
            STSetupKernel[OptionValue["KernelsAvailable"]];
        , showTimings, "Time taken to set up the kernels:"];

        stSetUIStage[uiComms, "Integrating", If[isScanPath, 9, 6]];
        stUpdateUIComms[uiComms, "JobTrackingDir", $STJobTrackingDir];
        Monitor[
            runQuietTimed[
                STLaunchHyperIntica[problemId,
                    "Strategy"                   -> OptionValue["Parallelization"],
                    "ShowIntegrands"             -> showIntegrands,
                    "ClearCachesPerIntegrand"    -> OptionValue["ClearCachesPerIntegrand"],
                    "ClearCachesMemoryThreshold" -> OptionValue["ClearCachesMemoryThreshold"],
                    "SelectFaces"                -> OptionValue["SelectFaces"],
                    "ReuseExistingResults"       -> OptionValue["ReuseExistingResults"],
                    "UIComms"                    -> uiComms,
                    "Integrator"                 -> OptionValue["Integrator"]
                ],
                verbose,
                showTimings,
                "Time taken to integrate:"
            ],
            monitorDisplay
        ];

        (*  clear HyperIntica memoization caches from all sub-kernels AND the
           main kernel after integration. HyperInt accumulates $LinearFactorsCache,
           $PartialFractionsCache, etc.; ClearSystemCache[] does not touch these
           Association-based caches.
           Cache hits on later runs return the prior result without re-firing the
           Wm/Wp letter-introduction side effect, so $HyperAlgebraicLetterTable
           stays empty and stWrapRootSubs[] returns the bare series with
           unsubstituted Wm[i]/Wp[i] symbols \[LongDash] verification then fails because
           STVerify can't resolve them.
           ParallelEvaluate alone misses the main kernel in serial mode
           (NumberOfSubkernels=1), so we explicitly call ForgetAllMemo[] here. *)
        ForgetAllMemo[];
        ParallelEvaluate[ForgetAllMemo[]];

        stSetUIStage[uiComms, "CollectingResults", If[isScanPath, 10, 7]];
        stStageTime["STReadResults", pref runQuiet2[STReadResults[problemId], verbose]] //
            stStageTime["Total", Total[#]] & //
            stStageTime["Series-1", Series[#, {eps, 0, outputOrder}]] & //
            stStageTime["zeta->mzv", # /. zeta -> mzv] & //
            stStageTime["Collect+SimplifyOutput",
                Collect[Normal[#], eps^___, OptionValue["SimplifyOutput"]]] & //
            stStageTime["CleanZeroInf",
                If[OptionValue["CleanOutput"] =!= False, CleanZeroInf[#], #]] & //
            stStageTime["Series-2", Series[#, {eps, 0, outputOrder}]] & //
            (* v1.0.443: drop bonus coefficients above outputOrder.
               When a Gamma(\[Omega]) prefactor pole cancels (e.g. squared-ISP
               numerators with \[Nu]_tot \[LessEqual] 0), the true leading order of the
               integral can be at \[CurlyEpsilon]^m with m > outputOrder.  Mathematica's
               Series returns that \[CurlyEpsilon]^m coefficient anyway, but STIntegrate
               only computed the parametric integrand through
               \[CurlyEpsilon]^(outputOrder + poleGamma) which is (m - outputOrder) orders
               short of what a correct \[CurlyEpsilon]^m needs.  Reporting it would be an
               accuracy lie.  Strictly truncate to outputOrder; if the series
               starts above outputOrder, return an empty-sentinel SeriesData
               so callers know "0 up through outputOrder, higher not tracked". *)
            stStageTime["stWrapRootSubs", stWrapRootSubs[#]] & //
            (* v1.0.443: if the reported series starts at \[CurlyEpsilon]^nmin with nmin >
               outputOrder, Mathematica's Series left a "bonus" leading
               coefficient that STIntegrate only partially computed (the
               parametric integrand was truncated at \[CurlyEpsilon]^(outputOrder+poleGamma),
               not at \[CurlyEpsilon]^(nmin+poleGamma) that the accurate bonus coefficient
               would require).  Strip it: emit an empty-sentinel SeriesData
               meaning "zero through \[CurlyEpsilon]^outputOrder, nothing tracked higher". *)
            stStageTime["TruncateOutput",
                If[Head[#] === SeriesData && #[[4]] > outputOrder && #[[3]] =!= {},
                    SeriesData[eps, 0, {}, outputOrder + 1, outputOrder + 1, 1],
                    #]] &

    , showTimings, "Overall timing:"]];

    If[saveSlowestIntegrand =!= False,
        slowestJob = STFindSlowestJob[];
        If[slowestJob =!= None,
            Put[slowestJob, saveSlowestIntegrand];
            Print["Slowest integrand saved to: ", saveSlowestIntegrand];
            Print["  Duration: ", slowestJob["Duration"], " seconds"];
            Print["  Face: ", slowestJob["Face"]];
            Print["  Counter term ID: ", slowestJob["CtId"]];
        ,
            Print["Warning: Could not find slowest integrand data."];
        ];
    ];

    stSetUIStage[uiComms, "Done", If[isScanPath, 10, 7]];
    (* Guarantee SeriesData output: if the assembly pipeline did not produce
       a SeriesData (e.g. eps-free result), wrap it now. *)
    result = If[Head[result] =!= SeriesData && Head[result] =!= Hold && !AssociationQ[result] && IntegerQ[outputOrder] && FreeQ[result, eps],
        SeriesData[eps, 0, {result}, 0, outputOrder + 1, 1],
        result
    ];

    (* Populate $integrationResult so STSubmitResult[] works from notebook *)
    Module[{efl, n0r, intm, extm, nickel},
      efl = g[[1, All, 1]];   (* internal edge pairs *)
      n0r = g[[2, All, 1]];   (* external leg vertices *)
      intm = g[[1, All, 2]];  (* internal edge masses *)
      extm = g[[2, All, 2]];  (* external leg masses *)
      nickel = Quiet @ Check[computeNickelIndex[efl, n0r, intm, extm], ""];
      $integrationResult = <|
          "uiResult" -> <|
              "nickelIndex" -> nickel,
              "Dimension" -> ToString[OptionValue["Dimension"], InputForm],
              "Order" -> outputOrder,
              "propExponents" -> Table[1, {Length[efl]}],
              "Substitutions" -> OptionValue["Substitutions"],
              "edges" -> g[[1]],
              "nodes" -> g[[2]]
          |>,
          "result" -> result
      |>;
    ];

    stEchoAlgebraicLettersSummary[result];

    result
], "stEvalGraphExit"]


(* ::Subsection::Closed:: *)
(*Variant: Euler integrand*)


(*To evaluate a Euler integral directly:*)

(*  check if f(xvars) is homogeneous in xvars using the "theorem":
   f is homogeneous iff Sum[xi * D[f,xi]] / f is free of all xvars. *)
Clear[STHomogeneousQ];
STHomogeneousQ[f_, xvars_] := If[f === 0, True, Module[{eulerD},
    eulerD = Simplify[Sum[xvars[[i]] * D[f, xvars[[i]]], {i, Length[xvars]}] / f];
    FreeQ[eulerD, Alternatives @@ xvars]
]];

STEvaluateEulerIntegral::nolr        = "No linearly reducible integration orders found for any gauge choice.";
STEvaluateEulerIntegral::timebound   = "No valid gauge found within the specified time and/or memory limit(s). Please increase the TimeUpperBound and/or MemoryPercentCutOff.";
STEvaluateEulerIntegral::membound    = "Gauge `1` exceeded memory limit and was skipped.";
STEvaluateEulerIntegral::timeout     = "Gauge `1` exceeded time limit and was skipped.";
STEvaluateEulerIntegral::nogauges    = "No valid gauge indices provided in IncludeGauges option. Must be integers between 1 and the number of variables (`1`).";
STEvaluateEulerIntegral::invalidgauges = "Warning: Some gauge indices in IncludeGauges are out of range (1 to `1`). Invalid indices ignored: `2`.";
(* 2026-03-31: message for failed tropical expansion *)
STEvaluateEulerIntegral::expansionfailed = "Tropical analysis failed (STExpandIntegral returned $Aborted). A divergence may not have been regulated.";
STEvaluateEulerIntegral::nogaugeLR = "StopAt -> \"AfterMinimalLRCheck\" requires a homogeneous integrand (or ScanGauges -> True). Non-homogeneous integrands cannot be gauge-fixed.";
STEvaluateEulerIntegral::notprojective = "ScanGauges -> True was requested, but the integrand is not projective (not homogeneous under x_i -> lambda x_i). Gauge-fixing assumes the integrand has gauge redundancy and will silently evaluate it at the gauge point, producing a meaningless result. Use ScanGauges -> False (or Automatic, which detects homogeneity) for ad-hoc non-projective integrals.";
STEvaluateEulerIntegral::notprojectiveAuto = "Integrand is non-homogeneous in the Feynman parameters `1` and contains no eps-dependent exponent to regulate it. The parametric pipeline would silently return 0 (e.g. SeriesData[eps, 0, {}, ...]) in this case. Lee-Pomeransky-style integrands (non-homogeneous with an eps-dependent exponent, e.g. (U+F)^(-D/2)) are not affected by this check. For a generic Riemann integral without an eps regulator, call HyperIntica directly, for example:\n  HyperIntica[integrand, {x1,0,1}, {x2,0,1}] /. GetAlgebraicBackSubRules[] /. ZeroInfPeriod :> ZeroInfPeriodAsMpl // FullSimplify";

Options[STEvaluateEulerIntegral] = Join[
    {
        "Order"                  -> Automatic,  (* Output order in eps: Automatic = through eps^0 (finite part); n = through eps^n *)
        "Verbose"                -> False,
        "ShowTimings"            -> True,
        "ShowIntegrands"         -> False,
        "SaveSlowestIntegrand"   -> False,
        "SaveAllIntegrands"      -> False,
        "SetProblemID"           -> Automatic,
        "StopAt"                 -> Automatic,
        "StartAt"                -> None,
        (* Automatic = detect from homogeneity; True = always scan; False = never *)
        "ScanGauges"             -> Automatic,
        "IncludeGauges"          -> All,
        "Parallelization"        -> All,
        "KernelsAvailable"       -> $ProcessorCount - 1,
        "SimplifyOutput"         -> Simplify,
        "Heuristic"              -> "LeafCountLinear",
        "ScanScoreInterval"      -> {1, 3},
        "ScoreInParallel"        -> All,
        "TimeUpperBound"         -> 10^17,
        "MemoryPercentCutOff"    -> None,
        "ScoringMemoryFraction"  -> 0.5,
        "SetupInParallel"        -> Automatic, (*  Automatic = all gauges in one parallel batch (original behaviour); 1 = serial on main kernel only; n > 1 = n sequential parallel batches *)
        "ClearCachesPerIntegrand"-> False,
        "ClearCachesMemoryThreshold" -> Infinity, (*  integer in GB; see Options[STIntegrate] for details *)
        "Integrator"             -> "HyperIntica",  (* "HyperIntica" (default), "HyperInt" (Maple via SThyperIntMaple), or "HyperFLINT" (C++/FLINT CLI via STHyperFlint) per-integrand worker *)
        "CleanOutput"            -> False,  (* If True, apply CleanZeroInf[] to the final result *)
        (* Face-selective integration.
           All              : integrate every face (default).
           i_Integer        : integrate only face i (all eps orders).
           {i1, i2, ...}    : integrate only faces i1, i2, ... (all eps orders).
           (o -> i)         : integrate only face i at eps order o specifically [Rule syntax].
           {i1, o2->i2, ...}: mixed list of face indices and (epsOrder->faceIndex) rules.
           Except[...]      : exclude instead of include; works with any of the above.
           Examples:  "SelectFaces" -> {2, 3}       - faces 2 and 3, all eps orders
                      "SelectFaces" -> (0 -> 2)     - face 2 at eps order 0 only
                      "SelectFaces" -> Except[{3}]  - all faces except face 3 *)
        "SelectFaces"            -> All,
        (* When True (default), skip any face whose result.m + successQ.m already exist on disk.
           Always prints a notice when a face is reused, so stale results are visible. *)
        "ReuseExistingResults"   -> True,
        "UIComms"                -> None,  (* Structured progress reporting for SubTropica UI; pass <|"IPCDir"->...|> to enable *)
        "ContourHandling"        -> "Abort", (* "Abort" = abort on undetermined contour direction; "Continue" = leave Hlog[Infinity,...] unevaluated *)
        FindRoots                -> True,   (* Default True as of v1.0.398; see Options[STEvaluateGraph] for rationale. *)
        "MethodLR"               -> "Lungo",  (* "Lungo" (default, OLD algorithm: discriminant/resultant + global dedup) or "Espresso" *)
        "MethodPolysAndPairs"    -> "Fast",  (* "Fast" (default) = extract polys directly from STtoCoeffMonPols; "Standard" = sum renormalized integrands per eps-order and call STpreparePolysAndPairs *)
        "ScoreProgress"          -> True     (* When True, Echo per-gauge LR status and wall time as each (sub)kernel finishes *)
    },
    Options[STGenerateIntegrand]
];


STEvaluateEulerIntegral[{prefArg_, integrandArg_, xvarsArg_, coeffsArg_}, opts:OptionsPattern[]] :=
Catch[
Module[{
    (* Convention: integrandArg is in user-facing convention (measure dx_i); multiply by Times@@xvarsArg
       here to convert to internal convention (measure dx_i/x_i) used throughout the pipeline. *)
    pref = prefArg, integrand = integrandArg * (Times @@ xvarsArg), xvars = xvarsArg, coeffs = coeffsArg,
    expansion, verbose, vb, showTimings, showIntegrands,
    saveSlowestIntegrand, saveAllIntegrands,
    problemId, monitorDisplay, slowestJob, result,
    heuristicValue, outputOrder, poleGamma, effectiveOrder, stopAt, startAt, resumeFrom,
    scanGauges, doScan,
    numberOfVars, includeGauges, gaugesToConsider, invalidGauges,
    problemIds, allIntegrands, allTrData, allExpansions,
    scores, bestGaugeIdx, bestGauge,
    timeUpperBound, memPercentCutOff, scoringMemoryFraction, setupInParallel, scoreProgress,
    findRootsValue, methodLRValue, methodPolysAndPairs,
    scanScoreInterval, scoreInParallel,
    uiComms,
    lrGaugesToCheck, lrCheckOneGauge, lrGaugeResults, lrGauges
},
    (* Apply substitutions if provided, for consistency with the graph path *)
    If[OptionValue["Substitutions"] =!= {},
        integrand = integrand //. OptionValue["Substitutions"] /. A_^B_ :> Factor[A]^B
    ];

    uiComms = OptionValue["UIComms"];
    stSetUIStage[uiComms, "Initializing", 1];

    (* Zero-variable short-circuit: if the input tuple has no Schwinger variables
       left (e.g. a fully gauge-fixed tadpole), the "integral" is just the
       constant pref \[Times] integrand. The tropical/NP/subtraction pipeline cannot
       handle empty xvars (Det[{}], empty-ray STEvalRay, etc.). *)
    If[xvarsArg === {},
        Module[{o0, trivResult, prefLocal},
            o0 = OptionValue["Order"];
            o0 = If[o0 === Automatic, 0, If[ListQ[o0], Max[o0], o0]];
            prefLocal = prefArg //. OptionValue["Substitutions"] /. A_^B_ :> Factor[A]^B;
            trivResult = Series[prefLocal * integrand, {eps, 0, o0}];
            Print["[SubTropica] Zero-variable Euler tuple \[LongDash] returning pref \[Times] integrand as a Series in eps."];
            stSetUIStage[uiComms, "Complete", 10];
            Throw[trivResult]
        ]
    ];

    STSetupKernel[OptionValue["KernelsAvailable"]];

    $STContourHandling = OptionValue["ContourHandling"];
    DistributeDefinitions[$STContourHandling];

    verbose               = OptionValue["Verbose"];
    vb                    = verbose;
    heuristicValue        = OptionValue["Heuristic"];
    showTimings           = OptionValue["ShowTimings"];
    showIntegrands        = OptionValue["ShowIntegrands"];
    saveSlowestIntegrand  = OptionValue["SaveSlowestIntegrand"];
    saveAllIntegrands     = OptionValue["SaveAllIntegrands"];
    outputOrder   = OptionValue["Order"];
    outputOrder   = If[outputOrder === Automatic, 0, outputOrder];
    (* Pole degree of the Gamma prefactor; effective integration depth = poleGamma + outputOrder *)
    poleGamma     = Max[0, -STleadingLaurentOrder[pref, eps]];
    effectiveOrder = poleGamma + outputOrder;
    stopAt                = OptionValue["StopAt"];
    scanGauges            = OptionValue["ScanGauges"];
    includeGauges         = OptionValue["IncludeGauges"];
    scanScoreInterval     = OptionValue["ScanScoreInterval"];
    scoreInParallel       = OptionValue["ScoreInParallel"];
    timeUpperBound        = OptionValue["TimeUpperBound"];
    memPercentCutOff      = OptionValue["MemoryPercentCutOff"];
    scoringMemoryFraction = Clip[OptionValue["ScoringMemoryFraction"], {0.01, 1.0}];
    scoreProgress         = TrueQ[OptionValue["ScoreProgress"]];
    findRootsValue        = OptionValue[FindRoots];
    methodLRValue         = OptionValue["MethodLR"];
    methodPolysAndPairs   = OptionValue["MethodPolysAndPairs"];
    setupInParallel       = OptionValue["SetupInParallel"];
    problemId             = ToString[If[OptionValue["SetProblemID"] === Automatic,
                                Unique[SubTropicaID], OptionValue["SetProblemID"]]];
    startAt               = OptionValue["StartAt"];
    resumeFrom            = None;

    (* Mirrors the auto-gauge branch above: True or Automatic \[DoubleRightArrow] arm letters;
       False \[DoubleRightArrow] disarm.  Per-face cascade (in stDispatchFubini2 / STEspressoFubini)
       handles the actual False\[RightArrow]True escalation per LR-search call. *)
    If[findRootsValue =!= False,
        $NoAlgebraicRootsContributions = False;
        $HyperIntroduceAlgebraicLetters = True;
        ClearAlgebraicLetters[];
        If[Length[Kernels[]] > 0, ParallelEvaluate[ClearAlgebraicLetters[]]];
        $stRootSubstitutions = {}
    ,
        $HyperIntroduceAlgebraicLetters = False;
        ClearAlgebraicLetters[];
        If[Length[Kernels[]] > 0, ParallelEvaluate[ClearAlgebraicLetters[]]];
        $stRootSubstitutions = {}
    ];

    (*Resume from checkpoint *)
    If[startAt =!= None,
        With[{ck = STLoadCheckpoint[ToString[startAt]]},
            If[ck === $Failed,
                Print["[SubTropica] Checkpoint \"", startAt, "\" not found. Running from scratch."],
                (* Restore pipeline state *)
                pref       = ck["Pref"];
                integrand  = ck["Integrand"];
                xvars      = ck["XVars"];
                coeffs     = ck["Coeffs"];
                expansion      = ck["Expansion"];
                effectiveOrder = ck["OrderValue"];
                outputOrder    = Lookup[ck, "OutputOrder", 0];
                problemId      = ck["ProblemID"];
                resumeFrom = ck["StopAt"];
                Echo[problemId, "Resuming from checkpoint:"];
                Print["  Previously stopped at: ", resumeFrom];
                (* For scanning-path checkpoints, restore additional scanning state *)
                If[TrueQ[ck["ScanningPath"]],
                    allIntegrands    = ck["AllIntegrands"];
                    allExpansions    = ck["AllExpansions"];
                    gaugesToConsider = ck["GaugesToConsider"];
                    problemIds       = ck["ProblemIDs"]
                ]
            ]
        ]
    ];

    Echo[problemId, "Problem ID:"];
    
    (* MG 2026-04-08: zero integrand (e.g. odd-rank tensor numerator vanishes by Lorentz symmetry).
       The 1-variable trivial path handles this accidentally; add an explicit check for all cases. *)
    If[integrand === 0,
        If[stopAt === "AfterBuildingIntegrand",
            STSaveCheckpoint[problemId, <|
                "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                "XVars" -> xvars, "Coeffs" -> coeffs, "Expansion" -> None,
                "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt, "Timestamp" -> DateString[]|>];
            Return[{pref, integrand/(Times @@ xvars), xvars, coeffs}]
        ];
        Print["[SubTropica] Zero integrand \[LongDash] integral vanishes in dimensional regularization."];
        Return[SeriesData[eps, 0, {}, 0, outputOrder + 1, 1]]
    ];

    If[saveSlowestIntegrand =!= False && !showIntegrands,
        showIntegrands = True;
        Print["Note: Enabling ShowIntegrands for SaveSlowestIntegrand tracking."];
    ];

    (* Resolve whether to scan gauges:
       Automatic -> detect from homogeneity of the integrand in xvars.
       True      -> always scan (projective assumption); guard here against
                    a common misuse where the caller passes a non-homogeneous
                    ad-hoc integral.  Without the guard, SubTropica silently
                    gauge-fixes the non-projective integrand to x_i = 1 and
                    returns the integrand's VALUE at that point instead of
                    its integral, which is mathematically meaningless. *)
    doScan = Which[
        TrueQ[scanGauges],
            If[Length[xvars] > 0 && !STHomogeneousQ[integrand, xvars],
                Message[STEvaluateEulerIntegral::notprojective]];
            True,
        scanGauges === False, False,
        True,                 STHomogeneousQ[integrand, xvars]
    ];
    If[verbose, Print["ScanGauges resolved to: ", doScan,
        If[scanGauges === Automatic, " (auto-detected from homogeneity)", ""]]];

    (* Non-projective + no-eps-regulator guard. A non-homogeneous integrand
       without any eps-dependent exponent falls into the NO-SCAN path, which
       the parametric pipeline can only return 0 for (silent wrong answer,
       seen as SeriesData[eps, 0, {}, ...]). Lee-Pomeransky integrands are
       non-homogeneous BUT carry an eps-dependent exponent (e.g. G^(-D/2) =
       G^(eps-2)), so they pass this check. Restricted to ScanGauges ->
       Automatic so explicit gauge-fixed callers (ScanGauges -> False) are
       unaffected. Checkpoint resumes also skipped. *)
    If[scanGauges === Automatic && !doScan && xvars =!= {} && resumeFrom === None &&
       FreeQ[integrand, Power[_, e_ /; !FreeQ[e, eps]]],
        Message[STEvaluateEulerIntegral::notprojectiveAuto, xvars];
        Return[$Failed]
    ];
    (* When resuming, always use the non-scanning path  integrand is already fixed *)
    If[resumeFrom =!= None, doScan = False];

    (* Set stage count now that doScan is resolved:
       Scan path: 10 stages; No-scan path: 7 stages (skip Building, Tropical, Scoring) *)
    stUpdateUIComms[uiComms, "StageCount", If[doScan, 10, 7]];

    (* Trivial case: homogeneous integrand with a single Feynman parameter (e.g. scalar tadpole).
       Gauge-fixing the only variable leaves nothing to integrate ; return directly without
       invoking HyperIntica.  We rewrite (base)^(f(eps)) -> Exp[f(eps)*ComplexExpand[Log[base]]]
       so that Mathematica's Series can expand power-of-eps factors over symbolic masses. *)
    If[doScan && Length[xvars] === 1,
        If[stopAt === "AfterBuildingIntegrand", (* MG 2026-04-08: trivial path must honour StopAt *)
            STSaveCheckpoint[problemId, <|
                "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                "XVars" -> xvars, "Coeffs" -> coeffs, "Expansion" -> None,
                "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt, "Timestamp" -> DateString[]|>];
            Return[{pref, integrand/(Times@@xvars), xvars, coeffs}]
        ];
        With[{trivPref = pref,
              trivInt  = integrand /. First[xvars] -> 1},
            If[verbose, Print["Trivial integral (no Feynman parameters after gauge-fixing). Returning directly."]];
            Return[
                (* Rewrite (base)^(f(eps)) as Exp[f(eps) * log] where log = PowerExpand[ComplexExpand[Log[base]]].
                   Note: ComplexExpand treats all symbols as real \[RightArrow] Log[-mm^2] = I*Pi + Log[mm^2].
                   PowerExpand then simplifies Log[mm^2] -> 2*Log[mm] for consistent output form. *)
                trivPref * trivInt /.
                    (base_ /; FreeQ[base, eps])^(pow_ /; !FreeQ[pow, eps]) :>
                        Exp[pow * PowerExpand[ComplexExpand[Log[base]]]] //
                    Normal@Series[#, {eps, 0, outputOrder}]& //
                    ReplaceAll[zeta -> mzv] //
                    Collect[#, eps^___, OptionValue["SimplifyOutput"]]& //
                    (If[FreeQ[#, eps],
                        SeriesData[eps, 0, {#}, 0, outputOrder + 1, 1],
                        Series[#, {eps, 0, outputOrder}]] &)
            ]
        ]
    ];

    (* Build dynamic monitor display *)
    monitorDisplay = If[showIntegrands,
        Dynamic[
            Module[{jobs, longestRunning, currentTime = AbsoluteTime[], elapsed},
                jobs = STReadActiveJobs[];
                If[AssociationQ[jobs] && Length[jobs] > 0,
                    longestRunning = First @ MinimalBy[Values[jobs], #["StartTime"] &];
                    elapsed = currentTime - longestRunning["StartTime"];
                    Column[{
                        Style[Row[{"Slowest active job: ", Round[elapsed, 0.1], " sec"}], Bold, Darker[Red]],
                        Row[{"Face: ", longestRunning["Face"]}],
                        Row[{"Counter term ID: ", longestRunning["CtId"]}],
                        Row[{"Integrand: ", longestRunning["Integrand"]}],
                        Row[{"Order: ", longestRunning["Order"]}],
                        Row[{"Active kernels: ", Length[jobs]}]
                    }],
                    "Waiting for jobs to start..."
                ]
            ],
            UpdateInterval -> 1.0
        ],
        "Working on integration..."
    ];

    If[stopAt === "AfterMinimalLRCheckOneShot",
        (* Abort if integrand is not homogeneous and no scan forced *)
        If[!doScan,
            Message[STEvaluateEulerIntegral::nogaugeLR]; Abort[]
        ];
        Module[{rawExpr, expsWithEps, polysAndPairs, bestOrder, score, gaugeVar},
            rawExpr = STtoCoeffMonPols[integrand, xvars];
            expsWithEps = Position[rawExpr//Last//Last, v_/;(v/.eps->0) <= 0, 1]//Flatten;
            polysAndPairs = (rawExpr//Last//First)[[expsWithEps]];
            If[polysAndPairs === {} || xvars === {},
                Return[<|
                    "GaugeResults" -> {<|"Gauge" -> First[xvars], "IsLR" -> True, "Order" -> Rest[xvars]|>},
                    "AnyLR" -> True,
                    "LRGauges" -> {First[xvars]}|>]
            ];
            Module[{espResult},
              espResult = Quiet[If[methodLRValue === "Lungo",
                  stDispatchFubini2[
                      {Join[polysAndPairs, xvars]},
                      xvars, Heuristic -> heuristicValue, FindRoots -> findRootsValue],
                  If[methodLRValue === "AnTropica",
                  STFubiniAT2[
                      {Join[polysAndPairs, xvars]},
                      xvars, ScreeningLR -> True, Heuristic -> heuristicValue, FindRoots -> findRootsValue],
                  STEspressoFubini2[
                      {Join[polysAndPairs, xvars]},
                      xvars, ScreeningLR -> True, Heuristic -> heuristicValue, FindRoots -> findRootsValue]]
              ]];
              If[findRootsValue =!= False, {bestOrder, score} = espResult[[1]], {bestOrder, score} = espResult];
            ];
            If[bestOrder === NOLR,
                Return[<|
                    "GaugeResults" -> {},
                    "AnyLR" -> False,
                    "LRGauges" -> {}|>],
                gaugeVar = Last[bestOrder];
                Return[<|
                    "GaugeResults" -> {<|"Gauge" -> gaugeVar, "IsLR" -> True, "Order" -> Most[bestOrder]|>},
                    "AnyLR" -> True,
                    "LRGauges" -> {gaugeVar}|>]
            ]
        ]
    ];

    If[stopAt === "AfterMinimalLRCheck",
        (* Abort if integrand is not homogeneous and no scan forced *)
        If[!doScan,
            Message[STEvaluateEulerIntegral::nogaugeLR]; Abort[]
        ];

        numberOfVars = Length[xvars];

        (* Determine which gauges to check *)
        lrGaugesToCheck = If[includeGauges === All,
            Range[numberOfVars],
            Select[includeGauges, IntegerQ[#] && 1 <= # <= numberOfVars &]
        ];

        (* Per-gauge check function *)
        (* Extract polynomial factors with eps-dependent or negative exponents via STtoCoeffMonPols,
           then run STEspressoFubini2 exactly as the normal pipeline does. *)
        lrCheckOneGauge[gi_Integer] := Module[{intgFixed, xvFixed, rawExpr, expsWithEps, polysAndPairs, bestOrder, score},
            intgFixed = integrand /. xvars[[gi]] -> 1;
            xvFixed = Delete[xvars, gi];
            rawExpr = STtoCoeffMonPols[intgFixed, xvFixed];
            expsWithEps = Position[rawExpr//Last//Last, v_/;(v/.eps->0) <= 0, 1]//Flatten;
            polysAndPairs = (rawExpr//Last//First)[[expsWithEps]];
            If[polysAndPairs === {} || xvFixed === {},
                Return[<|"Gauge" -> xvars[[gi]], "IsLR" -> True, "Order" -> xvFixed|>]
            ];
            Module[{espResult},
              espResult = Quiet[If[methodLRValue === "Lungo",
                  stDispatchFubini2[
                      {Join[polysAndPairs, xvFixed]},
                      xvFixed, Heuristic -> heuristicValue, FindRoots -> findRootsValue],
                  If[methodLRValue === "AnTropica",
                  STFubiniAT2[
                      {Join[polysAndPairs, xvFixed]},
                      xvFixed, Heuristic -> heuristicValue, FindRoots -> findRootsValue],
                  STEspressoFubini2[
                      {Join[polysAndPairs, xvFixed]},
                      xvFixed, Heuristic -> heuristicValue, FindRoots -> findRootsValue]]
              ]];
              If[findRootsValue =!= False, {bestOrder, score} = espResult[[1]], {bestOrder, score} = espResult];
            ];
            <|"Gauge" -> xvars[[gi]],
              "IsLR" -> (bestOrder =!= NOLR),
              "Order" -> If[bestOrder === NOLR, {}, bestOrder]|>
        ];

        (* Parallel with early stop: submit all, collect via WaitNext, break on first LR *)
        If[Length[lrGaugesToCheck] > 1 && Length[Kernels[]] > 0,
            DistributeDefinitions[lrCheckOneGauge, xvars, integrand, heuristicValue, findRootsValue, methodLRValue,
                STFasterFubini2, STFasterFubini, STFubiniLR, ppqIntersection];
            Module[{submissions, tmp},
                submissions = Table[
                    ParallelSubmit[{gi}, lrCheckOneGauge[gi]],
                    {gi, lrGaugesToCheck}];
                lrGaugeResults = {};
                While[submissions =!= {},
                    tmp = WaitNext[submissions];
                    AppendTo[lrGaugeResults, tmp[[1]]];
                    submissions = tmp[[-1]];
                    If[Last[lrGaugeResults]["IsLR"], Break[]]
                ];
                (* Drain any remaining submissions after early stop *)
                If[submissions =!= {}, Quiet[WaitAll[submissions]]]
            ],
            lrGaugeResults = Map[lrCheckOneGauge, lrGaugesToCheck]
        ];

        lrGauges = Select[lrGaugeResults, #["IsLR"] &][[All, "Gauge"]];

        Return[<|
            "GaugeResults" -> lrGaugeResults,
            "AnyLR" -> (Length[lrGauges] > 0),
            "LRGauges" -> lrGauges
        |>]
    ];

    result = timed[conditionalEchoTiming[

        If[doScan,

            (* Gauge-scan path *)
            numberOfVars = Length[xvars];

            gaugesToConsider = If[includeGauges === All,
                Range[numberOfVars],
                Select[includeGauges, IntegerQ[#] && 1 <= # <= numberOfVars &]
            ];

            If[includeGauges =!= All,
                invalidGauges = Complement[includeGauges, gaugesToConsider];
                If[Length[invalidGauges] > 0,
                    Message[STEvaluateEulerIntegral::invalidgauges, numberOfVars, invalidGauges];
                ];
            ];

            If[Length[gaugesToConsider] == 0,
                Message[STEvaluateEulerIntegral::nogauges, numberOfVars]; Abort[];
            ];

            If[verbose, Print["Considering gauges: ", gaugesToConsider,
                              " (out of ", numberOfVars, " total)"]];

            problemIds = Table[
                ToString[problemId] <> "_g" <> ToString[i],
                {i, gaugesToConsider}
            ];

            If[$STOverwritePreviousDirectories =!= False && resumeFrom === None, Quiet@STClearDirectories[problemId]];

            If[stopAt === "AfterBuildingIntegrand",
                STSaveCheckpoint[problemId, <|
                    "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                    "XVars" -> xvars, "Coeffs" -> coeffs, "Expansion" -> None,
                    "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt, "Timestamp" -> DateString[]|>];
                Return[{pref, integrand/(Times@@xvars), xvars, coeffs}]
            ];

            conditionalEchoTiming[

                If[resumeFrom =!= "AfterExpansion",
                (* step 1: build all gauge-fixed integrands *)
                stSetUIStage[uiComms, "BuildingIntegrands", 2];
                allIntegrands = {};
                runQuiet[
                    Do[
                        With[{gVar = xvars[[i]]},
                            AppendTo[allIntegrands, {
                                pref,
                                integrand /. gVar -> 1,
                                Delete[xvars, i],
                                coeffs
                            }]
                        ];
                    , {i, gaugesToConsider}]
                , verbose];

                (* step 2: concurrent polymake precomputation *)
                stSetUIStage[uiComms, "TropicalPrecomputation", 3];
                STTropicalDataPrecompute[allIntegrands, vb];

                (* step 3: expand all integrands in parallel *)
                stSetUIStage[uiComms, "ExpandingIntegrands", 4];
                allTrData = Table[
                    Module[{int2, xv2, mons2, pols2, polsNoCoeffs2, cacheKey2},
                        {pref, int2, xv2, coeffs} = allIntegrands[[i]];  (* pref/coeffs are Module locals here! *)
                        {mons2, pols2} = STtoMonPols[int2, xv2];
                        polsNoCoeffs2 = DeleteCases[STforgetCoeffs[#, xv2]& /@ pols2[[1]], 1];
                        cacheKey2 = {Times @@ polsNoCoeffs2, xv2};
                        If[KeyExistsQ[$STTropicalDataCache, cacheKey2],
                            $STTropicalDataCache[cacheKey2], {}]
                    ]
                , {i, Length[gaugesToConsider]}];

                DistributeDefinitions[allIntegrands, allTrData];

                allExpansions = runQuiet[
                    Quiet[
                        ParallelTable[
                            STExpandIntegral[
                                allIntegrands[[i, 2]], allIntegrands[[i, 3]],
                                allIntegrands[[i, 4]], {eps}, allTrData[[i]]]
                        , {i, Length[gaugesToConsider]}],
                        {FrontEndObject::notavail}]
                , verbose];
                ]; (* end If[resumeFrom =!= "AfterExpansion"]: steps 1-3 skipped on resume *)

            , showTimings, "Time taken to expand the integrands:"];

            (* Abort early if expansion failed (automatic gauge SCAN PATH) *)
            If[allExpansions === $Aborted || MemberQ[Flatten[{allExpansions}], $Aborted],
                Message[STEvaluateEulerIntegral::expansionfailed]; Return[$Aborted]];

            If[stopAt === "AfterExpansion",
                STSaveCheckpoint[problemId, <|
                    "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                    "XVars" -> xvars, "Coeffs" -> coeffs,
                    "AllIntegrands" -> allIntegrands, "AllExpansions" -> allExpansions,
                    "GaugesToConsider" -> gaugesToConsider, "ProblemIDs" -> problemIds,
                    "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt,
                    "ScanningPath" -> True, "Timestamp" -> DateString[]|>];
                Return[<|"CheckpointID" -> problemId, "Result" -> allExpansions|>]
            ];

            (* NOLR fallback: rerun setup+scoring with "Standard" if "Fast" yielded all-NOLR.
               On pass 1 all-NOLR + Fast, loop runs pass 2 with Standard; the existing NOLR
               abort below fires only if pass 2 also fails. *)
            Do[
            conditionalEchoTiming[
                stSetUIStage[uiComms, "SettingUpDirectories", 5];
                (* Always: recreate sector directories from allExpansions.
                   When SetupInParallel -> 1, run serially on the main kernel with no
                   DistributeDefinitions overhead.  For n > 1 we split into n sequential
                   chunks and distribute only one slice at a time to limit peak memory. *)
                Module[{nv, numChunks, chunkSize, chunks, sip = setupInParallel, ov = effectiveOrder},
                    nv = Length[gaugesToConsider];
                    (* 2026-04-30: Bug #3 fix. KernelsAvailable<=1 closes
                       the SubTropica subkernel pool, but downstream
                       ParallelDo can auto-launch fresh kernels lacking
                       SubTropica` definitions, leaving the gauge
                       directories empty. Force the serial-setup branch
                       below by treating sip as if it were 1 whenever
                       the user requested no parallel pool. *)
                    If[NumericQ[$STRequestedKernelCount] && $STRequestedKernelCount <= 1,
                        sip = 1
                    ];
                    If[sip === 1,
                        (* Serial path: main kernel only, no subkernel traffic *)
                        runQuiet[
                            Do[
                                Quiet@STsetupDirectoryExpansion[allExpansions[[k]], ov,
                                    allIntegrands[[k, 3]], allIntegrands[[k, 4]], problemIds[[k]],
                                    "MethodPolysAndPairs" -> methodPolysAndPairs]
                            , {k, nv}]
                        , verbose],
                        (* Parallel path *)
                        numChunks = Which[
                            sip === Automatic,        1,
                            IntegerQ[sip] && sip > 1, Min[sip, nv],
                            True,                     1];
                        chunkSize = Ceiling[nv / numChunks];
                        chunks    = Partition[Range[nv], UpTo[chunkSize]];
                        (* STsetupDirectoryExpansion is a static SubTropica`
                           function, populated on subkernels by the parallel
                           Get inside stSetupKernelImpl.  Per-call distribute
                           was redundant; removed. *)
                        Do[
                            With[{
                                ci    = chunks[[c]],
                                ce    = allExpansions[[chunks[[c]]]],
                                cint  = allIntegrands[[chunks[[c]]]],
                                cpids = problemIds[[chunks[[c]]]]
                            },
                                DistributeDefinitions[ce, cint, cpids, ov, methodPolysAndPairs];
                                runQuiet[
                                    ParallelDo[
                                        Quiet@STsetupDirectoryExpansion[ce[[k]], ov,
                                            cint[[k, 3]], cint[[k, 4]], cpids[[k]],
                                            "MethodPolysAndPairs" -> methodPolysAndPairs]
                                    , {k, Length[ci]}]
                                , verbose];
                                ParallelEvaluate[ClearSystemCache[]];
                            ]
                        , {c, numChunks}]
                    ]
                ];

            , showTimings, "Time taken to set up the integrand directories:"];

            stSetUIStage[uiComms, "ScoringGauges", 6];
            PrintTemporary["Working on gauge scorings..."];
            PrintTemporary["Considering gauges: ", gaugesToConsider];
            PrintTemporary["Scanning faces in interval: ", scanScoreInterval];
            PrintTemporary["Time limit per gauge: ",
                If[SameQ[timeUpperBound, 10^17], "The age of the Universe", timeUpperBound],
                If[SameQ[timeUpperBound, 10^17], ".", " seconds"]];
            If[memPercentCutOff =!= None && 0 < memPercentCutOff < 1,
                PrintTemporary["Memory cutoff per gauge: ", memPercentCutOff * 100, "% of available"]
            ];

            ParallelEvaluate[$HistoryLength = 0];

            (* Scoring *)
            scores = conditionalEchoTiming[With[{
                tub      = timeUpperBound,
                hv       = heuristicValue,
                frv      = findRootsValue,
                mlr      = methodLRValue,
                ssi      = scanScoreInterval,
                pids     = problemIds,
                nv       = Length[gaugesToConsider],
                gtc      = gaugesToConsider,
                sipValue = scoreInParallel,
                mpc      = memPercentCutOff,
                vb       = verbose,
                scp      = scoreProgress
            },
                Module[{numChunks, chunkSize, chunks, results, chunkIdx, useParallel},
                    numChunks = Which[
                        sipValue === All || sipValue === True || sipValue === 1,
                            Module[{availMB, budgetMB, safeWidth},
                                availMB   = MemoryAvailable[] / 1024^2;
                                budgetMB  = scoringMemoryFraction * availMB;
                                safeWidth = Max[1, Floor[budgetMB / 512]];
                                If[vb, Print["  [OPT] MemAvail: ", Round[availMB], " MB  |  ",
                                             "scoring budget: ", Round[scoringMemoryFraction * 100],
                                             "% (", Round[budgetMB], " MB)  |  ",
                                             "safe parallel width: ", safeWidth, " gauge(s)"]];
                                Ceiling[nv / safeWidth]
                            ],
                        IntegerQ[sipValue] && sipValue > 0,
                            Min[sipValue, nv],
                        sipValue === False,
                            nv,
                        True,
                            1
                    ];

                    (* 2026-04-30: Bug #3 fix (mirror of the
                       Schwinger+Automatic-Gauge branch above): force
                       serial when the user asked for KernelsAvailable<=1
                       even if Mma's ParallelEvaluate auto-launched a
                       fresh pool. *)
                    If[NumericQ[$STRequestedKernelCount] && $STRequestedKernelCount <= 1,
                        numChunks = nv
                    ];
                    useParallel = numChunks < nv;
                    (* Same hoist as the Schwinger+Automatic-Gauge branch:
                       static LR-search helpers are populated on subkernels
                       via parallel Get inside stSetupKernelImpl, no need
                       to re-broadcast per call. *)

                    chunkSize = Ceiling[nv / numChunks];
                    chunks = Partition[Range[nv], UpTo[chunkSize]];

                    If[vb, Print["  Scoring ", nv, " gauges (", gtc, ") in ", Length[chunks],
                                 " chunk(s) of size ~", chunkSize,
                                 If[useParallel, " (parallel)", " (serial)"]]];

                    results = {};
                    Do[
                        If[vb && Length[chunks] > 1,
                            Print["    Processing chunk ", chunkIdx, "/", Length[chunks],
                                  " (gauge indices ", gtc[[First[chunks[[chunkIdx]]]]],
                                  "-", gtc[[Last[chunks[[chunkIdx]]]]], ")"]
                        ];
                        If[useParallel,
                            Module[{evalObjs, remaining, result, proc, chunkScores},
                                evalObjs = Table[
                                    With[{pidx = pids[[idx]], gidx = idx},
                                        ParallelSubmit[
                                            Module[{memLimit, score, dt},
                                                memLimit = If[NumericQ[mpc] && 0 < mpc < 1,
                                                    Floor[mpc * MemoryAvailable[]],
                                                    Infinity
                                                ];
                                                {dt, score} = AbsoluteTiming[
                                                    Block[{Print = (Null &)},
                                                        If[memLimit === Infinity,
                                                            TimeConstrained[
                                                                STfindLinearlyReducibleOrders2[pidx,
                                                                    Heuristic -> hv,
                                                                    FindRoots -> frv,
                                                                    "MethodLR" -> mlr,
                                                                    "ScanGauges" -> True,
                                                                    "ScanScoreInterval" -> ssi
                                                                ] // Quiet,
                                                                tub,
                                                                10^500
                                                            ],
                                                            MemoryConstrained[
                                                                TimeConstrained[
                                                                    STfindLinearlyReducibleOrders2[pidx,
                                                                        Heuristic -> hv,
                                                                        FindRoots -> frv,
                                                                        "MethodLR" -> mlr,
                                                                        "ScanGauges" -> True,
                                                                        "ScanScoreInterval" -> ssi
                                                                    ] // Quiet,
                                                                    tub,
                                                                    10^500
                                                                ],
                                                                memLimit,
                                                                10^501
                                                            ]
                                                        ]
                                                    ]
                                                ];
                                                {gidx, score, dt}
                                            ]
                                        ]
                                    ],
                                    {idx, chunks[[chunkIdx]]}
                                ];
                                chunkScores = ConstantArray[Null, Length[chunks[[chunkIdx]]]];
                                remaining = evalObjs;
                                While[remaining =!= {},
                                    {result, proc, remaining} = WaitNext[remaining];
                                    chunkScores[[Position[chunks[[chunkIdx]], result[[1]]][[1, 1]]]] = result[[2]];
                                    If[scp, WriteString["stdout",
                                        ToString[gtc[[result[[1]]]]] <> " -> " <>
                                        Which[result[[2]] === Infinity, "non-LR",
                                              result[[2]] >= 10^400, "timeout",
                                              True, "LR (score "<>ToString[result[[2]]]<>")"] <>
                                        "  ("<>ToString[NumberForm[result[[3]], {4, 2}]]<>" s)\n"]]
                                ];
                                AppendTo[results, chunkScores]
                            ],
                            Module[{chunkScores},
                                chunkScores = {};
                                Do[
                                    Module[{memLimit, score, dt},
                                        memLimit = If[NumericQ[mpc] && 0 < mpc < 1,
                                            Floor[mpc * MemoryAvailable[]],
                                            Infinity
                                        ];
                                        {dt, score} = AbsoluteTiming[
                                            Block[{Print = (Null &)},
                                                If[memLimit === Infinity,
                                                    TimeConstrained[
                                                        STfindLinearlyReducibleOrders2[pids[[idx]],
                                                            Heuristic -> hv,
                                                            FindRoots -> frv,
                                                            "MethodLR" -> mlr,
                                                            "ScanGauges" -> True,
                                                            "ScanScoreInterval" -> ssi
                                                        ] // Quiet,
                                                        tub,
                                                        10^500
                                                    ],
                                                    MemoryConstrained[
                                                        TimeConstrained[
                                                            STfindLinearlyReducibleOrders2[pids[[idx]],
                                                                Heuristic -> hv,
                                                                FindRoots -> frv,
                                                                "MethodLR" -> mlr,
                                                                "ScanGauges" -> True,
                                                                "ScanScoreInterval" -> ssi
                                                            ] // Quiet,
                                                            tub,
                                                            10^500
                                                        ],
                                                        memLimit,
                                                        10^501
                                                    ]
                                                ]
                                            ]
                                        ];
                                        AppendTo[chunkScores, score];
                                        If[scp, WriteString["stdout",
                                            ToString[gtc[[idx]]] <> " -> " <>
                                            Which[score === Infinity, "non-LR",
                                                  score >= 10^400, "timeout",
                                                  True, "LR (score "<>ToString[score]<>")"] <>
                                            "  ("<>ToString[NumberForm[dt, {4, 2}]]<>" s)\n"]]
                                    ],
                                    {idx, chunks[[chunkIdx]]}
                                ];
                                AppendTo[results, chunkScores]
                            ]
                        ];
                        If[Length[chunks] > 1 && chunkIdx < Length[chunks],
                            ClearSystemCache[];
                            If[useParallel, ParallelEvaluate[ClearSystemCache[]]];
                        ];
                    , {chunkIdx, Length[chunks]}];

                    Flatten[results]
                ]
            ], showTimings, "Time taken to set up the gauge:"];

            ParallelEvaluate[ClearSystemCache[]];
            ParallelEvaluate[$HistoryLength = 1];

            Do[
                If[scores[[idx]] === 10^500,
                    Message[STEvaluateEulerIntegral::timeout,  gaugesToConsider[[idx]]]];
                If[scores[[idx]] === 10^501,
                    Message[STEvaluateEulerIntegral::membound, gaugesToConsider[[idx]]]];
            , {idx, Length[scores]}];

            scores = scores /. (10^501 -> 10^500);

            If[pass === 1 && methodPolysAndPairs === "Fast" && AllTrue[scores, # === Infinity &],
                Print["[NOLR fallback] No linearly-reducible order found for any gauge across all epsilon orders \[LongDash] truncating to the requested Order..."];
                methodPolysAndPairs = "Standard";
                Quiet@STClearDirectories[problemId];
                ,
                Break[]
            ];
            , {pass, 1, 2}];

            (* v1.0.420: see explanation at the mirror site in STEvaluateGraph. *)
            If[AllTrue[scores, # === Infinity &],
                Message[STEvaluateEulerIntegral::nolr];
                Throw[$Failed, "stEvalEulerExit"];
            ];
            If[AllTrue[scores, (# >= 10^500 || # === Infinity) &],
                Message[STEvaluateEulerIntegral::timebound];
                Throw[$Failed, "stEvalEulerExit"];
            ];

            bestGaugeIdx = Position[scores, Min[Select[scores, # < 10^500 &]]][[1, 1]];
            bestGauge    = gaugesToConsider[[bestGaugeIdx]];
            problemId    = problemIds[[bestGaugeIdx]];

            {pref, integrand, xvars, coeffs} = allIntegrands[[bestGaugeIdx]];
            Echo[{pref, integrand/(Times@@xvars), xvars, coeffs}, "Parametric integrand:"];
            Echo[scores /. 10^500 -> "\!\(\*SuperscriptBox[\(10\), \(500\)]\)",
                "Picking gauge " <> ToString[bestGauge] <>
                " from candidates " <> StringJoin[Riffle[ToString /@ gaugesToConsider, ", "]] <>
                ", scores"];

            (* Delete losing gauge directories to free disk/memory *)
            Module[{loserPids, matches},
                loserPids = Delete[problemIds, bestGaugeIdx];
                If[Length[loserPids] > 0,
                    If[vb, Print["  [OPT] Deleting ", Length[loserPids],
                                 " losing gauge director(ies) to free memory..."]];
                    Do[
                        matches = FileNames["integrands/" <> pid <> "_*"];
                        Quiet[DeleteDirectory[#, DeleteContents -> True]] & /@ matches;
                    , {pid, loserPids}];
                ];
            ];

            stSetUIStage[uiComms, "FindingLinearOrders", 7];
            Monitor[
                runQuietTimed[
                    STfindLinearlyReducibleOrders2[problemId,
                        Heuristic -> heuristicValue,
                        FindRoots -> findRootsValue,
                        "MethodLR" -> methodLRValue,
                        "ScanGauges" -> False,
                        "SkipExistingOrders" -> True,
                        "UIComms" -> uiComms
                    ],
                    verbose, showTimings, "Time taken to find the linear orderings:"
                ],
                "Working on linear orders..."
            ];

            ForgetProportionalPolynomialsQ[];
            STEchoLinearOrders[problemId];

            (* MethodPolysAndPairs: "Fast" -> "Standard" fallback if simple LR hit NOLR *)
            If[methodPolysAndPairs === "Fast" && stAnyFaceNOLR[problemId],
                Print["[NOLR fallback] No linearly-reducible order found for all epsilon orders \[LongDash] truncating to the requested Order..."];
                methodPolysAndPairs = "Standard";
                Quiet@STClearDirectories[problemId];
                runQuiet[
                    STsetupDirectoryExpansion[allExpansions[[bestGaugeIdx]], effectiveOrder, xvars, coeffs, problemId,
                        "MethodPolysAndPairs" -> "Standard"],
                    verbose
                ];
                Monitor[
                    runQuietTimed[
                        STfindLinearlyReducibleOrders2[problemId,
                            Heuristic -> heuristicValue,
                            FindRoots -> findRootsValue,
                            "MethodLR" -> methodLRValue,
                            "ScanGauges" -> False,
                            "UIComms" -> uiComms
                        ],
                        verbose, showTimings, "Time taken to find the linear orderings (fallback):"
                    ],
                    "Working on linear orders (fallback)..."
                ];
                ForgetProportionalPolynomialsQ[];
                STEchoLinearOrders[problemId];
            ];

            If[stopAt === "AfterLinearOrder",
                STSaveCheckpoint[problemId, <|
                    "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                    "XVars" -> xvars, "Coeffs" -> coeffs,
                    "Expansion" -> allExpansions[[bestGaugeIdx]],
                    "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt, "Timestamp" -> DateString[]|>];
                Return[<|"CheckpointID" -> problemId, "Result" -> ordersTEMP|>]
            ];

        ,
            (*NO-SCAN PATH (not homogeneous or ScanGauges->False)  *)
            conditionalEchoTiming[
                Echo[{pref, integrand/(Times@@xvars), xvars, coeffs}, "Parametric integrand:"];

                If[stopAt =!= "AfterBuildingIntegrand" && !MemberQ[{"AfterExpansion", "AfterLinearOrder"}, resumeFrom],
                    stSetUIStage[uiComms, "ExpandingIntegrands", 2];
                    expansion = runQuiet[STExpandIntegral[integrand, xvars, coeffs], verbose];
                    stSetUIStage[uiComms, "SettingUpDirectories", 3];
                    If[$STOverwritePreviousDirectories =!= False, Quiet@STClearDirectories[problemId]];
                    runQuiet[
                        STsetupDirectoryExpansion[expansion, effectiveOrder, xvars, coeffs, problemId,
                            "MethodPolysAndPairs" -> methodPolysAndPairs],
                        verbose
                    ]
                ];

            , showTimings, "Time taken to set up the integrands and directories:"];

            (* 2026-03-31: abort early if expansion failed *)
            If[expansion === $Aborted,
                Message[STEvaluateEulerIntegral::expansionfailed]; Return[$Aborted]];

            If[stopAt === "AfterBuildingIntegrand",
                STSaveCheckpoint[problemId, <|
                    "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                    "XVars" -> xvars, "Coeffs" -> coeffs, "Expansion" -> None,
                    "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt, "Timestamp" -> DateString[]|>];
                Return[{pref, integrand/(Times@@xvars), xvars, coeffs}]
            ];

            If[stopAt === "AfterExpansion",
                STSaveCheckpoint[problemId, <|
                    "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                    "XVars" -> xvars, "Coeffs" -> coeffs, "Expansion" -> expansion,
                    "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt, "Timestamp" -> DateString[]|>];
                Return[<|"CheckpointID" -> problemId, "Result" -> expansion|>]
            ];

            If[saveAllIntegrands =!= False,
                Put[
                    <|
                        "ProblemID"    -> problemId,
                        "Prefactor"    -> pref,
                        "Integrand"    -> integrand,
                        "XVars"        -> xvars,
                        "Coefficients" -> coeffs,
                        "Expansion"    -> expansion,
                        "Order"        -> effectiveOrder,
                        "Timestamp"    -> DateString[]
                    |>,
                    saveAllIntegrands
                ];
                Print["All integrands saved to: ", saveAllIntegrands];
            ];

            (* Skip linear-order finding when resuming past this stage *)
            stSetUIStage[uiComms, "FindingLinearOrders", 4];
            If[resumeFrom =!= "AfterLinearOrder",
                (* Mirror of STEvaluateGraph's pinned-gauge fix: the non-scan
                   LR search Abort[]s on the first NOLR face (ScanGauges->False,
                   SubTropica.wl ~14861), which would unwind past the "Fast" ->
                   "Standard" fallback below.  Trap it and, if still on "Fast",
                   rebuild under "Standard" and retry.  FindRoots is left at
                   findRootsValue here -- Automatic/True route algebraic letters
                   through stDispatchFubini2's own False->True cascade -- so,
                   unlike the graph branch (which resolves Automatic->False),
                   no separate FindRoots escalation is needed.  A genuine NOLR
                   under "Standard" re-aborts as before. *)
                If[CheckAbort[
                       Monitor[
                           runQuietTimed[
                               STfindLinearlyReducibleOrders2[problemId, Heuristic -> heuristicValue, FindRoots -> findRootsValue,
                                   "MethodLR" -> methodLRValue, "UIComms" -> uiComms],
                               verbose, showTimings, "Time taken to find the linear orderings:"
                           ],
                           "Working on linear orders..."
                       ];
                       False,
                       True
                   ],
                    If[methodPolysAndPairs =!= "Fast", Abort[]];
                    Print["[NOLR fallback] No linearly-reducible order for the no-scan integrand under \"Fast\" \[LongDash] retrying with MethodPolysAndPairs -> \"Standard\"..."];
                    methodPolysAndPairs = "Standard";
                    Quiet@STClearDirectories[problemId];
                    runQuiet[
                        STsetupDirectoryExpansion[expansion, effectiveOrder, xvars, coeffs, problemId,
                            "MethodPolysAndPairs" -> "Standard"],
                        verbose
                    ];
                    Monitor[
                        runQuietTimed[
                            STfindLinearlyReducibleOrders2[problemId, Heuristic -> heuristicValue, FindRoots -> findRootsValue,
                                "MethodLR" -> methodLRValue, "UIComms" -> uiComms],
                            verbose, showTimings, "Time taken to find the linear orderings (Standard fallback):"
                        ],
                        "Working on linear orders (Standard fallback)..."
                    ];
                ];
                ForgetProportionalPolynomialsQ[];
            ];

            STEchoLinearOrders[problemId];

            (* MethodPolysAndPairs: "Fast" -> "Standard" fallback if simple LR hit NOLR *)
            If[resumeFrom =!= "AfterLinearOrder" && methodPolysAndPairs === "Fast" && stAnyFaceNOLR[problemId],
                Print["[NOLR fallback] No linearly-reducible order found for all epsilon orders \[LongDash] truncating to the requested Order..."];
                methodPolysAndPairs = "Standard";
                Quiet@STClearDirectories[problemId];
                runQuiet[
                    STsetupDirectoryExpansion[expansion, effectiveOrder, xvars, coeffs, problemId,
                        "MethodPolysAndPairs" -> "Standard"],
                    verbose
                ];
                Monitor[
                    runQuietTimed[
                        STfindLinearlyReducibleOrders2[problemId, Heuristic -> heuristicValue, FindRoots -> findRootsValue,
                            "MethodLR" -> methodLRValue, "UIComms" -> uiComms],
                        verbose, showTimings, "Time taken to find the linear orderings (fallback):"
                    ],
                    "Working on linear orders (fallback)..."
                ];
                ForgetProportionalPolynomialsQ[];
                STEchoLinearOrders[problemId];
            ];

            If[stopAt === "AfterLinearOrder",
                STSaveCheckpoint[problemId, <|
                    "ProblemID" -> problemId, "Pref" -> pref, "Integrand" -> integrand,
                    "XVars" -> xvars, "Coeffs" -> coeffs, "Expansion" -> expansion,
                    "OrderValue" -> effectiveOrder, "OutputOrder" -> outputOrder, "StopAt" -> stopAt, "Timestamp" -> DateString[]|>];
                Return[<|"CheckpointID" -> problemId, "Result" -> ordersTEMP|>]
            ];
        ];

        stSetUIStage[uiComms, "SettingUpKernels", If[doScan, 8, 5]];
        conditionalEchoTiming[
            STSetupKernel[OptionValue["KernelsAvailable"]];
        , showTimings, "Time taken to set up the kernels:"];

        stSetUIStage[uiComms, "Integrating", If[doScan, 9, 6]];
        stUpdateUIComms[uiComms, "JobTrackingDir", $STJobTrackingDir];
        Monitor[
            runQuietTimed[
                STLaunchHyperIntica[problemId,
                    "Strategy"                   -> OptionValue["Parallelization"],
                    "ShowIntegrands"             -> showIntegrands,
                    "ClearCachesPerIntegrand"    -> OptionValue["ClearCachesPerIntegrand"],
                    "ClearCachesMemoryThreshold" -> OptionValue["ClearCachesMemoryThreshold"],
                    "SelectFaces"                -> OptionValue["SelectFaces"],
                    "ReuseExistingResults"       -> OptionValue["ReuseExistingResults"],
                    "UIComms"                    -> uiComms,
                    "Integrator"                 -> OptionValue["Integrator"]
                ],
                verbose, showTimings, "Time taken to integrate:"
            ],
            monitorDisplay
        ];

        (* Mirror STEvaluateGraph:15211: clear HyperIntica memoization caches on
           main kernel and subkernels after integration.  Cache hits on later
           runs would return cached expressions containing Wm[i]/Wp[i] atoms
           without re-firing the letter-minting side effect, leaving
           $HyperAlgebraicLetterTable empty and GetAlgebraicBackSubRules[] broken. *)
        ForgetAllMemo[];
        ParallelEvaluate[ForgetAllMemo[]];

        stSetUIStage[uiComms, "CollectingResults", If[doScan, 10, 7]];
        (* Construct answer \[LongDash] each step wrapped so we can tell which one
           stalls on pathological inputs. *)
        stStageTime["STReadResults", pref runQuiet2[STReadResults[problemId], verbose]] //
            stStageTime["Total", Total[#]] & //
            stStageTime["Series-1", Series[#, {eps, 0, outputOrder}]] & //
            stStageTime["zeta->mzv", # /. zeta -> mzv] & //
            stStageTime["Collect+SimplifyOutput",
                Collect[Normal[#], eps^___, OptionValue["SimplifyOutput"]]] & //
            stStageTime["CleanZeroInf",
                If[OptionValue["CleanOutput"] =!= False, CleanZeroInf[#], #]] & //
            stStageTime["Series-2", Series[#, {eps, 0, outputOrder}]] & //
            (* v1.0.443: drop bonus coefficients above outputOrder.
               When a Gamma(\[Omega]) prefactor pole cancels (e.g. squared-ISP
               numerators with \[Nu]_tot \[LessEqual] 0), the true leading order of the
               integral can be at \[CurlyEpsilon]^m with m > outputOrder.  Mathematica's
               Series returns that \[CurlyEpsilon]^m coefficient anyway, but STIntegrate
               only computed the parametric integrand through
               \[CurlyEpsilon]^(outputOrder + poleGamma) which is (m - outputOrder) orders
               short of what a correct \[CurlyEpsilon]^m needs.  Reporting it would be an
               accuracy lie.  Strictly truncate to outputOrder; if the series
               starts above outputOrder, return an empty-sentinel SeriesData
               so callers know "0 up through outputOrder, higher not tracked". *)
            stStageTime["stWrapRootSubs", stWrapRootSubs[#]] & //
            (* v1.0.443: if the reported series starts at \[CurlyEpsilon]^nmin with nmin >
               outputOrder, Mathematica's Series left a "bonus" leading
               coefficient that STIntegrate only partially computed (the
               parametric integrand was truncated at \[CurlyEpsilon]^(outputOrder+poleGamma),
               not at \[CurlyEpsilon]^(nmin+poleGamma) that the accurate bonus coefficient
               would require).  Strip it: emit an empty-sentinel SeriesData
               meaning "zero through \[CurlyEpsilon]^outputOrder, nothing tracked higher". *)
            stStageTime["TruncateOutput",
                If[Head[#] === SeriesData && #[[4]] > outputOrder && #[[3]] =!= {},
                    SeriesData[eps, 0, {}, outputOrder + 1, outputOrder + 1, 1],
                    #]] &

    , showTimings, "Overall timing:"]];

    (* Save slowest integrand if requested *)
    If[saveSlowestIntegrand =!= False,
        slowestJob = STFindSlowestJob[];
        If[slowestJob =!= None,
            Put[slowestJob, saveSlowestIntegrand];
            Print["Slowest integrand saved to: ", saveSlowestIntegrand];
            Print["  Duration: ", slowestJob["Duration"], " seconds"];
            Print["  Face: ", slowestJob["Face"]];
            Print["  Counter term ID: ", slowestJob["CtId"]];
        ,
            Print["Warning: Could not find slowest integrand data."];
        ];
    ];

    stSetUIStage[uiComms, "Done", If[doScan, 10, 7]];
    (* Guarantee SeriesData output: if the assembly pipeline did not produce
       a SeriesData (e.g. eps-free result), wrap it now. *)
    result = If[Head[result] =!= SeriesData && Head[result] =!= Hold && !AssociationQ[result] && IntegerQ[outputOrder] && FreeQ[result, eps],
        SeriesData[eps, 0, {result}, 0, outputOrder + 1, 1],
        result
    ];

    (* Populate $integrationResult so STSubmitResult[] works from notebook *)
    $integrationResult = <|
        "uiResult" -> <|
            "nickelIndex" -> Quiet @ Check[computeNickelIndex[$efl, $n0r, $intm, $extm], ""],
            "Dimension" -> ToString[OptionValue["Dimension"], InputForm],
            "Order" -> outputOrder,
            "propExponents" -> $propExponents,
            "propagators" -> If[Length[$edgeMomenta] == $ne,
                Table[ToString[$edgeMomenta[[i]]^2 - $intm[[i]]^2, InputForm], {i, $ne}],
                {}],
            "numerators" -> If[ListQ[numeratorsParsed] && Length[numeratorsParsed] > 0,
                {ToString[#[[1]], InputForm], #[[2]]} & /@ ({numeratorsParsed, numeratorExponents}\[Transpose]),
                {}],
            "Substitutions" -> OptionValue["Substitutions"],
            "Normalization" -> OptionValue["Normalization"],
            "edges" -> Table[{$efl[[i]], $intm[[i]]}, {i, $ne}],
            "nodes" -> Table[{$n0r[[i]], $extm[[i]]}, {i, $nl}],
            "internalMasses" -> Select[$intm, # =!= 0 && # =!= 0. &],
            "externalMasses" -> Select[$extm, # =!= 0 && # =!= 0. &]
        |>,
        "result" -> result
    |>;

    stEchoAlgebraicLettersSummary[result];

    result
], "stEvalEulerExit"]


(* ::Subsection::Closed:: *)
(*Variant: Propagators*)


(* This is a wrapper using the new propagator symmanzik code: *)
Clear[STEvaluateGraphFromPropagators];
Options[STEvaluateGraphFromPropagators] = DeleteDuplicates @ Join[
    Options[STSymanzik],
    Options[STEvaluateEulerIntegral],
    {"Gauge" -> Automatic}
];

STEvaluateGraphFromPropagators[propagators_List, opts:OptionsPattern[]] :=
    Module[{normalization, symResult, norm, gaugeOpt, gaugeRule, integ, xv, eulerOpts},
    normalization = OptionValue["Normalization"];
    symResult = STSymanzik[propagators, FilterRules[{opts}, Options[STSymanzik]]];
    (* Scaleless integral: STSymanzik returns 0 *)
    If[symResult === 0,
      Print["[SubTropica] Scaleless integral \[LongDash] vanishes in dimensional regularization."];
      Return[SeriesData[eps, 0, {}, 0, 1, 1]]];
    (* Validation failure: STSymanzik's guards return $Failed (or Null from
       older bare Return[] branches). Either way, symResult[[2]] would crash
       with Part::partd, so bail out here with a clear failure value. *)
    If[!MatchQ[symResult, {_, _, _List, _}],
      Return[$Failed]];
    (* STSymanzik returns integrand in internal convention (includes Times@@xvars measure factor).
       Divide by Times@@xvars to convert to user-facing convention before passing to
       STEvaluateEulerIntegral, which multiplies by Times@@xvars at its input boundary. *)
    norm = If[normalization === Automatic, Exp[LLinternal * eps * EulerGamma], normalization];
    integ = symResult[[2]] / (Times @@ symResult[[3]]);
    xv = symResult[[3]];

    (* Handle explicit "Gauge" -> {xi -> 1}: apply substitution, remove variable, disable scan *)
    gaugeOpt = OptionValue["Gauge"];
    If[MatchQ[gaugeOpt, {(_ -> 1) ..}],
        gaugeRule = gaugeOpt;
        integ = integ /. gaugeRule;
        xv = DeleteCases[xv, Alternatives @@ (First /@ gaugeRule)];
        eulerOpts = Join[
            DeleteCases[FilterRules[{opts}, Options[STEvaluateEulerIntegral]], "Gauge" -> _],
            {"ScanGauges" -> False}
        ];
    ,
        eulerOpts = FilterRules[stTranslateGaugeOpt[{opts}], Options[STEvaluateEulerIntegral]];
    ];

    Return[
        STEvaluateEulerIntegral[
            {norm * symResult[[1]], integ, xv, symResult[[4]]},
            eulerOpts
        ]
    ]
]


(* ::Subsection::Closed:: *)
(*Global*)


(* \[HorizontalLine]- STEvaluate
   Universal entry point.  Inspects its first argument(s) and dispatches to the
   appropriate STEvaluate* function, forwarding all options automatically.

   Supported calling conventions:

     STEvaluate[propagators, opts]
           propagators - list of inverse propagators (q^2 - m^2), e.g. {q[1]^2, (q[1]-p[1])^2 - m^2}
                         kinematics via "Substitutions"->{...}, dimension via "Dimension"->4-2eps
           \[RightArrow] dispatches to STEvaluateGraphFromPropagators 
         \[RightArrow] dispatches to STEvaluateGraphFromPropagators

     STEvaluate[{pref, integrand, xvars, coeffs}, opts]
         A pre-built parametric integrand tuple (output of STBuildIntegrandFromPropagators).
         Identified by the 3rd element being a List (the Schwinger-variable list).
         \[RightArrow] dispatches to STEvaluateEulerIntegral

     STEvaluate[graph, opts]
         A graph topology in the STEvaluateGraph edges-nodes format, or a Mathematica
         Graph object.  Catches everything not matched by the two forms above.
         \[RightArrow] dispatches to STEvaluateGraph
*)

Clear[STEvaluate];
Options[STEvaluate] = DeleteDuplicates @ Join[
    Options[STEvaluateGraph],
    Options[STEvaluateGraphFromPropagators]
    (* STEvaluateEulerIntegral options are already covered via STEvaluateGraphFromPropagators *)
];

(* Form 1: propagator notation; two lists followed by a numerator *)
 STEvaluate[propagators_List, opts:OptionsPattern[]] :=
      STEvaluateGraphFromPropagators[
          propagators,
          FilterRules[{opts}, Options[STEvaluateGraphFromPropagators]]
      ];

(* Form 2: pre-built Euler integrand tuple {pref, integrand, xvars_List, coeffs} *)
(* integrand is in user-facing convention (measure dx); STEvaluateEulerIntegral multiplies by Times@@xvars internally *)
STEvaluate[{prefArg_, integrandArg_, xvarsArg_List, coeffsArg_}, opts:OptionsPattern[]] :=
    STEvaluateEulerIntegral[
        {prefArg, integrandArg, xvarsArg, coeffsArg},
        FilterRules[{opts}, Options[STEvaluateEulerIntegral]]
    ];

(* Form 2b: same tuple with a checkpoint ID appended as 5th element; resumes from that checkpoint *)
(* integrand is in user-facing convention (measure dx); STEvaluateEulerIntegral multiplies by Times@@xvars internally *)
STEvaluate[{prefArg_, integrandArg_, xvarsArg_List, coeffsArg_, checkpointId_String}, opts:OptionsPattern[]] :=
    STEvaluateEulerIntegral[
        {prefArg, integrandArg, xvarsArg, coeffsArg},
        "StartAt" -> checkpointId,
        FilterRules[{opts}, Options[STEvaluateEulerIntegral]]
    ];

(* Form 3: graph topology; {edges_List, vertices_List} edges-nodes format *)
STEvaluate[g:{_List, _List}, opts:OptionsPattern[]] :=
    STEvaluateGraph[
        g,
        FilterRules[{opts}, Options[STEvaluateGraph]]
    ];

STEvaluate::badinput = StringJoin[
    FromCharacterCode[128680], " HEY YOU! ILLEGAL INPUT DETECTED! THE POLICE IS COMING FOR YOU. ", FromCharacterCode[128680], "\n",
    "Input format not recognized. STEvaluate accepts:\n",
    "  (1) STEvaluate[loops, props, numerator, opts]; propagator notation, e.g. STEvaluate[{q[1]}, {-q[1]^2, -(q[1]-p[1])^2}, 1]\n",
    "  (2) STEvaluate[{pref, integrand, xvars, coeffs}, opts]; pre-built parametric integrand tuple\n",
    "  (3) STEvaluate[{edges, vertices}, opts]; graph topology in SOFIA edges-nodes format"
];

STEvaluate[___] := Message[STEvaluate::badinput];


(* \[HorizontalLine]- STIntegrate
   User-facing entry point.  Inspects its arguments and dispatches to the
   appropriate internal function.

   Supported calling conventions:

     STIntegrate[]
           \[RightArrow] launches the interactive Feynman diagram GUI (SubTropica)

     STIntegrate[{edges, nodes}, opts]
           \[RightArrow] dispatches to STEvaluateGraph

     STIntegrate[propagators_List, opts]
           \[RightArrow] dispatches to STEvaluateGraphFromPropagators

     STIntegrate[{pref, integrand, xvars_List, coeffs}, opts]
           \[RightArrow] dispatches to STEvaluateEulerIntegral

     STIntegrate[integrand, {x,0,1}, {y,0,Infinity}, ..., opts]
           Mathematica-style integration limits.
           \[RightArrow] dispatches to STEvaluateEulerIntegral with prefactor = 1
              and automatically extracted coefficients.

     STIntegrate[integrand, x, y, ..., opts]
           Bare symbols default to bounds {0, Infinity}.
           \[RightArrow] same as above
*)

Clear[STIntegrate];
Options[STIntegrate] = DeleteDuplicates @ Join[
    Options[STEvaluateGraph],
    Options[STEvaluateGraphFromPropagators]
    (* STEvaluateEulerIntegral options are already covered via STEvaluateGraphFromPropagators *)
];


(* Valid option values for all STIntegrate options *)
$STOptionValues = <|
    "Order"                  -> {Automatic, "integer n = expand through eps^n"},
    "StopAt"                 -> {Automatic, "AfterBuildingIntegrand", "AfterExpansion", "AfterLinearOrder", "AfterMinimalLRCheck", "AfterMinimalLRCheckOneShot"},
    "StartAt"                -> {None, "checkpoint ID string"},
    "Gauge"                  -> {Automatic, "{x1 -> 1}", "{}  (no gauge)"},
    "IncludeGauges"          -> {All, "{1, 2, ...}  (list of gauge indices)"},
    "Verbose"                -> {True, False},
    "ShowTimings"            -> {True, False},
    "ShowIntegrands"         -> {True, False},
    "SaveSlowestIntegrand"   -> {True, False},
    "SaveAllIntegrands"      -> {False, "filename string"},
    "SetProblemID"           -> {Automatic, "string"},
    "Parallelization"        -> {All, "BruteForce", "PartialIntegrands"},
    "KernelsAvailable"       -> {"0 or 1 = fully serial (no subkernels)", "integer >= 2 (default: $ProcessorCount - 1)"},
    "SimplifyOutput"         -> {Simplify, FullSimplify, Identity},
    "Heuristic"              -> {"LeafCountLinear", "LeafCountRMS", "LeafCountPlusDegree", "LeafCountTimesTerms"},
    "ScanScoreInterval"      -> {"{min, max}  (default: {1, 3})"},
    "ScoreInParallel"        -> {All, "integer"},
    "TimeUpperBound"         -> {"integer (default: 10^17)"},
    "MemoryPercentCutOff"    -> {None, "number 0-100"},
    "ScoringMemoryFraction"  -> {"number 0-1 (default: 0.5)"},
    "SetupInParallel"        -> {Automatic, "1 = serial", "integer n > 1 = n parallel batches"},
    "ClearCachesPerIntegrand"-> {True, False},
