                old_parsed = review_waitlist_config_from_path(old_rel)
                new_parsed = review_waitlist_config_from_path(new_rel)
                old_was_waitlisted = False
                if old_parsed is not None:
                    old_was_waitlisted = review_waitlist_contains(old_parsed[0], old_parsed[1])
                    if not staying_records:
                        review_remove_from_waitlist(old_parsed[0], old_parsed[1])
