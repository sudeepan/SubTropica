stPySecDecEvaluate[integralData_Association, opts:OptionsPattern[STToPySecDec]] :=
Module[{cacheDir, hash, pkgDir, pkgName, soPath, kinPoint, kinValues,
	epsrel, maxeval, maxTime, verbose, script, scriptPath, proc, stdout, stderr,
	jsonResult, valStr, errStr, result, resultErr, realParamSymbols, realParamNames,
	missingParams},

	verbose = TrueQ[OptionValue[STToPySecDec, {opts}, "Verbose"]];
	epsrel = OptionValue[STToPySecDec, {opts}, "Accuracy"];
	maxeval = OptionValue[STToPySecDec, {opts}, "MaxEval"];
	kinPoint = OptionValue[STToPySecDec, {opts}, "KinematicPoint"];
	(* Resolve MaxTime: Automatic -> 3600 s (legacy default); Infinity -> no
	   cap (Python: signal.alarm(0) and subprocess.run(timeout=None));
	   explicit number -> seconds.  Same value applied to every timer in
	   the generated script. *)
	maxTime = OptionValue[STToPySecDec, {opts}, "MaxTime"];
	If[maxTime === Automatic, maxTime = 3600];

	If[stRequireTool["python3"] === $Failed, Return[$Failed]];

	realParamSymbols = integralData["realParamSymbols"];
	realParamNames = integralData["realParamNames"];

	If[kinPoint === {} && Length[realParamSymbols] > 0,
		Message[STToPySecDec::nokin, StringRiffle[ToString /@ realParamSymbols, ", "]];
		Return[$Failed]
	];

	missingParams = Select[realParamSymbols, FreeQ[kinPoint, # -> _] &];
	If[Length[missingParams] > 0,
		Message[STToPySecDec::missingkin, StringRiffle[ToString /@ missingParams, ", "]];
		Return[$Failed]
	];

	kinValues = realParamSymbols /. kinPoint;
	If[!AllTrue[kinValues, NumericQ],
		Message[STToPySecDec::missingkin,
			StringRiffle[ToString /@ Pick[realParamSymbols, Not /@ (NumericQ /@ kinValues)], ", "]];
		Return[$Failed]
	];
	kinValues = N /@ kinValues;

	cacheDir = OptionValue[STToPySecDec, {opts}, "CacheDirectory"];
	If[cacheDir === Automatic,
		(* Avoid naming the cache directory "pySecDec": on Python 3.14 with
		   PEP-420 namespace packages, a script run from inside a folder
		   whose parent is literally named "pySecDec" lets that parent
		   shadow the site-packages pySecDec install (which itself is a
		   namespace package with __file__ = None, so the local folder
		   "wins").  Result: "ModuleNotFoundError: No module named
		   'pySecDec'" even though the package is installed. *)
		cacheDir = FileNameJoin[{$SubTropicaInstallDir, "pysecdec_cache"}]
	];

	hash = IntegerString[Hash[integralData["topology"], "SHA256"], 16, 12];
	(* Use CNI-based directory name when available, else fall back to hash;
	   append a Dimension tag so different D values keep separate compiled
	   packages (before the fix, switching D silently reused a stale .so). *)
	Module[{dirName, cni = Lookup[integralData, "name", None],
	        dimTag = stDimDirTag[Lookup[integralData, "dimension", 4 - 2 eps]]},
		dirName = If[StringQ[cni],
			StringReplace[cni, {"|" -> "_", ":" -> "__"}],
			hash] <> "__" <> dimTag;
		pkgName = "integral";
		pkgDir = FileNameJoin[{cacheDir, dirName}];
		soPath = FileNameJoin[{pkgDir, pkgName, pkgName <> "_pylink.so"}];
	];

	(* Cache validation: if pkgDir already exists with a compiled .so,
	   verify that the cached integral matches the current call.  The
	   directory name (CNI) can collide if computeNickelIndex was buggy
	   in earlier runs, so we store a sidecar metadata file on build and
	   compare it on every hit.  Mismatch -> wipe and rebuild.
	   Dimension is part of the hash so any D change forces a rebuild
	   even when the dir name happens to match. *)
	Module[{metaPath, metaFile, currentMeta, cachedMeta, hashOfTopology},
		metaPath = FileNameJoin[{pkgDir, "subtropica_meta.json"}];
		hashOfTopology = IntegerString[
			Hash[{integralData["topology"], integralData["powers"],
			      integralData["normalization"], integralData["order"],
			      integralData["dimension"]},
			     "SHA256"], 16];
		currentMeta = <|
			"name" -> ToString[Lookup[integralData, "name", "?"]],
			"topologyHash" -> hashOfTopology,
			"dimension" -> ToString[Lookup[integralData, "dimension", "?"]],
			"nLoops" -> integralData["nLoops"],
			"nEdges" -> integralData["nEdges"],
			"stVersion" -> $SubTropicaVersion|>;
		If[FileExistsQ[soPath] && FileExistsQ[metaPath],
			cachedMeta = Quiet @ Check[Import[metaPath, "RawJSON"], $Failed];
			If[!AssociationQ[cachedMeta] ||
			   Lookup[cachedMeta, "topologyHash", ""] =!= hashOfTopology,
				If[verbose, Print["[STToPySecDec] cache mismatch at ", pkgDir,
					" -- wiping and rebuilding"]];
				Quiet[DeleteDirectory[pkgDir, DeleteContents -> True]]]];
		(* Always (re)write the metadata so subsequent hits validate. *)
		Quiet[CreateDirectory[pkgDir, CreateIntermediateDirectories -> True]];
		Export[metaPath, currentMeta, "RawJSON"]];

	Module[{integrator = OptionValue[STToPySecDec, {opts}, "Integrator"]},
	script = stBuildPySecDecScript[integralData, soPath, pkgDir, pkgName,
		kinValues, epsrel, maxeval, verbose, integrator, maxTime];
	];

	scriptPath = FileNameJoin[{pkgDir, "eval.py"}];
	Quiet[CreateDirectory[pkgDir, CreateIntermediateDirectories -> True]];
	Export[scriptPath, script, "Text"];

	If[verbose, Print["[STToPySecDec] Running pySecDec (cache: ", hash, ")..."]];

	proc = RunProcess[{$PythonCommand, scriptPath}];

	stderr = proc["StandardError"];
	stdout = proc["StandardOutput"];

	If[verbose && StringLength[stderr] > 0,
		Print["[STToPySecDec] stderr: ", StringTake[stderr, UpTo[500]]]
	];

	If[proc["ExitCode"] =!= 0,
		Which[
			proc["ExitCode"] === 2, Message[STToPySecDec::buildfail],
			proc["ExitCode"] === 3, Message[STToPySecDec::evalfail,
				"Evaluation timed out (" <> ToString[maxTime] <> "s)"],
			True, Message[STToPySecDec::pythonfail, proc["ExitCode"], StringTake[stderr, UpTo[200]]]
		];
		Return[$Failed]
	];

	Module[{resultLine, jsonStr},
		resultLine = SelectFirst[StringSplit[stdout, "\n"],
			StringStartsQ[#, "PYSECDEC_RESULT:"] &, ""];
		If[resultLine === "",
			Message[STToPySecDec::evalfail, "No result marker in output: " <> StringTake[stdout, UpTo[200]]];
			Return[$Failed]
		];
		jsonStr = StringDrop[resultLine, StringLength["PYSECDEC_RESULT:"]];
		jsonResult = Quiet[Check[ImportString[jsonStr, "RawJSON"], $Failed]];
	];
	If[jsonResult === $Failed,
		Message[STToPySecDec::evalfail, "Could not parse JSON: " <> StringTake[stdout, UpTo[200]]];
		Return[$Failed]
	];

	valStr = jsonResult["value"];
	errStr = jsonResult["error"];

	result = ToExpression[valStr, InputForm];
	resultErr = ToExpression[errStr, InputForm];

	{result, resultErr}
];


(* ::Subsection::Closed:: *)
(*STVerify: numerical verification of library entries*)


STVerify::usage =
"STVerify[cni_String, opts] verifies a stored library entry by comparing its symbolic result to a fresh numerical evaluation.
STVerify[{edges, nodes}, result, opts] verifies a user-supplied graph against a symbolic Laurent series.
STVerify[props, result, opts] verifies from a propagator list (no graph).
STVerify[{pref, integrand, xvars, coeffs}, result, opts] verifies from a pre-built Euler integrand quadruple (pySecDec only).
STVerify[{pref, integrand, xvars, coeffs, checkpoint_String}, result, opts] same as above with a checkpointed Disteval run.
Scalar products of momenta in propagators may be written as p*q, p\[CenterDot]q (CenterDot), or p.q (Dot).
\"Dimension\" defaults to the library entry's stored dimension when verifying by CNI, or to 4 - 2 eps otherwise; an explicit \"Dimension\" -> ... option overrides both.";

STVerify::noentry = "No library entry found for CNI `1` with a stored result.";
STVerify::decomp = "Could not decompress result for `1`.";
STVerify::psdFail = "STToPySecDec failed for `1`.";
STVerify::ginshFail = "STToGinsh evaluation failed for `1`.";
STVerify::backend = "STNIntegrate returned no numeric result for `1` (method=`2`).";
STVerify::badinput = "Input format not recognized. STVerify accepts: CNI string | {edges, nodes} + result | propagator list + result | {pref, integrand, xvars, coeffs} + result | {pref, integrand, xvars, coeffs, checkpoint} + result.";
STVerify::feyntropPoles = "feyntrop only verifies finite integrals (eps^0-leading); `1` has 1/eps poles. Use pySecDec, FIESTA, or AMFlow for divergent integrals.";

Options[STVerify] = {
