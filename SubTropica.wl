(* Face-selection helpers *)

(* Parse {epsOrder, faceIndex} integers from a face directory path of the form
   .../ord_<epsOrder>_face_<faceIndex> *)
Clear[STParseFaceDirectory];
STParseFaceDirectory[dir_String] :=
    {
        ToExpression @ StringReplace[dir, {___ ~~ "ord_" ~~ a___ ~~ "_face" ~~ ___ :> a}],
        ToExpression @ Last @ StringSplit[dir, "_face_"]
    }

(* Check whether {epsOrder, faceIndex} passes a SelectFaces filter.
   Supported filter forms:
     All              - always True
     i_Integer        - True if faceIndex == i (any eps order)
     (o -> i)         - True if epsOrder == o AND faceIndex == i  [Rule syntax, unambiguous]
     list_List        - True if any element matches; elements may be integers or (o->i) rules
     Except[inner]    - True if inner would be False; works with any of the above
   Note: a plain list {2, 3} always means face indices 2 and 3 (at all eps orders).
         Use (0 -> 2) to target face 2 at eps order 0 specifically! *)
Clear[STFaceMatchesFilterQ];
STFaceMatchesFilterQ[{_Integer, _Integer}, All] := True
STFaceMatchesFilterQ[face:{_Integer, _Integer}, e_Except] :=
    Not[STFaceMatchesFilterQ[face, First[e]]]
STFaceMatchesFilterQ[{_Integer, fi_Integer}, i_Integer] :=
    fi === i
STFaceMatchesFilterQ[{eo_Integer, fi_Integer}, Rule[o_Integer, i_Integer]] :=
    eo === o && fi === i
STFaceMatchesFilterQ[face:{_Integer, _Integer}, list_List] :=
    AnyTrue[list, STFaceMatchesFilterQ[face, #] &]

(* Filter a list of face directory triples {faceId, epsOrder, fullPath}
   (as returned by STListDirectoriesNP2) by a SelectFaces filter. *)
Clear[STFilterFaceDirectories];
STFilterFaceDirectories[dirs_List, All] := dirs
STFilterFaceDirectories[dirs_List, selectFaces_] :=
    Select[dirs, STFaceMatchesFilterQ[STParseFaceDirectory[#[[3]]], selectFaces] &]

(* Return True iff faceDir already has a successfully completed integration on disk
   (both result.m and successQ.m exist, and successQ.m contains True). *)
Clear[STFaceHasResultQ];
STFaceHasResultQ[faceDir_String] := Module[{sq},
    If[Not[FileExistsQ[faceDir <> "/result.m"]] ||
       Not[FileExistsQ[faceDir <> "/successQ.m"]],
        Return[False]
    ];
    sq = Quiet[Get[faceDir <> "/successQ.m"]];
    TrueQ[sq]
]


