(* Human-readable time formatting: 0.3s / 12.4s / 3m 24s / 1h 12m *)
stFormatTime[seconds_?NumericQ] := Which[
  seconds < 0.01, "< 0.01s",
  seconds < 60,   ToString[NumberForm[N[seconds], {4, 1}]] <> "s",
  seconds < 3600,
    Module[{m = Floor[seconds / 60], s = Mod[Round[seconds], 60]},
      ToString[m] <> "m " <> ToString[s] <> "s"],
  True,
    Module[{h = Floor[seconds / 3600], m = Floor[Mod[seconds, 3600] / 60]},
      ToString[h] <> "h " <> ToString[m] <> "m"]
];
stFormatTime[_] := "?";

(* Dynamic timing display for PrintTemporary *)
stFormatTimeDynamic[start_] := Dynamic[
  Module[{dt = AbsoluteTime[] - start},
    Which[dt < 60, Row[{"Time elapsed: ", NumberForm[dt, {4, 1}], "s"}],
      dt < 3600, Row[{"Time elapsed: ", Floor[dt/60], "m ", Mod[Round[dt], 60], "s"}],
      True, Row[{"Time elapsed: ", Floor[dt/3600], "h ", Floor[Mod[dt, 3600]/60], "m"}]]],
  UpdateInterval -> 1];

(* For timing: *)
SetAttributes[timed, HoldAll]
timed[expr_] := With[{start = AbsoluteTime[]},
  PrintTemporary @ stFormatTimeDynamic[start];
  expr]

SetAttributes[conditionalEchoTiming, HoldFirst];
conditionalEchoTiming[expr_, True, label_] := Module[{result, dt},
  dt = First[AbsoluteTiming[result = expr]];
  Echo[stFormatTime[dt], label];
  (* Machine-readable timing marker for the UI's Timings tab. The existing
     Echo stays for notebook users; this extra Print is only emitted when
     an integrate-handler UIComms session is live, and it's picked up by
     the InheritedBlock Print redirect as a "[timing] <seconds> <label>"
     record in progress.jsonl. *)
  If[AssociationQ[$stUIComms],
    Print["[timing] ", dt, " ", label]];
  result];
conditionalEchoTiming[expr_, False, _] := expr;

SetAttributes[runQuiet, HoldFirst];
runQuiet[expr_, True] := expr;
runQuiet[expr_, False] := Module[{result},
    (* Block Print on parallel kernels *)
    Quiet @ ParallelEvaluate[
        Unprotect[Print];
        Print = (Null &)
    ];
    (* Block Print on main kernel, execute expression *)
    result = Block[{Print = (Null &)}, expr];
    (* Restore Print on parallel kernels *)
    Quiet @ ParallelEvaluate[
        Unprotect[Print];
        ClearAll[Print]
    ];
    result
]

SetAttributes[runQuiet2, HoldFirst];
runQuiet2[expr_, True] := expr;
runQuiet2[expr_, False] := Block[{$Output = {}}, expr];

SetAttributes[runQuietTimed, HoldFirst];
runQuietTimed[expr_, verbose_, showTimings_, label_] :=
    conditionalEchoTiming[runQuiet[expr, verbose], showTimings, label];

(* stStageTime[label, expr]: stopwatch wrapper for the post-integration
   pipeline.  Evaluates `expr` (held until the Module body fires so the
   clock starts AFTER the previous stage finished) and prints a per-stage
   timing line whenever the stage takes >= 0.1 s, so fast steps stay silent.
   Meant for the //-chain in STEvaluateGraph / STEvaluateEulerIntegral that
   happens right after HyperIntica returns (`STReadResults`, `Series`,
   `Collect+Simplify`, `CleanZeroInf`, `stWrapRootSubs`).  When an entry
   silently stalls for hours we can then see which stage is the culprit. *)
SetAttributes[stStageTime, HoldRest];
stStageTime[label_String, expr_] := Module[{t0 = SessionTime[], r, dt, bc},
    r = expr;
    dt = SessionTime[] - t0;
    (* WriteString[stdout] bypasses Print's $Output redirection, so timing
       lines still appear when this wrapper fires inside a runQuiet2 /
       Block[{$Output={}}] scope (e.g. STReadResults under verbose=False).
       When $stPostStageInstrumentation is True we also report the
       ByteCount of the output so the caller can tell whether a slow
       stage actually simplified the expression or just churned. *)
    (* Quiet by default: only emit the stall line when the user has opted
       in via $stPostStageInstrumentation, or when a stage has taken long
       enough (>= 60 s) that a true pipeline stall is likely. The previous
       0.1 s floor caught every normal post-processing stage and made the
       log noisy on every STIntegrate run. *)
    If[TrueQ[$stPostStageInstrumentation] || dt >= 60,
        bc = Quiet @ Check[ByteCount[r], -1];
        WriteString["stdout",
            "  [post] ", label, " : ", Round[dt, 0.01], " s",
            "  (out ByteCount=", ToString[bc], ")\n"]];
    r];

If[!ValueQ[$stPostStageInstrumentation], $stPostStageInstrumentation = False];


(* stWrapRootSubs[series]: normalize an eps-free scalar up to SeriesData and
   return the series as-is. Wm[i]/Wp[i] algebraic letters from FindRoots stay
   as atoms in the returned expression; their back-substitution metadata
   lives in $stRootSubstitutions (populated by STReadResults) and in the
   structured `algebraicLetters` record persisted at save time.
   Before v1.0.389 this function wrapped the series in
       Hold[series /. {Wm[i] -> ..., Wp[i] -> ...}]
   to ship the substitution alongside the expression. That coupling made the
   downstream alphabet, TeX, and normalized-symbol paths see a Hold blob
   instead of the Wm/Wp letters, so they silently fell back to an empty
   alphabet or baked the Sqrt forms in on ReleaseHold. With Wm/Wp kept as
   atoms, stSymbolToTeX / stComputeNormalizedSymbolFields can now emit
   W^{\pm}_i directly. *)
stWrapRootSubs[series_] := If[
    Head[series] =!= SeriesData && FreeQ[series, eps],
    SeriesData[eps, 0, {series}, 0, 1, 1],
    series];


(* stEchoAlgebraicLettersSummary[result]: print a short summary at the end of
   STIntegrate / STEvaluateGraph listing the Wm[i]/Wp[i] pairs that survived
   into `result`.  No-op when no letters appear.  Raw Wm[i]/Wp[i] notation
   is used in all kernel outputs; subscripted W^{\pm}_i rendering lives only
   in the UI. *)
stEchoAlgebraicLettersSummary[result_] := Module[
    {indices, rec, poly, var, wmVal, wpVal},
    indices = Union @ Cases[result, (Wm | Wp)[i_Integer] :> i, Infinity];
    If[indices === {} || !AssociationQ[$HyperAlgebraicLetterTable],
        Return[Null]];
    Print["[FindRoots] ", Length[indices],
          " algebraic letter pair", If[Length[indices] === 1, "", "s"],
          " in the result:"];
    Do[
        rec   = Lookup[$HyperAlgebraicLetterTable, i, <||>];
        If[!AssociationQ[rec], Continue[]];
        poly  = rec["Polynomial"];
        var   = rec["Variable"];
        wmVal = rec["WmValue"];
        wpVal = rec["WpValue"];
        Print["  Wm[", i, "], Wp[", i,
              "]   roots of   ", poly, " == 0   in   ", var];
        Print["    Wm[", i, "] = ", wmVal];
        Print["    Wp[", i, "] = ", wpVal],
        {i, indices}];
    Print["  Use  STShowAlgebraicLetters[]  for a table, or  ",
          "result /. GetAlgebraicBackSubRules[]  to substitute."];];


(* - UIComms helpers: structured progress reporting for the SubTropica UI.
   When "UIComms" -> <|...|> is passed to STEvaluate, these functions update the
   global $stUIComms association and flush a JSON snapshot to stage.json in the IPC
   directory.  The first argument acts as a guard: None = no-op.
   All mutations go through the global $stUIComms symbol because Mathematica
   Associations cannot be mutated in place through function argument copies. *)

$stUIComms = None;

stUpdateUIComms[None, __] := Null;
stUpdateUIComms[_, key_String, value_] := (
    If[AssociationQ[$stUIComms],
        $stUIComms[key] = value;
        Quiet[Export[
            FileNameJoin[{$stUIComms["IPCDir"], "stage.json"}],
            ExportString[KeyDrop[$stUIComms, "IPCDir"], "RawJSON"],
            "Text"
        ]];
    ];
);

stSetUIStage[None, __] := Null;
stSetUIStage[_, stage_String, idx_Integer] := (
    If[AssociationQ[$stUIComms],
        $stUIComms["Stage"] = stage;
        $stUIComms["StageIndex"] = idx;
        Quiet[Export[
            FileNameJoin[{$stUIComms["IPCDir"], "stage.json"}],
            ExportString[KeyDrop[$stUIComms, "IPCDir"], "RawJSON"],
            "Text"
        ]];
    ];
);

(* - Decision records (axis 5 of the UI log redesign).

   STEmitDecision[subKind, fields] emits one kind="decision" JSONL record
   to progress.jsonl.  Available from anywhere the integrate handler is
   active -- reads $stUIComms["IPCDir"] to locate the file.  No-op when
   UIComms isn't set (notebook / headless invocations), so it's safe to
   sprinkle inside STEvaluate internals without breaking non-UI paths.

   Decision records carry a subKind discriminator ("gaugeSelected",
   "lrMethod", "findRoots", ...) plus free-form fields.  The UI renders
   them as distinctive rows in the structured log viewer and collects
   them in a "Kernel decisions" summary above the log.

   Recursion safety: we write via OpenAppend + WriteString[stream, ...]
   + Close.  The InheritedBlock inside the integrate handler only
   redirects WriteString["stdout", ...]; file-stream writes pass through
   to the built-in definition. *)

STEmitDecision[subKind_String, fields_Association] := Quiet[Module[
    {dir, path, record, json, s},
    If[!AssociationQ[$stUIComms], Return[Null]];
    dir = Lookup[$stUIComms, "IPCDir", Null];
    If[!StringQ[dir] || !DirectoryQ[dir], Return[Null]];
    path = FileNameJoin[{dir, "progress.jsonl"}];
    record = Join[
        <|"t" -> AbsoluteTime[], "level" -> "info", "kind" -> "decision",
          "source" -> "wrapper", "subKind" -> subKind|>,
        fields];
    json = Check[
        ExportString[record, "RawJSON", "Compact" -> True], Null];
    If[StringQ[json],
        s = OpenAppend[path, CharacterEncoding -> "UTF-8"];
        WriteString[s,
            StringReplace[json, {"\r" -> " ", "\n" -> " "}] <> "\n"];
        Close[s]
    ]
]];

STEmitDecision[_, _] := Null;  (* fallback: ignore malformed calls *)


