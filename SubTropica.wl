(*Elementary Polyhedral Calculations In Mathematica*)


STcompatibleRays[ray_,trData_]:=Module[{pos,compatible},
pos=FirstPosition[trData["rays"],ray][[1]];
compatible=Table[i,{i,1,trData["rays"]//Length}]//DeleteCases[#,pos]&;
compatible=compatible//Cases[#,v_/;Count[trData["cones"],cn_/;MemberQ[cn,v]&&MemberQ[cn,pos]]>0]&;
trData["rays"][[compatible]]
]


(* Given tropical Data, compute the sub-lattice formed by certain facets *)
STGetFaces[trData_,rays_:"All"]:=Module[{vertexInFacet,vertices,posRays,sps,possibleFaces,faces},
	If[rays==={},Return[{}]];
	vertices=trData["vertices"][[;;,2;;]];
	posRays=Association@@Table[trData["rays"][[i]]->i,{i,1,trData["rays"]//Length}];
	vertexInFacet=Association@@Table[
		sps=vertices . r;
		r-> Position[sps,Max[sps]]
		,
		{r,trData["rays"]}
	];

	If[rays==="All",
		possibleFaces=Subsets[trData["rays"]],
		possibleFaces=Subsets[trData["rays"][[rays]] ]
	];

	(* The empty face is always a face, the others only if have a common vertex*)
	faces=Join[{{}},possibleFaces[[2;;]]//DeleteCases[#,v_/;Intersection@@(vertexInFacet/@v)==={}]&]
	;

	(*{faces,posRays}//Return;*)
	faces=(posRays/@#&)/@faces
]


(* ::Subsection:: *)
(*Manipulating Euler Integrands*)


(* Convert an Euler Integrand into a standard form *) 
Clear[STtoMonPols];STtoMonPols[integrand_,vars_]:=Module[{factorized,mons,pols,exps,duplicatesPos,allVars,newExp},
factorized=integrand//Factor//STFactor//STpowerExpand;
If[MatchQ[factorized],Power[Alternatives@@vars,_],{{factorized[[2]]},{{},{}}}//Return];
If[MatchQ[factorized],Alternatives@@vars,{{1},{{},{}}}//Return];
If[MatchQ[factorized,(__)^_],Return[{Table[0,{v,vars}],{List@@factorized}//Transpose}]];
mons=Table[
((List@@factorized)//Cases[#,v^_|v]&)/.v^a_:> a/.v-> 1//Total
,{v,vars}]//Flatten;

pols=DeleteCases[List@@factorized,(Alternatives@@vars)^_|Alternatives@@vars,1];
pols=Table[
If[MatchQ[po,Power[a_,b_]],List@@po,{po,1}]
,{po,pols}];
pols=Transpose[pols];
(*flip the signs of all polys to standard*)
newExp=0;

If[Not[newExp===0],pols = {Join[{-1},pols[[1]]],Join[{newExp},pols[[2]]]}];
(*remove duplicates and add their exponents*)
duplicatesPos=Flatten/@(Last@Reap[MapIndexed[Sow[#2,#1]&,pols[[1]]]]);
pols=Table[{pols[[1,dpl//First  ]],pols[[2,dpl]]//Total},{dpl,duplicatesPos}]//Transpose;

{mons,pols}
]

(* Same but explicitly pull out overall prefactor *)
Clear[STtoCoeffMonPols];STtoCoeffMonPols[integrand_,vars_]:=Module[{monpol,cfs,noncfs},
monpol=STtoMonPols[integrand,vars];
cfs=monpol[[2,1]]//Position[#,v_/;Count[{v},Alternatives@@vars,\[Infinity]]===0,{1},Heads->False]&//Flatten;
noncfs=DeleteCases[Range[Length[monpol[[2,1]] ]], Alternatives@@cfs];
cfs=monpol[[2,1]][[cfs]]^monpol[[2,2]][[cfs]];

{Times@@cfs,monpol[[1]],{monpol[[2,1,noncfs]],monpol[[2,2,noncfs]]}}
]

STextractCoefficient[integrand_,xvars_]:=Module[{cfmonpol},
cfmonpol=STtoCoeffMonPols[integrand,xvars];
{cfmonpol[[1]],(Times@@(xvars^cfmonpol[[2]])) (Times@@(cfmonpol[[3,1]]^cfmonpol[[3,2]]))}
]

STforgetCoeffs[poly_,vars_]:=CoefficientRules[poly,vars]/.Rule->tRule/.tRule[a_,b_]:> tRule[a,1]/.tRule->Rule//FromCoefficientRules[#,vars]&;

Clear[STkeepLeading];
STkeepLeading[v_]:=v/.(SeriesData[a_,b_,{c_,___},d_,___]:> a^d c) 


(* factor (x y)^eps if at least one among x and y is positive, assuming the positivity of a globally defined set of variables *)
Clear[STpowerExpand];
STpowerExpand[v_]:=Module[{rules,rules2,assumptions},
rules= {(a_ b_)^c_/;Assuming[STPositiveVariables,Refine[a>0]]:> a^c b^c,(Power[a_,d_] b_)^c_/;Assuming[STPositiveVariables,Refine[a>0]]:> a^(c d) b^c,Power[a_,b_]^c_:> a^(b c)};
rules2={Power[a_,b_]:> Power[a,b//Factor]};
v//.rules/.rules2
]


STFactor[v_]:= v/. Power[a_,b_]/;Count[{b},eps,\[Infinity]]>0 :> Power[a//Factor,b]//PowerExpand//STpowerExpand


STSimplify[v_]:=v//STFactor//STpowerExpand;


(* ::Subsection:: *)
(*Tropicalization*)


STforgetCoeffs[poly_,vars_]:=CoefficientRules[poly,vars]/.Rule->tRule/.tRule[a_,b_]:> tRule[a,1]/.tRule->Rule//FromCoefficientRules[#,vars]&;


(* Evaluate a tropical function on a ray *)
STEvalRay[fun_,ray_,vars_]:=Module[{},
fun/.Table[vars[[i]]-> ray[[i]],{i,1,vars//Length}]
];
(* From exponent vector to monomial *)
STtoMonomial[latticePoint_,vars_]:= Times@@(vars^latticePoint);


(*STtropicalize a positive function*)
Clear[STtropicalize];
STtropicalize[v_/;NumberQ[v]]:=0;
STtropicalize[expr_]:=Module[{temp,factors,num,den,part,parts},
factors=expr//Factor//Together;
(*If[factors[[1]]//NumericQ,factors=factors/factors[[1]]];*)
num=factors//Numerator;
den=factors//Denominator;
(*If[Head[factors]===Times,factors=List@@factors,factors={factors}];*)
parts=
Table[
part=part//Expand;
part=part/.Times-> tTimes;
part=part/.tTimes[a__]:>  tTimes[Sequence@@DeleteCases[{a},v_/;NumberQ[v]]]/.tTimes-> Times;
part=part/.Plus-> Max;
part = part /.Times->tTimes/.tTimes[b__]:> tTimes[Sequence@@DeleteCases[{b},v_/;NumberQ[v]]]/.Power[b_,c_]:> c b /.tTimes-> Plus;
part=part/.Max-> tMax/.(tMax[l___,m_/;NumericQ[m],r___]:>  tMax[l,0,r])/.tMax-> Max
,{part,{num,den}}
];
If[num===1,-parts[[2]],If[den===1,parts[[1]],parts[[1]]-parts[[2]]]]
];


Clear[STtropicalizePoly];
STtropicalizePoly[expr_]:=Module[{expanded,part},
expanded=expr//Expand;
(*If[factors[[1]]//NumericQ,factors=factors/factors[[1]]];*)
(*If[Head[factors]===Times,factors=List@@factors,factors={factors}];*)

part=expanded//Expand;
part=part/.Times-> tTimes;
part=part/.tTimes[a__]:>  tTimes[Sequence@@DeleteCases[{a},v_/;NumberQ[v]]]/.tTimes-> Times;
part=part/.Plus-> Max;
part = part /.Times->tTimes/.tTimes[b__]:> tTimes[Sequence@@DeleteCases[{b},v_/;NumberQ[v]]]/.Power[b_,c_]:> c b /.tTimes-> Plus;
part=part/.Max-> tMax/.(tMax[l___,m_/;NumericQ[m],r___]:>  tMax[l,0,r])/.tMax-> Max;
part//Return;
];


