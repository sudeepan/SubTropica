                # becomes publicly visible immediately. Verify-false does not
                # re-add (the operator can re-queue manually if needed).
                promoted = False
                if verified:
                    parsed = review_waitlist_config_from_path(rel_path)
                    if parsed is not None:
                        promoted = review_remove_from_waitlist(parsed[0], parsed[1])
                self._ok('application/json',
                         json.dumps({'status': 'ok', 'verified': verified,
