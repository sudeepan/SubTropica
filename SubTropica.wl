	If[FileExistsQ["hyperInt/mathMaplecoms/temp.out"], DeleteFile["hyperInt/mathMaplecoms/temp.out"]];
	WriteString[mapleCommandFile,mapleCommand];
	
	(* call maple *)
	(*mapleCall="! maple -c 'read \\\"mathMaplecoms/mapleCommandFile.mpl\\\":' -c 'quit:'";*)
	mapleCall="! "<>$MapleCommand<>" -q mathMaplecoms/mapleCommandFile.mpl";
	
