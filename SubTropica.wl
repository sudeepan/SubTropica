                verified = bool(req.get('verified'))
                if not full or not os.path.isfile(full) or not rid:
                    raise ValueError('bad path or recordId')
                with open(full, 'r', encoding='utf-8') as f:
                    raw = f.read()
                entry = json.loads(raw)
                hit = False
                for rec in entry.get('Records', []):
                    if rec.get('recordId') == rid:
                        rec['verified'] = verified
                        rec['verifiedAt'] = review_today_iso() if verified else ''
