STrestrictPoly[pol_,ray_,vars_,depth_:0]:=Module[{min,coefsRules,lts},
coefsRules=CoefficientRules[pol,vars];
min=Min @@ Table[-cr[[1]] . ray,{cr,coefsRules}];
coefsRules=coefsRules//DeleteCases[#,v_/;- v[[1]] . ray>min-depth,{1}]&;
Table[(cr[[1]]/.coefsRules)STtoMonomial[cr[[1]],vars],{cr,coefsRules}]//Total
]
STrestrict[pol_,ray_,vars_,depth_:0]:=Module[{denValue},
	If[Count[{(pol//Denominator)},
		Alternatives@@vars,\[Infinity]]===0,
		((pol//Numerator//STrestrictPoly[#,ray,vars,depth]&))//Return
	];
	denValue=((pol//Denominator//STrestrictPoly[#,ray,vars,depth]&));
	((pol//Numerator//STrestrictPoly[#,ray,vars,depth]&))/denValue
 ];
 
STrestrict[pol_,rays_/;Head[rays[[1]]]===List,vars_,depth_:0]:=Module[{temp},
	temp=STrestrict[pol,rays[[1]],vars,depth];
	Do[temp=STrestrict[temp,rays[[i]],vars,depth];,{i,2,Length[rays]}];
	temp
]


Clear[STrestrictIntegrand];
STrestrictIntegrand[integrand_,vars_,{}]:=(integrand)
STrestrictIntegrand[integrand_,vars_,ray_]:=STrestrictIntegrand[integrand,vars,ray]=Module[{mon,pols},
{mon,pols}=integrand//STtoMonPols[#,vars]&;
 Times@@(vars^mon)Times@@((STrestrictPoly[#,ray,vars]&/@pols[[1,;;]])^pols[[2,;;]])
];
STrestrictIntegrand[integrand_,vars_,face_/;MatchQ[face,{List[___]...}]]:=Module[{},STrestrictIntegrand[STrestrictIntegrand[integrand,vars,face[[2;;]]],vars,face[[1]]]]


