(* Resolve a bare command name to an absolute path via `which`.  Returns
   the input unchanged when it already exists as a file; None if the
   command can't be located. *)
stResolvePath[path_] := Module[{pr, out},
  Which[
    !StringQ[path] || path === "",        None,
    FileExistsQ[path],                    AbsoluteFileName[path],
    True,
      pr = Quiet @ Check[
        TimeConstrained[RunProcess[{"which", path}], 5, $TimedOut],
        $Failed];
      If[AssociationQ[pr] && pr["ExitCode"] === 0,
        out = StringTrim[pr["StandardOutput"]];
        If[StringLength[out] > 0 && FileExistsQ[out], out, None],
        None]]];

(* Run <path> <args> with a 5-s timeout; return the first non-empty line
   of stdout merged with stderr (many tools print version on stderr), or
   one of "?" (timed out) / "" (nothing usable). *)
stBinaryVersion[path_, args_List] := Module[{pr, stdout, stderr, combined, first},
  pr = Quiet @ Check[
    TimeConstrained[RunProcess[Prepend[args, path]], 5, $TimedOut],
    $Failed];
  Which[
    pr === $TimedOut,     "?",
    !AssociationQ[pr],    "",
    True,
      stdout   = StringTrim @ Lookup[pr, "StandardOutput", ""];
      stderr   = StringTrim @ Lookup[pr, "StandardError", ""];
      combined = If[StringLength[stdout] > 0, stdout, stderr];
      first    = First[StringSplit[combined, "\n"], ""];
      StringTrim[StringTake[first, UpTo[60]]]]];

(* Per-tool version extractors for binaries that don't support --version
   or encode their version elsewhere. *)
stMapleVersion[path_] := Module[{pr, both, m},
  (* `maple -V` dumps a Usage line to stderr whose path contains the
     release year, e.g. ".../Maple.framework/Versions/2026/bin...". *)
  pr = Quiet @ Check[
    TimeConstrained[RunProcess[{path, "-V"}], 5, $TimedOut],
    $Failed];
  If[!AssociationQ[pr], Return["", Module]];
  both = Lookup[pr, "StandardOutput", ""] <> Lookup[pr, "StandardError", ""];
  m = StringCases[both,
    "Versions/" ~~ y:DigitCharacter.. :> "Maple " <> y, 1];
  If[Length[m] > 0, First[m], ""]];

stGinshVersion[path_] := Module[{abs, m},
  (* ginsh has no --version flag and only prints its banner to a TTY.
     Fall back to resolving the symlink and extracting the GiNaC version
     from a Homebrew-style Cellar path: /opt/homebrew/Cellar/ginac/1.8.10/... *)
  abs = Quiet[AbsoluteFileName[path]];
  If[!StringQ[abs], Return["", Module]];
  m = StringCases[abs,
    "/ginac/" ~~ v:RegularExpression["[0-9][0-9A-Za-z.\\-]*"] :> "GiNaC " <> v, 1];
  If[Length[m] > 0, First[m], ""]];

(* Test a single dependency and update its registry entry.
   The whole probe is wrapped in CheckAbort: if any RunProcess / FindFile
   / import path aborts (rather than returning $Failed), we mark the dep
   "error" and move on.  Without this guard a single misbehaving probe
   can take down the entire package load, since stPrintGreeting runs at
   top level during Needs["SubTropica`"]. *)
stTestOneDependency[name_String] := CheckAbort[Module[
  {dep, path, resolved, status, version, msg},
  dep = $STDependencies[name];
  path = dep["getPath"][];
  $STDependencies[name, "resolvedPath"] = "";

  {status, version, msg} = Switch[dep["type"],
    "binary",
      resolved = stResolvePath[path];
      If[resolved === None,
        {"missing", "", "not found at " <> ToString[path]},
        $STDependencies[name, "resolvedPath"] = resolved;
        Module[{v},
          v = Switch[name,
            "maple", stMapleVersion[resolved],
            "ginsh", stGinshVersion[resolved],
            "feyntrop",
              (* feyntrop has no version flag and crashes without JSON stdin;
                 report the short git SHA of the checkout if available. *)
              Module[{dir = DirectoryName[resolved], gr},
                gr = Quiet @ Check[
                  TimeConstrained[
                    RunProcess[{"git", "-C", dir, "rev-parse", "--short", "HEAD"}],
                    5, $TimedOut],
                  $Failed];
                If[AssociationQ[gr] && gr["ExitCode"] === 0,
                  "git " <> StringTrim[gr["StandardOutput"]],
                  ""]],
            "HyperFLINT",
              (* HyperFLINT has no --version flag; report git SHA of the
                 source checkout (binary lives at <repo>/build-release/, so
                 go up two levels from the binary to reach the repo). *)
              Module[{dir = ParentDirectory[DirectoryName[resolved]], gr},
                gr = Quiet @ Check[
                  TimeConstrained[
                    RunProcess[{"git", "-C", dir, "rev-parse", "--short", "HEAD"}],
                    5, $TimedOut],
                  $Failed];
                If[AssociationQ[gr] && gr["ExitCode"] === 0,
                  "git " <> StringTrim[gr["StandardOutput"]],
                  ""]],
            _,       stBinaryVersion[resolved, {"--version"}]];
          {"ok", v, ""}]],

    "make",
      (* GNU make >= 4 is required: macOS /usr/bin/make is 3.81 which has a
         pattern-rule bug that breaks pySecDec's disteval build (drops the
         -I flag).  Walk a list of candidate binaries, returning the first
         one whose --version matches "GNU Make N.M" with N >= 4.  The
         Homebrew full paths are probed explicitly because the Mathematica
         notebook front-end inherits launchd's PATH (which does not
         include /opt/homebrew/bin), so a bare `gmake` lookup can miss
         even when `brew install make` is in place. *)
      Module[{candidates, tryOne, hits, hit},
        candidates = {"/opt/homebrew/opt/make/libexec/gnubin/make",
                      "/opt/homebrew/bin/gmake",
                      "/usr/local/opt/make/libexec/gnubin/make",
                      "/usr/local/bin/gmake",
                      "gmake",
                      "make"};
        tryOne[cmd_] := Module[{out, line, major, resolved},
          out = Quiet @ Check[
            TimeConstrained[RunProcess[{cmd, "--version"}, "StandardOutput"],
              5, $TimedOut],
            ""];
          If[!StringQ[out] || out === "" || out === $TimedOut, Return[None, Module]];
          line = First[StringSplit[out, "\n"], ""];
          major = Quiet @ ToExpression @ First[
            StringCases[line, "GNU Make " ~~ d:DigitCharacter.. ~~ "." ~~ ___ :> d],
            ""];
          If[IntegerQ[major] && major >= 4,
            resolved = If[FileExistsQ[cmd], cmd,
              (* Bare name: ask `which` where it actually is *)
              Module[{whichPr = Quiet @ Check[RunProcess[{"which", cmd}], $Failed]},
                If[AssociationQ[whichPr] && whichPr["ExitCode"] === 0,
                  StringTrim[whichPr["StandardOutput"]], cmd]]];
            {"ok", StringTrim[StringTake[line, UpTo[30]]], "", resolved},
            None]];
        hits = tryOne /@ candidates;
        hit = FirstCase[hits, {"ok", _, _, _}, None];
        If[hit =!= None,
          $STDependencies[name, "resolvedPath"] = hit[[4]];
          {hit[[1]], hit[[2]], hit[[3]]},
          {"missing", "", "no GNU make (>= 4) found; macOS /usr/bin/make is 3.81"}]],


    "python-package",
      If[$STDependencies["python3", "status"] =!= "ok",
        {"missing", "", "python3 not available"},
        Module[{pr, locPr, loc},
          pr = Quiet @ Check[
            TimeConstrained[
              RunProcess[{$PythonCommand, "-c",
                "import " <> name <> "; print(getattr(" <> name <> ", '__version__', 'ok'))"},
                "StandardOutput"], 5, $TimedOut],
            $Failed];
          If[pr === $TimedOut, {"error", "", "import timed out"},
            If[StringQ[pr] && StringLength[StringTrim[pr]] > 0,
              (* Also record the package's on-disk location for the
                 path column (vs. the Python interpreter that runs it). *)
              locPr = Quiet @ Check[
                TimeConstrained[
                  RunProcess[{$PythonCommand, "-c",
                    "import " <> name <> ", os; print(os.path.dirname(" <> name <> ".__file__))"},
                    "StandardOutput"], 5, $TimedOut],
                ""];
              loc = If[StringQ[locPr], StringTrim[locPr], ""];
              If[loc =!= "",
                $STDependencies[name, "resolvedPath"] = loc];
              {"ok", StringTrim[pr], ""},
              {"missing", "", "import " <> name <> " failed"}]]]],

    "mathematica-package",
      Module[{pkgPath = path, pkgFile, ver},
        Which[
          name === "FiniteFlow",
            (* Populated by the FF/SPQR load block above.  Resolve
               the FiniteFlow`.m location for display. *)
            If[$STDependencies["FiniteFlow", "status"] === "ok",
              Module[{ff = Quiet[FindFile["FiniteFlow`"]]},
                If[StringQ[ff],
                  $STDependencies["FiniteFlow", "resolvedPath"] = ff]];
              {"ok", "", ""},
              {"untested", "", ""}],
          name === "FIESTA",
            pkgFile = FileNameJoin[{pkgPath, "FIESTA5.m"}];
            If[StringQ[pkgPath] && pkgPath =!= "" &&
               DirectoryQ[pkgPath] && FileExistsQ[pkgFile],
              $STDependencies[name, "resolvedPath"] = pkgFile;
              (* VersionString:="FIESTA 5.0" lives around line 516 *)
              ver = Quiet @ First[
                StringCases[
                  StringJoin @ Riffle[
                    Quiet @ Check[ReadList[pkgFile, String], {}], "\n"],
                  "VersionString:=\"" ~~ v:Except["\""].. ~~ "\"" :> v, 1],
                ""];
              {"ok", ver, ""},
              {"missing", "", "FIESTA5.m not found at " <> ToString[pkgPath]}],
          name === "AMFlow",
            pkgFile = FileNameJoin[{pkgPath, "AMFlow.m"}];
            If[StringQ[pkgPath] && pkgPath =!= "" &&
               DirectoryQ[pkgPath] && FileExistsQ[pkgFile],
              $STDependencies[name, "resolvedPath"] = pkgFile;
              (* $PackageInfo = {"1.2", "12-Jan-2026"}; *)
              ver = Quiet @ First[
                StringCases[
                  StringJoin @ Riffle[
                    Quiet @ Check[ReadList[pkgFile, String, 400], {}], "\n"],
                  "$PackageInfo" ~~ Whitespace... ~~ "=" ~~ Whitespace... ~~
                    "{\"" ~~ v:Except["\""].. ~~ "\"" :> "AMFlow " <> v, 1],
                ""];
              {"ok", ver, ""},
              {"missing", "", "AMFlow.m not found at " <> ToString[pkgPath]}],
          name === "LiteRed",
            pkgFile = FileNameJoin[{pkgPath, "Setup", "LiteRed.m"}];
            If[StringQ[pkgPath] && pkgPath =!= "" &&
               DirectoryQ[pkgPath] && FileExistsQ[pkgFile],
              $STDependencies[name, "resolvedPath"] = pkgFile;
              (* Version is encoded as the RNL context loaded by Setup,
                 e.g. <<RNL`LiteRed184` for v1.84.  Grab first two digits
                 after "LiteRed" and insert the implicit decimal point. *)
              ver = Quiet @ First[
                StringCases[
                  StringJoin @ Riffle[
                    Quiet @ Check[ReadList[pkgFile, String, 10], {}], "\n"],
                  "LiteRed" ~~ maj:DigitCharacter ~~ min:DigitCharacter.. :>
                    "LiteRed " <> maj <> "." <> min,
                  1],
                ""];
              {"ok", ver, ""},
              {"missing", "",
                "Setup/LiteRed.m not found under " <> ToString[pkgPath]}],
          name === "FIRE",
            pkgFile = FileNameJoin[{pkgPath, "FIRE6.m"}];
            If[StringQ[pkgPath] && pkgPath =!= "" &&
               DirectoryQ[pkgPath] && FileExistsQ[pkgFile],
              $STDependencies[name, "resolvedPath"] = pkgFile;
              (* Print["FIRE, version 6.5.2"] sits near the top of FIRE6.m *)
              ver = Quiet @ First[
                StringCases[
                  StringJoin @ Riffle[
                    Quiet @ Check[ReadList[pkgFile, String, 200], {}], "\n"],
                  "FIRE, version " ~~ v:RegularExpression["[0-9][0-9.]*"] :>
                    "FIRE " <> v, 1],
                ""];
              {"ok", ver, ""},
              {"missing", "",
                "FIRE6.m not found at " <> ToString[pkgPath]}],
          name === "SPQR",
            (* SPQR is delivered as a paclet; detection uses PacletObject
               when available, falling back to FindFile.  The welcome
               banner's FF/SPQR auto-detection has already attempted the
               load, so a successful resolve here confirms it. *)
            Module[{pobj, loc, v, ff},
              pobj = Quiet @ Check[PacletObject["SPQR"], Missing[]];
              Which[
                Head[pobj] === PacletObject,
                  loc = pobj["Location"];
                  v   = pobj["Version"];
                  If[StringQ[loc],
                    $STDependencies[name, "resolvedPath"] = loc];
                  {"ok",
                   If[StringQ[v] && v =!= "", "SPQR " <> v, "SPQR"], ""},
                StringQ[ff = Quiet[FindFile["SPQR`"]]],
                  $STDependencies[name, "resolvedPath"] = ff;
                  {"ok", "SPQR", ""},
                True,
                  {"missing", "",
                    "SPQR paclet not installed / not on $Path"}]],
          True, {"untested", "", ""}]],

    "maple-package",
      (* Plain Maple source file (.mpl).  Read enough of the header to
         catch both the copyright line and the "HyperInt, version X.Y"
         banner printf; avoids invoking Maple to keep kernel startup fast.
         Also handles Schnetz's HyperLogProcedures banner. *)
      If[!StringQ[path] || path === "",
        {"missing", "", "path not set"},
        If[!FileExistsQ[path],
          {"missing", "", "not found at " <> path},
          Module[{headerLines, joined, verCases, hlpCases, versionString},
            $STDependencies[name, "resolvedPath"] = path;
            headerLines = Quiet @ Check[ReadList[path, String, 120], {}];
            joined = StringJoin[Riffle[headerLines, "\n"]];
            verCases = StringCases[joined,
              "HyperInt, version " ~~ v:RegularExpression["[0-9][0-9A-Za-z.\\-]*"] :>
                "HyperInt " <> v, 1];
            hlpCases = StringCases[joined,
              "Hyperlog Procedures, Version " ~~
                v:RegularExpression["[0-9][0-9A-Za-z.\\-]*"] :>
                "HyperLogProcedures " <> v, 1];
            versionString = Which[
              Length[verCases] > 0,  First[verCases],
              Length[hlpCases] > 0,  First[hlpCases],
              True, ""];
            Which[
              StringContainsQ[joined, "Erik Panzer"] || StringContainsQ[joined, "PanzerErik/hyperint"],
                {"ok", If[versionString =!= "", versionString, "Panzer HyperInt"], ""},
              StringContainsQ[joined, "Hyperlog Procedures"] || StringContainsQ[joined, "Oliver Schnetz"],
                {"ok", If[versionString =!= "", versionString, "HyperLogProcedures"], ""},
              True,
                {"ok", versionString, "file found but no HyperInt/HLP header; using as-is"}]]]],

    _, {"untested", "", "unknown type"}
  ];

  $STDependencies[name, "status"]    = status;
  $STDependencies[name, "version"]   = version;
  $STDependencies[name, "statusMsg"] = msg;
  status
],
  (* on Abort: record the failure and continue the sweep. *)
  $STDependencies[name, "status"]    = "error";
  $STDependencies[name, "version"]   = "";
  $STDependencies[name, "statusMsg"] = "dependency probe aborted";
  "error"
];

(* Silent variant of the dependency sweep: runs the smoke tests, sets the
   status/version/statusMsg fields in $STDependencies, prints nothing.
   Used by stPrintGreeting so the startup banner is not doubled with a
   separate one-line checklist. *)
stRunDependencyTests[] := Module[{names},
  names = Keys[$STDependencies];
  (* FF's status is populated by the separate FF/SPQR load block above
     (it requires Needs[] + FFLoadLib[] to confirm the C library is wired
     in).  SPQR is just a paclet introspection, so we let the generic
     test handle it.  Each stTestOneDependency call is double-guarded:
     CheckAbort inside the definition handles probe-level aborts,
     CheckAbort here handles the pathological case where the guard
     itself fails.  Either way, one bad probe never aborts the sweep. *)
  Do[
    If[name =!= "FiniteFlow",
      CheckAbort[stTestOneDependency[name],
        $STDependencies[name, "status"]    = "error";
        $STDependencies[name, "statusMsg"] = "dependency probe aborted"]],
    {name, names}];
];

(* Run all dependency checks and print a summary report.  Public path used
   by ConfigureSubTropica[] and STCheckDependencies[]. *)
stRunDependencyChecks[] := Module[{names, items = {}, dep, status},
  stRunDependencyTests[];
  names = Keys[$STDependencies];

  (* Build compact one-line checklist with colored symbols:
       green checkmark = loaded
       yellow dash     = not loaded, optional
       red cross       = not loaded, required *)
  Do[
    dep = $STDependencies[name];
    status = dep["status"];
    AppendTo[items, Switch[status,
      "ok",
        If[$Notebooks,
          Style["\[Checkmark]" <> name, Darker[Green]],
          "\[Checkmark]" <> name],
      _,
        If[dep["required"],
          If[$Notebooks,
            Style["\[Times]" <> name, Red],
            "\[Times]" <> name],
          If[$Notebooks,
            Style["-" <> name, RGBColor[0.8, 0.6, 0]],
            "-" <> name]]]],
    {name, names}];

  (* Print single line; in notebook mode use Row for color, in terminal plain text *)
  If[$Notebooks,
    Print[Row[Riffle[items, "  "]]],
    Print[StringRiffle[ToString /@ items, "  "]]];

  (* Print expanded warning for missing REQUIRED deps only *)
  Do[
    dep = $STDependencies[name];
    If[dep["required"] && dep["status"] =!= "ok",
      Print["  \[WarningSign] ", name, " is REQUIRED: ", dep["installHint"],
        "\n    ", dep["configHint"]]],
    {name, names}];
];

(* Build one "[<glyph>] name" badge.  Only the glyph inside the brackets
   carries color; the brackets and dep name render in the default
   foreground.

   In notebook mode returns a flat LIST of renderable elements (not a Row)
   so the caller can Flatten it into a single top-level Row; nesting Rows
   inside Rows causes the Mathematica front end to fall back to a
   Column-style block layout that breaks the ASCII-art alignment.
   In terminal mode returns a plain String. *)
stBadge[name_String] := Module[{dep, status, glyph, color},
  dep = Lookup[$STDependencies, name, None];
  If[dep === None,
    Return[If[$Notebooks, {"[?] ", name}, "[?] " <> name]]];
  status = dep["status"];
  {glyph, color} = Switch[status,
    "ok",   {"\[Checkmark]", Darker[Green]},
    _,      If[TrueQ[dep["required"]],
               {"\[Times]", Red},
               {"-", RGBColor[0.8, 0.6, 0]}]];
  If[$Notebooks,
    {"[", Style[glyph, color], "] ", name},
    "[" <> glyph <> "] " <> name]
];

(* Plain-text glyph for a dep; used when we need to measure the width of
   a badge strip without rendering the Row. *)
stBadgeGlyph[name_String] := Module[{dep},
  dep = Lookup[$STDependencies, name, None];
  If[dep === None, Return["?"]];
  Switch[dep["status"],
    "ok", "\[Checkmark]",
    _,    If[TrueQ[Lookup[dep, "required", False]], "\[Times]", "-"]]
];

(* Build (do not print) one badge strip: "<prefix>[g] n1  [g] n2  ...".
   If width is an integer, right-pad to that width; otherwise no padding.
   In notebook mode returns a flat list of renderable elements (for
   splicing into a single top-level Row by the caller); in terminal mode
   returns a plain String. *)
stBuildBadgeRow[prefix_String, names_List] :=
  stBuildBadgeRow[prefix, names, Automatic];
stBuildBadgeRow[prefix_String, names_List, width_] := Module[
  {badges, termStr, padLen, tail},
  badges = stBadge /@ names;
  termStr = prefix <> StringRiffle[
    ("[" <> stBadgeGlyph[#] <> "] " <> #) & /@ names, "  "];
  padLen = If[IntegerQ[width], Max[0, width - StringLength[termStr]], 0];
  tail = If[padLen > 0, StringJoin @@ Table[" ", {padLen}], ""];
  If[$Notebooks,
    Flatten[{prefix, Riffle[badges, "  "], tail}],
    termStr <> tail]
];

(* Centered-badge row: computes the leading space prefix that positions
   the combined badge strip at the middle of the 71-char banner width.
   Each badge is "[<glyph>] <name>" (4 chars + name), joined by "  ". *)
stCenterBadgeRow[names_List] := Module[{contentLen, pad, prefix},
  contentLen = Total[(StringLength[#] + 4) & /@ names] +
    2 * Max[0, Length[names] - 1];
  pad = Max[0, Quotient[71 - contentLen, 2]];
  prefix = StringJoin @@ Table[" ", {pad}];
  stBuildBadgeRow[prefix, names]];

(* Regex-extract the "Version" field from PacletInfo.wl without
   evaluating the file as Wolfram code.  Returns the version string, or
   None if the manifest can't be read.  Used by the welcome banner as a
   backstop against the scripts/sync-version.wl step being forgotten. *)
stReadPacletVersion[] := Module[{f, text, m},
  f = FileNameJoin[{$SubTropicaInstallDir, "PacletInfo.wl"}];
  If[!FileExistsQ[f], Return[None]];
  text = Quiet[Check[Import[f, "Text"], $Failed]];
  If[!StringQ[text], Return[None]];
  m = StringCases[text,
    "\"Version\"" ~~ Whitespace... ~~ "->" ~~ Whitespace... ~~
      "\"" ~~ v:RegularExpression["[0-9.]+"] ~~ "\"" :> v, 1];
  If[Length[m] === 1, First[m], None]
];

(* Returns a one-line suggestion to run STBenchmark[] when the currently-
   installed $SubTropicaVersion has never been benchmarked on this machine
   (or the stored last-run record is for a different version).  Returns ""
   otherwise, or when the user has opted out via
   ConfigureSubTropica[BenchmarkNudge -> False]. *)
stBenchmarkNudgeLine[] := Module[{data, storedVersion},
  If[!TrueQ[$ShowBenchmarkNudge], Return[""]];
  If[!FileExistsQ[$STBenchmarkDataFile],
    Return["New install \[LongDash] run STBenchmark[] to verify your setup."]];
  data = Quiet[Check[Import[$STBenchmarkDataFile, "JSON"], $Failed]];
  If[data === $Failed || !MatchQ[data, {__Rule} | _?AssociationQ],
    Return["Run STBenchmark[] to verify your setup."]];
  data = Association[data];
  storedVersion = Lookup[data, "version", ""];
  If[storedVersion =!= $SubTropicaVersion,
    "New version (v" <> $SubTropicaVersion <>
      ") \[LongDash] run STBenchmark[] to re-verify your setup.",
    ""]
];

(* Print the greeting: the original ASCII island banner with dependency
   checkboxes woven in (polymake flag in the top-right sky next to the
   sun, backends and toolchain strips replacing two water rows),
   followed by the plain Welcome/author lines.  No frame, no poststamp.

   The whole banner is emitted in a single Print so the notebook front
   end renders it as one output cell (separate Prints become separate
   cells and break the art's visual continuity). *)
stPrintGreeting[] := Module[
  {skyRow2, integratorsRow, reducersRow, toolsRow,
   content, rendered, nudge},
  CheckAbort[stRunDependencyTests[],
    Print["[SubTropica] Dependency probe was aborted; continuing with best-effort status."]];

  (* The banner-rendering block below is wrapped in CheckAbort so that a
     Style/Row/Column/Print failure (e.g., an FE quirk during ASCII art
     composition) never takes down the whole package load.  The REQUIRED-
     dep warning loop further down runs outside this guard so users always
     see the actionable message even if the art silently fails. *)
  CheckAbort[Module[{},

  (* Polymake badge sits on the second sky row, to the right of the
     widening sun.  The sun is drawn as a 5-row half-circle reaching its
     widest at the water surface \[LongDash] 7 / 13 / 17 / 19 / 21 `@`s, each
     centered on column 40 so the profile reads as round. *)
  skyRow2 = If[$Notebooks,
    Flatten[{"             ^^              @@@@@@@@@@@@@                 ",
             stBadge["polymake"]}],
    "             ^^              @@@@@@@@@@@@@                 " <>
      stBadge["polymake"]];

  (* Badge rows: each centered across the 71-char banner width.  Grouped
     so that FiniteFlow and SPQR sit adjacent (they co-load and share a
     Groebner-basis code path), and so the tiers balance as 4 / 5 / 5. *)
  integratorsRow = stCenterBadgeRow[
    {"pySecDec", "FIESTA", "AMFlow", "feyntrop"}];
  reducersRow = stCenterBadgeRow[
    {"FiniteFlow", "SPQR", "LiteRed", "FIRE", "HyperInt"}];
  toolsRow = stCenterBadgeRow[
    {"maple", "ginsh", "python3", "curl", "make", "HyperFLINT"}];

  nudge = stBenchmarkNudgeLine[];

  content = Join[{
    "                                @@@@@@@",
    skyRow2,
    "        ^^        ^^       @@@@@@@@@@@@@@@@@",
    "                          @@@@@@@@@@@@@@@@@@@           ^^",
    "                         @@@@@@@@@@@@@@@@@@@@@",
    " ~~~~ ~~~ ~~~~ ~~~~~ ~~  &&&&&&&&&&&&&&&&&&&&& ~~~~~~~ ~~~~~~~ ~~~ ~~~~",
    " ~        ~~   ~  ~      ~~~~~~~~~~~~~~~~~~~~~ ~       ~~    ~~ ~  ~~~~",
    "  ~ ~~     ~~~    ~  ~~   ~~    ~~~~~   ~~  ~~~    ~    ~~~    ~~  ~~",
    integratorsRow,
    reducersRow,
    toolsRow,
    " ~  ~       ~ ~      ~           ~~ ~~~~~~  ~      ~~  ~             ~~",
    "       ~             ~        ~      ~      ~~   ~             ~",
    "",
    "Welcome to SubTropica v" <> $SubTropicaVersion <> "!",
    "",
    "by Mathieu Giroux, Sebastian Mizera, Giulio Salvatori"},
    If[nudge === "", {}, {"", nudge}]];

  If[$Notebooks,
    (* Each item becomes one Column row.  List-items (badge strips) are
       wrapped in Row so their elements render inline; strings stay as
       strings.  Every element is Style-wrapped individually with
       FontFamily -> "Courier" because Style on the outer Column does not
       reliably propagate FontFamily into nested Row items. *)
    rendered = Function[item,
      Style[
        If[ListQ[item], Row[item], item],
        FontFamily -> "Courier", FontSize -> 14,
        LineSpacing -> {0.9, 0}]] /@ content;
    Print[Column[rendered, Spacings -> 0,
      BaseStyle -> {FontFamily -> "Courier", FontSize -> 14,
        LineSpacing -> {0.9, 0}}]],
    Print[StringRiffle[content, "\n"]]];
  ],
    (* banner-CheckAbort on Abort: *)
    Print["[SubTropica] Welcome banner rendering was aborted (non-fatal)."]];

  (* Warn loudly about missing REQUIRED deps (currently only polymake).
     OUTSIDE the banner-CheckAbort so users always see this message, even
     if the art above silently aborted. *)
  Do[Module[{dep = $STDependencies[name]},
       If[TrueQ[dep["required"]] && dep["status"] =!= "ok",
         Print["  \[WarningSign] ", name, " is REQUIRED: ",
           dep["installHint"], "\n    ", dep["configHint"]]]],
    {name, Keys[$STDependencies]}];

  (* Note: PacletInfo.wl/$SubTropicaVersion drift is now enforced only
     by the paclet-release pipeline, not by this welcome banner.  The
     stReadPacletVersion[] helper above is still callable if a release
     script wants to check manually. *)
];

(* Guard function: check a tool is available before using it.
   Re-tests on first failure so mid-session installs work. *)
stRequireTool::missing = "`1` is not available. `2`";
stRequireTool[name_String] := Module[{dep},
  dep = Lookup[$STDependencies, name, None];
  If[dep === None, Message[stRequireTool::missing, name, "Unknown dependency."]; Return[$Failed]];
  If[dep["status"] === "ok", Return[True]];
  (* Re-test in case tool was installed after package load *)
  stTestOneDependency[name];
  If[$STDependencies[name, "status"] === "ok", Return[True]];
  Message[stRequireTool::missing, name,
    $STDependencies[name, "installHint"] <> ". Or: " <> $STDependencies[name, "configHint"]];
  $Failed
];

(* Public API *)
STCheckDependencies::usage = "STCheckDependencies[] re-runs all dependency smoke tests and prints a full report.";
STCheckDependencies[] := (stRunDependencyChecks[]; $STDependencies);

(* Per-user persistent config file.  ConfigureSubTropica auto-saves overrides
   here; package load auto-applies them so users don't have to re-configure
   every kernel restart.  Lives under the Mathematica user dir so it survives
   package upgrades. *)
$STConfigFile = FileNameJoin[{$UserBaseDirectory, "Kernel", "SubTropicaConfig.m"}];

(* Last-run record for STBenchmark.  Doubles as (a) source of truth for the
   welcome-banner version nudge, (b) baseline for regression tracking. *)
$STBenchmarkDataFile = FileNameJoin[{$UserBaseDirectory, "ApplicationData",
    "SubTropica", "benchmark-last-run.json"}];

(* Per-case outcome list from the most recent STBenchmark[] invocation.
   Each entry is an Association with keys "id", "category", "index",
   "label", "status", "time", "memory", "messages", "hash", "verified",
   "relError".  STBenchmark[] itself returns Null so the REPL doesn't
   echo the full list; reach for this variable when you need to drill
   into a specific case. *)
$STLastBenchmarkResults = {};

(* Show the "run STBenchmark[] to verify your setup" line in the welcome
   banner when the installed version hasn't been benchmarked yet. *)
$ShowBenchmarkNudge = True;

(* Auto-load saved config (silent if absent or unreadable).  Runs BEFORE the
   FF auto-detection block below so that a saved FiniteFlowPath gets picked
   up by FindFile / Needs in the natural way.

   Master kernel only: subkernels skip this block (Global`$STSubkernelMode
   is True on subkernels during STSetupKernel's parallel Get) because
   STSetupKernel mirrors the master's already-resolved $*Path /
   $*Command values back to every subkernel after the load. *)
Module[{loaded, applyOne},
    If[!TrueQ[Global`$STSubkernelMode] && FileExistsQ[$STConfigFile],
        loaded = Quiet[Check[Get[$STConfigFile], $Failed]];
        If[AssociationQ[loaded],
            applyOne[k_String, v_] := Switch[k,
                "PolymakePath",                $PolymakeCommand = v,
                "GinshPath",                   $GinshCommand = v,
                "MaplePath",                   $MapleCommand = v,
                "HyperIntPath",                If[StringQ[v] && v =!= "", $SThyperIntPath = v] (* else keep auto-discovered value *),
                "HyperFlintPath",              If[StringQ[v] && v =!= "",
                                                   $STHyperFlintPath = v;
                                                   $STHyperFlintDataPath = stResolveHyperFlintDataPath[v]],
                "HyperFlintDataPath",          If[StringQ[v] && v =!= "" && FileExistsQ[v],
                                                   $STHyperFlintDataPath = v],
                "HyperLogProceduresPath",      If[StringQ[v] && v =!= "", $STHyperLogProceduresPath = v] (* else keep auto-discovered value *),
                "PythonPath",                  $PythonCommand = v,
                "PolymakeConcurrencyFraction", $PolymakeConcurrencyFraction = v,
                "FiniteFlowPath",              $FiniteFlowPath = v,
                "FIESTAPath",                  $FIESTAPath = v,
                "AMFlowPath",                  $AMFlowPath = v,
                "LiteRedPath",                 $LiteRedPath = v,
                "LiteIBPPath",                 $LiteIBPPath = v,
                "FIREPath",                    $FIREPath = v,
                "FeyntropPath",                $FeyntropPath = v,
                "BenchmarkNudge",              $ShowBenchmarkNudge = TrueQ[v],
                _, Null];
            KeyValueMap[applyOne, loaded]]]];

(* Option defaults are all `Inherited` so a partial call leaves un-named
   globals alone (rather than resetting them to a hard-coded default and
   persisting the reset to disk).  Initial-load defaults come from the
   $-variable bindings near the top of this file (around line 232) and
   from the persisted $STConfigFile loader (around line 1012).  This is
   the fix for B1 in notes/test_campaign_bugs.md. *)
Options[ConfigureSubTropica] = {
    PolymakePath                -> Inherited,
    GinshPath                   -> Inherited,
    MaplePath                   -> Inherited,
    HyperIntPath                -> Inherited,    (* "" = re-run auto-discovery; Inherited = no change *)
    HyperFlintPath              -> Inherited,    (* "" = re-run auto-discovery; Inherited = no change *)
    HyperFlintDataPath          -> Inherited,    (* "" = derive from binary; Inherited = no change *)
    HyperLogProceduresPath      -> Inherited,    (* "" = re-run auto-discovery; Inherited = no change *)
    PythonPath                  -> Inherited,
    PolymakeConcurrencyFraction -> Inherited,
    FiniteFlowPath              -> Inherited,    (* "" = no FF; Inherited = no change *)
    SPQRPath                    -> Inherited,
    FIESTAPath                  -> Inherited,
    AMFlowPath                  -> Inherited,
    LiteRedPath                 -> Inherited,
    LiteIBPPath                 -> Inherited,
    FIREPath                    -> Inherited,
    FeyntropPath                -> Inherited,
    BenchmarkNudge              -> Inherited
};
With[{$SubTropicaDir = DirectoryName[$InputFileName]},

$SubTropicaInstallDir = $SubTropicaDir;
$SubTropicaVersion = "1.2.0";

(* Init-order fix: line 109 set $STHyperFlintDataPath before
   $SubTropicaInstallDir was bound, so the install-dir-derived data
   candidate was skipped.  Re-resolve now that both are set, in case
   the binary-path-only candidates didn't cover the dist layout
   (e.g. paclet user with prebuilt HF dist but no source tree). *)
If[!StringQ[$STHyperFlintDataPath] || $STHyperFlintDataPath === "" ||
   !FileExistsQ[$STHyperFlintDataPath],
    $STHyperFlintDataPath = stResolveHyperFlintDataPath[$STHyperFlintPath]];

(* FindRoots root-letter substitutions: W$i -> algebraic root expressions.
   Set by STReadResults when the integration used FindRoots alphabet letters.
   Applied in stEvalSymbolicAtPoint for numerical evaluation. *)
$stRootSubstitutions = {};

(* True when the verification kinematic point is in the Euclidean region
   (-F > 0 for all x_i > 0), so no i\[CurlyEpsilon] displacement is needed. *)
$stEuclideanPoint = False;

(*  Load-time auto-detection: use FF path if FiniteFlow+SPQR are already on $Path  *)
(*  Variable names use x-prefix to avoid collision with SPQR internals that clobber spqrLoaded  *)
(* MG 2026-04-08: Check[Quiet[...]] instead of Quiet[Check[...]] so load failures are caught.
   $LibraryPath augmented with FiniteFlow package root (parent of mathlink/) so FindLibrary
   locates fflowmlink.dylib. FFLoadLib[] retried if already cached with unloaded library.
   $UseFFPolynomialQuotient verified via FFDefaultNThreadsImplem (reliable C-library indicator). *)
(* CheckAbort: Check[Quiet[...]] does NOT intercept Abort[] \[LongDash] only messages.
   A FF C-library load that aborts (e.g., stale .dylib, ABI mismatch) would
   otherwise bubble past this block and take the whole package load down. *)
CheckAbort[
Block[{Print=(Null)&},Module[{xffLoaded, xspqrLoaded, xffFile},
    xffFile = Quiet[FindFile["FiniteFlow`"]];
    If[StringQ[xffFile], (* MG 2026-04-08 *)
        $LibraryPath = DeleteDuplicates[Join[$LibraryPath, {ParentDirectory[DirectoryName[xffFile]]}]]
    ];
    xffLoaded = True;
    Check[Quiet[Needs["FiniteFlow`"]], xffLoaded = False];
    If[xffLoaded && !MatchQ[FiniteFlow`Private`FFDefaultNThreadsImplem, _LibraryFunction], (* MG 2026-04-08 *)
        Quiet[FFLoadLib[]]
    ];
    xspqrLoaded = True;
    Check[Quiet[Needs["SPQR`"]], xspqrLoaded = False];
    If[xffLoaded && xspqrLoaded,
        $PolynomialQuotientFFFile = FileNameJoin[{$SubTropicaDir, "PolynomialQuotientFF.wl"}];
        Quiet[Get[$PolynomialQuotientFFFile]];
        $UseFFPolynomialQuotient = MatchQ[DownValues[SPQRPolynomialQuotient], {__}] &&
                                    MatchQ[FiniteFlow`Private`FFDefaultNThreadsImplem, _LibraryFunction], (* MG 2026-04-08 *)
        $UseFFPolynomialQuotient = False
    ]
]],
    (* on Abort: fall back to pure-WL PolynomialQuotient. *)
    $UseFFPolynomialQuotient = False;
    Print["[SubTropica] FF/SPQR auto-detect aborted; falling back to PolynomialQuotient[]."]];
If[$UseFFPolynomialQuotient,
    $STDependencies["FiniteFlow", "status"] = "ok";
    (* Record the FiniteFlow`.m path for the dependency-table view; FindFile
       after the Needs[] call resolves to the same file the load used.
       The FiniteFlow package doesn't bake in a version string, so fall back
       to the short git SHA of the checkout (matches what we do for
       feyntrop). *)
    Module[{ffPkg = Quiet[FindFile["FiniteFlow`"]], gr, repoRoot},
      If[StringQ[ffPkg],
        $STDependencies["FiniteFlow", "resolvedPath"] = ffPkg;
        repoRoot = ParentDirectory[DirectoryName[ffPkg]];
        gr = Quiet @ Check[
          TimeConstrained[
            RunProcess[{"git", "-C", repoRoot, "rev-parse", "--short", "HEAD"}],
            5, $TimedOut],
          $Failed];
        If[AssociationQ[gr] && gr["ExitCode"] === 0,
          $STDependencies["FiniteFlow", "version"] =
            "git " <> StringTrim[gr["StandardOutput"]]]]],
    $STDependencies["FiniteFlow", "status"] = "missing"
];

(* Polymake required-dependency check.  Polymake is the ONLY required external
   binary; without it any tropical analysis (STIntegrate, STTropicalAnalysis,
   ...) fails.  The greeting banner prints a checkbox strip and, below it,
   a warning block if polymake (or any other required dep) is missing. *)

(*  ConfigureSubTropica: for explicit path overrides or re-configuration.

    Each option's default is `Inherited` (see Options[ConfigureSubTropica]
    above).  We assign a global only when the caller actually supplied that
    option, so a partial call like ConfigureSubTropica[PythonPath -> X]
    leaves $AMFlowPath / $FeyntropPath / etc. alone instead of resetting
    them to package defaults and persisting the reset.  *)
ConfigureSubTropica[opts:OptionsPattern[]] := Module[
    {ffPath, spqrPath, ffLoaded, spqrLoaded, ffSpqrTouched},
    If[OptionValue[PolymakePath]   =!= Inherited, $PolymakeCommand = OptionValue[PolymakePath]];
    If[OptionValue[GinshPath]      =!= Inherited, $GinshCommand    = OptionValue[GinshPath]];
    If[OptionValue[MaplePath]      =!= Inherited, $MapleCommand    = OptionValue[MaplePath]];
    (* HyperInt / HyperFLINT keep the legacy "" sentinel for "re-run
       auto-discovery"; Inherited (the default) means "leave alone". *)
    Module[{hp = OptionValue[HyperIntPath]},
        If[hp =!= Inherited,
            $SThyperIntPath = If[StringQ[hp] && hp =!= "", hp, stDiscoverHyperInt[]]]];
    Module[{hfp = OptionValue[HyperFlintPath],
            hfd = OptionValue[HyperFlintDataPath]},
        If[hfp =!= Inherited,
            $STHyperFlintPath = If[StringQ[hfp] && hfp =!= "", hfp, stDiscoverHyperFlint[]]];
        Which[
            hfd =!= Inherited && StringQ[hfd] && hfd =!= "" && FileExistsQ[hfd],
                $STHyperFlintDataPath = hfd,
            hfp =!= Inherited,
                $STHyperFlintDataPath = stResolveHyperFlintDataPath[$STHyperFlintPath]]];
    Module[{hlp = OptionValue[HyperLogProceduresPath]},
        If[hlp =!= Inherited,
            $STHyperLogProceduresPath = If[StringQ[hlp] && hlp =!= "", hlp, stDiscoverHyperLogProcedures[]]]];
    If[OptionValue[PythonPath]                  =!= Inherited, $PythonCommand               = OptionValue[PythonPath]];
    If[OptionValue[PolymakeConcurrencyFraction] =!= Inherited, $PolymakeConcurrencyFraction = OptionValue[PolymakeConcurrencyFraction]];
    If[OptionValue[FIESTAPath]                  =!= Inherited, $FIESTAPath                  = OptionValue[FIESTAPath]];
    If[OptionValue[AMFlowPath]                  =!= Inherited, $AMFlowPath                  = OptionValue[AMFlowPath]];
    If[OptionValue[LiteRedPath]                 =!= Inherited, $LiteRedPath                 = OptionValue[LiteRedPath]];
    If[OptionValue[LiteIBPPath]                 =!= Inherited, $LiteIBPPath                 = OptionValue[LiteIBPPath]];
    If[OptionValue[FIREPath]                    =!= Inherited, $FIREPath                    = OptionValue[FIREPath]];
    If[OptionValue[FeyntropPath]                =!= Inherited, $FeyntropPath                = OptionValue[FeyntropPath]];
    If[OptionValue[BenchmarkNudge]              =!= Inherited, $ShowBenchmarkNudge          = TrueQ[OptionValue[BenchmarkNudge]]];

    (* Distribute $PolymakeCommand to any already-running subkernels
       so they can call polymake even if ConfigureSubTropica is called
       after STSetupKernel. *)
    If[Length[Kernels[]] > 0,
        DistributeDefinitions[$PolymakeCommand]
    ];

    (*  FiniteFlow / SPQR detection.  Only run if the caller actually
        passed at least one of FiniteFlowPath / SPQRPath; otherwise the
        load-time / persisted state is preserved and we don't re-print
        any banner. *)
    ffPath   = OptionValue[FiniteFlowPath];
    spqrPath = OptionValue[SPQRPath];
    ffSpqrTouched = (ffPath =!= Inherited) || (spqrPath =!= Inherited);
    If[ffPath =!= Inherited, $FiniteFlowPath = ffPath];

    If[ffSpqrTouched,
        (* Treat the omitted side as "" (no path), matching the old contract. *)
        If[ffPath   === Inherited, ffPath   = ""];
        If[spqrPath === Inherited, spqrPath = ""];

        (* Validate that provided paths exist before using them.
           Explicit paths override auto-detection: if a provided path is invalid,
           disable FF and report it. *)
        If[ffPath   =!= "" && !DirectoryQ[ffPath],
            $UseFFPolynomialQuotient = False;
            Print["Provided FiniteFlowPath \"", ffPath, "\" not found; FF disabled. PartialFractions[] will use PolynomialQuotient[]."];
            Return[]
        ];
        If[spqrPath =!= "" && !DirectoryQ[spqrPath],
            $UseFFPolynomialQuotient = False;
            Print["Provided SPQRPath \"", spqrPath, "\" not found; FF disabled. PartialFractions[] will use PolynomialQuotient[]."];
            Return[]
        ];

        (* Prepend valid user-supplied paths so Needs[] can locate the packages *)
        If[ffPath   =!= "", PrependTo[$Path, ffPath]];
        If[spqrPath =!= "", PrependTo[$Path, spqrPath]];

        (* MG 2026-04-08: augment $LibraryPath with ffPath and its parent (package root) *)
        If[ffPath =!= "",
            $LibraryPath = DeleteDuplicates[Join[$LibraryPath, {ffPath, ParentDirectory[ffPath]}]]];

        ffLoaded = True;
        Check[Quiet[Needs["FiniteFlow`"]], ffLoaded = False]; (* MG 2026-04-08: Check[Quiet[...]] *)
        If[ffLoaded && !MatchQ[FiniteFlow`Private`FFDefaultNThreadsImplem, _LibraryFunction], (* MG 2026-04-08 *)
            Quiet[FFLoadLib[]]
        ];
        spqrLoaded = True;
        Check[Quiet[Needs["SPQR`"]], spqrLoaded = False];

        If[ffLoaded && spqrLoaded,
            Quiet[Get[FileNameJoin[{$SubTropicaDir, "PolynomialQuotientFF.wl"}]]];
            $UseFFPolynomialQuotient = MatchQ[DownValues[SPQRPolynomialQuotient], {__}] &&
                                        MatchQ[FiniteFlow`Private`FFDefaultNThreadsImplem, _LibraryFunction]; (* MG 2026-04-08 *)
            If[$UseFFPolynomialQuotient,
                Print["FiniteFlow and SPQR loaded; PartialFractions[] will use SPQRPolynomialQuotient[]."],
                Print["FiniteFlow WL package loaded but C library could not be found; using PolynomialQuotient[]."]
            ],
            $UseFFPolynomialQuotient = False;
            Print["FiniteFlow/SPQR not found; using PolynomialQuotient[] in partial fractions."]
        ]
    ];

    (* Re-test all dependencies after path changes *)
    stRunDependencyChecks[];

    (* Persist the current configuration to $STConfigFile so the next kernel
       picks it up automatically on Get["SubTropica`"].  Silent on failure
       (e.g. read-only $UserBaseDirectory). *)
    Module[{config},
        config = <|
            "PolymakePath"                -> $PolymakeCommand,
            "GinshPath"                   -> $GinshCommand,
            "MaplePath"                   -> $MapleCommand,
            "HyperIntPath"                -> $SThyperIntPath,
            "HyperFlintPath"              -> $STHyperFlintPath,
            "HyperLogProceduresPath"      -> $STHyperLogProceduresPath,
            "PythonPath"                  -> $PythonCommand,
            "PolymakeConcurrencyFraction" -> $PolymakeConcurrencyFraction,
            "FiniteFlowPath"              -> $FiniteFlowPath,
            "FIESTAPath"                  -> $FIESTAPath,
            "AMFlowPath"                  -> $AMFlowPath,
            "LiteRedPath"                 -> $LiteRedPath,
            "LiteIBPPath"                 -> $LiteIBPPath,
            "FIREPath"                    -> $FIREPath,
            "FeyntropPath"                -> $FeyntropPath,
            "BenchmarkNudge"              -> $ShowBenchmarkNudge|>;
        Quiet[CreateDirectory[DirectoryName[$STConfigFile],
            CreateIntermediateDirectories -> True]];
        Quiet[Put[config, $STConfigFile]]];
]];

(* STResetConfig[] removes the persistent config so the next package load
   uses the package defaults. *)
STResetConfig[] := If[FileExistsQ[$STConfigFile],
    DeleteFile[$STConfigFile];
    Print["[SubTropica] Removed config: ", $STConfigFile];
    Print["[SubTropica] Defaults will apply on next Get[\"SubTropica`\"]."],
    Print["[SubTropica] No saved config to remove (", $STConfigFile, ")."]];


