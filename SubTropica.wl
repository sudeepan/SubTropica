                    raise ValueError('bad path or recordId')
                with open(full, 'r', encoding='utf-8') as f:
                    raw = f.read()
                entry = json.loads(raw)
                # Find the record and the reference it pins to.
                removed_ref = None
                records = entry.get('Records', [])
                new_records = []
                for rec in records:
                    if rec.get('recordId') == rid and removed_ref is None:
                        removed_ref = rec.get('reference', '')
                        continue
                    new_records.append(rec)
                if removed_ref is None:
                    raise ValueError('recordId not found')
                entry['Records'] = new_records
                # Remove the matching reference string only if no other Record still cites it.
                refs = entry.get('References', [])
                still_cited = any(r.get('reference') == removed_ref for r in new_records)
                if not still_cited and removed_ref in refs:
                    entry['References'] = [r for r in refs if r != removed_ref]
                review_atomic_write(full, review_serialize(entry, raw))
                review_invalidate_library_cache()
                self._ok('application/json',
                         json.dumps({'status': 'ok',
