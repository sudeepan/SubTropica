                if not full or new_entry is None:
                    raise ValueError('bad path or missing entry')
                # Preserve the original file style
                raw = ''
                if os.path.isfile(full):
                    with open(full, 'r', encoding='utf-8') as f:
                        raw = f.read()
                review_atomic_write(full, review_serialize(new_entry, raw))
                review_invalidate_library_cache()
                self._ok('application/json', json.dumps({'status': 'ok'}))
