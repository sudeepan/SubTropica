(* ================================================================== *)
(*  SubTropica  - Kernel Server (Step 3)          *)
(*                                                                      *)
(*  Serves the SubTropica web UI and handles API endpoints:           *)
(*    POST /api/lock       - topology analysis                *)
(*    POST /api/integrate  - collect config, return result    *)
(*    POST /api/cancel     - user canceled                    *)
(*    GET  /api/ping       - heartbeat                       *)
(*                                                                      *)
(*  USAGE:                                                              *)
(*    Get["SubTropica.m"]                                        *)
(*    result = SubTropica[]                                                 *)
(*    result = SubTropica["Verbose" -> True]  (* debug output *)            *)
(*    (* Opens native window, blocks until Integrate or Cancel *)      *)
(*    (* result is either the config Association or $Canceled *)        *)
(*                                                                      *)
(*  REQUIREMENTS: Mathematica 12.0+, SubTropica` package loaded        *)
(* ================================================================== *)

Options[FeynmanIntegrate] = {"Verbose" -> False};
Options[SubTropica] = {"Verbose" -> False};

(* \[HorizontalLine]\[HorizontalLine] Global state \[HorizontalLine]\[HorizontalLine] *)
$uiResult = None;
$viewerProcess = None;
$serverObj = None;
$stServerURL = None;   (* set by STIntegrate when the local Python server starts *)
$stServerPort = None;
$cacheDir = FileNameJoin[{$TemporaryDirectory, "SubTropica"}];
$stVerbose = False;

(* Gate for FeynmanIntegrate[]'s CellPrint calls.  When False (default),
   the GUI does not add reproducible STIntegrate[...] command cells or
   result cells to the user's main notebook.  Set to True for the
   previous behaviour (useful when you want to keep a runnable
   reproduction of the session).  Requested by Giulio, 2026-04-21. *)
$stPrintCells = False;

(* \[HorizontalLine]\[HorizontalLine] Logging helpers \[HorizontalLine]\[HorizontalLine] *)
(* stLog: only prints when Verbose is True *)
stLog[args___] := If[$stVerbose, Print[args]];
(* stErr: always prints (errors and critical status) *)
stErr[args___] := Print[args];

(* stWithSuppressedOutput: evaluate `expr` with $Output and $Echo
   redirected to a kernel.log file under the given IPC directory.
   Used by the UI request dispatchers (processOneRequest and the
   VERIFY_REQUEST handler) so that Print/Echo output from any handler
   \[LongDash] including third-party backends like FIESTA whose Print calls
   we don't control \[LongDash] does not spam the user's notebook
   front-end.  Status the user actually needs (the integrate/verify
   result association) flows through the JSON response file, not
   through Print. *)
SetAttributes[stWithSuppressedOutput, HoldRest];
stWithSuppressedOutput[ipcDir_String, expr_] := Module[
    {logFile, logStream, result},
    logFile = FileNameJoin[{ipcDir, "kernel.log"}];
    logStream = Quiet @ OpenAppend[logFile, CharacterEncoding -> "UTF-8"];
    If[logStream === $Failed,
        (* If we cannot open the log file, fall through and let Print
           go wherever it normally would \[LongDash] better noisy than dropped. *)
        result = expr,
        result = Block[{$Output = {logStream}, $Echo = {logStream}},
            expr];
        Quiet @ Close[logStream]];
    result];

(* stFormatHeldMessage: render a message captured via Internal`HandlerBlock
   (a held form like Hold[Message[STVerify::feyntropPoles, "x"], False])
   as a single human-readable string, e.g.:
       "STVerify::feyntropPoles: feyntrop only verifies finite ..."
   Used by the verify handler in handleVerify and STSubmitResult to surface
   the real cause of a failure in verify_result.json (B7). *)
SetAttributes[stFormatHeldMessage, HoldFirst];
stFormatHeldMessage[Hold[Message[mn_, args___], _]] := Module[
    {tag, template, rendered},
    tag = ToString[Unevaluated[mn]];  (* "STVerify::feyntropPoles" *)
    template = Quiet @ Check[mn, ""];
    rendered = If[StringQ[template] && template =!= "",
        Quiet @ Check[ToString[StringForm[template, args]], ""],
        ""];
    If[rendered =!= "",
        tag <> ": " <> rendered,
        tag <> If[Length[{args}] === 0, "",
            ": " <> StringRiffle[ToString[#, InputForm] & /@ {args}, ", "]]]
];
stFormatHeldMessage[other_] := ToString[other, InputForm];

(* Tags emitted by Mathematica internals that swamp the captured-messages
   list during a normal STVerify call (e.g. import probing during library
   lookup, our own SeriesData-pattern probe in stFormatHeldMessage's
   pole-detection sibling).  Filtered out before the messages array is
   shown in the JSON; the tags-to-drop list can be expanded as we hit new
   noise. *)
$stMessageNoiseTagPrefixes = {
    "MIMETypeToFormatList::",
    "SeriesData::sdatc",
    "General::newsym",
    "General::shdw",
    "Series::serlim",
    (* B12: messages that fire on every wolframscript invocation simply
       because there is no notebook front end / no parallel kernels yet
       to talk to.  Without filtering these, the B6/B7 surfacing logic
       would happily pick up `FrontEndObject::notavail` or
       `KernelObject::timekernels` as the first captured message and
       report it as the cause of an unrelated failure (the campaign
       saw "Failed: FrontEndObject::notavail" on bubble-equal-mass
       integrate failures whose real cause was buried further down the
       message stream). *)
    "FrontEndObject::notavail",
    "KernelObject::timekernels",
    "TaskRemove::taskid",
    "CreateDirectory::eexist",
    "LibraryFunction::overload",
    "Set::write"
};
stIsNoiseMessage[s_String] := AnyTrue[$stMessageNoiseTagPrefixes,
    StringStartsQ[s, #] &];
stIsNoiseMessage[_] := False;

(* stCleanupCapturedMessages: format + filter + dedupe. Used at every
   call site that reports captured messages to a JSON consumer. *)
stCleanupCapturedMessages[heldList_List] := DeleteDuplicates @ Select[
    stFormatHeldMessage /@ heldList,
    !stIsNoiseMessage[#] &];

(* \[HorizontalLine]\[HorizontalLine] Locked topology state (set by /api/lock) \[HorizontalLine]\[HorizontalLine] *)
$anResult = <||>;
$efl = {};
$n0r = {};
$ne = 0;
$nl = 0;
$nloops = 0;
$edgeMomenta = {};
$chordEdges = {};
$intm = {};
$extm = {};
$loopMomenta = {};
$extMomLabels = {};
$propExponents = {};
$edgeList = {};  (* original drawing edge list, for FeynmanPlot *)


(* ================================================================== *)
(*  TOPOLOGY HELPER FUNCTIONS                                          *)
(*  (extracted from SubTropica_v4_25.wl DynamicModule init)      *)
(* ================================================================== *)

(* Suppress shadowing warnings for l, p etc.
   which may conflict with SubTropica` symbols *)
Off[General::shdw];

feynmanAnalyzeTopology[edgePairs_List] := Module[
  {edgelist2 = edgePairs, extnodes, extPositions, partnerPositions, nodes0,
   extEdgeRows, edgelist3, vertices, nodes1, ivertices, reordering,
   edgelistfinal, nedges, nlegs, nloops},

  If[Length[edgelist2] == 0,
    Return[<|"edgelistfinal" -> {}, "nodes0" -> {}, "nodes0reordered" -> {},
      "vertices" -> {}, "reordering" -> {}, "nIntEdges" -> 0,
      "nExtLegs" -> 0, "nVertices" -> 0, "nLoops" -> 0|>]];

  extnodes = Select[Tally[Flatten[edgelist2]], #[[2]] == 1 &][[All, 1]];

  If[Length[extnodes] == 0,
    edgelist3 = Sort /@ edgelist2;
    vertices = edgelist3 // Flatten // DeleteDuplicates;
    reordering = Thread[vertices -> Range[Length[vertices]]];
    edgelistfinal = Sort /@ (edgelist3 /. reordering);
    nedges = Length[edgelistfinal];
    nloops = nedges - Length[vertices] + 1;
    Return[<|"edgelistfinal" -> edgelistfinal, "nodes0" -> {},
      "nodes0reordered" -> {}, "vertices" -> vertices,
      "reordering" -> reordering, "nIntEdges" -> nedges,
      "nExtLegs" -> 0, "nVertices" -> Length[vertices],
      "nLoops" -> nloops|>]];

  (* Preserve JS edge ordering: extract external legs in the order they
     appear in edgelist2 (= state.edges from JS canvas). Do NOT sort nodes0
     \[LongDash] the i-th external leg in JS should be p[i] in the kernel. *)
  extPositions = Position[edgelist2, #][[1]] & /@ extnodes;
  partnerPositions = extPositions /. {{r_, 1} -> {r, 2}, {r_, 2} -> {r, 1}};
  nodes0 = Extract[edgelist2, partnerPositions]; (* preserve JS order \[LongDash] no Sort *)
  extEdgeRows = extPositions[[All, 1]];
  edgelist3 = Sort /@ Delete[edgelist2, List /@ extEdgeRows];
  vertices = edgelist3 // Flatten // DeleteDuplicates;
  nodes1 = DeleteDuplicates[nodes0]; (* unique vertices, in first-appearance order *)
  ivertices = Complement[vertices, nodes1];
  reordering = Join[
    Thread[nodes1 -> Range[Length[nodes1]]],
    Thread[ivertices -> Range[Length[nodes1] + 1, Length[nodes1] + Length[ivertices]]]];
  edgelistfinal = Sort /@ (edgelist3 /. reordering);
  nedges = Length[edgelistfinal];
  nlegs = Length[nodes0];
  nloops = nedges - Length[vertices] + 1;

  <|"edgelistfinal" -> edgelistfinal, "nodes0" -> nodes0,
    "nodes0reordered" -> (nodes0 /. reordering), "vertices" -> vertices,
    "reordering" -> reordering, "nIntEdges" -> nedges,
    "nExtLegs" -> nlegs, "nVertices" -> Length[vertices],
    "nLoops" -> nloops|>
];


autoRouteMomenta[edgelistfinal_List, n0reordered_List,
                  numLoops_Integer, loopMomList_List, extMomList_List,
                  presetChords_List:{}] :=
  Quiet[Module[{ne2, nv, adjList, visited, treeEdges, chords, queue, currV,
          nbr, eidx, momenta, extMom, equations, unknowns, sol, allVerts},
    ne2 = Length[edgelistfinal];
    If[ne2 == 0, Return[{{}, {}}]];
    allVerts = Flatten[edgelistfinal] // DeleteDuplicates // Sort;
    nv = If[Length[allVerts] > 0, Max[allVerts], 0];
    If[nv == 0, Return[{Table[Null, {ne2}], {}}]];
    adjList = Table[{}, {nv}];
    Do[With[{a = edgelistfinal[[i, 1]], b = edgelistfinal[[i, 2]]},
      adjList[[a]] = Append[adjList[[a]], {i, b}];
      adjList[[b]] = Append[adjList[[b]], {i, a}]], {i, ne2}];
    If[Length[presetChords] > 0,
      (* Use JS-provided chord indices instead of BFS *)
      chords = presetChords;
      treeEdges = Complement[Range[ne2], chords];
      ,
      (* BFS spanning tree *)
      visited = Table[False, {nv}]; treeEdges = {};
      Do[If[MemberQ[allVerts, startV] && !visited[[startV]],
        queue = {startV}; visited[[startV]] = True;
        While[Length[queue] > 0,
          currV = First[queue]; queue = Rest[queue];
          Do[{eidx, nbr} = adjList[[currV]][[jj]];
            If[!visited[[nbr]], visited[[nbr]] = True;
              AppendTo[treeEdges, eidx]; AppendTo[queue, nbr]],
            {jj, Length[adjList[[currV]]]}]]], {startV, nv}];
      chords = Complement[Range[ne2], treeEdges];
    ];
    momenta = Table[Null, {ne2}];
    Do[momenta[[chords[[i]]]] =
      If[i <= Length[loopMomList], loopMomList[[i]], l[i]],
      {i, Min[numLoops, Length[chords]]}];
    Do[momenta[[treeEdges[[i]]]] = qTree[i], {i, Length[treeEdges]}];
    extMom = If[Length[extMomList] == Length[n0reordered], extMomList,
      Table[p[i], {i, Length[n0reordered]}]];
    equations = Table[
      Sum[If[edgelistfinal[[e, 2]] == vv, momenta[[e]], 0] -
        If[edgelistfinal[[e, 1]] == vv, momenta[[e]], 0], {e, ne2}]
      + Sum[If[n0reordered[[i]] == vv, extMom[[i]], 0],
        {i, Length[n0reordered]}] == 0, {vv, allVerts}];
    unknowns = Table[qTree[i], {i, Length[treeEdges]}];
    sol = Quiet[Solve[
      If[Length[equations] > Length[unknowns],
        equations[[;; Length[unknowns]]], equations], unknowns]];
    If[Length[sol] > 0, momenta = momenta /. sol[[1]] // Expand];
    (*Apply total momentum conservation per edge, only when it simplifies*)
    If[Length[extMom] >= 2,
      momenta = Table[Module[{mNew},
        mNew = Expand[momenta[[k]] /. extMom[[-1]] -> -Total[Most[extMom]]];
        If[LeafCount[mNew] < LeafCount[momenta[[k]]], mNew, momenta[[k]]]
      ], {k, Length[momenta]}]];
    {momenta, chords}
  ], General::shdw];


autoCompleteMomenta[edgelistfinal_List, n0reordered_List,
                     currentMomenta_List, numLoops_Integer, extMomList_List] :=
  Quiet[Module[{ne2, allVerts, momenta, filledQ, unknownIndices, unknowns,
          extMom, equations, sol},
    ne2 = Length[edgelistfinal];
    If[ne2 == 0, Return[{}]];
    allVerts = Flatten[edgelistfinal] // DeleteDuplicates // Sort;
    momenta = currentMomenta;
    filledQ = Table[!(momenta[[i]] === Null || momenta[[i]] === Automatic ||
      momenta[[i]] === 0), {i, ne2}];
    unknownIndices = Select[Range[ne2], !filledQ[[#]] &];
    If[Length[unknownIndices] == 0, Return[momenta]];
    Do[momenta[[unknownIndices[[i]]]] = qAuto[i],
      {i, Length[unknownIndices]}];
    extMom = If[Length[extMomList] == Length[n0reordered], extMomList,
      Table[p[i], {i, Length[n0reordered]}]];
    equations = Table[
      Sum[If[edgelistfinal[[e, 2]] == vv, momenta[[e]], 0] -
        If[edgelistfinal[[e, 1]] == vv, momenta[[e]], 0], {e, ne2}]
      + Sum[If[n0reordered[[i]] == vv, extMom[[i]], 0],
        {i, Length[n0reordered]}] == 0, {vv, allVerts}];
    unknowns = Table[qAuto[i], {i, Length[unknownIndices]}];
    sol = Quiet[Solve[
      If[Length[equations] > Length[unknowns],
        equations[[;; Length[unknowns]]], equations], unknowns]];
    If[Length[sol] > 0, momenta = momenta /. sol[[1]] // Expand];
    (*Apply total momentum conservation per edge, only when it simplifies*)
    If[Length[extMom] >= 2,
      momenta = Table[Module[{mNew},
        mNew = Expand[momenta[[k]] /. extMom[[-1]] -> -Total[Most[extMom]]];
        If[LeafCount[mNew] < LeafCount[momenta[[k]]], mNew, momenta[[k]]]
      ], {k, Length[momenta]}]];
    momenta
  ], General::shdw];


(* Preferred entry point: takes the natural {edges, nodes} pair and handles
   vertex/mass alignment internally.  edges have shape {{{v1, v2}, mass}, ...};
   nodes have shape {{vertex, extMass}, ...}.  Vertices may appear in any
   order in `nodes` -- this signature sorts them and permutes the external
   masses to keep them aligned.

   The 4-arg signature below was the original interface and SILENTLY
   mis-aligns external masses when the caller passes Sort[nodeVerts] without
   permuting nodeMasses to match.  Many entries in the library happened to
   have nodes already sorted by vertex, so the bug was hidden.  Entries
   like e12|e3|e3|e|:000|10|10|0| (2-mass-easy box) had unsorted nodes and
   produced wrong canonical CNIs that collided with 2-mass-hard variants. *)
computeNickelIndex[edges_List, nodes_List] /;
    AllTrue[edges, MatchQ[#, {{_, _}, _}] &] &&
    AllTrue[nodes, MatchQ[#, {_, _}] &] :=
  Module[{sortedNodes = SortBy[nodes, First]},
    computeNickelIndex[
      edges[[All, 1]],
      sortedNodes[[All, 1]],
      edges[[All, 2]],
      sortedNodes[[All, 2]]]];

computeNickelIndex[edgelistfinal_List, n0reordered_List,
                    intMasses_List, extMasses_List] :=
  Module[{ne2, nv, allVerts, extLegsAt, edgeMassMap,
          perms, bestStr = "", tryPerm, nickelStr, canonicalizeColor,
          n0c, extc, vertexMasses},
    ne2 = Length[edgelistfinal];
    allVerts = Flatten[edgelistfinal] // DeleteDuplicates // Sort;
    nv = Length[allVerts];
    If[nv == 0, Return[""]];
    (* Combine multiple external legs at the same vertex into a single
       effective leg. For any scalar Feynman integral, the integrand at a
       vertex depends only on the TOTAL incoming external momentum there,
       not on the individual legs. So two or more external legs attaching
       at the same vertex are integrand-equivalent to one effective leg
       carrying the combined momentum. The combined leg's mass\.b2 = (\[CapitalSigma]p\:1d62)\.b2
       is generically an independent scale (new symbol), so each combined
       vertex gets a fresh mass label. This is the counterpart of
       ui/app.js:buildCollapsedEdgeData(). *)
    vertexMasses = <||>;
    Do[Module[{v = n0reordered[[i]],
               mm = If[i <= Length[extMasses], extMasses[[i]], 0]},
      If[KeyExistsQ[vertexMasses, v],
        AppendTo[vertexMasses[v], mm],
        vertexMasses[v] = {mm}]
    ], {i, Length[n0reordered]}];
    n0c = Keys[vertexMasses];
    (* Combined mass is always a new scale \[LongDash] (\[CapitalSigma]p\:1d62)\.b2 is generically
       independent of the individual p\:1d62\.b2, even when all p\:1d62\.b2 are equal.
       Exception: a single leg at a vertex just keeps its own mass.
       Special case: if ALL external legs combine at a single vertex
       (i.e. only one distinct vertex has externals), momentum
       conservation forces the total external momentum there to zero,
       and the graph degenerates to a vacuum integral. *)
    extc = Map[
      Function[ms, If[Length[ms] == 1, First[ms], Unique["Mcomb$"]]],
      Values[vertexMasses]];
    extLegsAt = <||>;
    If[Length[n0c] == 1 && Length[vertexMasses[First[n0c]]] > 1,
      (* All externals at one vertex \[RightArrow] vacuum *)
      Null,
      Do[extLegsAt[n0c[[i]]] = {extc[[i]]}, {i, Length[n0c]}]
    ];
	 edgeMassMap = Association[
      Table[i -> If[i <= Length[intMasses], intMasses[[i]], 0], {i, ne2}]];
    (* Relabel mass tokens by first occurrence for lex-minimal color.
       Tokens: "0", "|", "n" pass through; integer mass values get
       relabeled to "1", "2", ... in order of first appearance. *)
    canonicalizeColor[tokens_List] := Module[{mapping = <||>, next = 1,
        res = {}},
      Do[If[StringQ[tok],
        AppendTo[res, tok],
        If[KeyExistsQ[mapping, tok],
          AppendTo[res, mapping[tok]],
          mapping[tok] = ToString[next];
          AppendTo[res, ToString[next]]; next++]
      ], {tok, tokens}];
      StringJoin[res]];

    tryPerm[perm_] := Module[{relabel, invPerm, bareParts, vertexData,
        origV, edgeInfos, extMs, bareStr, colorStr, hasMultiEdge,
        perVertexOrderings, bestColor, combos, colorTokens},
      relabel = AssociationThread[allVerts -> (perm - 1)];
      invPerm = AssociationThread[(perm - 1) -> allVerts];
      bareParts = {}; vertexData = {};
      Do[origV = invPerm[v];
        edgeInfos = SortBy[Flatten[Table[
          Module[{a = relabel[edgelistfinal[[e, 1]]],
                  b = relabel[edgelistfinal[[e, 2]]],
                  mv = edgeMassMap[e]},
            (* Self-loops (a==b==v) must be recorded in v's stanza (as v
               itself); otherwise the loop silently vanishes from the Nickel
               and graphs with tadpoles round-trip incorrectly. *)
            Which[
              a == v && b == v, {{v, mv}},
              a == v && b > v, {{b, mv}},
              b == v && a > v, {{a, mv}},
              True, {}]
          ], {e, ne2}], 1], First]; (* sort by neighbor only *)
        extMs = Lookup[extLegsAt, origV, {}];
        AppendTo[bareParts, StringJoin[
          Join[Table["e", {Length[extMs]}],
               ToString[#[[1]]] & /@ edgeInfos]]];
        (* Group multi-edges by neighbor *)
        AppendTo[vertexData, {v, extMs,
          If[Length[edgeInfos] > 0,
            SplitBy[edgeInfos, First],
            {}]}];
      , {v, 0, nv - 1}];
      bareStr = StringRiffle[bareParts, "|"] <> "|";

      (* Check if any multi-edge groups exist *)
      hasMultiEdge = AnyTrue[vertexData,
        AnyTrue[#[[3]], Length[#] > 1 &] &];

      If[!hasMultiEdge,
        (* Fast path: no multi-edges *)
        colorTokens = {};
        Do[Module[{vv = vd[[1]], ems = vd[[2]], grps = vd[[3]]},
          If[vv > 0, AppendTo[colorTokens, "|"]];
          Do[AppendTo[colorTokens, If[mv === 0 || mv === 0., "0", mv]],
            {mv, ems}];
          Do[Do[AppendTo[colorTokens,
            If[ei[[2]] === 0 || ei[[2]] === 0., "0", ei[[2]]]],
            {ei, grp}], {grp, grps}];
        ], {vd, vertexData}];
        colorStr = canonicalizeColor[colorTokens] <> "|",
        (* Slow path: try all orderings of multi-edge groups *)
        perVertexOrderings = Table[
          Module[{grps = vd[[3]], groupPerms},
            groupPerms = If[Length[#] > 1, Permutations[#], {#}] & /@ grps;
            If[Length[groupPerms] == 0, {{}},
              Flatten[#, 1] & /@ Tuples[groupPerms]]
          ], {vd, vertexData}];
        bestColor = None;
        Do[colorTokens = {};
          Do[Module[{vi, vd, ems, flat},
            vi = idx; vd = vertexData[[vi]]; ems = vd[[2]];
            flat = combo[[vi]];
            If[vd[[1]] > 0, AppendTo[colorTokens, "|"]];
            Do[AppendTo[colorTokens, If[mv === 0 || mv === 0., "0", mv]],
              {mv, ems}];
            Do[AppendTo[colorTokens,
              If[ei[[2]] === 0 || ei[[2]] === 0., "0", ei[[2]]]],
              {ei, flat}];
          ], {idx, Length[vertexData]}];
          Module[{c = canonicalizeColor[colorTokens] <> "|"},
            If[bestColor === None || Order[c, bestColor] == 1,
              bestColor = c]];
        , {combo, Tuples[perVertexOrderings]}];
        colorStr = bestColor;
      ];
      (* Convention: always include explicit color suffix, even when *)
      (* all-massless. Keeps CNickelIndex format consistent.          *)
      bareStr <> ":" <> colorStr
    ];

    perms = If[nv <= 8, Permutations[Range[nv]], {Range[nv]}];
    bestStr = tryPerm[First[perms]];
    Do[nickelStr = tryPerm[p2];
      If[Order[nickelStr, bestStr] == 1, bestStr = nickelStr],
      {p2, Rest[perms]}];
    bestStr
  ];


(* \[HorizontalLine]\[HorizontalLine] STCNickelToGraph: reconstruct {edges, nodes} from CNickelIndex \[HorizontalLine]\[HorizontalLine] *)
(* Inverse of computeNickelIndex.  Given a CNickelIndex string like
   "e12|e2|e|:100|20|3|", returns {edges, nodes} in STIntegrate format:
     edges = {{{v1,v2}, mass}, ...}   (1-indexed vertices)
     nodes = {{v, extMass}, ...}
   Mass labeling follows the UI thumbnail convention (generateThumbnail):
     - internal mass digit d \[Rule] m  (single scale) or m[d] (multiple)
     - external-only digit d \[Rule] M  (single scale) or M[d] (multiple)
     - shared digit (both internal + external) \[Rule] m / m[d]
     - 2-leg functions: all external legs \[Rule] M                          *)

STCNickelToGraph[cni_String] := Module[
  {bare, massStr, bareSegs, massSegs, nickelList, massList,
   edges, legs, internalDigits, externalDigits, extOnlyDigits,
   mScales, bigMScales, massMap, nLegs, edgesOut, nodesOut,
   charToNode},

  (* --- 1. Split CNI into bare + mass parts --- *)
  If[StringContainsQ[cni, ":"],
    {bare, massStr} = StringSplit[cni, ":", 2],
    bare = cni;
    massStr = StringReplace[bare, c : Except["|"] :> "0"]];

  (* --- 2. Parse bare Nickel string \[Rule] nickelList (0-indexed) --- *)
  (* Character \[Rule] node mapping: "e"\[Rule]-1 (LEG), "0"-"9"\[Rule]0-9, "A"-"Z"\[Rule]10-35 *)
  charToNode[c_String] := Which[
    c === "e", -1,
    DigitQ[c], ToExpression[c],
    UpperCaseQ[c], ToCharacterCode[c][[1]] - ToCharacterCode["A"][[1]] + 10,
    True, $Failed];

  bareSegs = StringSplit[bare, "|", All];
  massSegs = StringSplit[massStr, "|", All];
  (* Drop trailing empty segments from final "|" *)
  If[Length[bareSegs] > 0 && Last[bareSegs] === "", bareSegs = Most[bareSegs]];
  If[Length[massSegs] > 0 && Last[massSegs] === "", massSegs = Most[massSegs]];
  If[Length[bareSegs] == 0, Return[$Failed]];
  (* Pad massSegs if shorter than bareSegs *)
  If[Length[massSegs] < Length[bareSegs],
    massSegs = PadRight[massSegs, Length[bareSegs], {""}]];

  (* nickelList[[v+1]] = list of forward-neighbor node IDs for vertex v (0-indexed) *)
  nickelList = Table[
    charToNode /@ Characters[bareSegs[[v + 1]]],
    {v, 0, Length[bareSegs] - 1}];

  (* massList: aligned mass digits, one per half-edge in traversal order *)
  massList = Table[
    If[StringLength[massSegs[[v + 1]]] >= j,
      ToExpression[StringPart[massSegs[[v + 1]], j]],
      0],
    {v, 0, Length[massSegs] - 1},
    {j, Length[nickelList[[v + 1]]]}] // Flatten;

  (* --- 3. Build edge list from nickelList (port of edgesFromNickel) --- *)
  (* Each entry in nickelList[[v+1]] gives a forward edge from v to m.
     m = -1 means external leg. Edges/legs paired with massList entries. *)
  edges = {};  (* {vertex0, vertex1, massDigit} for internal edges *)
  legs = {};   (* {vertex, massDigit} for external legs *)
  Module[{idx = 0},
    Do[
      Do[
        idx++;
        Module[{m = nickelList[[v + 1, j]], md = massList[[idx]]},
          If[m == -1,
            AppendTo[legs, {v, md}],
            (* Internal edge: store sorted pair *)
            AppendTo[edges, {Min[v, m], Max[v, m], md}]]],
        {j, Length[nickelList[[v + 1]]]}],
      {v, 0, Length[nickelList] - 1}]];

  (* --- 4. Classify mass digits (matching UI generateThumbnail) --- *)
  internalDigits = Union[Select[edges[[All, 3]], # > 0 &]];
  externalDigits = Union[Select[legs[[All, 2]], # > 0 &]];
  extOnlyDigits = Complement[externalDigits, internalDigits];

  (* mScales = internal \[Union] shared; bigMScales = external-only *)
  mScales = Union[internalDigits, Intersection[externalDigits, internalDigits]];
  bigMScales = extOnlyDigits;

  (* Build mass symbol map: digit \[Rule] Mathematica symbol *)
  massMap = <|0 -> 0|>;
  Do[AssociateTo[massMap,
    d -> If[Length[mScales] == 1, m, m[d]]], {d, mScales}];
  Do[If[!KeyExistsQ[massMap, d],
    AssociateTo[massMap,
      d -> If[Length[bigMScales] == 1, M, M[d]]]], {d, bigMScales}];

  (* --- 5. Build output in 1-indexed STIntegrate format --- *)
  nLegs = Length[legs];

  edgesOut = Table[
    {{edges[[i, 1]] + 1, edges[[i, 2]] + 1}, massMap[edges[[i, 3]]]},
    {i, Length[edges]}];

  (* 2-leg (self-energy): all external legs share a single on-shell scale
     by momentum conservation (p_1 = -p_2 \[Rule] p_1\.b2 = p_2\.b2), so a single
     mass symbol M is sufficient \[LongDash] *provided* the CNI color is non-zero.
     If the CNI color for an external leg is 0, the leg is genuinely
     massless (off-shell free variable or massless on-shell) and must
     stay massless. The pre-2026-05-14 unconditional `M` assignment
     produced nodes that disagreed with the CNI color string (\[LongDash]> validator
     finding N: n=2 mass conservation). *)
  nodesOut = If[nLegs == 2,
    Table[{legs[[i, 1]] + 1, If[legs[[i, 2]] == 0, 0, M]}, {i, nLegs}],
    (* General case: leg i gets mass M[i] (position-indexed) for external-only,
       or m/m[d] (class-indexed) for shared/internal.  Single external mass \[RightArrow] M. *)
    Table[{legs[[i, 1]] + 1,
      Which[
        legs[[i, 2]] == 0, 0,
        MemberQ[extOnlyDigits, legs[[i, 2]]],
          If[Length[bigMScales] == 1, M, M[i]],
        True, massMap[legs[[i, 2]]]]}, {i, nLegs}]];

  {edgesOut, nodesOut}
];

(* Convenience: build a complete STIntegrate command string from CNI *)
STCNickelToSTCommand[cni_String, opts___Rule] := Module[
  {graph, optsStr},
  graph = STCNickelToGraph[cni];
  If[graph === $Failed, Return[$Failed]];
  optsStr = If[Length[{opts}] == 0, "",
    ", " <> StringJoin[Riffle[
      (ToString[#[[1]]] <> " -> " <> ToString[#[[2]], InputForm]) & /@ {opts},
      ", "]]];
  "STIntegrate[" <> ToString[graph, InputForm] <> optsStr <> "]"
];


(* \[HorizontalLine]\[HorizontalLine] stComputeLegOrder: canonical leg ordering from stCommand \[HorizontalLine]\[HorizontalLine] *)
(* Given a result's stCommand string, returns the leg permutation:
   legOrder[[i]] = original leg number (1-indexed position in nodes list)
   for the i-th external leg encountered in the canonical Nickel traversal.
   Returns {} if the stCommand cannot be parsed or has no external legs. *)

stComputeLegOrder[stCommand_String] := Module[
  {held, graphArg, edgePairs, nodeList, edgelistfinal, n0reordered,
   intMasses, extMasses, allVerts, nv, extLegsAt, ne2, edgeMassMap,
   perms, bestStr, bestPerm, tryPerm, canonicalizeColor},

  (* Parse stCommand to extract graph {{edges}, {nodes}} *)
  held = Quiet @ Check[ToExpression[stCommand, InputForm, Hold], $Failed];
  If[held === $Failed, Return[{}]];
  graphArg = Quiet @ Check[held[[1, 1]], $Failed];
  If[!ListQ[graphArg] || Length[graphArg] < 2, Return[{}]];

  edgePairs = graphArg[[1]];  (* {{{v1,v2}, mass}, ...} *)
  nodeList = graphArg[[2]];   (* {{vertex, mass}, ...} *)
  If[!ListQ[edgePairs] || !ListQ[nodeList] || Length[nodeList] == 0, Return[{}]];

  (* Build computeNickelIndex inputs *)
  edgelistfinal = edgePairs[[All, 1]];  (* {{v1,v2}, ...} *)
  n0reordered = nodeList[[All, 1]];     (* {v1, v2, ...} *)
  intMasses = edgePairs[[All, 2]];
  extMasses = nodeList[[All, 2]];

  allVerts = Flatten[edgelistfinal] // DeleteDuplicates // Sort;
  nv = Length[allVerts];
  ne2 = Length[edgelistfinal];
  If[nv == 0, Return[{}]];

  extLegsAt = <||>;
  Do[Module[{v = n0reordered[[i]],
             mm = If[i <= Length[extMasses], extMasses[[i]], 0]},
    If[KeyExistsQ[extLegsAt, v],
      AppendTo[extLegsAt[v], {mm, i}],  (* store {mass, originalLegIndex} *)
      extLegsAt[v] = {{mm, i}}]
  ], {i, Length[n0reordered]}];

  edgeMassMap = Association[
    Table[i -> If[i <= Length[intMasses], intMasses[[i]], 0], {i, ne2}]];

  canonicalizeColor[tokens_List] := Module[{mapping = <||>, next = 1, res = {}},
    Do[If[StringQ[tok], AppendTo[res, tok],
      If[KeyExistsQ[mapping, tok],
        AppendTo[res, mapping[tok]],
        mapping[tok] = ToString[next];
        AppendTo[res, ToString[next]]; next++]
    ], {tok, tokens}];
    StringJoin[res]];

  tryPerm[perm_] := Module[{relabel, invPerm, bareParts, vertexData,
      origV, edgeInfos, extMs, bareStr, colorStr, hasMultiEdge,
      perVertexOrderings, bestColor, colorTokens, legSeq = {}},
    relabel = AssociationThread[allVerts -> (perm - 1)];
    invPerm = AssociationThread[(perm - 1) -> allVerts];
    bareParts = {}; vertexData = {};
    Do[origV = invPerm[v];
      edgeInfos = SortBy[Flatten[Table[
        Module[{a = relabel[edgelistfinal[[e, 1]]],
                b = relabel[edgelistfinal[[e, 2]]],
                mv = edgeMassMap[e]},
          (* Self-loops must be emitted into v's stanza (see Nickel
             reference convention): a == b == v is a self-loop edge. *)
          Which[
            a == v && b == v, {{v, mv}},
            a == v && b > v, {{b, mv}},
            b == v && a > v, {{a, mv}},
            True, {}]
        ], {e, ne2}], 1], First];
      extMs = Lookup[extLegsAt, origV, {}];
      (* Record which original legs appear at this canonical vertex *)
      Do[AppendTo[legSeq, em[[2]]], {em, extMs}];
      AppendTo[bareParts, StringJoin[
        Join[Table["e", {Length[extMs]}],
             ToString[#[[1]]] & /@ edgeInfos]]];
      AppendTo[vertexData, {v, extMs[[All, 1]],
        If[Length[edgeInfos] > 0, SplitBy[edgeInfos, First], {}]}];
    , {v, 0, nv - 1}];
    bareStr = StringRiffle[bareParts, "|"] <> "|";

    hasMultiEdge = AnyTrue[vertexData, AnyTrue[#[[3]], Length[#] > 1 &] &];
    If[!hasMultiEdge,
      colorTokens = {};
      Do[Module[{vv = vd[[1]], ems = vd[[2]], grps = vd[[3]]},
        If[vv > 0, AppendTo[colorTokens, "|"]];
        Do[AppendTo[colorTokens, If[mv === 0 || mv === 0., "0", mv]], {mv, ems}];
        Do[Do[AppendTo[colorTokens, If[ei[[2]] === 0 || ei[[2]] === 0., "0", ei[[2]]]],
          {ei, grp}], {grp, grps}];
      ], {vd, vertexData}];
      colorStr = canonicalizeColor[colorTokens] <> "|",
      perVertexOrderings = Table[
        Module[{grps = vd[[3]], groupPerms},
          groupPerms = If[Length[#] > 1, Permutations[#], {#}] & /@ grps;
          If[Length[groupPerms] == 0, {{}},
            Flatten[#, 1] & /@ Tuples[groupPerms]]
        ], {vd, vertexData}];
      bestColor = None;
      Do[colorTokens = {};
        Do[Module[{vi, vd, ems, flat},
          vi = idx; vd = vertexData[[vi]]; ems = vd[[2]];
          flat = combo[[vi]];
          If[vd[[1]] > 0, AppendTo[colorTokens, "|"]];
          Do[AppendTo[colorTokens, If[mv === 0 || mv === 0., "0", mv]], {mv, ems}];
          Do[AppendTo[colorTokens, If[ei[[2]] === 0 || ei[[2]] === 0., "0", ei[[2]]]],
            {ei, flat}];
        ], {idx, Length[vertexData]}];
        Module[{c = canonicalizeColor[colorTokens] <> "|"},
          If[bestColor === None || Order[c, bestColor] == 1, bestColor = c]];
      , {combo, Tuples[perVertexOrderings]}];
      colorStr = bestColor;
    ];
    {bareStr <> ":" <> colorStr, legSeq}
  ];

  perms = If[nv <= 8, Permutations[Range[nv]], {Range[nv]}];
  {bestStr, bestPerm} = tryPerm[First[perms]];
  Do[Module[{res = tryPerm[p2]},
    If[Order[res[[1]], bestStr] == 1,
      bestStr = res[[1]]; bestPerm = res[[2]]]],
    {p2, Rest[perms]}];

  bestPerm  (* list of original leg indices in canonical order *)
];


(* ================================================================== *)
(*  EXPRESSION DISPLAY                                                 *)
(*  Convert Mathematica expressions to Unicode display strings         *)
(* ================================================================== *)

subscriptDigits = <|0 -> "\:2080", 1 -> "\:2081", 2 -> "\:2082",
  3 -> "\:2083", 4 -> "\:2084", 5 -> "\:2085", 6 -> "\:2086",
  7 -> "\:2087", 8 -> "\:2088", 9 -> "\:2089"|>;

toSubscript[n_Integer] := StringJoin[
  Lookup[subscriptDigits, #, ToString[#]] & /@
    IntegerDigits[Abs[n]]];

(* Canonicalize a momentum expression for consistent display *)
canonicalMomentum[expr_] := Expand[expr];

(*Check whether the leading term of a momentum expression is negative.
  "Leading" means: first nonzero coefficient among l[1],l[2],...,p[1],p[2],...
  Returns True if the expression should be negated for canonical display.*)
leadingTermNegativeQ[expr_] := Module[{expanded, vars, c},
  expanded = Expand[expr];
  vars = Join[Table[l[i], {i, 10}], Table[p[i], {i, 10}]];
  Do[c = Coefficient[expanded, v]; If[c =!= 0, Return[Negative[c], Module]], {v, vars}];
  False
];

toDisplayString[expr_] := Module[{str, cexpr},
  cexpr = canonicalMomentum[expr];
  (* Convert to InputForm string, then simplify notation *)
  str = ToString[cexpr, InputForm];
  (* Strip any context prefixes like  or SubTropica`Private` *)
  str = StringReplace[str, RegularExpression["[A-Za-z`]+`"] -> ""];
  (* l[1] -> l1, p[2] -> p2 *)
  str = StringReplace[str, {
    RegularExpression["l\\[(\\d+)\\]"] -> "l$1",
    RegularExpression["p\\[(\\d+)\\]"] -> "p$1",
    RegularExpression["qTree\\[(\\d+)\\]"] -> "q$1",
    RegularExpression["qAuto\\[(\\d+)\\]"] -> "q$1"
  }];
  (* Clean up *)
  StringReplace[str, {" " -> " "}]
];

(* Convert expression to canonical InputForm string *)
toCanonicalInputForm[expr_] := Module[{str, cexpr},
  cexpr = canonicalMomentum[expr];
  str = ToString[cexpr, InputForm];
  (* Strip context prefixes *)
  StringReplace[str, RegularExpression["[A-Za-z`]+`"] -> ""]
];


(* ================================================================== *)
(*  DIAGRAM SVG GENERATION                                             *)
(*  Uses FeynmanPlot if available, falls back to "use JS renderer"     *)
(* ================================================================== *)

generateDiagramSVG[edgeList_List, intm_List, extm_List,
                    edgeMomenta_List, chordEdges_List] :=
  Module[{an, pEdges, pNodes, nE, labels, hlOpt, graphic, svg},
    Quiet @ Check[
      an = feynmanAnalyzeTopology[edgeList];
      nE = an["nIntEdges"];
      If[nE == 0 && an["nExtLegs"] == 0, Return[Null]];
      pEdges = Table[{an["edgelistfinal"][[i]],
        If[i <= Length[intm], intm[[i]], 0]}, {i, nE}];
      pNodes = Table[{an["nodes0reordered"][[i]],
        If[i <= Length[extm], extm[[i]], 0]}, {i, an["nExtLegs"]}];
      labels = If[Length[edgeMomenta] == nE && !MatchQ[edgeMomenta, {Null ..}],
        edgeMomenta /. {h_Symbol[n_Integer] :> Subscript[h, n]},
        Range[nE]];
      hlOpt = If[Length[chordEdges] > 0, {SubTropica`HighlightedEdges -> chordEdges}, {}];
      graphic = Show[SubTropica`FeynmanPlot[{pEdges, pNodes},
        SubTropica`EdgesLabel -> labels, Sequence @@ hlOpt], ImageSize -> 400];
      svg = ExportString[graphic, "SVG"];
      svg,
      Null  (* fallback: let JS render *)
    ]
  ];


(* ================================================================== *)
(*  /api/lock HANDLER                                                  *)
(*  Receives {vertices, edgePairs} from JS, runs full analysis         *)
(* ================================================================== *)

handleLock[body_String] := Module[
  {parsed, edgePairs, jsChords, nickel, momResult, edgeData, extMassData,
   responseJSON, jsonStr},

  (* Wrap everything in Check so we always return valid JSON *)
  Check[

  parsed = Quiet @ ImportString[body, "RawJSON"];
  If[!AssociationQ[parsed], Return[
    ExportString[<|"status" -> "error", "error" -> "Invalid JSON"|>, "RawJSON"]]];

  stLog["[SubTropica] /api/lock received"];

  (* Extract edge pairs (1-indexed from JS) *)
  edgePairs = parsed["edgePairs"];
  If[!ListQ[edgePairs] || Length[edgePairs] == 0, Return[
    ExportString[<|"status" -> "error",
      "error" -> "No edges provided"|>, "RawJSON"]]];

  edgePairs = Sort /@ edgePairs;
  stLog["[SubTropica] Edge pairs: ", edgePairs];

  (* Store original edge list for FeynmanPlot *)
  $edgeList = edgePairs;

  (* Run topology analysis *)
  $anResult = feynmanAnalyzeTopology[edgePairs];
  $efl = $anResult["edgelistfinal"];
  $ne = $anResult["nIntEdges"];
  $nl = $anResult["nExtLegs"];
  $nloops = $anResult["nLoops"];

  (* Rebuild nodes0reordered in JS external-edge order.
     The JS sends edgePairs in state.edges order. We walk them in order,
     find external edges (degree-1 vertex), get the internal partner,
     and apply the kernel reordering. This guarantees p[i] corresponds
     to the i-th external edge in the JS canvas. *)
  Module[{deg, jsExtPartners, reord},
    deg = Tally[Flatten[edgePairs]];
    deg = Association[Rule @@@ deg];  (* vertex -> count *)
    jsExtPartners = {};
    Do[
      Module[{a = edgePairs[[e, 1]], b = edgePairs[[e, 2]]},
        Which[
          deg[a] === 1, AppendTo[jsExtPartners, b],
          deg[b] === 1, AppendTo[jsExtPartners, a]]],
      {e, Length[edgePairs]}];
    reord = $anResult["reordering"];
    $n0r = jsExtPartners /. reord;
  ];

  stLog["[SubTropica] Analyzed: ", $ne, " int edges, ", $nl, " ext legs, ", $nloops, " loops"];
  stLog["[SubTropica] edgelistfinal: ", $efl];
  stLog["[SubTropica] nodes0reordered: ", $n0r];

  (* Initialize masses and exponents *)
  $intm = Table[0, {$ne}];
  $extm = Table[0, {$nl}];
  $propExponents = Table[1, {$ne}];

  (* Compute Nickel index *)
  nickel = Quiet @ Check[computeNickelIndex[$efl, $n0r, $intm, $extm], ""];
  stLog["[SubTropica] Nickel: ", nickel];

  (* Set up loop and external momenta  - Quiet suppresses shadowing
     warnings when SubTropica` also defines l and p symbols *)
  Quiet[
    $loopMomenta = Table[l[i], {i, $nloops}];
    $extMomLabels = Table[p[i], {i, $nl}];
    (* All external momenta are independent p[1]..p[n];
       momentum conservation is enforced by the solver, not by substitution. *)
    , General::shdw
  ];

  (* Extract JS chord positions if provided (syncs chord selection with UI) *)
  jsChords = If[KeyExistsQ[parsed, "jsChordPositions"] &&
                ListQ[parsed["jsChordPositions"]],
    parsed["jsChordPositions"], {}];

  (* Auto-route momenta (using JS chords if provided) *)
  momResult = Quiet[Check[
    autoRouteMomenta[$efl, $n0r, $nloops, $loopMomenta, $extMomLabels, jsChords],
    {Table[Null, {$ne}], {}}], General::shdw];
  $edgeMomenta = momResult[[1]];
  $chordEdges = momResult[[2]];

  stLog["[SubTropica] Momenta: ", $edgeMomenta];
  stLog["[SubTropica] Chords: ", $chordEdges];

  (* Build edge data for JSON *)
  (* Use only strings and numbers for JSON safety *)
  edgeData = Table[Module[{mom = $edgeMomenta[[i]], flip, displayMom},
    flip = If[mom === Null || mom === None, False, leadingTermNegativeQ[mom]];
    displayMom = If[flip, -mom, mom];
    <|
    "id" -> i,
    "from" -> $efl[[i, 1]],
    "to" -> $efl[[i, 2]],
    "momentum" -> If[mom === Null || mom === None, "",
      toCanonicalInputForm[displayMom]],
    "momentumDisplay" -> If[mom === Null || mom === None, "",
      toDisplayString[displayMom]],
    "mass" -> "0",
    "exponent" -> 1,
    "isChord" -> MemberQ[$chordEdges, i],
    "arrowReversed" -> flip
  |>], {i, $ne}];

  (* External mass data *)
  extMassData = Table[<|
    "vertex" -> $n0r[[i]],
    "value" -> "0"
  |>, {i, $nl}];

  (* JS renderer handles the diagram with mass coloring, edge numbers,
     momentum labels, and custom styling. No need for kernel SVG. *)

  responseJSON = <|
    "status" -> "ok",
    "topology" -> <|
      "nickelIndex" -> If[StringQ[nickel], nickel, ""],
      "loopCount" -> $nloops,
      "edgeCount" -> $ne,
      "legCount" -> $nl,
      "edges" -> edgeData,
      "externalMasses" -> extMassData,
      "diagramSVG" -> ""
    |>
  |>;

  stLog["[SubTropica] Building JSON response..."];
  jsonStr = ExportString[responseJSON, "RawJSON"];
  stLog["[SubTropica] Response ready (", StringLength[jsonStr], " bytes)"];
  jsonStr

  , (* Check fallback  - if anything above errors *)
  stErr["[SubTropica] ERROR in handleLock: ", $MessageList];
  ExportString[<|"status" -> "error",
    "error" -> "Kernel analysis failed: " <> ToString[$MessageList]|>, "RawJSON"]
  ]
];


(* ================================================================== *)
(*  /api/integrate HANDLER                                             *)
(*  Receives full config from JS, builds the Association               *)
(* ================================================================== *)

(* Helper: safely parse a JS value that might be a Mma expression.
   Supports subscript shorthand: x_y -> Subscript[x,y], x_{yz} -> Subscript[x,yz] *)
safeToExpr[s_String] := Module[{tmp, expr},
  tmp = StringReplace[s,
    RegularExpression["([a-zA-Z]+)_\\{([^}]+)\\}"] :> "Subscript[$1,$2]"];
  tmp = StringReplace[tmp,
    RegularExpression["([a-zA-Z]+)_([a-zA-Z0-9])"] :> "Subscript[$1,$2]"];
  expr = Quiet @ Check[ToExpression[tmp], s];
  If[expr === $Failed, s, expr]
];
safeToExpr[x_] := x;

handleIntegrate[body_String] := Module[
  {parsed, dim, epsOrd, numRowsParsed, propExpParsed, diagramName},

  parsed = Quiet @ ImportString[body, "RawJSON"];
  If[!AssociationQ[parsed], Return[
    ExportString[<|"status" -> "error", "error" -> "Invalid JSON"|>, "RawJSON"]]];

  (* Parse masses and exponents.
     The JS sends internalMasses and propExponents for ALL edges (internal + external)
     in the original canvas order.  We need to extract only the internal-edge entries.
     feynmanAnalyzeTopology preserves the relative ordering of internal edges
     (it just deletes external rows and relabels vertices), so no permutation
     is needed \[LongDash] the i-th internal row maps directly to $efl[[i]]. *)
  Module[{allMasses, allExps, extNodes, intRows},
    allMasses = If[KeyExistsQ[parsed, "internalMasses"] && Length[parsed["internalMasses"]] > 0,
      safeToExpr /@ parsed["internalMasses"], {}];
    allExps = If[KeyExistsQ[parsed, "propExponents"],
      safeToExpr /@ parsed["propExponents"], {}];

    If[Length[allMasses] > 0 && Length[$edgeList] > 0,
      (* Identify external vertices: appear in exactly one edge *)
      extNodes = Select[Tally[Flatten[$edgeList]], #[[2]] == 1 &][[All, 1]];
      (* Internal edge rows: neither endpoint is external *)
      intRows = Select[Range[Length[$edgeList]],
        !MemberQ[extNodes, $edgeList[[#, 1]]] && !MemberQ[extNodes, $edgeList[[#, 2]]] &];
      $intm = PadRight[allMasses[[intRows]], $ne, 0];
      $propExponents = If[Length[allExps] >= Max[intRows, {0}],
        PadRight[allExps[[intRows]], $ne, 1],
        Table[1, {$ne}]];
    ,
      (* Fallback: no masses from JS, keep defaults *)
      If[Length[$intm] < $ne, $intm = PadRight[$intm, $ne, 0]];
      If[Length[allExps] > 0,
        $propExponents = PadRight[allExps[[;; Min[Length[allExps], $ne]]], $ne, 1]];
    ];
  ];
  If[KeyExistsQ[parsed, "externalMasses"] && Length[parsed["externalMasses"]] > 0,
    $extm = safeToExpr /@ parsed["externalMasses"]];
  If[Length[$extm] < $nl, $extm = PadRight[$extm, $nl, 0]];

  stLog["[SubTropica] Internal masses (mapped): ", $intm];
  stLog["[SubTropica] External masses: ", $extm];
  stLog["[SubTropica] Prop exponents: ", $propExponents];

  (* Parse numerator rows *)
  numRowsParsed = If[KeyExistsQ[parsed, "numeratorRows"],
    (With[{nr = #}, {safeToExpr[nr["expr"]], safeToExpr[nr["exp"]]}] &) /@
      parsed["numeratorRows"],
    {}];

  (* Parse dimension and eps order *)
  dim = If[KeyExistsQ[parsed, "dimension"],
    Quiet @ Check[ToExpression[parsed["dimension"]], 4 - 2 eps], 4 - 2 eps];
  epsOrd = If[KeyExistsQ[parsed, "epsOrder"],
    Quiet @ Check[ToExpression[parsed["epsOrder"]], 0], 0];

  (* Parse name *)
  diagramName = If[KeyExistsQ[parsed, "autoName"] && TrueQ[parsed["autoName"]],
    Automatic,
    If[KeyExistsQ[parsed, "diagramName"] && StringQ[parsed["diagramName"]] &&
       StringLength[parsed["diagramName"]] > 0,
      parsed["diagramName"], Automatic]];

  (* Parse custom loop/ext momenta if not auto *)
  If[KeyExistsQ[parsed, "autoLoopMom"] && !TrueQ[parsed["autoLoopMom"]] &&
     KeyExistsQ[parsed, "loopMomLabels"],
    Module[{parsedLoops = safeToExpr /@ parsed["loopMomLabels"]},
      If[AllTrue[parsedLoops, MatchQ[#, _Symbol | _[_Integer]] &],
        $loopMomenta = parsedLoops,
        (*Print["[SubTropica] Warning: loop momenta must be simple symbols (e.g. l[1], k[1]), not expressions like ",
          ToString[parsedLoops, InputForm], ". Reverting to automatic labels."];*)
        $loopMomenta = Table[l[i], {i, $nloops}]]]];

  If[KeyExistsQ[parsed, "autoExtMom"] && !TrueQ[parsed["autoExtMom"]] &&
     KeyExistsQ[parsed, "extMomLabels"],
    $extMomLabels = MapIndexed[
      (* Fill empty/Null labels with default p[i] *)
      Function[{label, idx},
        Module[{expr = safeToExpr[label]},
          If[expr === Null || expr === "" || expr === $Failed, p[idx[[1]]], expr]
        ]],
      parsed["extMomLabels"]
    ];
    (* Re-route momenta with new labels, preserving chord selection from lock *)
    Module[{res},
      res = Quiet @ Check[
        autoRouteMomenta[$efl, $n0r, $nloops, $loopMomenta, $extMomLabels, $chordEdges],
        {$edgeMomenta, $chordEdges}];
      $edgeMomenta = res[[1]]; $chordEdges = res[[2]]]];

  (* Parse advanced options *)
  Module[{opt = parsed, toBool, toVal, toStr, toSym},
    toBool[key_, default_] := If[KeyExistsQ[opt, key], TrueQ[opt[key]], default];
    toVal[key_, default_] := If[KeyExistsQ[opt, key] && opt[key] =!= "", safeToExpr[opt[key]], default];
    (* Keep as string  - for options like "Representation", "Heuristic" *)
    toStr[key_, default_] := If[KeyExistsQ[opt, key] && StringQ[opt[key]], opt[key], default];
    (* Convert special names to symbols: "All"->All, "None"->None, "Automatic"->Automatic *)
    toSym[key_, default_] := If[KeyExistsQ[opt, key],
      Switch[opt[key], "All", All, "None", None, "Automatic", Automatic,
        _, safeToExpr[opt[key]]], default];
        
    (* Build mass substitution rules from the user's mass configuration:
       Subscript[m, i] -> $intm[[i]] for internal masses,
       Subscript[M, i] -> $extm[[i]] for external masses.
       These are prepended to user substitutions so STSymanzik output
       automatically uses the configured mass values. *)
    Module[{massRules, userSubs},
      massRules = Join[
        Table[Subscript[m, i] -> $intm[[i]], {i, Length[$intm]}],
        Table[Subscript[M, i] -> $extm[[i]], {i, Length[$extm]}]];
      (* Only keep rules for nonzero masses \[LongDash] zero masses are the default *)
      massRules = Select[massRules, #[[2]] =!= 0 && #[[2]] =!= 0. &];
      userSubs = toVal["substitutions", {}];
      $massSubstitutions = If[ListQ[userSubs] && Length[userSubs] > 0,
        Join[massRules, userSubs], massRules];
    ];

    (* Build the Association matching the original DialogReturn schema.
       Store in $integrationConfig  - NOT $uiResult, which is the loop sentinel. *)
    $integrationConfig = <|
      "edges" -> Table[{$efl[[i]], $intm[[i]]}, {i, $ne}],
      "nodes" -> Table[{$n0r[[i]], $extm[[i]]}, {i, $nl}],
      "edgeMomenta" -> $edgeMomenta,
      "propExponents" -> $propExponents,
      "numRows" -> numRowsParsed,
      "chordEdges" -> $chordEdges,
      "loopMomenta" -> $loopMomenta,
      "extMomLabels" -> $extMomLabels,
      "nickelIndex" -> If[KeyExistsQ[parsed, "jsNickel"] && StringLength[parsed["jsNickel"]] > 0,
        parsed["jsNickel"],
        Quiet @ Check[computeNickelIndex[$efl, $n0r, $intm, $extm], ""]],
      "SetProblemID" -> diagramName,
      "Dimension" -> dim,
      "Order" -> epsOrd,
      "Representation" -> toStr["representation", "Schwinger"],
      "Normalization" -> If[toStr["normalization", "Automatic"] === "Automatic",
        Automatic, safeToExpr[opt["normalization"]]],
      (*"Substitutions" -> toVal["substitutions", {}],*)
	  "Substitutions" -> $massSubstitutions,
      "Verbose" -> toBool["verbose", False],
      "ShowTimings" -> toBool["showTimings", True],
      "ShowIntegrands" -> toBool["showIntegrands", False],
      "SimplifyOutput" -> Switch[toStr["simplifyOutput", "Simplify"],
        "Simplify", Simplify, "FullSimplify", FullSimplify,
        "Identity", Identity, _, Simplify],
      "CleanOutput" -> toBool["cleanOutput", False],
      "SaveSlowestIntegrand" -> toBool["saveSlowest", False],
      "SaveAllIntegrands" -> toBool["saveAll", False],
      "Gauge" -> If[toStr["gauge", "Automatic"] === "Automatic",
        Automatic, safeToExpr[opt["gauge"]]],
      "IncludeGauges" -> toSym["includeGauges", All],
      "Heuristic" -> toStr["heuristic", "LeafCountLinear"],
      "ScanScoreInterval" -> toVal["scanScoreInterval", {1, 3}],
      "ScoreInParallel" -> toSym["scoreInParallel", All],
      "TimeUpperBound" -> toVal["timeUpperBound", 10^17],
      "MemoryPercentCutOff" -> toSym["memoryCutOff", None],
      "ScoringMemoryFraction" -> toVal["scoringMemFrac", 0.5],
      "Parallelization" -> toSym["parallelization", All],
      "KernelsAvailable" -> toVal["kernels", $ProcessorCount - 1],
      "ClearCachesPerIntegrand" -> toBool["clearCaches", False],
      "ReuseExistingResults" -> toBool["reuseResults", True],
      "SelectFaces" -> toSym["selectFaces", All],
      "StopAt" -> Switch[toStr["stopAt", "Automatic"],
        "Automatic", Automatic,
        "AfterBuildingIntegrand", "AfterBuildingIntegrand",
        "AfterMinimalLRCheck", "AfterMinimalLRCheck",
        "AfterMinimalLRCheckOneShot", "AfterMinimalLRCheckOneShot",
        "AfterExpansion", "AfterExpansion",
        "AfterLinearOrder", "AfterLinearOrder",
        _, Automatic],
      "StartAt" -> toSym["startAt", None],
      "ContourHandling" -> toStr["contourHandling", "Abort"],
      "FindRoots" -> toBool["findRoots", True],
      "MethodLR" -> toStr["methodLR", "Lungo"],
      "SetupInParallel" -> toSym["setupInParallel", Automatic],
      "suppressCommand" -> toBool["suppressCommand", False]
    |>;
  ];

  (* \[HorizontalLine]\[HorizontalLine] Reuse cached LR gauge from estimate if available \[HorizontalLine]\[HorizontalLine] *)
  (* If the estimate found an LR gauge and the user hasn't explicitly set one,
     inject it to skip the expensive gauge-scanning step (N expansions + scoring). *)
  If[$integrationConfig["Gauge"] === Automatic &&
     $STCachedLRGauge =!= None && MatchQ[$STCachedLRGauge, _Symbol],
    stLog["[SubTropica] Reusing LR gauge from estimate: ", $STCachedLRGauge];
    $integrationConfig["Gauge"] = {$STCachedLRGauge -> 1};
  ];
  (* Clear cache \[LongDash] it's been consumed or is stale *)
  $STCachedLRGauge = None;

  stLog["[SubTropica] Integration submitted"];
  stLog["  Dimension: ", $integrationConfig["Dimension"]];
  stLog["  Masses: ", $intm, " / ext: ", $extm];
  stLog["  Numerators: ", numRowsParsed];

  (* Signal the main loop to start integration *)
  $integrationPending = True;

  ExportString[<|"status" -> "started"|>, "RawJSON"]
];


(* ================================================================== *)
(*  /api/estimate HANDLER                                              *)
(*  Lightweight tropical-expansion estimate (no integration).          *)
(*  Returns complexity metrics; touches NO globals.                    *)
(* ================================================================== *)

handleEstimate[body_String] := Module[
  {parsed, generationId, skipExpansion,
   (* topology analysis \[LongDash] all local *)
   edgePairs0, anResult0, efl0, n0r0, ne0, nl0, nloops0,
   (* masses *)
   allMasses, allExps, extNodes0, intRows0, intm0, extm0,
   (* integrand *)
   dim0, g0, edges0, nodes0, genResult, pref0, integrand0, xvars0, coeffs0,
   (* LR probe state \[LongDash] initialized early so the response can
      reference it whether or not we run the expansion. *)
   isLREst = False, lrGaugeEst = "", lrOrderEst = {},
   (* Tropical expansion results. Populated only when skipExpansion
      is False; left at sentinel values otherwise. *)
   checkpointID = "", expansion0,
   nNPTerms = -1, facetsList = {}, prefactorPoleOrders = {},
   totalFacets = 0, leadingOrder = 0,
   (* numerator rows from the client (optional) *)
   numRowsEst, fullExpsEst},

  (* Outer Quiet: benign messages that escape from degenerate integrands
     (vacuum period, scaleless diagrams, Lee-Pomeransky scaleless corners)
     should NOT poison the estimate response. Quiet + CheckAbort lets us
     detect real aborts without tripping on warnings. The body handles
     all known failure modes with explicit Returns. *)
  Quiet[
  CheckAbort[

  parsed = Quiet @ ImportString[body, "RawJSON"];
  If[!AssociationQ[parsed], Return[
    ExportString[<|"status" -> "error", "error" -> "Invalid JSON"|>, "RawJSON"]]];

  generationId = Lookup[parsed, "generationId", ""];

  (* skipExpansion short-circuits the expensive STExpandIntegral +
     metric-extraction block. The Export tab uses this for the
     propagator / quadruple forms, which need STGenerateIntegrand but
     not the tropical expansion. The LR probe still runs because it is
     cheap and its result is useful on its own. *)
  skipExpansion = TrueQ[Lookup[parsed, "skipExpansion", False]];

  (* \[HorizontalLine]\[HorizontalLine] Topology analysis (local, mirrors handleLock) \[HorizontalLine]\[HorizontalLine] *)
  edgePairs0 = parsed["edgePairs"];
  If[!ListQ[edgePairs0] || Length[edgePairs0] == 0, Return[
    ExportString[<|"status" -> "error", "error" -> "No edges"|>, "RawJSON"]]];
  edgePairs0 = Sort /@ edgePairs0;

  anResult0 = feynmanAnalyzeTopology[edgePairs0];
  efl0  = anResult0["edgelistfinal"];
  ne0   = anResult0["nIntEdges"];
  nl0   = anResult0["nExtLegs"];
  nloops0 = anResult0["nLoops"];

  If[ne0 == 0, Return[
    ExportString[<|"status" -> "ok", "generationId" -> generationId,
      "nTerms" -> 0, "nSubIntegrands" -> 0, "nDivFacets" -> 0,
      "leadingEpsOrder" -> 0, "nLoops" -> 0, "nVars" -> 0|>, "RawJSON"]]];

  (* Build local n0r (same logic as handleLock lines 10199-10211) *)
  Module[{deg, jsExtPartners, reord},
    deg = Association[Rule @@@ Tally[Flatten[edgePairs0]]];
    jsExtPartners = {};
    Do[Module[{a = edgePairs0[[e, 1]], b = edgePairs0[[e, 2]]},
      Which[
        deg[a] === 1, AppendTo[jsExtPartners, b],
        deg[b] === 1, AppendTo[jsExtPartners, a]]],
      {e, Length[edgePairs0]}];
    reord = anResult0["reordering"];
    n0r0 = jsExtPartners /. reord;
  ];

  (* \[HorizontalLine]\[HorizontalLine] Parse masses (same logic as handleIntegrate lines 10335-10360) \[HorizontalLine]\[HorizontalLine] *)
  allMasses = If[KeyExistsQ[parsed, "internalMasses"] && Length[parsed["internalMasses"]] > 0,
    safeToExpr /@ parsed["internalMasses"], {}];
  allExps = If[KeyExistsQ[parsed, "propExponents"],
    safeToExpr /@ parsed["propExponents"], {}];

  If[Length[allMasses] > 0 && Length[edgePairs0] > 0,
    extNodes0 = Select[Tally[Flatten[edgePairs0]], #[[2]] == 1 &][[All, 1]];
    intRows0 = Select[Range[Length[edgePairs0]],
      !MemberQ[extNodes0, edgePairs0[[#, 1]]] && !MemberQ[extNodes0, edgePairs0[[#, 2]]] &];
    intm0 = PadRight[allMasses[[intRows0]], ne0, 0];
  ,
    intm0 = Table[0, {ne0}];
  ];
  extm0 = If[KeyExistsQ[parsed, "externalMasses"] && Length[parsed["externalMasses"]] > 0,
    PadRight[safeToExpr /@ parsed["externalMasses"], nl0, 0],
    Table[0, {nl0}]];

  (* Parse numerator rows (same shape as handleIntegrate). Each entry is
     {expression, exponent}; the kernel treats numerators as propagators
     with a (typically negative) exponent. *)
  numRowsEst = If[KeyExistsQ[parsed, "numeratorRows"] && ListQ[parsed["numeratorRows"]],
    (With[{nr = #}, {safeToExpr[nr["expr"]], safeToExpr[nr["exp"]]}] &) /@
      parsed["numeratorRows"],
    {}];

  (* \[HorizontalLine]\[HorizontalLine] Build graph and generate integrand \[HorizontalLine]\[HorizontalLine] *)
  dim0 = Quiet @ Check[ToExpression[Lookup[parsed, "dimension", "4 - 2 eps"]], 4 - 2 eps];
  edges0 = Table[{efl0[[i]], intm0[[i]]}, {i, ne0}];
  nodes0 = Table[{n0r0[[i]], extm0[[i]]}, {i, nl0}];
  g0 = {edges0, nodes0};

  (* Silence both the generator-side and Symanzik-side vacuumPeriod
     messages. STSymanzik::vacuumPeriod is benign (U polynomial still
     carries the integral), but if it escapes Quiet here, the outer
     Check[] around handleEstimate catches it and returns a 500 \[LongDash] even
     though the preview would otherwise have been valid. Power::infy /
     Part::partw / General::indet also escape deep inside the Symanzik
     pipeline for Lee-Pomeransky scaleless configurations (which are
     valid inputs), so silence them here too. *)
  genResult = Quiet[
    Block[{Print = (Null &)},
      TimeConstrained[
        CheckAbort[
          STGenerateIntegrand[g0, "Gauge" -> {}, "Dimension" -> dim0,
            "Representation" -> Lookup[parsed, "representation", "Schwinger"]],
          0],
        20, $Failed]],
    {STGenerateIntegrand::vacuumPeriod, STGenerateIntegrand::zeroF,
     STSymanzik::vacuumPeriod, STSymanzik::zeroF,
     Power::infy, Power::indet, General::indet,
     Part::partw, Part::partd, Part::pkspec1}];

  (* Scaleless or failed *)
  If[genResult === 0 || genResult === $Failed || !MatchQ[genResult, {_, _, _List, _}],
    Return[ExportString[<|"status" -> "ok", "generationId" -> generationId,
      "nTerms" -> 0, "nSubIntegrands" -> 0, "nDivFacets" -> 0,
      "leadingEpsOrder" -> 0, "nLoops" -> nloops0, "nVars" -> ne0 - 1,
      "scaleless" -> (genResult === 0)|>, "RawJSON"]]];

  {pref0, integrand0, xvars0, coeffs0} = genResult;

  (* \[HorizontalLine]\[HorizontalLine] Build propagators and set $ST* export globals \[HorizontalLine]\[HorizontalLine]
     Moved above the tropical-expansion block so the Export tab can
     fetch propagator / quadruple strings without paying for
     STExpandIntegral (see the skipExpansion branch below). *)
  Module[{loopMom0, extMom0, momResult0, edgeMom0, props0},
    Quiet[
      loopMom0 = Table[l[i], {i, nloops0}];
      extMom0 = Table[p[i], {i, nl0}];
      momResult0 = Check[
        autoRouteMomenta[efl0, n0r0, nloops0, loopMom0, extMom0],
        {Table[Null, {ne0}], {}}];
      edgeMom0 = momResult0[[1]];
    , General::shdw];

    (* Build inverse-propagator list: k^2 - m^2
       This is the STSymanzik / STIntegrate[propagators] convention. *)
    props0 = Table[Module[{k = edgeMom0[[i]], mi = intm0[[i]]},
      If[k === Null || k === None, 0,
        k^2 - mi^2]],
      {i, ne0}];

    (* Seed propagator exponent list. Anything the client passed via
       propExponents overrides the default of 1 for the internal edges,
       otherwise all propagators start at exponent 1. *)
    fullExpsEst = If[Length[allExps] > 0 && Length[intRows0] > 0,
      PadRight[allExps[[intRows0]], ne0, 1],
      Table[1, {ne0}]];

    (* Append numerator rows so propsStr and quadStr match what the
       kernel actually integrates when the user clicks Integrate. Without
       this, the Export tab shows the denominator-only integrand and the
       user's copy-paste command is missing the numerator. *)
    If[Length[numRowsEst] > 0,
      Do[
        AppendTo[props0, numRowsEst[[j, 1]]];
        AppendTo[fullExpsEst, numRowsEst[[j, 2]]],
        {j, Length[numRowsEst]}]];

    (* Set export globals \[LongDash] these are available in the user's notebook *)
    $STEdges = edges0;
    $STNodes = nodes0;
    $STGraph = {edges0, nodes0};
    $STPrefactor = pref0;
    $STIntegrand = integrand0;
    $STVariables = xvars0;
    $STCoefficients = coeffs0;
    $STQuadruple = {pref0, integrand0, xvars0, coeffs0};
    $STPropagators = props0;
  ];

  (* \[HorizontalLine]\[HorizontalLine] OneShot LR check \[HorizontalLine]\[HorizontalLine]
     Moved above the expansion too so skipExpansion still yields a
     usable isLR / lrGauge alongside the propagator / quadruple strings. *)
  Module[{rawExpr, expsWithEps, polysAndPairs, espResult, bestOrder, score0,
          lrGaugeSym = None},
    Block[{Print = (Null &)},
      TimeConstrained[
        (
          rawExpr = STtoCoeffMonPols[integrand0, xvars0];
          expsWithEps = Position[rawExpr // Last // Last, v_ /; (v /. eps -> 0) <= 0, 1] // Flatten;
          polysAndPairs = (rawExpr // Last // First)[[expsWithEps]];
          If[polysAndPairs === {} || xvars0 === {},
            (* Trivially LR *)
            isLREst = True;
            lrGaugeSym = If[xvars0 =!= {}, First[xvars0], None];
            lrGaugeEst = If[xvars0 =!= {}, ToString[First[xvars0], InputForm], ""];
            lrOrderEst = If[Length[xvars0] > 1, ToString[Rest[xvars0], InputForm], "{}"];
          ,
            espResult = Quiet[STEspressoFubini2[
              {Join[polysAndPairs, xvars0]},
              xvars0, ScreeningLR -> True, Heuristic -> "LeafCountLinear", FindRoots -> False]];
            {bestOrder, score0} = espResult;
            If[bestOrder =!= NOLR,
              isLREst = True;
              lrGaugeSym = Last[bestOrder];
              lrGaugeEst = ToString[Last[bestOrder], InputForm];
              lrOrderEst = ToString[Most[bestOrder], InputForm];
            ];
          ];
        ),
        15, (* 15s budget for LR check *)
        Null (* timeout: leave isLREst = False *)
      ]
    ];

    (* Cache LR gauge for integration reuse. *)
    $STCachedLRGauge = If[isLREst && lrGaugeSym =!= None, lrGaugeSym, None];
  ];

  (* \[HorizontalLine]\[HorizontalLine] Tropical expansion (30 s budget) \[HorizontalLine]\[HorizontalLine]
     Skipped entirely when the client passes skipExpansion -> True
     (used by the Export tab's automatic background prefetch).
     Direct STExpandIntegral on the STGenerateIntegrand output: routing
     through STIntegrate[{tuple}] would double-multiply by (Times @@ xvars)
     at the STEvaluateEulerIntegral entry and yield a wrong expansion. *)
  If[!skipExpansion,
    expansion0 = Block[{Print = (Null &)},
      TimeConstrained[
        CheckAbort[
          Quiet[STExpandIntegral[integrand0, xvars0, coeffs0],
            {STSymanzik::vacuumPeriod, STSymanzik::zeroF,
             Power::infy, Power::indet, General::indet, General::ovfl,
             General::munfl, Part::partw, Part::partd, Part::pkspec1}],
          $Aborted],
        30, $Failed]];

    If[expansion0 === $Failed || expansion0 === $Aborted,
      Return[ExportString[<|"status" -> "ok", "generationId" -> generationId,
        "nNPTerms" -> -1, "facetsList" -> {}, "prefactorPoleOrders" -> {},
        "nTerms" -> -1, "nSubIntegrands" -> -1, "nDivFacets" -> -1,
        "leadingEpsOrder" -> 0, "nLoops" -> nloops0,
        "nVars" -> Length[xvars0],
        "isLR" -> isLREst, "lrGauge" -> lrGaugeEst, "lrOrder" -> lrOrderEst,
        "graphStr" -> ToString[$STGraph, InputForm],
        "propsStr" -> ToString[$STPropagators, InputForm],
        "quadStr"  -> ToString[$STQuadruple, InputForm],
        "exponentsStr" -> If[AllTrue[fullExpsEst, # === 1 &], "",
                             ToString[fullExpsEst, InputForm]],
        "hasNumerators" -> (Length[numRowsEst] > 0),
        "timeout" -> True|>, "RawJSON"]]];

    (* Best-effort checkpoint save (Quiet so a save failure doesn't poison
       the response). *)
    checkpointID = ToString[Unique[SubTropicaID]];
    Quiet[
      STSaveCheckpoint[checkpointID, <|
        "ProblemID"   -> checkpointID,
        "Pref"        -> pref0,
        "Integrand"   -> integrand0,
        "XVars"       -> xvars0,
        "Coeffs"      -> coeffs0,
        "Expansion"   -> expansion0,
        "OrderValue"  -> 0,
        "OutputOrder" -> 0,
        "StopAt"      -> "AfterExpansion",
        "Timestamp"   -> DateString[]|>],
      {General::writeerr, General::noopen}];

    (* Extract the three list metrics *)
    If[!ListQ[expansion0] || Length[expansion0] === 0,
      nNPTerms = 0;
      facetsList = {};
      prefactorPoleOrders = {};
    ,
      nNPTerms = Length[expansion0];
      facetsList = Quiet @ Check[
        Length /@ expansion0[[All, 2]],
        Table[0, {nNPTerms}]];
      prefactorPoleOrders = Quiet @ Check[
        STleadingLaurentOrder[#, eps] & /@ expansion0[[All, 1]],
        Table[0, {nNPTerms}],
        {Power::infy, Power::indet, General::indet}]
    ];
    totalFacets = Total[facetsList /. _Missing -> 0];
    leadingOrder = If[Length[prefactorPoleOrders] > 0,
      Min[prefactorPoleOrders /. _Missing -> 0], 0];
  ];

  (* \[HorizontalLine]\[HorizontalLine] Response \[HorizontalLine]\[HorizontalLine]
     Single return for both the light (skipExpansion) and full paths.
     When skipExpansion is True the tropical-metric fields carry their
     sentinel defaults set in the Module header (nNPTerms = -1, etc.)
     so the client can distinguish "integrand-only" responses from
     real Tier-2 data. *)
  ExportString[<|
    "status"           -> "ok",
    "generationId"     -> generationId,
    "skipExpansion"    -> skipExpansion,
    (* New structured metrics \[LongDash] sentinel values if skipExpansion *)
    "nNPTerms"             -> nNPTerms,
    "facetsList"           -> facetsList,
    "prefactorPoleOrders"  -> prefactorPoleOrders,
    "npUsed"               -> (nNPTerms > 1),
    (* Back-compat scalars *)
    "nTerms"           -> nNPTerms,
    "nSubIntegrands"   -> totalFacets,
    "nDivFacets"       -> 0,
    "leadingEpsOrder"  -> leadingOrder,
    "nLoops"           -> nloops0,
    "nVars"            -> Length[xvars0],
    "isLR"             -> isLREst,
    "lrGauge"          -> lrGaugeEst,
    "lrOrder"          -> lrOrderEst,
    (* Expanded InputForm strings for Export tab \[LongDash] always populated
       since the globals block runs before the skipExpansion branch. *)
    "graphStr"         -> ToString[$STGraph, InputForm],
    "propsStr"         -> ToString[$STPropagators, InputForm],
    "quadStr"          -> ToString[$STQuadruple, InputForm],
    "exponentsStr"     -> If[AllTrue[fullExpsEst, # === 1 &], "",
                             ToString[fullExpsEst, InputForm]],
    "hasNumerators"    -> (Length[numRowsEst] > 0),
    "checkpointID"     -> checkpointID
  |>, "RawJSON"]

  , (* CheckAbort fallback \[LongDash] fires only on actual kernel Abort *)
  stErr["[SubTropica] handleEstimate aborted: ", $MessageList];
  ExportString[<|"status" -> "error",
    "error" -> "Estimate aborted"|>, "RawJSON"]
  ] (* close CheckAbort *)
  , {STSymanzik::vacuumPeriod, STSymanzik::zeroF,
     STGenerateIntegrand::vacuumPeriod, STGenerateIntegrand::zeroF,
     Last::nolast, Most::nomost, First::nofirst,
     (* Numerical-pathology messages that can fire deep inside the
        tropical / Symanzik pipeline for scaleless or near-scaleless
        integrands. In the estimate context they are never informative. *)
     Power::infy, Power::indet, General::indet, General::ovfl,
     General::munfl, Part::partw, Part::partd, Part::pkspec1}
  ] (* close outer Quiet *)
];


(* ================================================================== *)
(*  /api/autoMomenta HANDLER                                           *)
(*  Re-routes all momenta via BFS spanning tree                        *)
(* ================================================================== *)

handleAutoMomenta[body_String] := Module[{parsed, res, momData},
  parsed = Quiet @ ImportString[body, "RawJSON"];

  (* Parse custom labels if provided *)
  If[AssociationQ[parsed],
    If[KeyExistsQ[parsed, "loopMomLabels"],
      $loopMomenta = safeToExpr /@ parsed["loopMomLabels"]];
    If[KeyExistsQ[parsed, "extMomLabels"],
      $extMomLabels = safeToExpr /@ parsed["extMomLabels"]]];

  res = Quiet @ Check[
    autoRouteMomenta[$efl, $n0r, $nloops, $loopMomenta, $extMomLabels],
    {Table[Null, {$ne}], {}}];
  $edgeMomenta = res[[1]];
  $chordEdges = res[[2]];

  momData = Table[Module[{mom = $edgeMomenta[[i]], flip, displayMom},
    flip = If[mom === Null, False, leadingTermNegativeQ[mom]];
    displayMom = If[flip, -mom, mom];
    <|
    "inputForm" -> If[mom === Null, "", toCanonicalInputForm[displayMom]],
    "display" -> If[mom === Null, "", toDisplayString[displayMom]],
    "arrowReversed" -> flip
  |>], {i, $ne}];

  stLog["[SubTropica] Auto-routed momenta, chords: ", $chordEdges];
  ExportString[<|"status" -> "ok", "momenta" -> momData,
    "chords" -> $chordEdges|>, "RawJSON"]
];


(* ================================================================== *)
(*  /api/solveMomCons HANDLER                                         *)
(*  Fills unknown momenta from momentum conservation                   *)
(* ================================================================== *)

handleSolveMomCons[body_String] := Module[{parsed, currentMom, res, momData},
  parsed = Quiet @ ImportString[body, "RawJSON"];

  If[AssociationQ[parsed] && KeyExistsQ[parsed, "currentMomenta"],
    currentMom = Table[
      With[{s = parsed["currentMomenta"][[i]]},
        If[StringQ[s] && StringLength[s] > 0,
          Quiet @ Check[ToExpression[s], Null], Null]],
      {i, Length[parsed["currentMomenta"]]}];

    If[KeyExistsQ[parsed, "extMomLabels"],
      $extMomLabels = safeToExpr /@ parsed["extMomLabels"]];

    res = Quiet @ Check[
      autoCompleteMomenta[$efl, $n0r, currentMom, $nloops, $extMomLabels],
      currentMom];
    $edgeMomenta = res;

    momData = Table[Module[{mom = $edgeMomenta[[i]], flip, displayMom},
      flip = If[mom === Null, False, leadingTermNegativeQ[mom]];
      displayMom = If[flip, -mom, mom];
      <|
      "inputForm" -> If[mom === Null, "", toCanonicalInputForm[displayMom]],
      "display" -> If[mom === Null, "", toDisplayString[displayMom]],
      "arrowReversed" -> flip
    |>], {i, $ne}];

    stLog["[SubTropica] Solved momentum conservation"];
    ExportString[<|"status" -> "ok", "momenta" -> momData|>, "RawJSON"],

    (* Bad request *)
    ExportString[<|"status" -> "error",
      "error" -> "Missing currentMomenta"|>, "RawJSON"]
  ]
];


(* ================================================================== *)
(*  /api/refreshDiagram HANDLER                                        *)
(*  Re-renders diagram SVG and recomputes Nickel index with current    *)
(*  mass values from the UI                                            *)
(* ================================================================== *)

handleRefreshDiagram[body_String] := Module[{parsed, nickel},
  parsed = Quiet @ ImportString[body, "RawJSON"];

  (* Update masses from form values *)
  If[AssociationQ[parsed],
    If[KeyExistsQ[parsed, "internalMasses"],
      $intm = safeToExpr /@ parsed["internalMasses"]];
    If[KeyExistsQ[parsed, "externalMasses"],
      $extm = safeToExpr /@ parsed["externalMasses"]]];

  (* Recompute Nickel index with updated masses *)
  nickel = Quiet @ Check[computeNickelIndex[$efl, $n0r, $intm, $extm], ""];

  stLog["[SubTropica] Nickel refreshed: ", nickel];
  ExportString[<|"status" -> "ok",
    "nickelIndex" -> nickel|>, "RawJSON"]
];


(* ================================================================== *)
(*  /api/kinematics HANDLER                                            *)
(*  Returns p_i . p_j substitution rules from basis[n] as LaTeX        *)
(* ================================================================== *)

handleKinematics[body_String] := Quiet @ Check[
  handleKinematicsImpl[body],
  ExportString[<|"status" -> "ok", "rules" -> {}, "extMassRules" -> {}, "intMassRules" -> {}|>, "RawJSON"]
];

handleKinematicsImpl[body_String] := Module[
  {parsed, nLegs, masses, intMasses, userSubsStr, kinRules, kinData,
   formatTeX, massSymNames, greenTeX, extMassRules, intMassRules},

  parsed = Quiet @ ImportString[body, "RawJSON"];
  nLegs = If[AssociationQ[parsed] && KeyExistsQ[parsed, "nLegs"],
    parsed["nLegs"],
    If[IntegerQ[$nl], $nl, 0]];

  If[!IntegerQ[nLegs] || nLegs < 2,
    Return[ExportString[<|"status" -> "ok", "rules" -> {}|>, "RawJSON"]]];

  (* External mass values from the UI (list of strings like "0", "m", etc.) *)
  masses = If[AssociationQ[parsed] && KeyExistsQ[parsed, "masses"],
    parsed["masses"], Table["0", nLegs]];

  (* Internal mass values from the UI (list of ints: 0, 1, 2, ...) *)
  intMasses = If[AssociationQ[parsed] && KeyExistsQ[parsed, "intMasses"],
    parsed["intMasses"], {}];

  (* User substitutions string from the UI (e.g. "{s -> 1, t -> 2}") *)
  userSubsStr = If[AssociationQ[parsed] && KeyExistsQ[parsed, "substitutions"],
    parsed["substitutions"], "{}"];

  (* Use basis[nLegs] where Subscript[M,i] = p_i^2 (mass squared).
     In SubTropica convention, the mass entered by the user IS the
     mass squared: propagators are q^2 - m (not q^2 - m^2). *)
  kinRules = Quiet @ Check[basis[nLegs], {}];

  (* Helper: wrap TeX in green-colored class for output variables. *)
  greenTeX[t_String] := "\\htmlClass{kin-var}{" <> t <> "}";

  (* Helper: format an expression for display.
     1. Substitute masses: Subscript[M,i] -> massExpr (no squaring!)
     2. Apply homogeneizeKin2 to get final code variable names
     3. Convert to TeX and color code variables green *)
  formatTeX[expr_, massSubs_List:{}] := Module[{substituted, homog, tex},
    substituted = expr //. massSubs // Simplify;
    homog = homogeneizeKin2[substituted];
    tex = ToString[TeXForm[homog]];
    (* Strip Global` context prefix artifacts *)
    tex = StringReplace[tex, "\\text{Global$\\grave{ }$" ~~ name:LetterCharacter.. ~~ "}" :> name];
    (* Color code variables green: s12, MM, MM1, mm, mm1, mmH, etc. *)
    tex = StringReplace[tex, {
      (* Mandelstam: s followed by 2+ digits *)
      RegularExpression["(?<![a-zA-Z\\\\])s(\\d{2,})(?![a-zA-Z])"] :>
        greenTeX["\\texttt{s$1}"],
      (* MM/mm with index (numeric or alpha): \text{MM1}, \text{mmH}, etc. *)
      RegularExpression["\\\\text\\{(MM\\w+)\\}"] :> greenTeX["\\texttt{$1}"],
      RegularExpression["\\\\text\\{(mm\\w+)\\}"] :> greenTeX["\\texttt{$1}"],
      (* Bare MM/mm (single mass scale) *)
      RegularExpression["\\\\text\\{MM\\}"] :> greenTeX["\\texttt{MM}"],
      RegularExpression["\\\\text\\{mm\\}"] :> greenTeX["\\texttt{mm}"],
      (* Bare MM/mm without \text{} wrapper *)
      RegularExpression["(?<![a-zA-Z\\\\])MM(\\w+)(?![a-zA-Z])"] :>
        greenTeX["\\texttt{MM$1}"],
      RegularExpression["(?<![a-zA-Z\\\\])mm(\\w+)(?![a-zA-Z])"] :>
        greenTeX["\\texttt{mm$1}"],
      RegularExpression["(?<![a-zA-Z\\\\])MM(?![a-zA-Z\\d])"] :>
        greenTeX["\\texttt{MM}"],
      RegularExpression["(?<![a-zA-Z\\\\])mm(?![a-zA-Z\\d])"] :>
        greenTeX["\\texttt{mm}"]
    }];
    tex
  ];

  (* Build mass substitutions: Subscript[M,i] -> massExpr.
     In basis[n], Subscript[M,i] IS p_i^2 = mass squared.
     The user's mass value IS the mass squared (SubTropica convention). *)
  massSubs = Table[
    Module[{massExpr},
      massExpr = If[masses[[i]] === "0" || masses[[i]] === "",
        0,
        safeToExpr[masses[[i]]]
      ];
      Subscript[M, i] -> massExpr
    ]
  , {i, Min[Length[masses], nLegs]}];

  (* User substitutions *)
  userSubs = Quiet[Check[ToExpression[userSubsStr, InputForm, Hold] // ReleaseHold, {}]];
  If[!ListQ[userSubs], userSubs = {}];
  userSubs = userSubs /. Rule[sym_Symbol, val_] :> Rule[Symbol["Global`" <> SymbolName[sym]], val];
  allSubs = Join[massSubs, userSubs];

  (* \[HorizontalLine]\[HorizontalLine] Kinematic dot-product rules \[HorizontalLine]\[HorizontalLine] *)
  kinData = DeleteDuplicates[Table[
    Module[{lhsTeX, rhs, rhsTex},
      lhsTeX = ToString[TeXForm[r[[1]]]];
      rhs = r[[2]];
      rhsTex = formatTeX[rhs, allSubs];

      <|"lhs" -> lhsTeX,
        "rhs" -> rhsTex, "rhsSub" -> "",
        "type" -> If[SameQ[r[[1, 1]], r[[1, 2]]], "extMom", "mandelstam"],
        "diagonal" -> SameQ[r[[1, 1]], r[[1, 2]]],
        "zero" -> SameQ[rhs //. allSubs // Simplify, 0]|>
    ]
  , {r, kinRules}], #1["lhs"] === #2["lhs"] &];

  (* \[HorizontalLine]\[HorizontalLine] External mass rules: p_i^2 = code_variable (skip massless) \[HorizontalLine]\[HorizontalLine] *)
  extMassRules = Table[
    Module[{massStr = masses[[i]], massExpr, rhsTex},
      If[massStr === "0" || massStr === "", Nothing,
        massExpr = safeToExpr[massStr];
        rhsTex = formatTeX[massExpr, {}];
        <|"lhs" -> "p_{" <> ToString[i] <> "}^2",
          "rhs" -> rhsTex, "rhsSub" -> "",
          "type" -> "extMom", "diagonal" -> True, "zero" -> False|>
      ]
    ]
  , {i, nLegs}];

  (* \[HorizontalLine]\[HorizontalLine] Internal mass rules: m_i^2 = code_variable (skip massless) \[HorizontalLine]\[HorizontalLine] *)
  intMassRules = Module[{distinctMasses, singleIntMass, rules = {}},
    distinctMasses = DeleteDuplicates[Select[intMasses, # =!= 0 &]];
    singleIntMass = Length[distinctMasses] === 1;
    Do[
      Module[{massExpr, rhsTex},
        (* Use same convention: single mass -> bare m, multi -> Subscript[m,i] *)
        massExpr = If[singleIntMass, m, Subscript[m, mv]];
        rhsTex = formatTeX[massExpr, {}];
        AppendTo[rules, <|
          "lhs" -> If[singleIntMass, "m^2", "m_{" <> ToString[mv] <> "}^2"],
          "rhs" -> rhsTex, "rhsSub" -> "",
          "type" -> "intMass", "diagonal" -> False, "zero" -> False
        |>];
      ];
    , {mv, distinctMasses}];
    rules
  ];

  ExportString[<|"status" -> "ok",
    "rules" -> kinData,
    "extMassRules" -> extMassRules,
    "intMassRules" -> intMassRules
  |>, "RawJSON"]
];


(* ================================================================== *)
(*  /api/deleteResult HANDLER                                          *)
(*  Removes a computed result from a library entry.json by index       *)
(* ================================================================== *)

handleDeleteResult[body_String] := Module[
  {parsed, topoKey, configKey, resultIndex, entryPath, entry, results},

  parsed = Quiet @ ImportString[body, "RawJSON"];
  If[!AssociationQ[parsed], Return[
    ExportString[<|"status" -> "error", "error" -> "Invalid JSON"|>, "RawJSON"]]];

  topoKey = parsed["topoKey"];
  configKey = parsed["configKey"];
  resultIndex = parsed["resultIndex"];

  If[!StringQ[topoKey] || !StringQ[configKey] || !IntegerQ[resultIndex],
    Return[ExportString[<|"status" -> "error",
      "error" -> "Missing topoKey, configKey, or resultIndex"|>, "RawJSON"]]];

  entryPath = FileNameJoin[{$SubTropicaInstallDir, "library-local",
    stSanitizeNickel[topoKey], stSanitizeNickel[configKey], "entry.json"}];
  If[!FileExistsQ[entryPath],
    entryPath = FileNameJoin[{$SubTropicaInstallDir, "library-bundled",
      stSanitizeNickel[topoKey], stSanitizeNickel[configKey], "entry.json"}]];

  If[!FileExistsQ[entryPath],
    Return[ExportString[<|"status" -> "error",
      "error" -> "Entry not found"|>, "RawJSON"]]];

  entry = Quiet @ Check[Import[entryPath, "RawJSON"], $Failed];
  If[!AssociationQ[entry],
    Return[ExportString[<|"status" -> "error",
      "error" -> "Cannot parse entry"|>, "RawJSON"]]];

  results = Lookup[entry, "Results", {}];
  (* resultIndex is 0-based from JS *)
  If[resultIndex < 0 || resultIndex >= Length[results],
    Return[ExportString[<|"status" -> "error",
      "error" -> "Index out of range"|>, "RawJSON"]]];

  entry["Results"] = Delete[results, resultIndex + 1];  (* Mathematica is 1-based *)
  Export[entryPath, entry, "RawJSON"];
  stLog["[SubTropica] Deleted result ", resultIndex, " from ", entryPath];
  ExportString[<|"status" -> "ok"|>, "RawJSON"]
];



(* ================================================================== *)
(*  /api/transformResult HANDLER                                       *)
(*  Apply soft transforms (normalization, substitutions, external      *)
(*  masses) to a cached library result.                                *)
(* ================================================================== *)

handleTransformResult[body_String] := Module[
  {parsed, resultExpr, transforms, result, tex, normExpr, loops},

  parsed = Quiet @ ImportString[body, "RawJSON"];
  If[!AssociationQ[parsed], Return[
    ExportString[<|"status" -> "error", "error" -> "Invalid JSON"|>, "RawJSON"]]];

  (* Parse the cached result expression: prefer Compress'd binary, fall back to InputForm *)
  resultExpr = If[StringQ[Lookup[parsed, "resultCompressed", None]],
    Quiet @ Check[Uncompress[parsed["resultCompressed"]], $Failed],
    $Failed];
  If[resultExpr === $Failed,
    resultExpr = Quiet @ Check[ToExpression[parsed["resultInputForm"]], $Failed]];
  If[resultExpr === $Failed, Return[
    ExportString[<|"status" -> "error", "error" -> "Cannot parse result"|>, "RawJSON"]]];

  transforms = Lookup[parsed, "transforms", {}];

  (* Apply each transform in order *)
  Do[Module[{t = transforms[[i]]},
    Switch[t["type"],

      (* Normalization rescaling: multiply by N_current / N_cached *)
      "normalization",
      Module[{fromNorm, toNorm, ratio},
        fromNorm = t["from"];
        toNorm = t["to"];
        (* Parse normalization expressions; "Automatic" = Exp[L * eps * EulerGamma] *)
        loops = If[IntegerQ[$nloops], $nloops, 1];
        fromNorm = If[fromNorm === "Automatic",
          Exp[loops * eps * EulerGamma],
          Quiet @ Check[ToExpression[fromNorm], 1]];
        toNorm = If[toNorm === "Automatic",
          Exp[loops * eps * EulerGamma],
          Quiet @ Check[ToExpression[toNorm], 1]];
        ratio = Simplify[toNorm / fromNorm];
        resultExpr = Expand[resultExpr * ratio]],

      (* Substitutions: apply user rules to symbolic result *)
      "substitutions",
      Module[{rules},
        rules = Quiet @ Check[ToExpression[t["rules"]], {}];
        If[ListQ[rules], resultExpr = resultExpr /. rules]],

      (* Internal mass renaming: old symbol -> new symbol *)
      "internalMasses",
      Module[{renames, rules = {}},
        renames = t["renames"];
        If[AssociationQ[renames],
          KeyValueMap[Function[{old, new},
            AppendTo[rules,
              Quiet @ Check[ToExpression[old], Nothing] ->
              Quiet @ Check[ToExpression[new], Nothing]]],
            renames];
          rules = DeleteCases[rules, Nothing -> _ | _ -> Nothing];
          If[Length[rules] > 0, resultExpr = resultExpr /. rules]]],

      (* External masses: apply M_i -> value substitutions *)
      "externalMasses",
      Module[{masses, cachedMasses, rules = {}},
        masses = t["masses"];
        cachedMasses = Lookup[t, "cachedMasses", {}];
        If[ListQ[masses],
          Do[
            Module[{curVal, oldVal},
              curVal = If[masses[[j]] =!= "0" && masses[[j]] =!= "",
                Quiet @ Check[ToExpression[masses[[j]]], 0], 0];
              oldVal = If[ListQ[cachedMasses] && j <= Length[cachedMasses] &&
                cachedMasses[[j]] =!= "0" && cachedMasses[[j]] =!= "",
                Quiet @ Check[ToExpression[cachedMasses[[j]]], 0], 0];
              (* Only add rule if the value changed *)
              If[curVal =!= oldVal,
                AppendTo[rules, Subscript[M, j] -> curVal]]],
            {j, Length[masses]}];
          If[Length[rules] > 0, resultExpr = resultExpr /. rules]]],

      (* Unknown transform type \[LongDash] skip *)
      _, Null
    ]], {i, Length[transforms]}];

  (* Generate TeX from the transformed result *)
  tex = Quiet @ Check[ToString[resultExpr, TeXForm], ""];
  result = ToString[resultExpr, InputForm];

  Module[{sf = stComputeSymbolFields[resultExpr]},
  ExportString[<|
    "status" -> "ok",
    "result" -> result,
    "resultTeX" -> tex,
    "symbolTeX" -> sf[[1]],
    "alphabet" -> sf[[2]],
    "symbolWeight" -> sf[[3]],
    "symbolTerms" -> sf[[4]]
  |>, "RawJSON"]]
];


(* \[HorizontalLine]\[HorizontalLine] Contributor identity (voluntary attribution for library submissions) \[HorizontalLine]\[HorizontalLine] *)

$stContributorFile = FileNameJoin[{$SubTropicaInstallDir, "contributor.json"}];
$stContributor = None;

stLoadContributor[] := Module[{data},
  If[$stContributor =!= None, Return[$stContributor]];
  If[FileExistsQ[$stContributorFile],
    data = Quiet @ Check[Import[$stContributorFile, "RawJSON"], $Failed];
    If[AssociationQ[data],
      $stContributor = data;
      Return[data]]];
  $stContributor = <|"name" -> "", "anonymous" -> False|>;
  $stContributor
];

STSetContributor[name_String, opts___Rule] := Module[{data},
  data = <|
    "name" -> name,
    "anonymous" -> TrueQ[Lookup[{opts}, "Anonymous", False]]
  |>;
  $stContributor = data;
  Export[$stContributorFile, data, "RawJSON"];
  stLog["[SubTropica] Contributor set: ",
    If[data["anonymous"], "(anonymous)", data["name"]]];
  data
];
STSetContributor::usage = "STSetContributor[\"Name\"] sets your contributor \
identity for library submissions. \
Use \"Anonymous\" -> True to submit without attribution.";

stGetContributorField[] := Module[{c = stLoadContributor[]},
  If[TrueQ[c["anonymous"]] || !StringQ[c["name"]] || StringLength[c["name"]] == 0,
    "Anonymous", c["name"]]
];

handleGetContributor[body_String] :=
  ExportString[stLoadContributor[], "RawJSON"];

handleSetContributor[body_String] := Module[{parsed},
  parsed = Quiet @ ImportString[body, "RawJSON"];
  If[!AssociationQ[parsed], Return[
    ExportString[<|"status" -> "error", "error" -> "Invalid JSON"|>, "RawJSON"]]];
  STSetContributor[
    Lookup[parsed, "name", ""],
    "Anonymous" -> TrueQ[Lookup[parsed, "anonymous", False]]
  ];
  ExportString[<|"status" -> "ok"|>, "RawJSON"]
];


(* \[HorizontalLine]\[HorizontalLine] stTeXCleanup: shared string-level LaTeX notation cleanup \[HorizontalLine]\[HorizontalLine] *)
(* Used by stResultToTeX and stSymbolToTeX for consistent notation. *)

stTeXCleanup[tex_String] := StringReplace[tex, {
    (* Hlog placeholders \[RightArrow] H(args; z) *)
    "\\text{stTeXH}" -> "H",
    ",\\text{stTeXSemicolon}," -> "\\,;",
    ",\\text{stTeXSemicolon}" -> "\\,;",
    (* Remove {}^ artifact from Superscript[Subscript[...]] *)
    "{}^" -> "^",
    (* eps \[RightArrow] varepsilon *)
    "\\text{eps}" -> "\\varepsilon",
    (* Mandelstam variables: s12 \[RightArrow] s_{12}, s23 \[RightArrow] s_{23}, etc. *)
    RegularExpression["\\\\text\\{s(\\d+)\\}"] -> "s_{$1}",
    (* Feynman parameters: x1 \[RightArrow] x_1, x2 \[RightArrow] x_2, ... (used in
       polynomialTeX for algebraic-letter tooltips) *)
    RegularExpression["\\\\text\\{x(\\d+)\\}"] -> "x_{$1}",
    (* Normalize Zeta[n] output to \zeta *)
    RegularExpression["\\\\text\\{mzv\\}\\s*\\("] -> "\\zeta(",
    RegularExpression["\\\\zeta\\s+\\("] -> "\\zeta(",
    (* Remove braced sign operators {+} and {-} that KaTeX rejects *)
    "{+}" -> "+",
    "{-}" -> "-",
    (* Mass-squared symbols: mm \[RightArrow] m^2, MM \[RightArrow] M^2 *)
    RegularExpression["\\\\text\\{mm\\}"] -> "m^2",
    RegularExpression["\\\\text\\{MM\\}"] -> "M^2"
}];


(* \[HorizontalLine]\[HorizontalLine] stExpandProductLetters: Leibniz rule for the symbol \[HorizontalLine]\[HorizontalLine] *)
(* Expands product letters in symbol terms:
     {c, {A, B*C, D}} -> {c, {A, B, D}} + {c, {A, C, D}}
   Powers are treated as repeated factors:
     {c, {A, B^n, D}} -> {n*c, {A, B, D}}
   Numeric prefactors in letters are absorbed into the coefficient
   (d log(-x) = d log(x) at the symbol level modulo i\[Pi] constants).
   Input/output: list of {coefficient, {letter1, letter2, ...}}. *)
stExpandProductLetters[sym_List] := Module[{result = {}},
  Do[Module[{coef = term[[1]], letters = term[[2]], expanded},
    expanded = {{coef, {}}};
    Do[
      Module[{factors = stExtractLogFactors[letter], newExpanded = {}},
        Do[
          Do[AppendTo[newExpanded, {
              partial[[1]] * fac[[2]],
              Append[partial[[2]], fac[[1]]]}],
            {fac, factors}],
          {partial, expanded}];
        expanded = newExpanded],
      {letter, letters}];
    result = Join[result, expanded]],
    {term, sym}];
  (* Combine terms with identical letter lists *)
  Module[{grouped = <||>, key},
    Do[
      key = term[[2]];
      If[KeyExistsQ[grouped, key],
        grouped[key] += term[[1]],
        grouped[key] = term[[1]]],
      {term, result}];
    KeyValueMap[{#2, #1} &, grouped] // Select[#[[1]] =!= 0 &]
  ]
];

(* \[HorizontalLine]\[HorizontalLine] stCombineWmWpRatios: algebraic-pair ratio merge \[HorizontalLine]\[HorizontalLine] *)
(* Merges symbol terms that differ only in one slot by a Wm[i] \[LeftRightArrow] Wp[i]
   swap AND have opposite coefficients, collapsing them into a single term
   whose letter at the differing slot is WmOverWp[i] (:= Wm[i]/Wp[i]).
     {c,  {a, Wm[i], b}}  +  {-c, {a, Wp[i], b}}   \[Rule]   {c, {a, WmOverWp[i], b}}
     {c,  {a, Wp[i], b}}  +  {-c, {a, Wm[i], b}}   \[Rule]   {-c, {a, WmOverWp[i], b}}
   Iterated to a fixed point so cascades collapse fully.

   Rationale: at the symbol level, \[PartialD] log(Wm) - \[PartialD] log(Wp) = \[PartialD] log(Wm/Wp), so the
   tensor slot containing Wm/Wp carries the same physical information as the
   two-term difference, with half as many terms and a cleaner alphabet. *)

stTryMergeWmWp[{c1_, w1_List}, {c2_, w2_List}] :=
  Module[{diffs, k, a, b, idx},
    If[Length[w1] =!= Length[w2], Return[None]];
    If[!PossibleZeroQ[c1 + c2], Return[None]];
    diffs = Select[Range[Length[w1]], w1[[#]] =!= w2[[#]] &];
    If[Length[diffs] =!= 1, Return[None]];
    k = diffs[[1]];
    a = w1[[k]]; b = w2[[k]];
    Which[
      MatchQ[a, Wm[_Integer]] && MatchQ[b, Wp[_Integer]] && a[[1]] === b[[1]],
        idx = a[[1]];
        {c1, ReplacePart[w1, k -> WmOverWp[idx]]},
      MatchQ[a, Wp[_Integer]] && MatchQ[b, Wm[_Integer]] && a[[1]] === b[[1]],
        idx = a[[1]];
        {c2, ReplacePart[w1, k -> WmOverWp[idx]]},
      True, None]];

stCombineWmWpRatios[terms_List] := Module[{cur = terms, step},
  step[ts_List] := Module[{n = Length[ts], found = None, mt, i, j},
    Do[Do[
      mt = stTryMergeWmWp[ts[[i]], ts[[j]]];
      If[mt =!= None, found = {i, j, mt}; Break[]],
      {j, i + 1, n}];
      If[found =!= None, Break[]],
    {i, 1, n}];
    If[found === None, ts,
      Append[Delete[ts, {{found[[1]]}, {found[[2]]}}], found[[3]]]]];
  FixedPoint[step, cur, 10 Length[terms] + 10]
];


(* Extract {base, exponent} pairs from a symbol letter.
   Times[a, b, c^2] -> {{a,1}, {b,1}, {c,2}}.
   Numeric factors (integers, rationals) are dropped. *)
stExtractLogFactors[letter_] := Which[
  NumericQ[letter], {{1, 1}},          (* constant letter \[LongDash] keep as placeholder *)
  Head[letter] === Times,
    Flatten[stExtractLogFactors /@ (List @@ letter), 1] //
      Select[!NumericQ[#[[1]]] &] //
      If[# === {}, {{letter, 1}}, #] &,
  Head[letter] === Power && NumericQ[letter[[2]]],
    {{letter[[1]], letter[[2]]}},
  True, {{letter, 1}}
];


(* \[HorizontalLine]\[HorizontalLine] stSymbolToTeX: convert a single expression to its symbol in LaTeX \[HorizontalLine]\[HorizontalLine] *)
(* Returns {symbolTeX, alphabetTeXList} where alphabetTeXList is a list of
   LaTeX strings for the distinct letters. Returns {"", {}} on failure. *)

stSymbolToTeX[expr_] := Module[
  {sym, terms, letterPool, termTexs, tex, coef, letters, coefTeX, letterTexs,
   letterExpr, coefExpr, alphabetExprs, alphabetTeX, massRules},

  (* Compute the symbol as a list of {coef, {letter1, letter2, ...}} *)
  sym = Quiet @ Check[
    ConvertToSymbol[expr, "AsList" -> True, "Expand" -> True, "DropConstants" -> True],
    $Failed];

  If[!ListQ[sym] || sym === {}, Return[{"", {}, 0, 0}]];

  (* Filter out pure-constant terms (empty letter list) *)
  terms = Select[sym, Length[#[[2]]] > 0 &];
  If[terms === {}, Return[{"", {}, 0, 0}]];

  (* Algebraic ratio merge: a \[TensorProduct] Wm[i] \[TensorProduct] b  -  a \[TensorProduct] Wp[i] \[TensorProduct] b  =  a \[TensorProduct] WmOverWp[i] \[TensorProduct] b.
     Run after Leibniz expansion (which ConvertToSymbol already handled
     internally for atomic letters). *)
  terms = stCombineWmWpRatios[terms];
  terms = Select[terms, Length[#[[2]]] > 0 &];
  If[terms === {}, Return[{"", {}, 0, 0}]];

  (* Mass and root-letter symbol replacement rules *)
  massRules = {
    mm[i_]^n_ :> Superscript[Subscript[m, i], 2 n],
    mm[i_]    :> Superscript[Subscript[m, i], 2],
    MM[i_]^n_ :> Superscript[Subscript[M, i], 2 n],
    MM[i_]    :> Superscript[Subscript[M, i], 2],
    MM^n_     :> Superscript[M, 2 n],
    MM        :> Superscript[M, 2],
    mm^n_     :> Superscript[m, 2 n],
    mm        :> Superscript[m, 2],
    Wm[i_]^n_ :> Superscript[Subsuperscript[W, i, "-"], n],
    Wm[i_]    :> Subsuperscript[W, i, "-"],
    Wp[i_]^n_ :> Superscript[Subsuperscript[W, i, "+"], n],
    Wp[i_]    :> Subsuperscript[W, i, "+"],
    WmOverWp[i_]^n_ :> Superscript[HoldForm[Divide[Subsuperscript[W, i, "-"], Subsuperscript[W, i, "+"]]], n],
    WmOverWp[i_]    :> HoldForm[Divide[Subsuperscript[W, i, "-"], Subsuperscript[W, i, "+"]]]
  };

  letterPool = {};
  termTexs = {};

  Do[
    coef = term[[1]];
    letters = term[[2]];

    (* Convert each letter to TeX *)
    letterTexs = Map[
      Function[letter,
        letterExpr = letter /. massRules;
        AppendTo[letterPool, letter];
        Quiet @ Check[ToString[letterExpr, TeXForm], ToString[letter]]
      ],
      letters];

    (* Apply string-level cleanup to each letter TeX *)
    letterTexs = Map[stTeXCleanup, letterTexs];

    (* Format coefficient \[LongDash] Simplify, Together, then apply mass symbol cleanup *)
    coefExpr = Together[Simplify[coef]] /. massRules;
    coefTeX = Which[
      coef === 1,  "",
      coef === -1, "-",
      True, Quiet @ Check[stTeXCleanup[ToString[coefExpr, TeXForm]], ToString[coef]] <> "\\,"
    ];

    (* Build term: coef (letter1 \otimes letter2 \otimes ...) *)
    AppendTo[termTexs,
      coefTeX <> "(" <> StringRiffle[letterTexs, " \\otimes "] <> ")"
    ],

    {term, terms}
  ];

  (* Join terms with + (fix double signs) *)
  tex = StringRiffle[termTexs, " + "];
  tex = StringReplace[tex, "+ -" -> "- "];

  (* Build alphabet: unique letters with TeX *)
  alphabetExprs = DeleteDuplicates[letterPool, Simplify[#1 - #2] === 0 &];
  alphabetTeX = Map[
    Function[letter,
      Module[{le},
        le = letter /. massRules;
        stTeXCleanup[Quiet @ Check[ToString[le, TeXForm], ToString[letter]]]
      ]
    ],
    alphabetExprs];

  {tex, alphabetTeX, Max[Length /@ terms[[All, 2]]], Length[terms]}
];


(* \[HorizontalLine]\[HorizontalLine] Symbol normalization: W_i letters with simplified coefficients \[HorizontalLine]\[HorizontalLine] *)

(* Shared mass display rules *)
$stNormMassRules = {
  mm[i_]^n_ :> Superscript[Subscript[m, i], 2 n],
  mm[i_]    :> Superscript[Subscript[m, i], 2],
  MM[i_]^n_ :> Superscript[Subscript[M, i], 2 n],
  MM[i_]    :> Superscript[Subscript[M, i], 2],
  MM^n_     :> Superscript[M, 2 n],
  MM        :> Superscript[M, 2],
  mm^n_     :> Superscript[m, 2 n],
  mm        :> Superscript[m, 2],
  (* FindRoots algebraic root letters *)
  Wm[i_]^n_ :> Superscript[Subsuperscript[W, i, "-"], n],
  Wm[i_]    :> Subsuperscript[W, i, "-"],
  Wp[i_]^n_ :> Superscript[Subsuperscript[W, i, "+"], n],
  Wp[i_]    :> Subsuperscript[W, i, "+"],
  (* Compound ratio letter from stCombineWmWpRatios (symbol-level Leibniz) *)
  WmOverWp[i_]^n_ :> Superscript[HoldForm[Divide[Subsuperscript[W, i, "-"], Subsuperscript[W, i, "+"]]], n],
  WmOverWp[i_]    :> HoldForm[Divide[Subsuperscript[W, i, "-"], Subsuperscript[W, i, "+"]]]
};

(* Detect scale from a list of symbolic letters.
   If the top-level letter list is entirely algebraic (Wm[i]/Wp[i]), also
   look through $HyperAlgebraicLetterTable polynomials so we can still find
   an mm/MM/Mandelstam scale to normalize against. *)
stDetectScale[allLetters_List] := Module[{scale = None, lettersPlusPoly},
  Do[If[MatchQ[l, mm | mm[_]], scale = l; Break[]], {l, Sort[allLetters]}];
  If[scale === None,
    Do[If[MatchQ[l, MM | MM[_]], scale = l; Break[]], {l, Sort[allLetters]}]];
  If[scale === None,
    Module[{mandels = Select[allLetters, MatchQ[#, _Symbol] && StringMatchQ[SymbolName[#], "s" ~~ DigitCharacter ..] &]},
      If[mandels =!= {}, scale = Sort[mandels][[1]]]]];

  If[scale === None && Length[$HyperAlgebraicLetterTable] > 0,
    lettersPlusPoly = DeleteDuplicates @ Join[
      allLetters,
      Cases[Values[$HyperAlgebraicLetterTable][[All, "Polynomial"]],
        (mm | mm[_] | MM | MM[_]), Infinity]];
    Do[If[MatchQ[l, mm | mm[_]], scale = l; Break[]], {l, Sort[lettersPlusPoly]}];
    If[scale === None,
      Do[If[MatchQ[l, MM | MM[_]], scale = l; Break[]], {l, Sort[lettersPlusPoly]}]]];

  scale
];

(* Build W mapping from a list of symbolic letters and a chosen scale.
   Returns {wMap <|letter -> <|label, kind, pairIndex, definition,
     originalLetter, (polynomialTeX, discriminantTeX for algebraic)|>|>, scaleTeX}.

   Letter kinds:
     - "algebraic":  Wm[i]/Wp[i] from FindRoots. `definition` is the root
         formula  (\\pm\\sqrt{\\Delta} - b) / 2a; `pairIndex` is the shared
         i so the UI can group the (W^-, W^+) pair into a single pill;
         `polynomialTeX` and `discriminantTeX` give the quadratic for
         tooltip display.
     - "rational":   everything else. `definition` is `letter / scale`,
         matching the existing wDefinitions behaviour; `pairIndex` is Null. *)
stBuildWMap[allLetters_List, scale_] := Module[
  {wMap = <||>, wCount = 0, scaleTeX, table = $HyperAlgebraicLetterTable},

  scaleTeX = stTeXCleanup[Quiet @ Check[ToString[scale /. $stNormMassRules, TeXForm], ToString[scale]]];

  Do[
    Module[{l = letter, lTeX, defTeX, label, kind = "rational",
            pairIdx = Null, extra = <||>},
      If[Simplify[l - scale] === 0, Continue[]];
      If[AnyTrue[Keys[wMap], Simplify[l - #] === 0 || Simplify[l + #] === 0 &], Continue[]];

      Which[
        (* Algebraic: Wm[i] or Wp[i] with a populated letter-table entry. *)
        MatchQ[l, (Wm | Wp)[_Integer]] && KeyExistsQ[table, l[[1]]],
          Module[{i = l[[1]], sgn, rootExpr, polyTeX, discTeX, rec},
            rec     = table[i];
            sgn     = If[Head[l] === Wm, "-", "+"];
            rootExpr= If[Head[l] === Wm, rec["WmValue"], rec["WpValue"]];
            label   = "W^" <> sgn <> "_" <>
                      If[i >= 10, "{" <> ToString[i] <> "}", ToString[i]];
            kind    = "algebraic";
            pairIdx = i;
            lTeX    = stTeXCleanup[Quiet @ Check[
                        ToString[l /. $stNormMassRules, TeXForm], ToString[l]]];
            defTeX  = stTeXCleanup[Quiet @ Check[
                        ToString[rootExpr /. $stNormMassRules, TeXForm], lTeX]];
            polyTeX = stTeXCleanup[Quiet @ Check[
                        ToString[rec["Polynomial"] /. $stNormMassRules, TeXForm], ""]];
            discTeX = stTeXCleanup[Quiet @ Check[
                        ToString[rec["Discriminant"] /. $stNormMassRules, TeXForm], ""]];
            extra   = <|
              "polynomialTeX"   -> polyTeX,
              "discriminantTeX" -> discTeX
            |>],

        (* Rational: default numbered W_k = letter / scale. *)
        True,
          wCount++;
          label  = "W_" <>
                   If[wCount >= 10, "{" <> ToString[wCount] <> "}", ToString[wCount]];
          lTeX   = stTeXCleanup[Quiet @ Check[
                     ToString[l /. $stNormMassRules, TeXForm], ToString[l]]];
          defTeX = stTeXCleanup[Quiet @ Check[
                     ToString[HoldForm[Divide[#1, #2]] &[l /. $stNormMassRules,
                                                         scale /. $stNormMassRules], TeXForm],
                     lTeX <> "/" <> scaleTeX]]
      ];

      wMap[l] = Join[
        <|"label"          -> label,
          "kind"           -> kind,
          "pairIndex"      -> pairIdx,
          "definition"     -> defTeX,
          "originalLetter" -> lTeX|>,
        extra]
    ],
    {letter, allLetters}
  ];
  {wMap, scaleTeX}
];

(* Apply a pre-built W mapping to a single expression's symbol.
   Factors out the GCD of all surviving coefficients as a per-order prefactor.
   Returns {normalizedTeX, nTerms} or {"", 0} if all terms drop. *)
stApplyWMap[expr_, scale_, wMap_Association] := Module[
  {sym, terms, survivors = {}, lookupW},

  sym = Quiet @ Check[
    ConvertToSymbol[expr, "AsList" -> True, "Expand" -> True, "DropConstants" -> True],
    $Failed];
  If[!ListQ[sym] || sym === {}, Return[{"", 0}]];
  terms = Select[sym, Length[#[[2]]] > 0 &];
  (* Leibniz rule: d log(A*B) = d log(A) + d log(B) *)
  terms = stExpandProductLetters[terms];
  (* Algebraic ratio merge: d log(Wm[i]) - d log(Wp[i]) = d log(Wm[i]/Wp[i]) *)
  terms = stCombineWmWpRatios[terms];
  terms = Select[terms, Length[#[[2]]] > 0 &];
  If[terms === {}, Return[{"", 0}]];

  lookupW[l_] := Module[{key, i},
    key = SelectFirst[Keys[wMap], Simplify[l - #] === 0 || Simplify[l + #] === 0 &, None];
    If[key =!= None, Return[wMap[key]["label"]]];
    (* Compound ratio letter WmOverWp[i] from stCombineWmWpRatios \[LongDash] emit
       \frac{W^-_i}{W^+_i} directly; no wMap entry needed. *)
    If[MatchQ[l, WmOverWp[_Integer]],
      i = l[[1]];
      Return["\\frac{W^-_" <>
        If[i >= 10, "{" <> ToString[i] <> "}", ToString[i]] <>
        "}{W^+_" <>
        If[i >= 10, "{" <> ToString[i] <> "}", ToString[i]] <> "}"]];
    None
  ];

  (* Pass 1: collect surviving {coefficient, {W labels}} pairs *)
  Do[
    Module[{coef = term[[1]], letters = term[[2]], hasScale = False, wLabels = {}},
      Do[
        If[Simplify[letter - scale] === 0, hasScale = True; Break[]];
        Module[{w = lookupW[letter]},
          If[w === None, hasScale = True; Break[]];
          AppendTo[wLabels, w]],
        {letter, letters}
      ];
      If[hasScale, Continue[]];
      AppendTo[survivors, {Together[Simplify[coef]], wLabels}];
    ],
    {term, terms}
  ];

  If[survivors === {}, Return[{"", 0}]];

  (* Pass 2: factor out GCD of all coefficients *)
  Module[{allCoefs, gcd, prefactor, prefactorTeX, termTexs, tex},
    allCoefs = survivors[[All, 1]];
    gcd = If[Length[allCoefs] === 1,
      (* Single term: factor out the whole coefficient *)
      allCoefs[[1]],
      (* Multiple terms: compute GCD of numerators / LCM of denominators *)
      Quiet @ Check[
        Module[{nums, dens, gcdNum, lcmDen},
          nums = Numerator /@ allCoefs;
          dens = Denominator /@ allCoefs;
          gcdNum = Fold[PolynomialGCD, First[nums], Rest[nums]];
          lcmDen = Fold[PolynomialLCM, First[dens], Rest[dens]];
          Together[gcdNum / lcmDen]],
        1]
    ];

    (* Only use the GCD if it simplifies things (not 1 or -1) *)
    If[gcd === 0, gcd = 1];
    prefactor = Together[Simplify[gcd]];

    (* Build TeX *)
    termTexs = {};
    Do[
      Module[{reduced, coefTeX},
        reduced = Together[Simplify[s[[1]] / prefactor]];
        coefTeX = Which[
          reduced === 1, "",
          reduced === -1, "-",
          True, stTeXCleanup[Quiet @ Check[
            ToString[reduced /. $stNormMassRules, TeXForm], ToString[reduced]]] <> "\\,"
        ];
        AppendTo[termTexs,
          coefTeX <> "(" <> StringRiffle[s[[2]], " \\otimes "] <> ")"];
      ],
      {s, survivors}
    ];

    tex = StringRiffle[termTexs, " + "];
    tex = StringReplace[tex, "+ -" -> "- "];

    (* Prepend prefactor: use brackets only when multiple terms *)
    If[prefactor =!= 1,
      Module[{pfTeX, useBrackets = Length[survivors] > 1},
        If[prefactor === -1,
          tex = If[useBrackets,
            "-\\!\\left[" <> tex <> "\\right]",
            "-" <> tex],
          pfTeX = stTeXCleanup[Quiet @ Check[
            ToString[prefactor /. $stNormMassRules, TeXForm], ToString[prefactor]]];
          tex = If[useBrackets,
            pfTeX <> "\\!\\left[" <> tex <> "\\right]",
            pfTeX <> "\\," <> tex]
        ]
      ]
    ];

    {tex, Length[survivors]}
  ]
];


(* \[HorizontalLine]\[HorizontalLine] stComputeNormalizedSymbolFields: main entry point \[HorizontalLine]\[HorizontalLine] *)
(* Truncate a long TeX string at a syntactically-safe boundary.  The older
   version tracked only `{` / `}` depth, which meant cuts could land inside
   `\left[...\right]` pairs, inside `\begin{aligned}...\end{aligned}`
   environments, or between `\left(` and its matching `\right)`, producing
   un-renderable fragments that UI-side KaTeX flags in red.

   This helper tracks, in a single pass:
     - `{` / `}` brace depth
     - `[` / `]` and `(` / `)` paren/bracket depth
     - `\left` / `\right` sequence-pair depth (tokens advance the cursor
       so we don't double-count when they sit next to a `(` or `[`)
     - `\begin{aligned}` / `\end{aligned}` environment depth

   A "top-level" cut point is one where ALL four depths are 0.  We find
   the last `+`/`-` at a top-level position within `maxChars`, truncate
   there, then emit in order the closers that balance anything still
   open: `}` for braces, `\right.` for unmatched `\left`s, `]`/`)` for
   paren depth, and `\end{aligned}` for open environments.  Close in
   reverse-open order so the nesting resolves correctly.

   Returns the truncated + balanced + " + \\cdots"-appended TeX, or the
   original string unchanged if it was already within `maxChars`. *)
stTruncateTeX[tex_String, maxChars_Integer] := Module[
  {s = tex, L, chars, len, i, ch, rest,
   braceDepth = 0, parenDepth = 0, bracketDepth = 0,
   leftDepth = 0, alignedDepth = 0,
   leftStack = {},  (* stack of (leftDelim) chars for each unmatched \left *)
   envStack = {},   (* stack of aligned/etc. environments opened but not closed *)
   cutPos = 0, j, lastInBudget = 0, firstOutOfBudget = 0,
   out, nOpenBrace, nCloseBrace},

  L = StringLength[tex];
  If[L <= maxChars, Return[tex]];

  (* Scan up to a little past maxChars to find the best cut point.
     Using Characters[] for single-character ops but also peeking ahead
     at the remaining string for multi-char tokens like \left / \right /
     \begin{aligned} / \end{aligned}.

     We scan up to `2 * maxChars` so that if the preferred cut-point
     (depth-0 +/- within `maxChars`) doesn't exist because the
     expression is a single giant macro argument (e.g. one long
     `\frac{...very long...}` at the top level), the scan can still
     find a depth-0 boundary farther out.  Failing that, the fallback
     below returns the full string untruncated \[LongDash] safer than cutting
     inside a macro and producing unrenderable output. *)
  chars = Characters[StringTake[tex, Min[2 * maxChars, L]]];
  len = Length[chars];
  i = 1;
  While[i <= len,
    ch = chars[[i]];

    (* Detect multi-char tokens by peeking at the remaining substring. *)
    rest = StringTake[tex, {i, Min[i + 30, L]}];

    Which[
      StringStartsQ[rest, "\\begin{aligned}"],
        alignedDepth++; AppendTo[envStack, "aligned"];
        i += StringLength["\\begin{aligned}"],

      StringStartsQ[rest, "\\end{aligned}"],
        alignedDepth = Max[alignedDepth - 1, 0];
        If[envStack =!= {}, envStack = Most[envStack]];
        i += StringLength["\\end{aligned}"],

      StringStartsQ[rest, "\\left"] &&
        StringLength[rest] >= 6 &&
        !LetterQ[StringTake[rest, {6, 6}]],
        (* \left<delim> \[LongDash] consume the token AND the delimiter that follows,
           capturing the delim so we can emit a matching "closer" later. *)
        leftDepth++;
        AppendTo[leftStack, StringTake[rest, {6, 6}]];
        i += 6,

      StringStartsQ[rest, "\\right"] &&
        StringLength[rest] >= 7 &&
        !LetterQ[StringTake[rest, {7, 7}]],
        leftDepth = Max[leftDepth - 1, 0];
        If[leftStack =!= {}, leftStack = Most[leftStack]];
        i += 7,

      ch === "{", braceDepth++; i++,
      ch === "}", braceDepth = Max[braceDepth - 1, 0]; i++,
      ch === "(", parenDepth++; i++,
      ch === ")", parenDepth = Max[parenDepth - 1, 0]; i++,
      ch === "[", bracketDepth++; i++,
      ch === "]", bracketDepth = Max[bracketDepth - 1, 0]; i++,

      (ch === "+" || ch === "-") &&
        braceDepth === 0 && parenDepth === 0 &&
        bracketDepth === 0 && leftDepth === 0 &&
        i > 200,
        (* Prefer a cut at or below maxChars; fall back to the first
           beyond-budget cut if no in-budget cut exists. *)
        If[i <= maxChars,
          lastInBudget = i - 1,
          If[firstOutOfBudget === 0, firstOutOfBudget = i - 1]];
        i++,

      True, i++
    ]
  ];

  (* Prefer the in-budget cut.  Fall back to the beyond-budget cut if
     the expression is one giant macro with no depth-0 +/- inside
     `maxChars`.  If neither exists (entire 2*maxChars is inside
     nested macros), return the full string \[LongDash] safer than cutting
     inside a macro argument and producing malformed LaTeX that no
     cleanup can repair. *)
  cutPos = Which[
    lastInBudget > 0,        lastInBudget,
    firstOutOfBudget > 0,    firstOutOfBudget,
    True,                    Return[tex]  (* give up on truncation *)
  ];
  s = StringTake[tex, cutPos];

  (* Reset bookkeeping and re-scan the truncated string so the stacks
     reflect the actual unclosed state at the cut point.  (The earlier
     scan went past `cutPos` looking for candidate cuts, so its end-of-
     scan depths don't match what's unclosed in `s`.) *)
  braceDepth = 0; parenDepth = 0; bracketDepth = 0; leftDepth = 0;
  alignedDepth = 0; leftStack = {}; envStack = {};
  i = 1; len = StringLength[s];
  While[i <= len,
    rest = StringTake[s, {i, Min[i + 30, len]}];
    Which[
      StringStartsQ[rest, "\\begin{aligned}"],
        alignedDepth++; AppendTo[envStack, "aligned"];
        i += StringLength["\\begin{aligned}"],
      StringStartsQ[rest, "\\end{aligned}"],
        alignedDepth = Max[alignedDepth - 1, 0];
        If[envStack =!= {}, envStack = Most[envStack]];
        i += StringLength["\\end{aligned}"],
      StringStartsQ[rest, "\\left"] &&
        StringLength[rest] >= 6 &&
        !LetterQ[StringTake[rest, {6, 6}]],
        leftDepth++; AppendTo[leftStack, StringTake[rest, {6, 6}]]; i += 6,
      StringStartsQ[rest, "\\right"] &&
        StringLength[rest] >= 7 &&
        !LetterQ[StringTake[rest, {7, 7}]],
        leftDepth = Max[leftDepth - 1, 0];
        If[leftStack =!= {}, leftStack = Most[leftStack]];
        i += 7,
      StringTake[s, {i, i}] === "{", braceDepth++; i++,
      StringTake[s, {i, i}] === "}", braceDepth = Max[braceDepth - 1, 0]; i++,
      StringTake[s, {i, i}] === "(", parenDepth++; i++,
      StringTake[s, {i, i}] === ")", parenDepth = Max[parenDepth - 1, 0]; i++,
      StringTake[s, {i, i}] === "[", bracketDepth++; i++,
      StringTake[s, {i, i}] === "]", bracketDepth = Max[bracketDepth - 1, 0]; i++,
      True, i++
    ]
  ];

  (* Emit closers in innermost-first order so nesting unwinds correctly.
     Braces (macro arguments) are always innermost in SubTropica's TeX,
     then `\left<d>` pairs, then bare brackets/parens, then the
     `\begin{aligned}` environment as the outermost scope.  All four
     classes are tracked as integer depths or LIFO stacks; we don't
     have the interleaving order between classes, but emitting in
     this class-order handles every case the generator produces.  *)
  out = s;
  Do[out = out <> "}", {braceDepth}];
  (* If we closed any brace, emit an empty `{}` too.  This is harmless
     for "regular" brace groups (an empty group renders as nothing), but
     crucially it gives binary macros their required second argument:
     `\frac{a}` alone trips "Expected argument" in KaTeX, but `\frac{a}{}`
     renders as a/nothing.  Same fix for `\binom{a}`, `\overset{a}`, etc.
     One `{}` suffices \[LongDash] the potentially-pending binary macro needs
     exactly one extra brace group. *)
  If[braceDepth > 0, out = out <> "{}"];
  Do[out = out <> "\\right.", {Length[leftStack]}];
  Do[out = out <> "]", {bracketDepth}];
  Do[out = out <> ")", {parenDepth}];
  Do[out = out <> "\\end{aligned}", {alignedDepth}];
  out = out <> " + \\cdots";
  out
];


(* Two-pass approach for SeriesData: first collect all letters across orders,
   then apply the global W mapping to each order.
   Returns <|"normalizedSymbolTeX"->..., "wDefinitions"->..., "normalizedAlphabet"->...,
   "symbolScale"->..., "normalizedSymbolTerms"->...|> or <||> on failure. *)

stComputeNormalizedSymbolFields[result_] := Module[
  {maxChars = 5000},

  Quiet @ Check[
    If[Head[result] === SeriesData,
      Module[{sd = result, minPow, rawCoeffs, nCoeffs,
              globalLetters = {}, scale, wMap, scaleTeX,
              orderTexs = {}, totalTerms = 0},
        minPow = sd[[4]] / sd[[6]];
        rawCoeffs = sd[[3]];
        nCoeffs = Length[rawCoeffs];

        (* Pass 1: collect all letters across all orders *)
        Do[
          Module[{coeff = rawCoeffs[[i]], sym, terms},
            If[coeff === 0, Continue[]];
            sym = Quiet @ Check[
              ConvertToSymbol[coeff, "AsList" -> True, "Expand" -> True, "DropConstants" -> True],
              $Failed];
            If[ListQ[sym],
              terms = Select[sym, Length[#[[2]]] > 0 &];
              globalLetters = Join[globalLetters, Flatten[terms[[All, 2]]]]]],
          {i, nCoeffs}
        ];
        globalLetters = DeleteDuplicates[globalLetters, Simplify[#1 - #2] === 0 &];
        If[Length[globalLetters] < 2, Return[<||>]];

        (* FindRoots letters Wp[i], Wm[i] are kept as native symbol letters
           with labels W^+_i, W^-_i.  No substitution or Leibniz expansion;
           the W_j labeling applies only to the remaining rational letters. *)

        scale = stDetectScale[globalLetters];
        If[scale === None, Return[<||>]];
        {wMap, scaleTeX} = stBuildWMap[globalLetters, scale];
        If[Length[wMap] == 0, Return[<||>]];

        (* Pass 2: apply W mapping to each order.  Orders whose coefficient
           has no logarithmic structure (stApplyWMap returns "") get the raw
           coefficient rendered instead, so the user sees every computed eps
           order rather than having empty-symbol orders silently skipped. *)
        Do[
          Module[{power = minPow + (i - 1), coeff = rawCoeffs[[i]], nTex, nTerms},
            If[coeff === 0, Continue[]];
            {nTex, nTerms} = stApplyWMap[coeff, scale, wMap];
            If[nTex === "",
              nTex = stTeXCleanup[Quiet @ Check[
                ToString[coeff /. $stNormMassRules, TeXForm], ""]];
              If[nTex === "", Continue[]];
              nTerms = 1];
            totalTerms += nTerms;
            AppendTo[orderTexs,
              "\\varepsilon^{" <> ToString[power] <> "}&\\colon\\;" <> nTex]],
          {i, nCoeffs}
        ];

        If[orderTexs === {}, Return[<||>]];
        Module[{tex},
          tex = If[Length[orderTexs] > 1,
            "\\begin{aligned}" <> StringRiffle[orderTexs, " \\\\ "] <> "\\end{aligned}",
            orderTexs[[1]]];
          tex = stTruncateTeX[tex, maxChars];
          <|"normalizedSymbolTeX" -> tex,
            "wDefinitions" -> Values[wMap],
            "normalizedAlphabet" -> Values[wMap][[All, "label"]],
            "symbolScale" -> scaleTeX,
            "normalizedSymbolTerms" -> totalTerms|>
        ]
      ],

      (* Not a SeriesData \[LongDash] single expression *)
      Module[{sym, terms, allLetters, scale, wMap, scaleTeX, nTex, nTerms,
              resultForSymbol = result},
        sym = Quiet @ Check[
          ConvertToSymbol[result, "AsList" -> True, "Expand" -> True, "DropConstants" -> True],
          $Failed];
        If[!ListQ[sym] || sym === {}, Return[<||>]];
        terms = Select[sym, Length[#[[2]]] > 0 &];
        If[terms === {}, Return[<||>]];
        allLetters = DeleteDuplicates[Flatten[terms[[All, 2]]], Simplify[#1 - #2] === 0 &];
        If[Length[allLetters] < 2, Return[<||>]];
        (* FindRoots letters Wp[i], Wm[i] kept as native symbol letters. *)
        scale = stDetectScale[allLetters];
        If[scale === None, Return[<||>]];
        {wMap, scaleTeX} = stBuildWMap[allLetters, scale];
        If[Length[wMap] == 0, Return[<||>]];
        {nTex, nTerms} = stApplyWMap[resultForSymbol, scale, wMap];
        If[nTex === "", Return[<||>]];
        <|"normalizedSymbolTeX" -> nTex,
          "wDefinitions" -> Values[wMap],
          "normalizedAlphabet" -> Values[wMap][[All, "label"]],
          "symbolScale" -> scaleTeX,
          "normalizedSymbolTerms" -> nTerms|>
      ]
    ],
    <||>
  ]
];


(* \[HorizontalLine]\[HorizontalLine] stComputeSymbolFields: wrapper handling SeriesData \[HorizontalLine]\[HorizontalLine] *)
(* Returns {symbolTeX, alphabetTeXList, weight, termCount}.
   For SeriesData, computes symbol at each epsilon order and formats
   as stacked display. Weight is the max across all orders. *)

stComputeSymbolFields[result_] := Module[
  {coeffs, powers, allAlphabet, orderTexs, tex, symResult,
   coeff, power, symTex, symAlph, symWt, symNTerms,
   maxWeight = 0, totalTerms = 0, denom, maxChars = 5000},

  Quiet @ Check[
    If[Head[result] === SeriesData,
      (* Extract coefficients and their epsilon powers *)
      Module[{sd = result, minPow, nCoeffs, rawCoeffs},
        minPow = sd[[4]] / sd[[6]];  (* starting power *)
        rawCoeffs = sd[[3]];
        nCoeffs = Length[rawCoeffs];

        allAlphabet = {};
        orderTexs = {};

        Do[
          power = minPow + (i - 1);
          coeff = rawCoeffs[[i]];
          If[coeff === 0, Continue[]];

          {symTex, symAlph, symWt, symNTerms} = stSymbolToTeX[coeff];
          (* When the coefficient has no logarithmic structure, stSymbolToTeX
             returns an empty TeX string.  Don't silently drop the order \[LongDash]
             render the raw coefficient instead so the user still sees that
             this eps order was computed. *)
          If[symTex === "",
            symTex = stTeXCleanup[Quiet @ Check[
              ToString[coeff /. $stNormMassRules, TeXForm], ""]];
            If[symTex === "", Continue[]];
            symAlph = {}; symWt = 0; symNTerms = 1];

          allAlphabet = Join[allAlphabet, symAlph];
          maxWeight = Max[maxWeight, symWt];
          totalTerms += symNTerms;
          AppendTo[orderTexs,
            "\\varepsilon^{" <> ToString[power] <> "}&\\colon\\;" <> symTex],
          {i, nCoeffs}
        ];

        allAlphabet = DeleteDuplicates[allAlphabet];

        If[orderTexs === {},
          {"", {}, 0, 0},
          tex = If[Length[orderTexs] > 1,
            "\\begin{aligned}" <> StringRiffle[orderTexs, " \\\\ "] <> "\\end{aligned}",
            (* Single order: strip the alignment marker so KaTeX
               (which rejects a bare '&' outside of an aligned block)
               can render it. *)
            StringReplace[orderTexs[[1]], "&\\colon" -> "\\colon"]
          ];
          tex = stTruncateTeX[tex, maxChars];
          {tex, allAlphabet, maxWeight, totalTerms}
        ]
      ],

      (* Not a SeriesData \[LongDash] compute directly *)
      {symTex, symAlph, symWt, symNTerms} = stSymbolToTeX[result];
      If[symTex === "",
        {"", {}, 0, 0},
        symTex = stTruncateTeX[symTex, maxChars];
        {symTex, symAlph, symWt, symNTerms}
      ]
    ],
    (* Catch-all on any error *)
    {"", {}, 0, 0}
  ]
];


(* \[HorizontalLine]\[HorizontalLine] stExtractAlgebraicLetters: structured FindRoots metadata \[HorizontalLine]\[HorizontalLine] *)
(* Walks $HyperAlgebraicLetterTable and emits a list of Associations, one per
   surviving algebraic-letter index, suitable for storage as the
   `algebraicLetters` field in entry.json.

   Each entry has:
     index             : integer (matches Wm[i]/Wp[i] in the stored result)
     polynomial        : InputForm string of the quadratic in `variable`
     variable          : InputForm string of the Feynman parameter
     LC                : leading coefficient (InputForm)
     sum               : Vieta sum  (= Wm + Wp, rational)          (InputForm)
     product           : Vieta product (= Wm * Wp, rational)       (InputForm)
     discriminant      : b^2 - 4ac                                 (InputForm)
     minusRoot         : (-b - Sqrt[Delta]) / (2 LC)               (InputForm)
     plusRoot          : (-b + Sqrt[Delta]) / (2 LC)               (InputForm)
     minusRootTeX      : LaTeX of minusRoot (via $stNormMassRules)
     plusRootTeX       : LaTeX of plusRoot
     polynomialTeX     : LaTeX of polynomial (with masses rendered as m\:1d62\.b2/M\.b2)
     discriminantTeX   : LaTeX of discriminant

   If deltaSigns (delta[i] -> +/-1 sign decisions from STVerify iepsilon
   resolution) are present on disk, they are attached per-index as
   `deltaSign`. This function does not set that field; STVerify does, when
   it writes the record back. *)

stExtractAlgebraicLetters[] := stExtractAlgebraicLetters[$HyperAlgebraicLetterTable];
stExtractAlgebraicLetters[table_Association] := Module[{idxList, texOf},
  idxList = Sort @ Keys[table];
  If[Length[idxList] == 0, Return[{}]];
  texOf[e_] := stTeXCleanup[Quiet @ Check[
      ToString[e /. $stNormMassRules, TeXForm], ToString[e]]];
  Map[
    Function[i, Module[{r = table[i]},
      <|
        "index"           -> i,
        "variable"        -> ToString[r["Variable"], InputForm],
        "polynomial"      -> ToString[r["Polynomial"], InputForm],
        "LC"              -> ToString[r["LC"], InputForm],
        "sum"             -> ToString[r["Sum"], InputForm],
        "product"         -> ToString[r["Product"], InputForm],
        "discriminant"    -> ToString[r["Discriminant"], InputForm],
        "minusRoot"       -> ToString[r["WmValue"], InputForm],
        "plusRoot"        -> ToString[r["WpValue"], InputForm],
        "polynomialTeX"   -> texOf[r["Polynomial"]],
        "discriminantTeX" -> texOf[r["Discriminant"]],
        "minusRootTeX"    -> texOf[r["WmValue"]],
        "plusRootTeX"     -> texOf[r["WpValue"]]
      |>]],
    idxList]];


(* \[HorizontalLine]\[HorizontalLine] stResultToTeX: convert integration result to truncated LaTeX preview \[HorizontalLine]\[HorizontalLine] *)
(* Returns {texString, truncatedQ}.  For SeriesData, keeps at most maxTerms
   coefficients; for anything else, hard-truncates at maxChars.
   Used by STSaveResult, STSubmitResult, and handleDecodeResult. *)

stResultToTeX[expr_, maxChars_Integer: 3000, maxTerms_Integer: 3] := Module[
  {tex, truncated = False, truncExpr, texExpr},

  If[expr === $Failed || expr === $Aborted || expr === Null, Return[{"", False}]];

  (* Skip non-expression results (e.g., diagnostic metadata from StopAt) *)
  If[Head[expr] === Association || Head[expr] === List && MatchQ[expr, {__Rule}],
    Return[{"", False}]];

  (* \[HorizontalLine]\[HorizontalLine] Expression-level rendering \[HorizontalLine]\[HorizontalLine] *)
  (* First pass: mass + root-letter symbols (must run before Hlog so inner masses are resolved) *)
  texExpr = expr /. {
      mm[i_]^n_ :> Superscript[Subscript[m, i], 2 n],
      mm[i_]    :> Superscript[Subscript[m, i], 2],
      MM[i_]^n_ :> Superscript[Subscript[M, i], 2 n],
      MM[i_]    :> Superscript[Subscript[M, i], 2],
      MM^n_     :> Superscript[M, 2 n],
      MM        :> Superscript[M, 2],
      Wm[i_]^n_ :> Superscript[Subsuperscript[W, i, "-"], n],
      Wm[i_]    :> Subsuperscript[W, i, "-"],
      Wp[i_]^n_ :> Superscript[Subsuperscript[W, i, "+"], n],
      Wp[i_]    :> Subsuperscript[W, i, "+"],
      WmOverWp[i_]^n_ :> Superscript[HoldForm[Divide[Subsuperscript[W, i, "-"], Subsuperscript[W, i, "+"]]], n],
      WmOverWp[i_]    :> HoldForm[Divide[Subsuperscript[W, i, "-"], Subsuperscript[W, i, "+"]]]
  };
  (* Second pass: Hlog \[RightArrow] H(args; z) with semicolon placeholder *)
  texExpr = texExpr /. Hlog[z_, w_List] :> stTeXH @@ Join[w, {stTeXSemicolon, z}];

  (* SeriesData: truncate to first maxTerms coefficients if needed *)
  If[Head[texExpr] === SeriesData && Length[texExpr[[3]]] > maxTerms,
    truncated = True;
    truncExpr = texExpr;
    (* Remember the actual series order before truncation *)
    Module[{actualOrder = texExpr[[5]] / texExpr[[6]]},
      truncExpr[[3]] = truncExpr[[3, ;; maxTerms]];
      truncExpr[[5]] = truncExpr[[4]] + maxTerms;
      tex = Quiet @ Check[ToString[truncExpr, TeXForm], ""];
      (* Replace the auto-generated O-term with (more terms) + O(eps^actualOrder) *)
      tex = StringReplace[tex,
        RegularExpression["\\+?O\\\\left\\(.*?\\\\right\\)"] ->
          "+(\\text{more terms})+O\\left(\\varepsilon^" <> ToString[actualOrder] <> "\\right)"]
    ],
    tex = Quiet @ Check[ToString[texExpr, TeXForm], ""]
  ];

  (* \[HorizontalLine]\[HorizontalLine] String-level notation cleanup \[HorizontalLine]\[HorizontalLine] *)
  tex = stTeXCleanup[tex];

  (* Hard-truncate if still too long. Routes through stTruncateTeX which
     balances `{`/`}`, `[`/`]`, `(`/`)`, `\left`/`\right`, and
     `\begin{aligned}`/`\end{aligned}` at once \[LongDash] so the cut can't land
     inside a `\left[...\right]` or an aligned environment and leave
     a dangling opener.  The old inline balance logic tracked only
     `\left`/`\right` and produced "resultTeX ending with `... H\right.`"
     artifacts that KaTeX rejected. *)
  If[StringLength[tex] > maxChars && !truncated,
    truncated = True;
    tex = stTruncateTeX[tex, maxChars]];

  {tex, truncated}
];

(* \[HorizontalLine]\[HorizontalLine] handleDecodeResult: on-demand decompression for library display \[HorizontalLine]\[HorizontalLine] *)

handleDecodeResult[body_String] := Module[
  {parsed, expr, inputForm, texResult},

  parsed = Quiet @ ImportString[body, "RawJSON"];
  If[!AssociationQ[parsed], Return[
    ExportString[<|"status" -> "error", "error" -> "Invalid JSON"|>, "RawJSON"]]];

  expr = If[StringQ[Lookup[parsed, "resultCompressed", None]],
    Quiet @ Check[Uncompress[parsed["resultCompressed"]], $Failed], $Failed];
  If[expr === $Failed, Return[
    ExportString[<|"status" -> "error", "error" -> "Cannot decompress"|>, "RawJSON"]]];

  inputForm = ToString[expr, InputForm];
  texResult = stResultToTeX[expr];

  Module[{sf = stComputeSymbolFields[expr]},
  ExportString[<|
    "status" -> "ok",
    "resultTeX" -> texResult[[1]],
    "resultInputForm" -> inputForm,
    "truncated" -> texResult[[2]],
    "symbolTeX" -> sf[[1]],
    "alphabet" -> sf[[2]],
    "symbolWeight" -> sf[[3]],
    "symbolTerms" -> sf[[4]]
  |>, "RawJSON"]]
];


(* \[HorizontalLine]\[HorizontalLine] stStripDefaultOptions: remove options matching current defaults.
   Fallback for legacy entries saved before stBuildSTCommand was updated
   to strip defaults at save time. \[HorizontalLine]\[HorizontalLine] *)

stStripDefaultOptions[cmd_String] := Module[
  {held, head, n, graph, opts, defaults, nonDefault},
  (* Parse the command string without evaluating it *)
  held = ToExpression[cmd, InputForm, HoldComplete];
  If[!MatchQ[held, HoldComplete[_[__]]], Return[cmd]];
  head = Extract[held, {1, 0}, HoldComplete][[1]];
  n = Length[held[[1]]] - 1;  (* number of option arguments *)
  graph = Extract[held, {1, 1}, HoldComplete][[1]];
  If[n == 0, Return[cmd]];
  opts = Table[Extract[held, {1, i + 1}, HoldComplete][[1]], {i, n}];
  (* Get defaults for the head (STIntegrate, STEvaluateGraph, etc.) *)
  defaults = Quiet @ Check[Options[head], {}];
  If[!ListQ[defaults] || Length[defaults] == 0, Return[cmd]];
  (* Keep only options whose values differ from the default *)
  nonDefault = Select[opts,
    Function[opt, Module[{key, val, def},
      If[!MatchQ[opt, _Rule | _RuleDelayed], Return[True]];
      key = opt[[1]]; val = opt[[2]];
      def = key /. defaults;
      (* Keep if no default found or value differs *)
      def === key || val =!= def
    ]]];
  ToString[head[graph, Sequence @@ nonDefault], InputForm]
];

(* \[HorizontalLine]\[HorizontalLine] handleSafeExit: normalize exported globals and signal the GUI loop to exit \[HorizontalLine]\[HorizontalLine]
   The native viewer's window "x" button can race with handleEstimate /
   handleIntegrate and leave $STQuadruple (and friends) partially set, so
   when a subsequent script reads them the user sees confusing partial
   state.  This handler ensures the exported globals are well-formed
   before setting $uiResult, which makes FeynmanIntegrate's main loop
   exit cleanly and kill the server + viewer.  Requested by Giulio,
   2026-04-21. *)

handleSafeExit[body_String] := Module[{parsed, silent},
  parsed = Quiet @ ImportString[body, "RawJSON"];
  silent = AssociationQ[parsed] && TrueQ[Lookup[parsed, "silent", False]];

  (* Only reset a global if it is unset or malformed; preserve the
     last-drawn state otherwise, so the user can still read
     $STQuadruple etc. after the GUI closes. *)
  If[!ValueQ[$STQuadruple] || !ListQ[$STQuadruple] || Length[$STQuadruple] =!= 4,
    $STQuadruple = {1, 1, {}, {}}];
  If[!ValueQ[$STEdges]        || !ListQ[$STEdges],        $STEdges = {}];
  If[!ValueQ[$STNodes]        || !ListQ[$STNodes],        $STNodes = {}];
  If[!ValueQ[$STGraph]        || !ListQ[$STGraph] || Length[$STGraph] =!= 2,
    $STGraph = {$STEdges, $STNodes}];
  If[!ValueQ[$STPropagators]  || !ListQ[$STPropagators],  $STPropagators = {}];
  If[!ValueQ[$STPrefactor],    $STPrefactor   = 1];
  If[!ValueQ[$STIntegrand],    $STIntegrand   = 1];
  If[!ValueQ[$STVariables]    || !ListQ[$STVariables],    $STVariables    = {}];
  If[!ValueQ[$STCoefficients] || !ListQ[$STCoefficients], $STCoefficients = {}];

  (* Close the pre-warmed subkernel pool (FeynmanIntegrate launches
     $ProcessorCount-1 subkernels at GUI start; without this cleanup they
     persist in the notebook after Save-and-exit and slow subsequent work).
     Reset the setup flags so the next FeynmanIntegrate session relaunches
     fresh. Quiet so a close failure doesn't stall the exit. *)
  If[Length[Kernels[]] > 0, Quiet @ CloseKernels[]];
  $STActiveKernelCount = 0;
  $KernelSetupQ = False;

  (* Signal FeynmanIntegrate's polling loop to exit with a safeExit flag
     so it skips the "integration result" post-processing path.  When
     silent is True (Save-and-exit button), FeynmanIntegrate returns Null
     instead of the usual snapshot Association, so nothing prints in the
     notebook. *)
  $uiResult = <|"safeExit" -> True, "silent" -> silent|>;

  ExportString[<|"status" -> "ok",
    "message" -> "safe-exit acknowledged"|>, "RawJSON"]
];


(* \[HorizontalLine]\[HorizontalLine] handleSendToNotebook: inject result + command into the active notebook \[HorizontalLine]\[HorizontalLine] *)

handleSendToNotebook[body_String] := Module[
  {parsed, expr, command, cleanCmd, cmdExpr},

  parsed = Quiet @ ImportString[body, "RawJSON"];
  If[!AssociationQ[parsed], Return[
    ExportString[<|"status" -> "error", "error" -> "Invalid JSON"|>, "RawJSON"]]];

  expr = If[StringQ[Lookup[parsed, "resultCompressed", None]] &&
              StringLength[parsed["resultCompressed"]] > 0,
    Quiet @ Check[Uncompress[parsed["resultCompressed"]], $Failed], $Failed];
  (* Fall back to the kernel's current integration result *)
  If[expr === $Failed && AssociationQ[$integrationResult],
    expr = $integrationResult["result"]];
  If[expr === $Failed || expr === Null, Return[
    ExportString[<|"status" -> "error", "error" -> "No result available"|>, "RawJSON"]]];

  command = Lookup[parsed, "stCommand", ""];

  (* If no command was provided, build one from the current integration config *)
  If[!StringQ[command] || StringLength[command] == 0,
    command = If[AssociationQ[$integrationConfig],
      Quiet @ Check[stBuildSTCommand[$integrationConfig], ""], ""]];

  (* Strip default options from STIntegrate command for cleaner display *)
  cleanCmd = Quiet @ Check[stStripDefaultOptions[command], command];

  (* Write command + result as a grouped pair of cells.
     The command cell looks like Input but is NOT evaluatable \[LongDash]
     it serves only as a record of what produced the result.
     We use NotebookWrite to $stNotebook for reliable cell insertion. *)
  Module[{nb, cmdCell, outCell, group},
    nb = If[$stNotebook =!= $Failed, $stNotebook, Quiet @ Check[EvaluationNotebook[], $Failed]];
    If[nb === $Failed, Return[ExportString[<|"status" -> "error",
      "error" -> "No notebook available"|>, "RawJSON"]]];

    (* Command cell: plain text (not BoxData) so it CANNOT be evaluated.
       Using "Text" style with monospace font to look like code. *)
    cmdCell = If[StringQ[cleanCmd] && StringLength[cleanCmd] > 0,
      Cell[cleanCmd, "Text",
        FontFamily -> "Source Code Pro",
        FontSize -> 12,
        FontColor -> GrayLevel[0.3],
        Background -> GrayLevel[0.97],
        CellFrame -> {{0, 0}, {0, 0}},
        CellMargins -> {{66, 10}, {4, 4}}]
    , Nothing];

    outCell = Cell[BoxData[ToBoxes[expr]], "Output", GeneratedCell -> True,
      ShowCellLabel -> False];

    (* Write cells individually \[LongDash] NOT as CellGroupData, which triggers
       evaluation when the front end opens the group. *)
    If[cmdCell =!= Nothing, NotebookWrite[nb, cmdCell, After]];
    NotebookWrite[nb, outCell, After];
  ];

  ExportString[<|"status" -> "ok"|>, "RawJSON"]
];


(* \[HorizontalLine]\[HorizontalLine] handleSyncLibrary: sync with central GitHub library \[HorizontalLine]\[HorizontalLine] *)

handleSyncLibrary[body_String] := Module[{result, downloaded = 0},
  result = Check[STSyncLibrary[], $Failed];
  If[result === $Failed,
    Return[ExportString[<|"status" -> "error",
      "error" -> "Central library not available. Try again later."|>, "RawJSON"]]];
  If[result === "up-to-date",
    Return[ExportString[<|"status" -> "ok", "downloaded" -> 0|>, "RawJSON"]]];
  If[AssociationQ[result],
    downloaded = Lookup[result, "downloaded", 0]];
  (* Rebuild library.json after sync *)
  Quiet @ Check[STBuildLibraryJSON[], Null];
  ExportString[<|"status" -> "ok", "downloaded" -> downloaded|>, "RawJSON"]
];


(* ================================================================== *)
(*  PYTHON HTTP SERVER                                                 *)
(*  Cross-platform: macOS, Linux, Windows                             *)
(*  Python serves HTML + handles HTTP. Mathematica-dependent API       *)
(*  calls go through file-based IPC.                                   *)
(* ================================================================== *)

findPython[] := Module[{candidates, result, cmd},
  candidates = Switch[$OperatingSystem,
    "Windows", {"python", "python3"},
    _, {"python3", "python"}];
  Do[
    result = Quiet @ Check[
      RunProcess[{c, "--version"}, "StandardOutput"],
      $Failed];
    If[StringQ[result] && StringContainsQ[result, "Python 3"],
      stLog["[SubTropica] Found: ", c, " -> ", StringTrim[result]];
      Return[c, Module]],
  {c, candidates}];
  $Failed
];

generatePythonServer[port_Integer, uiDir_String, ipcDir_String, bundledLibDir_String, localLibDir_String] :=
  StringJoin[
"import http.server, json, os, sys, time, threading, mimetypes

PORT = ", ToString[port], "
ST_VERSION = '", $SubTropicaVersion, "'
UI_DIR = r'", StringReplace[uiDir, "\\" -> "\\\\"], "'
IPC_DIR = r'", StringReplace[ipcDir, "\\" -> "\\\\"], "'
LIBRARY_BUNDLED_DIR = r'", StringReplace[bundledLibDir, "\\" -> "\\\\"], "'
LIBRARY_LOCAL_DIR = r'", StringReplace[localLibDir, "\\" -> "\\\\"], "'
FAV_FILE = r'", StringReplace[FileNameJoin[{Directory[], ".subtropica_favorites.json"}], "\\" -> "\\\\"], "'
CONFIG_FAV_FILE = r'", StringReplace[FileNameJoin[{Directory[], ".subtropica_config_favorites.json"}], "\\" -> "\\\\"], "'
REVIEW_REJECTS_LOG = r'", StringReplace[FileNameJoin[{$SubTropicaInstallDir, "scripts", "rejected_diagrams.log"}], "\\" -> "\\\\"], "'
REVIEW_EXTRACTED_JSON = r'", StringReplace[FileNameJoin[{$SubTropicaInstallDir, "scripts", "extracted_integrals.json"}], "\\" -> "\\\\"], "'
REVIEW_REJECTS_STATE = r'", StringReplace[FileNameJoin[{$SubTropicaInstallDir, "scripts", "rejects_review_state.json"}], "\\" -> "\\\\"], "'
REVIEW_PDF_CACHE_DIR = r'", StringReplace[FileNameJoin[{$HomeDirectory, ".subtropica", "pdf-cache"}], "\\" -> "\\\\"], "'
REVIEW_NAME_SUGGESTIONS = r'", StringReplace[FileNameJoin[{$SubTropicaInstallDir, "scripts", "name_suggestions.json"}], "\\" -> "\\\\"], "'

MIME_MAP = {
    '.html': 'text/html; charset=utf-8',
    '.js':   'application/javascript; charset=utf-8',
    '.mjs':  'application/javascript; charset=utf-8',
    '.css':  'text/css; charset=utf-8',
    '.json': 'application/json; charset=utf-8',
    '.svg':  'image/svg+xml',
    '.png':  'image/png',
    '.jpg':  'image/jpeg',
    '.jpeg': 'image/jpeg',
    '.ico':  'image/x-icon',
    '.woff': 'font/woff',
    '.woff2': 'font/woff2',
    '.ttf':  'font/ttf',
}

BINARY_EXTS = {'.png', '.jpg', '.jpeg', '.ico'}

def serve_static(path):
    safe = os.path.normpath(path).lstrip('/')
    fp = os.path.join(UI_DIR, safe)
    if not os.path.isfile(fp):
        return None
    if not os.path.abspath(fp).startswith(os.path.abspath(UI_DIR)):
        return None
    ext = os.path.splitext(fp)[1].lower()
    ct = MIME_MAP.get(ext, 'application/octet-stream')
    mode = 'rb' if ext in BINARY_EXTS else 'r'
    enc = None if mode == 'rb' else 'utf-8'
    with open(fp, mode, encoding=enc) as f:
        data = f.read()
    if isinstance(data, str):
        # Template substitution for cache-busting: index.html (and any
        # other text asset) can reference {{ST_VERSION}} to embed the
        # current SubTropica version as a query param, so every version
        # bump invalidates the browser cache of the referenced asset.
        data = data.replace('{{ST_VERSION}}', ST_VERSION)
        data = data.encode('utf-8')
    return (ct, data)

_counter = [0]
_lock = threading.Lock()

def next_id():
    with _lock:
        _counter[0] += 1
        return f'r{_counter[0]}_{int(time.time()*1000)}'

_library_cache = [None, 0]  # [json_string, mtime]

