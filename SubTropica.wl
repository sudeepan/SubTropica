                    old_data = json.loads(old_raw)
                # Determine which Records go, which stay
                moved_records = []
                staying_records = []
                if old_data:
                    for rec in old_data.get('Records', []):
                        if rec.get('recordId') in records_to_move:
                            moved_records.append(rec)
                        else:
