	"ComplexMode"        -> Automatic,
	(* AMFlow-specific *)
	"AMFlowIBPReducer"   -> "FiniteFlow+LiteRed",
	"AMFlowPrecision"    -> 16,
	"AMFlowFamily"       -> Automatic,
	"AMFlowNThread"      -> 4,
	(* feyntrop-specific *)
	"FeyntropLambda"     -> 0,
	"FeyntropSeed"       -> 0,
	"FeyntropNThread"    -> Automatic,
	(* B8: hard wall-clock cap on a single backend run, applied at the
	   stVerifyRunBackend boundary via TimeConstrained.  Automatic scales
	   with loop count (60 s + 5 min per loop), capped at 30 min, so a
	   single hard case can't take down the long-running UI kernel.
	   Pass an explicit number (seconds) to override, or Infinity to
	   disable the cap entirely. *)
	"MaxTime"            -> Automatic
};

(* ---- Shared helpers used by all STVerify forms ---- *)

(* stLoadRootSubs[resultData]: rebuild the in-memory $stRootSubstitutions
   rule list from the structured `algebraicLetters` field of a stored
   Results[[i]] record.  Each entry contributes Wm[i] -> <minusRoot>,
   Wp[i] -> <plusRoot>; if `deltaSign` is present (an integer +/- 1
   resolved by a previous STVerify pass), a delta[i] -> sign rule is
   appended.  Returns a flat list of Rules suitable for `expr /. rules`,
   or {} when no algebraic letters are stored.

   The legacy `rootSubstitutions` InputForm string (dual-written through
   v1.0.453) is no longer consulted; v1.0.455 dropped it from the schema. *)

stLoadRootSubs[resultData_Association] := Module[{al},
	al = Lookup[resultData, "algebraicLetters", Null];
	If[ListQ[al] && al =!= {},
		Return @ Flatten @ Map[
			Function[r, Module[{i, m, p, d, rules},
				i = Lookup[r, "index", 0];
				m = Quiet[Check[ToExpression @ Lookup[r, "minusRoot", "0"], 0]];
				p = Quiet[Check[ToExpression @ Lookup[r, "plusRoot",  "0"], 0]];
				rules = {Wm[i] -> m, Wp[i] -> p};
				d = Lookup[r, "deltaSign", Null];
				If[IntegerQ[d] && (d === 1 || d === -1),
					AppendTo[rules, delta[i] -> d]];
				rules]],
			al]];
	{}
];


(* Generic symbolic evaluator.  `subRules` is a list of substitution rules to
   apply to `result` before numerical evaluation (via STToGinsh or plain N).
   For the graph form, `subRules` comes from stBuildSymbolicSubRules to handle
   the mm/MM/sij aliasing; for propagator/quadruple forms it's just the user's
   kinematic point applied directly. *)
stVerifyEvalSymbolicGeneric[result_, subRules_List, verbose_] := Module[
	{substituted, hasHlogs, hasMZV, evaluated},

	substituted = result;
	If[MatchQ[substituted, _Hold], substituted = ReleaseHold[substituted]];
	substituted = substituted /. {mzv -> zeta, HyperInt`mzv -> zeta};

	If[ValueQ[$stRootSubstitutions] && $stRootSubstitutions =!= {},
		substituted = substituted /. $stRootSubstitutions];

	substituted = substituted /. subRules;

	If[verbose, Print["[STVerify] After substitution: ", Short[substituted, 2]]];

	hasHlogs = !FreeQ[substituted, Hlog | HyperInt`Hlog | HyperInt`Mpl];
	hasMZV = !FreeQ[substituted, zeta];

	If[hasHlogs || hasMZV,
		(* B19: ginsh is the only trustworthy numerical evaluator for Hlog /
		   zeta arguments \[LongDash] N[] silently produces nonsense (Integrate`V leaks)
		   when the substituted expression still has unbound symbols. So if
		   STToGinsh returns $Failed, surface it directly; the caller's
		   stVerifyHandleSymbolicEval site converts $Failed into a clean
		   "ginsh/eval failed" outcome with the underlying messages
		   (STToGinsh::unbound / ::nonNumeric) preserved for diagnostics. *)
		evaluated = Quiet[Check[STToGinsh[substituted], $Failed],
			{STToGinsh::unbound, STToGinsh::nonNumeric}];
		If[evaluated === $Failed && verbose,
			Print["[STVerify] STToGinsh failed; not falling back to N (would silently produce wrong numbers under unbound symbols)."]],
		evaluated = Quiet[Check[N[substituted /. zeta[n_] :> Zeta[n]], $Failed]]
	];

	evaluated
];

(* Run the numerical backend via STNIntegrate, forwarding every relevant
   option out of an STVerify options list.  Returns {value, error} or $Failed.

   Option-forwarding discipline: only user-supplied options are passed
   through (via FilterRules on optsList).  Options whose STVerify default
   happens to equal STNIntegrate's default must NOT be forwarded when
   absent from user opts \[LongDash] e.g. "Integrator" -> Automatic, which would
   trip a pre-existing ordering bug in stNIntegratePySecDec where the
   Automatic \[RightArrow] Qmc fix-up is appended after the Automatic rule, and the
   first rule wins. *)
stVerifyRunBackend[numericInput_, kinPoint_, normalization_, order_, maxeval_, optsList_List] :=
Module[{method, verbose, stnOpts, r, maxTime, nLoopsGuess},
	method  = "Method"  /. optsList /. Options[STVerify];
	verbose = TrueQ["Verbose" /. optsList /. Options[STVerify]];

	(* Forward only options the user actually supplied.  Drop the ones we
	   set explicitly below so the explicit values win. *)
	stnOpts = FilterRules[optsList, Options[STNIntegrate]];
	stnOpts = DeleteCases[stnOpts,
		Rule[("Method" | "Substitutions" | "KinematicPoint" | "Order" |
		      "MaxEval" | "Verbose" | "Normalization" | "MaxTime"), _]];

	(* B8: hard cap on backend wall-clock to keep one runaway integral
	   from taking down the long-running UI kernel.  Resolve "MaxTime"
	   (Automatic -> 60 s + 5 min per loop, max 30 min; explicit number
	   wins; Infinity disables).  We can only infer nLoops cheaply for
	   the graph form; fall back to nLoopsGuess = 1 otherwise. *)
	maxTime = "MaxTime" /. optsList /. Options[STVerify];
	nLoopsGuess = Which[
		MatchQ[numericInput, {_List, _List}],
			Module[{edges = numericInput[[1]]},
				1 + Length[edges] -
					Length[Union[Flatten[edges[[All, 1]]]]]],
		True, 1];
	If[maxTime === Automatic,
		maxTime = Min[60 + 300 * Max[nLoopsGuess, 1], 1800]];

	If[verbose && maxTime =!= Infinity,
		Print["[STVerify] backend wall-clock cap: ",
			Round[maxTime, 1], "s (method=", method, ")"]];

	(* B2: the previous implementation used `Quiet @ Check[..., $Failed]`,
	   which converted the result to $Failed if ANY message fired during
	   the backend run (FiniteFlow status messages, polymake noise, etc.)
	   \[LongDash] including the long sequence of benign messages AMFlow's
	   SolveIntegrals emits.  Use CheckAbort instead so a normal
	   message-firing run still yields the integrator's actual result. *)
	r = CheckAbort[
		TimeConstrained[
			STNIntegrate[numericInput,
				"Method"        -> method,
				"Substitutions" -> kinPoint,
				"Order"         -> order,
				"MaxEval"       -> maxeval,
				"Verbose"       -> verbose,
				"Normalization" -> normalization,
				"MaxTime"       -> maxTime,
				Sequence @@ stnOpts
			],
			maxTime,
			$TimedOut
		],
		$Aborted
	];
	Which[
		r === $Aborted || r === $Failed, $Failed,
		r === $TimedOut,
			Message[STVerify::backendTimeout, method, Round[maxTime, 1]];
			$Failed,
		AssociationQ[r] && KeyExistsQ[r, "Value"] && KeyExistsQ[r, "Error"],
			{r["Value"], r["Error"]},
		MatchQ[r, {_, _}], r,
		True, $Failed
	]
];

STVerify::backendTimeout = "Backend `1` exceeded the wall-clock cap of `2` s; returning $Failed. Pass \"MaxTime\" -> <seconds> (or Infinity) to STVerify to override.";

(* STVerify[cni] \[LongDash] verify a library entry by CNI string *)
STVerify[cni_String, opts:OptionsPattern[]] := Module[
	{allFiles, entryFile, entry, edges, nodes, nLoops, nEdges, nVerts,
	 resultData, result, kinPoint, psdResult, symbolicEval, comparison,
	 verbose, order, maxeval, tolerance, resultIdx, libPath, seed,
	 normalization, dim, verifyOpts},

	verbose = TrueQ[OptionValue["Verbose"]];
	order = OptionValue["Order"];
	tolerance = OptionValue["Tolerance"];
	resultIdx = OptionValue["ResultIndex"];
	libPath = OptionValue["LibraryPath"];

	(* 1. Find entry *)
	allFiles = FileNames["entry.json", libPath, Infinity];
	entryFile = SelectFirst[allFiles, Module[{e},
		e = Quiet[Import[#, "RawJSON"]];
		e =!= $Failed && e["CNickelIndex"] === cni &&
		Length[Lookup[e, "Results", {}]] >= resultIdx &&
		KeyExistsQ[e["Results"][[resultIdx]], "resultCompressed"]
	] &, None];

	If[entryFile === None,
		Message[STVerify::noentry, cni];
		Return[<|"pass" -> False, "reason" -> "entry not found", "cni" -> cni|>]
	];

	entry = Import[entryFile, "RawJSON"];
	edges = ToExpression[entry["edges"]];
	nodes = ToExpression[entry["nodes"]];
	nEdges = Length[edges];
	nVerts = Length[Union[Flatten[edges[[All, 1]]]]];
	nLoops = 1 + nEdges - nVerts;

	(* 2. Decompress stored result *)
	resultData = entry["Results"][[resultIdx]];
	result = Quiet[Check[Uncompress[resultData["resultCompressed"]], $Failed]];
	If[result === $Failed,
		Message[STVerify::decomp, cni];
		Return[<|"pass" -> False, "reason" -> "decompress failed", "cni" -> cni, "loops" -> nLoops|>]
	];

	(* Load root-letter substitutions from the structured `algebraicLetters`
	   field (post-v1.0.389 entries). `deltaSign` (+/- 1), if stored per
	   index, is appended as a delta[i] -> sign rule so stVerifyEvalSymbolicGeneric
	   can resolve iepsilon-disambiguated signs.  Entries written before the
	   Phase-5 recompute may be missing `algebraicLetters` \[LongDash] those return
	   an empty rule list and STVerify will fail the W-atom substitution,
	   flagging the entry for re-save. *)
	$stRootSubstitutions = stLoadRootSubs[resultData];

	If[verbose,
		Print["[STVerify] ", cni, " (L=", nLoops, ", E=", nEdges, ", legs=", Length[nodes], ")"];
		Print["[STVerify] Variables: ", Variables[result]]
	];

	(* 3. Generate deterministic Euclidean kinematic point.
	   Only assign nonzero values to parameters that appear in the result;
	   parameters absent from the result were zero in the original computation.
	   Use Cases to find all symbolic atoms (Variables misses symbols inside Log/Hlog). *)
	seed = Hash[cni, "CRC32"];
	Module[{resultSymbols, rolled},
		resultSymbols = Cases[result, _Symbol | _Symbol[_Integer], {0, Infinity}]
			// DeleteDuplicates // DeleteCases[_?(MemberQ[{eps, Pi, E, I, SeriesData, List, Plus, Times, Power, Log, Hlog, zeta, mzv, Rational, Complex}, #] &)];
		rolled = stMakeNonDegenerateVerificationPoint[edges, nodes, seed, resultSymbols, 20, verbose];
		kinPoint = rolled[[1]];
		seed     = rolled[[2]];
	];
	If[kinPoint === $Failed,
		Return[<|"pass" -> False,
			"reason" -> "no Euclidean kinematic point found",
			"cni" -> cni, "loops" -> nLoops|>]];
	If[verbose, Print["[STVerify] KinematicPoint: ", kinPoint, "  (final seed=", seed, ")"]];

	(* 3b. Detect shared internal/external mass symbols.
	   When a symbol appears as both an internal edge mass and an external
	   node mass, the constraint msq = m^2 makes F factor at the special
	   kinematic point.  Each backend handles this (v1.0.297):
	   \[Bullet] pySecDec: bakes p^2 = m^2 into its compile-time replacement
	     rules; sector decomposition sees the factored F.
	   \[Bullet] FIESTA: the numeric substitution inside UF[] automatically
	     makes the generic (m^2 - msq) x_i x_j coefficient vanish, and S2
	     sector decomposition handles the resulting two-monomial F
	     correctly (at least at one loop).
	   \[Bullet] AMFlow: substitutes M_i^2 \[RightArrow] m^2 in the symbolic Replacement
	     list, shrinking the family by one parameter; leading pole is
	     correct.
	   \[Bullet] feyntrop: returns only \[CurlyEpsilon]^0 and higher, so it cannot
	     represent the 1/\[CurlyEpsilon]^2 pole at all \[LongDash] still skip. *)
	Module[{shared = stSharedMassLegs[{edges, nodes}][[1]], method},
		method = OptionValue["Method"];
		If[Length[shared] > 0 && method === "feyntrop",
			If[verbose, Print["[STVerify] Shared mass ", shared, " \[LongDash] feyntrop cannot represent \[CurlyEpsilon]-poles; skipping"]];
			Return[<|"pass" -> False, "reason" -> "shared mass (feyntrop cannot represent poles)",
				"cni" -> cni, "loops" -> nLoops, "sharedMasses" -> shared|>]
		];
		If[Length[shared] > 0 && verbose,
			Print["[STVerify] Shared mass ", shared, " \[LongDash] ", method, " will bake the constraint"]
		]
	];

	(* 3c. Refuse feyntrop on divergent integrals.
	   feyntrop's tropical Monte Carlo evaluates only the finite (eps^0)
	   piece, so it cannot match a symbolic answer that carries 1/eps
	   poles (the comparison silently disagrees, as observed on 1L bubble
	   m^2+s).  Detect by inspecting the decompressed Laurent series for
	   any SeriesData with negative leading order, or any explicit
	   eps^(-n) factor. *)
	Module[{method, hasPole},
		method = OptionValue["Method"];
		If[method === "feyntrop",
			(* Quiet[ ..., SeriesData::sdatc] avoids the pattern matcher's
			   structural validation on the placeholder SeriesData below. *)
			hasPole = Quiet[
				!FreeQ[result, SeriesData[eps, _, _, n_?Negative, _, _]] ||
				!FreeQ[result, eps^_?Negative],
				SeriesData::sdatc];
			If[hasPole,
				Message[STVerify::feyntropPoles, cni];
				Return[<|"pass" -> False,
					"reason" -> "feyntrop only verifies finite integrals (no eps poles)",
					"cni" -> cni, "loops" -> nLoops|>]]]];

	(* 4. Run numerical evaluation (routes through STNIntegrate so all four
	   backends \[LongDash] pySecDec / FIESTA / AMFlow / feyntrop \[LongDash] are available). *)
	maxeval = OptionValue["MaxEval"];
	If[maxeval === Automatic, maxeval = If[nLoops <= 1, 10^6, 10^7]];

	normalization = Quiet[ToExpression[resultData["normalization"]]];

	(* Resolve Dimension for the numerical backend.
	   Precedence: user-supplied "Dimension" opt > entry's stored "dimension" >
	   default 4 - 2 eps.  Parsing a non-empty stored field that fails ToExpression
	   is a library-entry issue worth surfacing under Verbose. *)
	Module[{userDim = "Dimension" /. {opts}, storedDim,
		parsed},
		storedDim = Lookup[resultData, "dimension", ""];
		dim = Which[
			userDim =!= "Dimension",
				userDim,
			StringQ[storedDim] && storedDim =!= "",
				parsed = Quiet @ Check[ToExpression[storedDim], $Failed];
				If[parsed === $Failed,
					If[verbose,
						Print["[STVerify] WARNING: stored \"dimension\" field '",
							storedDim, "' did not parse; falling back to 4 - 2 eps"]];
					4 - 2 eps,
					parsed],
			True,
				4 - 2 eps
		]
	];
	If[verbose, Print["[STVerify] Dimension: ", dim]];

	(* Forward the resolved dim to stVerifyRunBackend by overriding any
	   user-supplied "Dimension" rule; downstream FilterRules preserves it
	   into STNIntegrate via Options[STNIntegrate]. *)
	verifyOpts = Join[
		{"Dimension" -> dim},
		DeleteCases[{opts}, Rule["Dimension", _]]];

	psdResult = stVerifyRunBackend[{edges, nodes}, kinPoint, normalization,
		order, maxeval, verifyOpts];

	If[psdResult === $Failed,
		If[verbose, Print["[STVerify] ", OptionValue["Method"], " FAILED"]];
		Message[STVerify::backend, cni, OptionValue["Method"]];
		Message[STVerify::psdFail, cni];  (* back-compat *)
		Return[<|"pass" -> False, "reason" -> "numeric backend failed",
			"cni" -> cni, "loops" -> nLoops|>]
	];

	(* 5. Evaluate symbolic result at kinematic point *)
	symbolicEval = stEvalSymbolicAtPoint[result, edges, nodes, kinPoint, verbose];
	If[symbolicEval === $Failed,
		If[verbose, Print["[STVerify] symbolic evaluation FAILED"]];
		Message[STVerify::ginshFail, cni];
		Return[<|"pass" -> False, "reason" -> "ginsh/eval failed",
			"cni" -> cni, "loops" -> nLoops, "psd" -> psdResult|>]
	];

	(* 6. Compare Laurent coefficients *)
	comparison = stCompareLaurent[psdResult, symbolicEval, order, tolerance, verbose];

	Join[comparison, <|"cni" -> cni, "loops" -> nLoops, "kinPoint" -> kinPoint|>]
];

(* STVerify[{edges, nodes}, result] \[LongDash] verify from graph directly (no library lookup).
   Routes numerical evaluation through STNIntegrate so all four backends
   (pySecDec / FIESTA / AMFlow / feyntrop) are available via the "Method" option.

   NumSamples > 1: re-invoke self numSamples times with {"NumSamples" -> 1,
   "Seed" -> baseSeed + k*1009} and aggregate.  Overall pass iff every
   per-sample pass.  maxRelErr is the worst-case across samples.  Each
   sample's full result association is returned under "samples". *)
STVerify[{edges_List, nodes_List}, result_, opts:OptionsPattern[STVerify]] := Module[
	{nLoops, nEdges, nVerts, kinPoint, psdResult, symbolicEval, comparison,
	 verbose, order, maxeval, tolerance, seed, normalization, cni,
	 symLead, psdOrder, numSamples, userSeed},

	verbose = TrueQ[OptionValue["Verbose"]];
	order = OptionValue["Order"];
	tolerance = OptionValue["Tolerance"];
	normalization = Automatic;
	nEdges = Length[edges];
	nVerts = Length[Union[Flatten[edges[[All, 1]]]]];
	nLoops = 1 + nEdges - nVerts;
	cni = Quiet[Check[
		computeNickelIndex[edges, nodes],
		"graph_" <> ToString[Hash[{edges, nodes}, "CRC32"]]]];

	numSamples = OptionValue["NumSamples"];
	userSeed = OptionValue["Seed"];
	If[IntegerQ[numSamples] && numSamples > 1,
		Module[{baseSeed, samples, passAll, maxErr, relErrs},
			baseSeed = If[NumericQ[userSeed], userSeed, Hash[cni, "CRC32"]];
			samples = Table[
				If[verbose, Print["[STVerify] ---- sample ", k, " / ", numSamples, " ----"]];
				STVerify[{edges, nodes}, result,
					Sequence @@ Join[
						DeleteCases[{opts}, Rule[("NumSamples" | "Seed"), _]],
						{"NumSamples" -> 1, "Seed" -> baseSeed + 1009 k}]],
				{k, 0, numSamples - 1}];
			passAll = AllTrue[samples, (#["pass"] === True) &];
			relErrs = Cases[samples, KeyValuePattern["maxRelErr" -> v_?NumericQ] :> v];
			maxErr = If[relErrs === {}, None, Max[relErrs]];
			Return[<|
				"pass"       -> passAll,
				"numSamples" -> numSamples,
				"maxRelErr"  -> maxErr,
				"samples"    -> samples,
				"cni"        -> cni,
				"loops"      -> nLoops|>]]];

	(* Scaleless short-circuit: if the integral is identically zero in
	   dim-reg AND the symbolic result is zero (or empty SeriesData), the
	   answer is correct by construction.  Skipping the backend avoids its
	   build-time error on scaleless integrands. *)
	If[stIsScalelessGraph[edges, nodes],
		Module[{symZero},
			symZero = result === 0 ||
				(Head[result] === SeriesData && result[[3]] === {}) ||
				(Head[result] === SeriesData &&
					AllTrue[result[[3]], # === 0 || # === 0. &]);
			If[symZero,
				If[verbose, Print["[STVerify] scaleless integral, symbolic = 0 -> auto-pass"]];
				Return[<|"pass" -> True, "reason" -> "verified_scaleless",
					"maxRelErr" -> 0., "cni" -> cni, "loops" -> nLoops,
					"note" -> "All masses zero with " <> ToString[Length[nodes]] <>
						" external legs - integral is identically zero in dim-reg"|>],
				If[verbose, Print["[STVerify] scaleless integral but symbolic != 0 -> FAIL"]];
				Return[<|"pass" -> False, "reason" -> "scaleless_nonzero_symbolic",
					"cni" -> cni, "loops" -> nLoops|>]]]];

	seed = If[NumericQ[userSeed], userSeed, Hash[cni, "CRC32"]];
	Module[{resultSymbols, rolled},
		resultSymbols = Cases[result, _Symbol | _Symbol[_Integer], {0, Infinity}]
			// DeleteDuplicates // DeleteCases[_?(MemberQ[{eps, Pi, E, I, SeriesData, List, Plus, Times, Power, Log, Hlog, zeta, mzv, Rational, Complex}, #] &)];
		rolled = stMakeNonDegenerateVerificationPoint[edges, nodes, seed, resultSymbols, 20, verbose];
		kinPoint = rolled[[1]];
		seed     = rolled[[2]];
	];
	If[kinPoint === $Failed,
		Return[<|"pass" -> False,
			"reason" -> "no Euclidean kinematic point found",
			"cni" -> cni, "loops" -> nLoops|>]];
	If[verbose, Print["[STVerify] seed=", seed, "  KinematicPoint: ", kinPoint]];

	(* B11: feyntrop cannot handle shared internal/external mass symbols
	   because it returns only eps^0 and higher; the constraint msq = m^2
	   produces an integrand with 1/eps^2 poles it cannot represent.
	   pySecDec / FIESTA / AMFlow all handle this correctly (see the
	   per-backend notes on the cni-form's shared-mass guard above). *)
	Module[{shared = stSharedMassLegs[{edges, nodes}][[1]], method},
		method = OptionValue["Method"];
		If[Length[shared] > 0 && method === "feyntrop",
			If[verbose, Print["[STVerify] Shared mass ", shared,
				" \[LongDash] feyntrop cannot represent \[CurlyEpsilon]-poles; skipping"]];
			Return[<|"pass" -> False, "reason" -> "shared mass (feyntrop cannot represent poles)",
				"cni" -> cni, "loops" -> nLoops, "sharedMasses" -> shared|>]
		];
	];

	(* B10: feyntrop only verifies finite (eps^0-leading) integrals; refuse
	   to run it on a divergent symbolic result.  Detect 1/eps poles by
	   inspecting the Laurent series for a SeriesData with negative leading
	   order, or any explicit eps^(-n) factor. *)
	Module[{method, hasPole},
		method = OptionValue["Method"];
		If[method === "feyntrop",
			hasPole = Quiet[
				!FreeQ[result, SeriesData[eps, _, _, n_?Negative, _, _]] ||
				!FreeQ[result, eps^_?Negative],
				SeriesData::sdatc];
			If[hasPole,
				Message[STVerify::feyntropPoles, cni];
				Return[<|"pass" -> False,
					"reason" -> "feyntrop only verifies finite integrals (no eps poles)",
					"cni" -> cni, "loops" -> nLoops|>]]]];

	maxeval = OptionValue["MaxEval"];
	If[maxeval === Automatic, maxeval = If[nLoops <= 1, 10^6, 10^7]];

	(* Detect the symbolic series's leading order so we ask the backend for at
	   least that many extra orders.  Empirically pySecDec's requested_orders=[k]
	   returns a window ending at eps^k, omitting deeper poles \[LongDash] e.g.
	   requested_orders=[0] on a 1-loop box with eps^-2 pole returns only eps^-1,
	   eps^0.  Bumping requested_orders up by the loop count (and by the
	   symbolic leading depth) ensures the backend captures the full pole
	   structure. *)
	(* v1.0.453: don't bump Order.  The old comment here claimed that
	   "requested_orders=[0] on a 1-loop box with eps^-2 pole returns only
	   eps^-1, eps^0" and bumped psdOrder up by nLoops + (-symLead) to
	   compensate.  That was a workaround for an older pySecDec convention
	   and no longer needed: pySecDec with `Order -> 0` returns the full
	   series from the leading pole through \[CurlyEpsilon]^0.  Aggressively bumping the
	   Order caused verification to time out on multi-scale integrals like
	   the massless pentagon (pySecDec spent >300s trying to compute
	   through \[CurlyEpsilon]^2). *)
	psdResult = stVerifyRunBackend[{edges, nodes}, kinPoint, normalization,
		order, maxeval, {opts}];
	If[psdResult === $Failed,
		Message[STVerify::backend, cni, OptionValue["Method"]];
		Return[<|"pass" -> False, "reason" -> "numeric backend failed",
			"cni" -> cni, "loops" -> nLoops|>]
	];

	symbolicEval = stEvalSymbolicAtPoint[result, edges, nodes, kinPoint, verbose];
	If[symbolicEval === $Failed,
		Return[<|"pass" -> False, "reason" -> "ginsh/eval failed",
			"cni" -> cni, "loops" -> nLoops, "psd" -> psdResult|>]
	];

	(* Euclidean sanity check: if the symbolic result has large imaginary parts
	   at a Euclidean point, the analytic continuation representation (Log[x] with
	   x < 0) produces complex Laurent coefficients that don't match the backend's
	   real coefficients.  Fall back to a non-Euclidean evaluation. *)
	If[TrueQ[$stEuclideanPoint] && Head[symbolicEval] === SeriesData,
		Module[{coeffs, maxImRatio},
			coeffs = N[symbolicEval[[3]]];
			maxImRatio = Max[Table[
				If[Abs[Re[c]] > 10^-10, Abs[Im[c]/Re[c]], Abs[Im[c]]],
				{c, coeffs}]];
			If[maxImRatio > 0.01,
				If[verbose, Print["[STVerify] Euclidean eval has complex coefficients (Im/Re=",
					maxImRatio, "), retrying with non-Euclidean point"]];
				$stEuclideanPoint = False;
				(* Block the Euclidean detection to force non-Euclidean fallback path *)
				Block[{stFindEuclideanRegion = (None &)},
					kinPoint = stMakeVerificationPoint[edges, nodes, seed + 1]];
				If[kinPoint === $Failed,
					Return[<|"pass" -> False,
						"reason" -> "no Euclidean kinematic point found",
						"cni" -> cni, "loops" -> nLoops, "psd" -> psdResult|>]];
				If[verbose, Print["[STVerify] New KinematicPoint: ", kinPoint]];
				psdResult = stVerifyRunBackend[{edges, nodes}, kinPoint, normalization,
					order, maxeval, {opts}];
				If[psdResult === $Failed,
					Return[<|"pass" -> False, "reason" -> "numeric backend failed (non-Euclidean retry)",
						"cni" -> cni, "loops" -> nLoops|>]
				];
				symbolicEval = stEvalSymbolicAtPoint[result, edges, nodes, kinPoint, verbose];
				If[symbolicEval === $Failed,
					Return[<|"pass" -> False, "reason" -> "ginsh/eval failed (non-Euclidean retry)",
						"cni" -> cni, "loops" -> nLoops, "psd" -> psdResult|>]
				];
			]
		]
	];

	comparison = stCompareLaurent[psdResult, symbolicEval, order, tolerance, verbose];
	Join[comparison, <|"cni" -> cni, "loops" -> nLoops, "kinPoint" -> kinPoint|>]
];


(* ---- Form 3: propagator list (no graph) ----
   Builds a prime-ratio kinematic point over the free symbols of `props`
   (same mechanism STNIntegrate uses internally).  Symbolic result is
   evaluated via direct substitution \[LongDash] no mm/MM/sij alias rewriting,
   because the propagator-list numerical path emits results in the user's
   own symbols. *)
STVerify[props_List, result_, opts:OptionsPattern[STVerify]] /;
	!MatchQ[props, {_List, _List}] &&
	!MatchQ[props, {_, _, _List, _}] &&
	!MatchQ[props, {_, _, _List, _, _String}] := Module[
	{verbose, order, tolerance, maxeval, normalization, freeSyms,
	 subsRaw, subsCanonical, subsExpanded, symbolicEval, psdResult,
	 comparison, cni, nLoops},

	verbose = TrueQ[OptionValue["Verbose"]];
	order = OptionValue["Order"];
	tolerance = OptionValue["Tolerance"];
	normalization = Automatic;
	nLoops = 0;
	cni = "props_" <> ToString[Hash[props, "CRC32"]];

	(* Build kinPoint.  If user supplied Substitutions/KinematicPoint, honour it;
	   otherwise generate a prime-ratio point over all free symbols. *)
	subsRaw = stReadSubstitutions[{opts}];
	If[subsRaw === $Failed,
		Return[<|"pass" -> False, "reason" -> "bad Substitutions", "cni" -> cni|>]];
	freeSyms = Union @ Cases[props, _Symbol, {0, Infinity}] //
		DeleteCases[_?(MemberQ[{eps, Pi, E, I, EulerGamma, Infinity}, #]&)];
	{subsCanonical, subsExpanded} =
		stResolveEulerSubstitutions[subsRaw, freeSyms, props];
	If[subsCanonical === $Failed,
		Return[<|"pass" -> False, "reason" -> "could not resolve Substitutions",
			"cni" -> cni|>]];

	If[verbose, Print["[STVerify/props] KinematicPoint: ", subsCanonical]];

	maxeval = OptionValue["MaxEval"];
	If[maxeval === Automatic, maxeval = 10^6];

	psdResult = stVerifyRunBackend[props, subsCanonical, normalization,
		order, maxeval, {opts}];
	If[psdResult === $Failed,
		Message[STVerify::backend, cni, OptionValue["Method"]];
		Return[<|"pass" -> False, "reason" -> "numeric backend failed",
			"cni" -> cni, "loops" -> nLoops|>]];

	(* Direct symbolic substitution \[LongDash] no graph-symbol aliasing. *)
	symbolicEval = stVerifyEvalSymbolicGeneric[result, subsCanonical, verbose];
	If[symbolicEval === $Failed,
		Return[<|"pass" -> False, "reason" -> "ginsh/eval failed",
			"cni" -> cni, "loops" -> nLoops, "psd" -> psdResult|>]];

	comparison = stCompareLaurent[psdResult, symbolicEval, order, tolerance, verbose];
	Join[comparison, <|"cni" -> cni, "loops" -> nLoops,
		"kinPoint" -> subsCanonical|>]
];


(* ---- Form 4: pre-built Euler integrand quadruple ----
   {pref, integrand, xvars, coeffs} \[LongDash] pySecDec only (same constraint as
   STNIntegrate).  Symbolic result is evaluated at a prime-ratio point over
   `coeffs`. *)
STVerify[{pref_, integrand_, xvars_List, coeffs_}, result_,
		opts:OptionsPattern[STVerify]] /;
	VectorQ[xvars, (Head[#] === Symbol) &] && !MatchQ[pref, _List] :=
	stVerifyEulerQuadruple[{pref, integrand, xvars, coeffs}, result, {opts}];

(* ---- Form 5: checkpointed 5-tuple ---- *)
STVerify[{pref_, integrand_, xvars_List, coeffs_, checkpoint_String}, result_,
		opts:OptionsPattern[STVerify]] /;
	VectorQ[xvars, (Head[#] === Symbol) &] :=
	stVerifyEulerQuadruple[{pref, integrand, xvars, coeffs, checkpoint},
		result, {opts}];

stVerifyEulerQuadruple[quadOrFive_List, result_, optsList_List] := Module[
	{verbose, order, tolerance, maxeval, normalization,
	 pref, integrand, xvars, coeffs, checkpointId = None,
	 subsRaw, subsCanonical, subsExpanded, symbolicEval, psdResult,
	 comparison, cni, nLoops, numericInput},

	verbose = TrueQ["Verbose" /. optsList /. Options[STVerify]];
	order = "Order" /. optsList /. Options[STVerify];
	tolerance = "Tolerance" /. optsList /. Options[STVerify];
	normalization = Automatic;
	nLoops = 0;

	Which[
		Length[quadOrFive] == 4,
			{pref, integrand, xvars, coeffs} = quadOrFive,
		Length[quadOrFive] == 5,
			{pref, integrand, xvars, coeffs, checkpointId} = quadOrFive,
		True, Message[STVerify::badinput]; Return[$Failed]];

	cni = "euler_" <> ToString[Hash[{pref, integrand, xvars, coeffs}, "CRC32"]];

	subsRaw = stReadSubstitutions[optsList];
	If[subsRaw === $Failed,
		Return[<|"pass" -> False, "reason" -> "bad Substitutions", "cni" -> cni|>]];
	{subsCanonical, subsExpanded} =
		stResolveEulerSubstitutions[subsRaw, coeffs, {integrand, pref}];
	If[subsCanonical === $Failed,
		Return[<|"pass" -> False, "reason" -> "could not resolve Substitutions",
			"cni" -> cni|>]];

	If[verbose, Print["[STVerify/Euler] KinematicPoint: ", subsCanonical]];

	maxeval = "MaxEval" /. optsList /. Options[STVerify];
	If[maxeval === Automatic, maxeval = 10^6];

	numericInput = If[checkpointId === None,
		{pref, integrand, xvars, coeffs},
		{pref, integrand, xvars, coeffs, checkpointId}];

	psdResult = stVerifyRunBackend[numericInput, subsCanonical, normalization,
		order, maxeval, optsList];
	If[psdResult === $Failed,
		Message[STVerify::backend, cni, "Method" /. optsList /. Options[STVerify]];
		Return[<|"pass" -> False, "reason" -> "numeric backend failed",
			"cni" -> cni, "loops" -> nLoops|>]];

	symbolicEval = stVerifyEvalSymbolicGeneric[result, subsCanonical, verbose];
	If[symbolicEval === $Failed,
		Return[<|"pass" -> False, "reason" -> "ginsh/eval failed",
			"cni" -> cni, "loops" -> nLoops, "psd" -> psdResult|>]];

	comparison = stCompareLaurent[psdResult, symbolicEval, order, tolerance, verbose];
	Join[comparison, <|"cni" -> cni, "loops" -> nLoops,
		"kinPoint" -> subsCanonical|>]
];


(* ---- Helper: find Euclidean region from the F polynomial ---- *)
(* The Euclidean region is where -F(x) > 0 for all Schwinger parameters x_i > 0.
   Since -F is a polynomial in x_i with coefficients linear in kinematic invariants,
   this reduces to: every monomial coefficient in -F must be > 0.
   Returns {inequalities, samplePoint} or None if no Euclidean region exists. *)

stFindEuclideanRegion[edges_, nodes_] := Module[
	{raw, integrand, xvars, fFactor, negF, monomials, coefficients,
	 kinVars, inequalities, samplePoint, sharedReduction,
	 negFreduced, samplingCandidate},

	(* Get the integrand from SOFIA \[LongDash] no gauge fixing, extract F polynomial.
	   SOFIASymanzik emits harmless First::nofirst / First::argt messages from
	   empty-subtopology passes on some graphs (e.g. spectacles e1122|e|e|);
	   suppress those explicitly so the outer Check only triggers on real
	   failures.  Without this Quiet list, Check returned $Failed on the
	   spectacles family even though SOFIA's actual return value was the
	   correct integrand, causing stFindEuclideanRegion to erroneously
	   report "no Euclidean region". *)
	raw = Check[
		Flatten[Quiet[
			SOFIASymanzik[{edges, nodes}, dimension -> 4 - 2 eps],
			{First::nofirst, First::argt, General::stop}]][[1]],
		$Failed];
	If[raw === $Failed, Return[None]];

	xvars = Union @ Cases[raw, s_Symbol /; StringStartsQ[SymbolName[s], "x"], Infinity];

	(* Extract the F factor: the polynomial raised to a power involving eps
	   that also depends on kinematic variables *)
	fFactor = Cases[raw, a_^b_ /; !FreeQ[b, eps] && !FreeQ[a, Alternatives @@ xvars]
		&& !FreeQ[a, mm | MM | s12 | s23 | s13 | s14 | s24 | s34 | s15 | s25 | s35 | s45]
		:> a, Infinity];
	If[fFactor === {},
		(* No F factor \[LongDash] vacuum or scaleless *)
		Return[None]];

	(* -F should be positive in Euclidean.  SOFIA's integrand has (-F)^power
	   where -F = the polynomial.  We need -F > 0, i.e., the polynomial > 0. *)
	negF = fFactor[[1]];

	(* Shared-mass reduction: when an external leg i carries the same mass
	   symbol as some internal edge j, the on-shell constraint p_i^2 = m_j^2
	   identifies two nominally-independent symbols in F (external M_isq,
	   internal mm or mm_j) as the SAME quantity.  Without this identification
	   the termwise test below treats them as independent and may spuriously
	   reject a Euclidean region whose inequality set becomes consistent
	   once the symbols are collapsed.  Apply the reduction by rewriting
	   every MM / MM[i] on the external side to the corresponding mm / mm[j]
	   on the internal side. *)
	sharedReduction = DeleteCases[Table[
		Module[{sharedSym = stIsSharedMassLeg[{edges, nodes}, i],
		        nm = nodes[[i, 2]], lhsSq, rhsSq},
			If[sharedSym === None, Nothing,
				(* Left-hand side: what appears in F for external leg i.
				   Follow the same Python-name convention downstream code
				   uses (stMmaExprToPython[nm] <> "sq"). *)
				lhsSq = Which[
					Expand[nm^2] === 0, Nothing,
					MatchQ[Expand[nm^2], _Symbol], Expand[nm^2],
					True, Symbol[StringReplace[
						stMmaExprToPython[nm], "**" -> ""] <> "sq"]];
				(* Right-hand side: the INTERNAL mass-squared symbol under
				   the convention m \[RightArrow] mm, m[i] \[RightArrow] mm[i]. *)
				rhsSq = Which[
					MatchQ[sharedSym, _Symbol[_Integer]], mm[sharedSym[[1]]],
					MatchQ[sharedSym, _Symbol], mm,
					True, Nothing];
				If[lhsSq === Nothing || rhsSq === Nothing, Nothing,
					lhsSq -> rhsSq]]],
		{i, Length[nodes]}], Nothing];
	negFreduced = negF /. sharedReduction;

	(* Expand and collect monomials in x variables on the REDUCED polynomial *)
	negFreduced = Expand[negFreduced];
	monomials = MonomialList[negFreduced, xvars];

	(* Extract the kinematic coefficient of each x-monomial. *)
	coefficients = DeleteDuplicates[monomials /. Thread[xvars -> 1]];

	kinVars = Complement[Variables[negFreduced], xvars];

	(* Termwise sufficient test: each monomial coefficient > 0 *)
	inequalities = And @@ (# > 0 & /@ coefficients);

	(* Try to find a rational sample point.  FindInstance typically returns
	   small integers (e.g. MM[k] -> -1); re-cast into the prime-ratio
	   convention used everywhere else so the output format is uniform
	   with stEuclideanSamplingFallback and stMakeVerificationPoint. *)
	samplePoint = Quiet @ Check[
		FindInstance[inequalities, kinVars, Rationals],
		{}];

	If[samplePoint =!= {} && samplePoint =!= $Failed,
		Module[{fiPoint, primes, primeIdx = 0, seed, pickRatio, primeInstance},
			fiPoint = samplePoint[[1]];
			seed = Hash[{edges, nodes, "EuclFinder"}, "CRC32"];
			primes = Prime /@ Range[PrimePi[100]];
			pickRatio[] := Module[{k1, k2, p1, p2},
				k1 = Mod[BitXor[seed, Hash[{primeIdx, "n"}, "CRC32"]], Length[primes]] + 1;
				primeIdx++;
				k2 = Mod[BitXor[seed, Hash[{primeIdx, "d"}, "CRC32"]], Length[primes]] + 1;
				primeIdx++;
				p1 = primes[[k1]]; p2 = primes[[k2]];
				If[p1 === p2, p2 = primes[[Mod[k2, Length[primes]] + 1]]];
				p1 / p2];
			primeInstance = Table[
				Module[{var = r[[1]], v = r[[2]], sgn},
					sgn = Sign[v];
					var -> (If[sgn === 0, 1, sgn] * pickRatio[])],
				{r, fiPoint}];
			(* Sanity check that the prime-ratio rescaling still satisfies
			   the inequalities (it should, since the inequalities from the
			   termwise test are sign-constraints scale-invariant in each
			   kinematic variable).  Fall back to the raw FindInstance
			   instance if some exotic constraint sneaks in. *)
			If[TrueQ[inequalities /. primeInstance],
				Return[{inequalities, primeInstance}],
				Return[{inequalities, fiPoint}]]]];

	(* ---------- Sampling fallback ----------
	   Termwise test failed, but the polynomial may still be positive on
	   (0,\[Infinity])^n (polynomial positivity is weaker than termwise).
	   Pick a reasonable candidate point from the standard prior (masses
	   positive prime-ratios, Mandelstams negative prime-ratios) and
	   evaluate negF at a grid of simplex points.  If negF > 0 at every
	   sample, accept the candidate with an explicit sampling flag.

	   Rigour: sampling is NOT a proof of positivity.  We lattice the
	   simplex with enough granularity that the typical modes of failure
	   (zero crossings between corners/edges) are caught: all 4 corners,
	   edge midpoints, face centroids, and a handful of random interior
	   points.  A polynomial tangent to 0 between sample points can slip
	   through; this is an accepted tradeoff for enabling Euclidean
	   verification of graphs whose F has a sign-cancelling term. *)
	samplingCandidate = stEuclideanSamplingFallback[negFreduced, xvars, kinVars];
	If[samplingCandidate =!= None,
		Return[{inequalities, samplingCandidate}]];

	None
];

(* Helper: try several prime-ratio kinematic candidates against a
   lattice of prime-ratio Schwinger samples.  Returns the first
   candidate whose -F is strictly positive at every sample, else None.

   Why prime ratios (v1.1.2):
   \[Bullet] Kinematic candidate: a hardcoded {mass\[RightArrow]1, s\[RightArrow]-1} point often
     sits on low-codimension cancellation surfaces of -F (e.g. for the
     shared-mass box e12|e3|e3|e|:100|11|12|1|, the x2 coefficient of
     -F is -mm[1] which rejects termwise AND the unit-mass candidate
     gives zero at x = (0,1,0,0), tripping the sampling probe).  Prime
     ratios give scale-separated, generic values so such cancellations
     happen with probability zero.
   \[Bullet] Schwinger samples: likewise, sparse {1, 1/100} corners are a
     measure-zero slice of the simplex.  Prime-ratio coordinates probe
     generic directions in (0,\[Infinity])^n, catching sign-flips that structured
     lattices can miss.

   Schwinger probes: n "corners" (one x_i dominant, others suppressed
   by 1/p_large so the corner limit is approached), plus nInt generic
   interior points.  Every coordinate comes from a deterministic
   prime-ratio pool keyed on Hash[{negF, xvars, kinVars, ...}]. *)
stEuclideanSamplingFallback[negF_, xvars_, kinVars_] := Module[
	{primes, nPrimes, baseSeed, pickRatio, classifyKin, buildKinCandidate,
	 buildSchwingerSamples, candidate, samples, n = Length[xvars],
	 vals, allPos, nCandidates = 5, nInt = 8, cand, result = None},

	primes = Prime /@ Range[PrimePi[100]];    (* 25 primes up to 97 *)
	nPrimes = Length[primes];
	baseSeed = Hash[{negF, xvars, kinVars}, "CRC32"];

	(* Pick a deterministic p/q prime ratio from an arbitrary key.
	   Ensures p =!= q so the ratio is never trivially 1. *)
	pickRatio[key_] := Module[{k1, k2, p, q},
		k1 = Mod[Hash[{baseSeed, key, "num"}, "CRC32"], nPrimes] + 1;
		k2 = Mod[Hash[{baseSeed, key, "den"}, "CRC32"], nPrimes] + 1;
		p = primes[[k1]]; q = primes[[k2]];
		If[p === q, q = primes[[Mod[k2, nPrimes] + 1]]];
		p/q];

	(* kinVars may be bare symbols (mm, s12, Msq) or indexed heads
	   (mm[1], MM[2], s[1,2]).  Classify by symbol-name prefix: any
	   name starting with m/M (masses and their squares) gets a
	   positive ratio; names starting with s (Mandelstams, invariants)
	   get a negative ratio.  Other symbols default to positive. *)
	classifyKin[v_] := Module[{nm = Which[
		MatchQ[v, _Symbol], SymbolName[v],
		MatchQ[v, _Symbol[___]], SymbolName[Head[v]],
		True, ""]},
		Which[
			StringStartsQ[nm, "mm"] || StringStartsQ[nm, "Msq"] ||
			  StringStartsQ[nm, "MM"] || StringStartsQ[nm, "M"] ||
			  StringStartsQ[nm, "m"], +1,
			StringStartsQ[nm, "s"], -1,
			True, +1]];

	buildKinCandidate[cIdx_] := Table[
		v -> classifyKin[v] * pickRatio[{"kin", cIdx, v}],
		{v, kinVars}];

	(* n corner-like probes: x_i = prime ratio near 1, all other x_j
	   suppressed by 1/(prime ratio * 10000) so the Schwinger corner
	   limit is effectively reached.  Plus nInt fully-generic interior
	   probes with every coordinate a fresh prime ratio. *)
	buildSchwingerSamples[cIdx_] := Join[
		Table[
			Thread[xvars -> Table[
				If[i === j,
					pickRatio[{"corner", cIdx, i, j, "dom"}],
					pickRatio[{"corner", cIdx, i, j, "sub"}] / 10000],
				{j, n}]],
			{i, n}],
		Table[
			Thread[xvars -> Table[
				pickRatio[{"int", cIdx, k, j}],
				{j, n}]],
			{k, nInt}]];

	(* Try up to nCandidates kinematic assignments.  Accept the first
	   whose -F is strictly positive at every Schwinger sample. *)
	Do[
		cand = buildKinCandidate[cIdx];
		samples = buildSchwingerSamples[cIdx];
		vals = Table[
			Quiet @ Check[Expand[(negF /. pt) /. cand], Indeterminate],
			{pt, samples}];
		allPos = AllTrue[vals, NumericQ[#] && # > 0 &];
		If[allPos,
			result = cand;
			Break[]],
		{cIdx, nCandidates}];

	result
];


(* ---- Helper: generate deterministic Euclidean kinematic point ---- *)

stMakeVerificationPoint::sharedMassNoEuclidean =
	"Shared-mass graph with no parametric Euclidean region: an internal edge mass symbol also appears on an external leg, forcing p^2 = m^2 on-shell, so -F changes sign across the Schwinger simplex.  Verification via the i\[CurlyEpsilon] prescription currently gives Ginsh/pySecDec disagreement that depends on the sign choice per kinematic symbol, with no universal fix.  STVerify refuses to generate a point for this graph until the branch-resolution issue is fixed; entries of this type cannot currently be verified and are excluded from the library.";

stMakeVerificationPoint::noEuclidean =
	"No Euclidean region found for this graph's F polynomial.  STVerify refuses to generate a non-Euclidean point because the i\[CurlyEpsilon] prescription for the symbolic evaluation is graph-specific and no universal choice has been implemented yet.  Entries of this type are excluded from the library until the branch-resolution issue is fixed.";

stMakeVerificationPoint[edges_, nodes_, seed_Integer, resultVars_List:{}] := Catch[Module[
	{edgeMasses, nodeMasses, nExt, rules, intMassSyms, extInvariants,
	 genKin, mandelstams, flattenSym, primes, pickPrime, euclidean,
	 edgesF, nodesF, stb, hasSharedMass, cniForMsg, applySharedMassOnShell},

	(* Flatten Subscript notation so Cases[_Symbol | _[_Integer], ...] picks
	   up Subscript[m, k] / Subscript[M, k] as the flat symbols mk / Mk.
	   Without this, Cases descends past the 2-arg Subscript head and grabs
	   only the inner m / M, collapsing distinct indexed masses to one rule.
	   STNIntegrate already flattens upstream; doing it here too is idempotent
	   and also fixes STVerify's direct calls. *)
	stb = {
		Subscript[x_, args__Integer] :> Symbol["Global`" <> ToString[x] <> StringJoin[ToString /@ {args}]],
		Subscript[x_, i_] :> x[i]};
	edgesF = edges /. stb;
	nodesF = nodes /. stb;

	edgeMasses = edgesF[[All, 2]];
	nodeMasses = nodesF[[All, 2]];
	nExt = Length[nodesF];
	flattenSym[sym_] := Symbol[stMmaExprToPython[sym]];
	rules = {};

	(* Shared-mass on-shell correction for the rule list.  For each
	   external leg whose mass symbol also appears on some internal edge,
	   the on-shell constraint p^2 = m^2 means the external-invariant
	   symbol (e.g. m2sq) must equal the internal mass squared rather
	   than getting an independent, potentially NEGATIVE, prime ratio
	   from the default generator.  Without this, pySecDec (which bakes
	   p^2=m^2 into its replacement_rules template) and the symbolic
	   side (which treats m2sq as an independent symbol) land at
	   inconsistent numeric points and verification spuriously fails.
	   Applied at every return site below so both Euclidean and
	   non-Euclidean paths get the fix. *)
	applySharedMassOnShell[rs_List] := Module[{out = rs, nm, sharedSym, sq, invSym, intValue},
		Do[
			nm = nodeMasses[[i]];
			sharedSym = stIsSharedMassLeg[{edgesF, nodesF}, i];
			If[sharedSym =!= None,
				sq = Expand[nm^2];
				If[sq =!= 0,
					invSym = Which[
						MatchQ[sq, _Symbol], sq,
						True, Symbol[StringReplace[stMmaExprToPython[nm], "**" -> ""] <> "sq"]];
					intValue = flattenSym[sharedSym] /. out;
					If[intValue =!= flattenSym[sharedSym],
						out = DeleteCases[out, Rule[invSym, _]];
						AppendTo[out, invSym -> Expand[intValue^2]]]]],
			{i, nExt}];
		out];

	(* Shared-mass detection: any external-leg mass symbol that also
	   appears on an internal edge.  When this is true AND no Euclidean
	   region exists, verification is fundamentally unsupported in the
	   current framework \[LongDash] the on-shell constraint p^2=m^2 puts the
	   integral on a mass-shell singularity whose Minkowski i\[CurlyEpsilon]
	   prescription we don't reliably reproduce symbolically.  The
	   refusal is emitted below, after stFindEuclideanRegion fails. *)
	hasSharedMass = AnyTrue[Range[nExt],
		stIsSharedMassLeg[{edgesF, nodesF}, #] =!= None &];

	(* Step 1: Try to find a Euclidean region point from the F polynomial.
	   If successful, the kinematic point satisfies -F > 0 for all x_i > 0
	   and no i\[CurlyEpsilon] prescription is needed. *)
	euclidean = Quiet @ stFindEuclideanRegion[edgesF, nodesF];
	If[euclidean =!= None,
		Module[{ineqs = euclidean[[1]], kinVars, testPoint, attempts = 0},
			(* Generate prime-ratio kinematic values that satisfy the Euclidean
			   inequalities.  Strategy: build a random point using the standard
			   prime-ratio generator, then check the inequalities.  If they fail,
			   try flipping signs or scaling until they pass. *)
			kinVars = Variables[ineqs];

			(* Build the standard prime-ratio point first *)
			primes = Prime /@ Range[PrimePi[100]];
			Module[{primeIdx = 0},
			pickPrime[] := Module[{idx},
				idx = Mod[BitXor[seed, Hash[primeIdx, "CRC32"]], Length[primes]] + 1;
				primeIdx++;
				primes[[idx]]];

			intMassSyms = Cases[edgeMasses, _Symbol | _[_Integer], {0, Infinity}] // DeleteDuplicates;
			intMassSyms = flattenSym /@ intMassSyms;
			Do[Module[{p1, p2},
				p1 = pickPrime[]; p2 = pickPrime[];
				While[p1 === p2, p2 = pickPrime[]];
				AppendTo[rules, ms -> Sqrt[p1/p2]]],
				{ms, intMassSyms}];

			extInvariants = Table[
				Module[{nm = nodeMasses[[i]], sq},
					sq = Expand[nm^2];
					Which[sq === 0, Nothing, MatchQ[sq, _Symbol], sq,
						True, Symbol[StringReplace[stMmaExprToPython[nm], "**" -> ""] <> "sq"]]],
				{i, nExt}] // DeleteDuplicates // DeleteCases[Nothing];
			Do[Module[{p1, p2},
				p1 = pickPrime[]; p2 = pickPrime[];
				While[p1 === p2, p2 = pickPrime[]];
				AppendTo[rules, inv -> -(p1/p2)]],
				{inv, extInvariants}];

			If[nExt >= 3,
				genKin = GenerateKinematics[nExt];
				mandelstams = Cases[genKin[[All, 2]], Subscript[s, __], {0, Infinity}]
					// DeleteDuplicates;
				mandelstams = flattenSym /@ mandelstams;
				Do[Module[{p1, p2},
					p1 = pickPrime[]; p2 = pickPrime[];
					While[p1 === p2, p2 = pickPrime[]];
					AppendTo[rules, sv -> -(p1/p2)]],
					{sv, mandelstams}]];
			]; (* end prime Module *)

			rules = DeleteDuplicates[rules];

			(* Build mapping from F-polynomial variable names (MM, MM[i]) to
			   the kinematic point variable names (Msq, M<i>sq, ...), where
			   i = boundary-ordered leg position.  Variable names are
			   generated by stMmaExprToPython[nodeMass] <> "sq".
			   Mandelstams (s12, s23, ...) already match. *)
			Module[{varMap = {}, trailingIndex},
				(* After flattening, Subscript[M, 2] becomes the flat Symbol M2
				   and no longer matches _Symbol[_Integer].  Parse the name:
				   if it ends in digits, treat them as the indexed-mass key. *)
				trailingIndex[sym_Symbol] := Module[{n, d},
					n = SymbolName[sym];
					d = StringCases[n, DigitCharacter .. ~~ EndOfString];
					If[d === {}, None, FromDigits[d[[1]]]]];
				Do[Module[{nm = nodeMasses[[i]], idx},
					Which[
						nm === 0, Null,
						MatchQ[nm, Sqrt[_Symbol]],
							AppendTo[varMap, Expand[nm^2] -> Expand[nm^2]],
						MatchQ[nm, _Symbol[_Integer]],
							AppendTo[varMap, MM[nm[[1]]] -> Symbol[stMmaExprToPython[nm] <> "sq"]],
						MatchQ[nm, _Symbol],
							idx = trailingIndex[nm];
							If[idx === None,
								AppendTo[varMap, MM -> Symbol[stMmaExprToPython[nm] <> "sq"]],
								AppendTo[varMap, MM[idx] -> Symbol[stMmaExprToPython[nm] <> "sq"]]]
					]], {i, nExt}];
				(* Also map internal masses: mm -> m^2, mm[k] -> mk^2.
				   The kinematic point has unsquared masses (m, m1, m2, ...),
				   so mm = m_val^2, mm[k] = mk_val^2. *)
				Do[Module[{mass = edgeMasses[[j]], idx},
					Which[
						mass === 0, Null,
						MatchQ[mass, _Symbol[_Integer]],
							AppendTo[varMap, mm[mass[[1]]] -> Symbol[stMmaExprToPython[mass]]^2],
						MatchQ[mass, _Symbol],
							idx = trailingIndex[mass];
							If[idx === None,
								AppendTo[varMap, mm -> Symbol[stMmaExprToPython[mass]]^2],
								AppendTo[varMap, mm[idx] -> Symbol[stMmaExprToPython[mass]]^2]]
					]], {j, Length[edgeMasses]}];
				varMap = DeleteDuplicates[varMap];
				(* Apply mapping to inequalities so they use rule variable names *)
				ineqs = ineqs /. varMap;
			];

			(* Check if the initial point satisfies Euclidean inequalities. *)
			testPoint = ineqs /. rules;
			If[TrueQ[testPoint],
				$stEuclideanPoint = True;
				Throw[applySharedMassOnShell[rules], "euclidean"]
			];

			(* If not, use FindInstance on the inequalities to get a satisfying
			   point, then scale by prime ratios for irrationality. *)
			Module[{ineqVars, fiPoint, scale, fiRules, distinctPairs},
				ineqVars = Cases[ineqs, _Symbol, {0, Infinity}] //
					DeleteDuplicates //
					Select[!MemberQ[{And, Or, Greater, Less, GreaterEqual, LessEqual,
						Equal, True, False, Inequality}, #] &];
				If[ineqVars =!= {},
					(* Require ineqVars pairwise distinct so FindInstance doesn't
					   collapse two unrelated variables (e.g. m2, m3) to the same
					   rational when the inequality region is symmetric in them.
					   Degenerate points inject ComplexInfinity into the symbolic
					   result via denominators like mm3/(mm2 - mm3).  Fall back to
					   the unconstrained solve if distinctness is infeasible. *)
					distinctPairs = If[Length[ineqVars] >= 2,
						And @@ Flatten @ Table[
							ineqVars[[i]] != ineqVars[[j]],
							{i, Length[ineqVars] - 1}, {j, i + 1, Length[ineqVars]}],
						True];
					fiPoint = Quiet @ Check[
						FindInstance[
							ineqs && And @@ (# != 0 & /@ ineqVars) && distinctPairs,
							ineqVars, Rationals, 1],
						{}];
					If[fiPoint === {} || fiPoint === $Failed,
						fiPoint = Quiet @ Check[
							FindInstance[ineqs && And @@ (# != 0 & /@ ineqVars),
								ineqVars, Rationals, 1],
							{}]];
					If[fiPoint =!= {} && fiPoint =!= $Failed,
						fiRules = fiPoint[[1]];
						scale = Prime[Mod[seed, 10] + 3] / Prime[Mod[seed, 10] + 7];
						rules = Table[
							Module[{var = r[[1]], fiVal},
								fiVal = var /. fiRules;
								If[NumericQ[fiVal] && fiVal =!= 0,
									var -> fiVal * scale,
									r]],
							{r, rules}];
						testPoint = ineqs /. rules;
						If[TrueQ[testPoint],
							$stEuclideanPoint = True;
							Throw[applySharedMassOnShell[rules], "euclidean"]]
					]
				]
			];
		]
	];

	(* Step 1 exhausted without finding an Euclidean point.

	   For the current release, verification is REFUSED whenever no
	   Euclidean region exists, regardless of whether the graph has
	   shared masses.  The non-Euclidean i\[CurlyEpsilon] fallback (kept in the
	   codepath below) produces Ginsh/pySecDec disagreement that depends
	   on the i\[CurlyEpsilon] sign pattern per kinematic symbol, and there is no
	   universal sign choice that works across all graphs (bubble-pent
	   wants {mm2,s12} positive, box(e) wants mm1 positive; intersection
	   empty).  Fixing this requires a graph-specific i\[CurlyEpsilon] auto-scan
	   which is future work.  Until then, we pre-empt spurious
	   verified-pass (or verify-refused with sentinel 99) outcomes by
	   throwing $Failed here.  Callers see "no Euclidean kinematic
	   point found" as a structured reason and can decide how to
	   handle (skip, queue for manual review, etc.). *)
	If[hasSharedMass,
		Message[stMakeVerificationPoint::sharedMassNoEuclidean];
		Throw[$Failed, "euclidean"]];
	Message[stMakeVerificationPoint::noEuclidean];
	Throw[$Failed, "euclidean"];

	(* Step 2: Fallback \[LongDash] random prime-ratio point (may not be Euclidean).
	   The i\[CurlyEpsilon] prescription will be applied during evaluation. *)
	$stEuclideanPoint = False;

	primes = Prime /@ Range[PrimePi[100]];
	Module[{primeIdx = 0},

	pickPrime[] := Module[{idx},
		idx = Mod[BitXor[seed, Hash[primeIdx, "CRC32"]], Length[primes]] + 1;
		primeIdx++;
		primes[[idx]]
	];

	intMassSyms = Cases[edgeMasses, _Symbol | _[_Integer], {0, Infinity}] // DeleteDuplicates;
	intMassSyms = flattenSym /@ intMassSyms;
	Do[
		Module[{p1, p2},
			p1 = pickPrime[]; p2 = pickPrime[];
			While[p1 === p2, p2 = pickPrime[]];
			AppendTo[rules, ms -> Sqrt[p1/p2]]
		],
		{ms, intMassSyms}
	];

	extInvariants = Table[
		Module[{nm = nodeMasses[[i]], sq},
			sq = Expand[nm^2];
			Which[
				sq === 0, Nothing,
				MatchQ[sq, _Symbol], sq,
				True, Symbol[StringReplace[stMmaExprToPython[nm], "**" -> ""] <> "sq"]
			]
		],
		{i, nExt}
	] // DeleteDuplicates // DeleteCases[Nothing];

	Do[
		Module[{p1, p2},
			p1 = pickPrime[]; p2 = pickPrime[];
			While[p1 === p2, p2 = pickPrime[]];
			AppendTo[rules, inv -> -(p1/p2)]
		],
		{inv, extInvariants}
	];

	If[nExt >= 3,
		genKin = GenerateKinematics[nExt];
		mandelstams = Cases[genKin[[All, 2]], Subscript[s, __], {0, Infinity}]
			// DeleteDuplicates;
		mandelstams = flattenSym /@ mandelstams;
		Do[
			Module[{p1, p2},
				p1 = pickPrime[]; p2 = pickPrime[];
				While[p1 === p2, p2 = pickPrime[]];
				AppendTo[rules, sv -> -(p1/p2)]
			],
			{sv, mandelstams}
		];
	];

	]; (* end Module for primeIdx *)

	(* Step 1 (Euclidean attempt) and Step 2 (fallback) both append rules for
	   masses, ext invariants, and Mandelstams to the same `rules` list.  When
	   Step 1 fails its Euclidean test without throwing, Step 2's appended rules
	   create duplicate keys with different prime values.  DeleteDuplicates only
	   removes EXACT duplicates, so we additionally keep the first occurrence
	   per key.  Without this, pySecDec receives conflicting kinematic values
	   for the same Mandelstam and either silently uses one or fails to build. *)
	DeleteDuplicatesBy[DeleteDuplicates[applySharedMassOnShell[rules]], First]
], "euclidean"];


(* ---- Algebraic-letter degeneracy guard ----

   stMakeVerificationPoint can deterministically land on a kinematic point
   where the algebraic letters {Wm[i], Wp[i]} hit a boundary singularity
   that makes the result's denominators vanish (1/0 -> ComplexInfinity).
   The 2-mass hexagonal core with bubble insertion (b)
   `1123|e|e4|e4|e|:0000|1|00|10|0|` was the original culprit:
   Hash[cni,"CRC32"] = 2227685404 produces {Msq=-17/31, s12=-51/124,
   s23=-17/124} where s12+s23 = -17/31 = MM, hence Wm,Wp are primitive 6th
   roots of unity and 1+Wm+Wp = 0 identically.

   stLetterDegeneraciesAtPoint reports degenerate letter indices (0, 1,
   -1, Wm=Wp, 1+Wm+Wp=0) under a candidate point; Vieta's identity
   Wp*Wm = -(Wp+Wm) for these square-root letters means the latter check
   also catches the equivalent Wp*Wm=1 condition.

   stMakeNonDegenerateVerificationPoint wraps stMakeVerificationPoint and
   reseeds (seed, seed+1, ..., seed+maxAttempts-1) until a non-degenerate
   point is found.  Used by STVerify in both the library/CNI form and the
   graph form.  Falls back to the original seed's point if every attempt
   degenerates (rather than blocking verification entirely); the
   downstream STToGinsh/ginsh failure path then surfaces a "ginsh/eval
   failed" outcome with a clean trace. *)

stLetterDegeneraciesAtPoint[kinPoint_List, rootSubs_List, edges_, nodes_] := Module[
	{indices, ksubs, tol = 10^-10},
	If[rootSubs === {}, Return[{}]];
	indices = Cases[rootSubs, HoldPattern[Wm[i_] -> _] :> i] // DeleteDuplicates;
	If[indices === {}, Return[{}]];
	ksubs = Quiet[Check[stBuildSymbolicSubRules[edges, nodes, kinPoint], $Failed]];
	If[ksubs === $Failed, Return[{}]];
	Cases[
		Table[
			Module[{wm, wp},
				wm = Quiet[N[Wm[i] /. rootSubs /. ksubs]];
				wp = Quiet[N[Wp[i] /. rootSubs /. ksubs]];
				If[!NumericQ[wm] || !NumericQ[wp],
					Nothing,
					Which[
						Abs[wm] < tol,            {i, "Wm=0"},
						Abs[wp] < tol,            {i, "Wp=0"},
						Abs[wm - 1] < tol,        {i, "Wm=1"},
						Abs[wp - 1] < tol,        {i, "Wp=1"},
						Abs[wm + 1] < tol,        {i, "Wm=-1"},
						Abs[wp + 1] < tol,        {i, "Wp=-1"},
						Abs[wp - wm] < tol,       {i, "Wp=Wm (disc=0)"},
						Abs[1 + wm + wp] < tol,   {i, "1+Wm+Wp=0"},
						True,                     Nothing]]],
			{i, indices}],
		_List]
];

stMakeVerificationPoint::allDegenerate =
	"All `1` seed reroll attempts (starting from seed=`2`) gave kinematic points where some algebraic letter Wm[i]/Wp[i] hits a boundary singularity (=0, =1, =-1, Wm=Wp, or 1+Wm+Wp=0).  Falling back to the original seed's point; symbolic evaluation will likely produce ComplexInfinity in Hlog c-lists and the verifier will report ginsh/eval failed.  Inspect the result for spurious denominators in the algebraic-letter alphabet.";

stMakeNonDegenerateVerificationPoint[edges_, nodes_, seed_Integer,
	resultVars_List:{}, maxAttempts_Integer:20, verbose_:False] := Module[
	{try = 0, currSeed = seed, kinPoint, degens,
	 firstKinPoint = Null, firstSeed = seed},
	While[try < maxAttempts,
		kinPoint = stMakeVerificationPoint[edges, nodes, currSeed, resultVars];
		If[kinPoint === $Failed, Return[{$Failed, currSeed}]];
		If[try == 0, firstKinPoint = kinPoint; firstSeed = currSeed];
		degens = stLetterDegeneraciesAtPoint[kinPoint,
			If[ValueQ[$stRootSubstitutions], $stRootSubstitutions, {}],
			edges, nodes];
		If[degens === {}, Return[{kinPoint, currSeed}]];
		If[verbose,
			Print["[STVerify] seed=", currSeed,
				" landed on algebraic-letter degeneracy ", degens,
				"; rerolling (attempt ", try + 1, "/", maxAttempts, ")"]];
		try++;
		currSeed = seed + try
	];
	Message[stMakeVerificationPoint::allDegenerate, maxAttempts, seed];
	{firstKinPoint, firstSeed}
];


(* ---- Helper: build substitution rules mapping pySecDec params \[RightArrow] symbolic result vars ----
   Convention: symbolic result uses homogeneized variables from homogeneizeKin2:
     MM = p^2 (single external mass squared, from node mass M)
     MM[i] = p_i^2 (indexed external invariant, i = boundary leg position)
     mm = m^2 (single int mass squared)
     mm[i] = m_i^2 (indexed int mass squared)
     s12, s23, ... (Mandelstam invariants, boundary-ordered)

   Corresponding pySecDec parameters (generated by stMmaExprToPython):
     Msq (= MM), M<i>sq (= MM[i]) \[LongDash] squared external invariants
     m, mi (unsquared internal masses, so mm = m_val^2)
     s12, s13, ... (same names)

   Substitution: pass kinematic values DIRECTLY, no Abs or sign manipulation.
   In the Euclidean region (MM < 0, s_ij < 0, mm > 0), Log arguments like
   Log[mm - MM] = Log[mm + |p^2|] are positive.  The (-F)^omega branch in the
   integrand (normalization.tex Eq. 6) ensures the result is real. *)

stBuildSymbolicSubRules[edges_, nodes_, kinPoint_List] := Module[
	{edgeMasses, nodeMasses, nExt, subRules, flattenSym,
	 edgesF, nodesF, stb},

	(* Flatten Subscript notation so _Symbol matches Subscript[m, k]'s flat
	   form and so the emitted LHS names (mm, mm2, MM, MM2, ...) line up with
	   the symbolic result, which homogeneizeKin2 always produces as flat
	   symbols.  Idempotent for callers that already flattened. *)
	stb = {
		Subscript[x_, args__Integer] :> Symbol["Global`" <> ToString[x] <> StringJoin[ToString /@ {args}]],
		Subscript[x_, i_] :> x[i]};
	edgesF = edges /. stb;
	nodesF = nodes /. stb;

	edgeMasses = edgesF[[All, 2]];
	nodeMasses = nodesF[[All, 2]];
	nExt = Length[nodesF];
	flattenSym[sym_] := Symbol[stMmaExprToPython[sym]];
	subRules = {};

	(* Feynman i\[CurlyEpsilon] prescription for the symbolic result evaluation.
	   Applied to kinematic substitutions before ginsh/N evaluation.
	   pySecDec and FIESTA handle their own i\[CurlyEpsilon] internally.
	     mm  \[RightArrow] mm_val  * (1 - i*\[CurlyEpsilon])    internal mass squared
	     MM  \[RightArrow] MM_val  * (1 + i*\[CurlyEpsilon])    external invariant (p^2)
	     sij \[RightArrow] sij_val * (1 + i*\[CurlyEpsilon])    Mandelstam invariants
	   \[CurlyEpsilon] = 10^-5.
	   The multiplicative prescription x \[RightArrow] x(1+i\[CurlyEpsilon]) corresponds to
	   approaching the branch cut from below for x < 0.  This matches
	   the analytic continuation convention used by HyperIntica/HyperInt,
	   where Log[x] for x < 0 picks the branch Log|x| \[Minus] i\[Pi] (below the
	   cut), consistent with the (-F)^omega representation. *)
	Module[{iep = 10^-5, trailingIndex, mmSym, MMSym},
	(* Digit suffix of a flat symbol name (None if no trailing digits). *)
	trailingIndex[sym_Symbol] := Module[{n, d},
		n = SymbolName[sym];
		d = StringCases[n, DigitCharacter .. ~~ EndOfString];
		If[d === {}, None, FromDigits[d[[1]]]]];
	(* Build the flat LHS symbol that homogeneizeKin2 produces:
	   idx === None -> bare "mm" / "MM"; otherwise "mm<idx>" / "MM<idx>".  *)
	mmSym[None] := mm;
	mmSym[idx_Integer] := ToExpression["mm" <> ToString[idx]];
	MMSym[None] := MM;
	MMSym[idx_Integer] := ToExpression["MM" <> ToString[idx]];

	(* Append a rule with the flat LHS.  Also append an indexed-form
	   alias mm[idx] -> val (resp. MM[idx] -> val) so the same subRules
	   set matches both the flat-kinematics convention produced by
	   homogeneizeKin2 (Subscript pathway) and the indexed-form
	   convention produced by STIntegrate graphs specified directly as
	   `m[1]` / `M[2]` heads (e.g. the 2-mass kite from library entry
	   e11|e|:123|1| and similar).  Otherwise the indexed form is left
	   untouched by `result /. subRules` and numerical eval fails. *)
	appendMassRule[sym_, rhs_] := (
		AppendTo[subRules, sym -> rhs];
		If[MatchQ[sym, _Symbol?(
				StringMatchQ[SymbolName[#], "mm" ~~ DigitCharacter ..] &)],
			Module[{idx = FromDigits[StringDrop[SymbolName[sym], 2]]},
				AppendTo[subRules, mm[idx] -> rhs];
				(* Real-argument form mm[1.] that HyperInt's FindRoots path
				   occasionally emits (N applied to the index via
				   homogeneizeKin2's numeric detection). *)
				AppendTo[subRules, mm[N[idx]] -> rhs]]];
		If[MatchQ[sym, _Symbol?(
				StringMatchQ[SymbolName[#], "MM" ~~ DigitCharacter ..] &)],
			Module[{idx = FromDigits[StringDrop[SymbolName[sym], 2]]},
				AppendTo[subRules, MM[idx] -> rhs];
				AppendTo[subRules, MM[N[idx]] -> rhs]]]);

	(* Internal masses: mm<idx> = m<idx>^2 * (1 - i*\[CurlyEpsilon]). *)
	Do[
		Which[
			mass === 0, Null,
			MatchQ[mass, _Symbol[_Integer]],
				Module[{pyParam, val, idx},
					pyParam = flattenSym[mass];
					idx = mass[[1]];
					val = pyParam /. kinPoint;
					If[NumericQ[val], appendMassRule[mmSym[idx], val^2 (1 - I iep)]]
				],
			MatchQ[mass, _Symbol],
				Module[{pyParam, val, idx},
					pyParam = flattenSym[mass];
					idx = trailingIndex[mass];
					val = pyParam /. kinPoint;
					If[NumericQ[val], appendMassRule[mmSym[idx], val^2 (1 - I iep)]]
				],
			True, Null
		],
		{mass, DeleteDuplicates[edgeMasses]}
	];

	(* External invariants: MM<idx> = p_<idx>^2 * (1 + i*\[CurlyEpsilon]).
	   Shared-mass legs (node-mass symbol that also appears on an internal
	   edge) are SKIPPED here: their p^2 = m^2 is already encoded via the
	   mm rule above, and emitting a second rule with the same LHS (`MM`)
	   would collide with any non-shared leg's rule and let the first rule
	   win (case: triangle with one shared `m` + one non-shared `M`, where
	   MM would spuriously take the `msq` value instead of `Msq`, skewing
	   the numerical comparison by a factor depending on mm - MM). *)
	Do[Module[{nm = nodeMasses[[i]], sharedSym},
		sharedSym = stIsSharedMassLeg[{edgesF, nodesF}, i];
		Which[
			nm === 0, Null,
			sharedSym =!= None, Null,  (* handled by mm rule *)
			MatchQ[nm, Sqrt[_Symbol]],
				Module[{sq = Expand[nm^2], val},
					val = sq /. kinPoint;
					If[NumericQ[val], AppendTo[subRules, sq -> val (1 + I iep)]]
				],
			MatchQ[nm, _Symbol[_Integer]],
				Module[{pyParam, val, idx},
					pyParam = Symbol[stMmaExprToPython[nm] <> "sq"];
					idx = nm[[1]];
					val = pyParam /. kinPoint;
					If[NumericQ[val], appendMassRule[MMSym[idx], val (1 + I iep)]]
				],
			MatchQ[nm, _Symbol],
				Module[{pyParam, val, idx},
					pyParam = Symbol[stMmaExprToPython[nm] <> "sq"];
					idx = trailingIndex[nm];
					val = pyParam /. kinPoint;
					If[NumericQ[val], appendMassRule[MMSym[idx], val (1 + I iep)]]
				],
			True, Null
		]],
		{i, nExt}
	];

	(* Mandelstams: sij * (1 + i*\[CurlyEpsilon]) *)
	Module[{mandelstamRules},
		mandelstamRules = Cases[kinPoint, (s_ -> v_) /; StringMatchQ[ToString[s], "s" ~~ DigitCharacter ..]
			:> (s -> v (1 + I iep))];
		subRules = Join[subRules, mandelstamRules];
	];

	]; (* end i\[CurlyEpsilon] Module *)

	(* Pass through any remaining kinPoint rules (for param names that match directly) *)
	subRules = Join[subRules, kinPoint];

	DeleteDuplicates[subRules]
];


(* ---- Helper: evaluate symbolic result at a numeric kinematic point (graph form) ----
   Delegates the substitution/Hlog/ginsh pipeline to stVerifyEvalSymbolicGeneric
   once the graph-specific mm/MM/sij aliases have been built.

   The symbolic result from SubTropica uses the Feynman branch (-F)^omega in the
   integrand (see normalization.tex Eq. 6), which implicitly includes the
   (-1)^{nu_tot} sign.  No additional sign correction is needed \[LongDash] the result
   can be compared directly to pySecDec/FIESTA output. *)
stEvalSymbolicAtPoint[result_, edges_, nodes_, kinPoint_, verbose_] :=
	stVerifyEvalSymbolicGeneric[result,
		stBuildSymbolicSubRules[edges, nodes, kinPoint],
		verbose];


(* ---- Helper: compare Laurent coefficients ---- *)

stCompareLaurent[{psdVal_, psdErr_}, ginshExpr_, maxOrder_Integer, tolerance_, verbose_] := Module[
	{psdNormal, ginshNormal, minOrder, comparisons, relErrs, pass},

	psdNormal = If[Head[psdVal] === SeriesData, Normal[psdVal], psdVal];
	ginshNormal = If[Head[ginshExpr] === SeriesData, Normal[ginshExpr], ginshExpr];

	(* Resolve delta symbols: delta[x_] = \[PlusMinus]1 (sign ambiguity from FindRoots).
	   Try all 2^n combinations and pick the one with smallest max relErr.
	   The winning substitution is appended to $stRootSubstitutions so it gets
	   persisted in the result record alongside the Wp/Wm root letters. *)
	Module[{deltas, nDeltas, bestNormal = ginshNormal, bestErr = Infinity, bestSigns},
		deltas = Union @ Cases[ginshNormal, delta[_], Infinity];
		nDeltas = Length[deltas];
		If[nDeltas > 0 && nDeltas <= 4,
			If[verbose, Print["[STVerify] Resolving ", nDeltas, " delta symbols: ", deltas]];
			Do[
				Module[{signs, trial, trialErr},
					signs = IntegerDigits[combo, 2, nDeltas] * 2 - 1;  (* {-1,1} combinations *)
					trial = ginshNormal /. Thread[deltas -> signs];
					(* Quick check: max relErr across all orders *)
					trialErr = Max @ Table[
						Module[{pC = Coefficient[psdNormal, eps, k], gC, pN, gN},
							gC = Coefficient[trial, eps, k];
							pN = N[pC]; gN = N[gC];
							Which[
								!NumericQ[gN] || !NumericQ[pN], Infinity,
								Abs[gN] > 10^-10, Abs[(pN - gN)/gN],
								Abs[pN] > 10^-10, Infinity,
								True, 0.]],
						{k, If[Head[psdVal] === SeriesData, psdVal[[4]], 0], maxOrder}];
					If[trialErr < bestErr,
						bestErr = trialErr;
						bestNormal = trial;
						bestSigns = signs;
						If[verbose, Print["[STVerify] delta signs ", signs, " -> relErr=", trialErr]]]],
				{combo, 0, 2^nDeltas - 1}];
			ginshNormal = bestNormal;
			(* Save resolved delta substitutions alongside Wp/Wm root letters *)
			$stRootSubstitutions = Join[$stRootSubstitutions,
				Thread[deltas -> bestSigns]];
			If[verbose, Print["[STVerify] Resolved deltas: ", Thread[deltas -> bestSigns]]];
		];
	];

	(* Determine Laurent order range from BOTH sides.  If symbolic has a
	   deeper pole than pySecDec (or vice versa), include those orders so the
	   discrepancy is flagged instead of silently ignored. *)
	minOrder = Min[
		If[Head[psdVal] === SeriesData, psdVal[[4]], 0],
		If[Head[ginshExpr] === SeriesData, ginshExpr[[4]], 0]];

	comparisons = {};
	relErrs = {};
	Module[{nonNumeric = False},

	Do[
		Module[{pC, gC, pN, gN, relErr},
			pC = Coefficient[psdNormal, eps, k];
			gC = Coefficient[ginshNormal, eps, k];
			pN = N[pC];
			gN = N[gC];

			If[verbose,
				Print["[STVerify] eps^(", k, "): psd = ", pN, "  symbolic = ", gN]
			];

			(* Guard against non-numeric coefficients (e.g. unresolved
			   Integrate`V[i.][j.] from NIntegrate leaks, or $Failed
			   propagating from ginsh). Without this, Abs[gN]>10^-10
			   returns an unevaluated inequality and Which leaves the
			   whole reason expression unevaluated. *)
			relErr = Which[
				!NumericQ[pN] || !NumericQ[gN], nonNumeric = True; Infinity,
				Abs[gN] > 10^-10, Abs[(pN - gN)/gN],
				Abs[pN] > 10^-10, Infinity,
				True, 0.
			];
			AppendTo[comparisons, <|"order" -> k, "psd" -> pN, "symbolic" -> gN, "relErr" -> relErr|>];
			AppendTo[relErrs, relErr];
		],
		{k, minOrder, maxOrder}
	];

	pass = AllTrue[relErrs, NumericQ[#] && # < tolerance &];
	If[nonNumeric, pass = False];

	If[verbose,
		Print["[STVerify] ", If[pass, "PASS", "FAIL"],
			" (max relErr = ", Max[relErrs], ", tolerance = ", tolerance, ")"]
	];

	<|
		"pass" -> pass,
		"reason" -> Which[
			pass, "verified",
			nonNumeric, "non-numeric coefficient (ginsh/NIntegrate leak)",
			True, "relative error exceeds tolerance"],
		"maxRelErr" -> If[Length[relErrs] > 0,
			Module[{numeric = Select[relErrs, NumericQ]},
				If[numeric === {}, Infinity, Max[numeric]]],
			0.],
		"relErr" -> relErrs,
		"coefficients" -> comparisons,
		"psd" -> {psdVal, psdErr},
		"symbolic" -> ginshExpr
	|>
	] (* close Module[nonNumeric] *)
];


(* ::Subsection::Closed:: *)
(*STComputeAndVerify: compute symbolic result + numerical verification pipeline*)


STComputeAndVerify::usage = "STComputeAndVerify[cni, opts] computes a Feynman integral \
symbolically via STIntegrate and verifies it numerically against pySecDec and/or FIESTA. \
Returns an Association with the result, verification status, timing, and a ready-to-save record.";

Options[STComputeAndVerify] = {
	"Dimension"          -> 4 - 2 eps,
	"Order"              -> 0,
	"Timeout"            -> 600,
	"Verify"             -> True,
	"Tolerance"          -> 10^-3,
	"MaxEval"            -> Automatic,
	"VerifyMethods"      -> {"pySecDec", "FIESTA"},
	"Integrator"         -> "Qmc",
	"MethodLR"           -> "Lungo",
	"NumberOfSubkernels" -> 1,
	"NumberOfLinks"      -> 4,
	"Verbose"            -> False,
	"LibraryPath"        -> "library-bundled"
};

STComputeAndVerify[cni_String, opts:OptionsPattern[]] := Module[
	{allFiles, entryFile, entry, edges, nodes, nEdges, nVerts, nLoops,
	 dim, order, timeout, methodLR, verbose, result, t0, elapsed,
	 status, byteCount, verif, record, config, timestamp},

	verbose = TrueQ[OptionValue["Verbose"]];
	dim = OptionValue["Dimension"];
	order = OptionValue["Order"];
	timeout = OptionValue["Timeout"];
	methodLR = OptionValue["MethodLR"];
	timestamp = DateString[{"Year", "-", "Month", "-", "Day", " ", "Hour", ":", "Minute", ":", "Second"}];

	(* 1. Locate entry *)
	allFiles = FileNames["entry.json", OptionValue["LibraryPath"], Infinity];
	entryFile = SelectFirst[allFiles, Module[{e},
		e = Quiet[Import[#, "RawJSON"]];
		e =!= $Failed && e["CNickelIndex"] === cni] &, None];

	If[entryFile === None,
		Return[<|"cni" -> cni, "status" -> "NOT_FOUND", "result" -> $Failed|>]
	];

	entry = Import[entryFile, "RawJSON"];
	edges = ToExpression[entry["edges"]];
	nodes = ToExpression[entry["nodes"]];
	nEdges = Length[edges];
	nVerts = Length[Union[Flatten[edges[[All, 1]]]]];
	nLoops = 1 + nEdges - nVerts;

	If[verbose, Print["[STComputeAndVerify] ", cni, " (L=", nLoops, " E=", nEdges,
		" legs=", Length[nodes], " method=", methodLR, ")"]];

	(* 2. Symbolic computation *)
	t0 = AbsoluteTime[];
	result = Quiet @ CheckAbort[
		TimeConstrained[
			STIntegrate[{edges, nodes},
				Dimension -> dim, Order -> order,
				CleanOutput -> True, FindRoots -> True,
				"MethodLR" -> methodLR,
				"KernelsAvailable" -> OptionValue["NumberOfSubkernels"]],
			timeout,
			$TimedOut],
		$ComputationFailed];
	elapsed = AbsoluteTime[] - t0;

	(* Classify outcome *)
	status = Which[
		result === $TimedOut, "TIMEOUT",
		result === $ComputationFailed, "FAILED",
		result === $Failed, "FAILED",
		Head[result] =!= SeriesData && !NumericQ[result], "NOT_SERIES",
		True, "OK"
	];

	If[verbose, Print["[STComputeAndVerify] status=", status, " elapsed=", stFormatTime[elapsed]]];

	byteCount = If[status === "OK", ByteCount[result], 0];

	(* 3. Build result record from $integrationResult *)
	record = If[status === "OK",
		Module[{cfg, nr, sf, nf},
			cfg = If[AssociationQ[$integrationResult],
				$integrationResult["uiResult"],
				<|"Dimension" -> ToString[dim, InputForm], "Order" -> order,
				  "propExponents" -> ConstantArray[1, nEdges],
				  "Substitutions" -> {}, "edges" -> edges, "nodes" -> nodes|>
			];
			nr = <|
				"resultCompressed" -> Compress[result],
				"resultTeX" -> Quiet @ Check[stResultToTeX[result][[1]], ""],
				"dimension" -> ToString[dim, InputForm],
				"epsOrder" -> ToString[order],
				"propExponents" -> Lookup[cfg, "propExponents", ConstantArray[1, nEdges]],
				"propagators" -> Lookup[cfg, "propagators", {}],
				"numerators" -> Lookup[cfg, "numerators", {}],
				"internalMasses" -> Lookup[cfg, "internalMasses", {}],
				"externalMasses" -> Lookup[cfg, "externalMasses", {}],
				"substitutions" -> Module[{s = Lookup[cfg, "Substitutions", {}]},
					If[StringQ[s], s, ToString[s, InputForm]]],
				"normalization" -> "Automatic",
				"stVersion" -> "SubTropica v" <> $SubTropicaVersion,
				"stCommand" -> Quiet @ Check[stBuildSTCommand[cfg], ""],
				"contributor" -> Quiet @ Check[stGetContributorField[], ""],
				"timestamp" -> timestamp,
				"byteCount" -> byteCount,
				"methodLR" -> methodLR,
				"recomputeBranch" -> "(-F)^eF"
			|>;
			(* FindRoots algebraic letters (structured metadata).  The legacy
			   `rootSubstitutions` InputForm string was dropped in v1.0.455;
			   consumers rebuild the Wm[i]/Wp[i] rule list from `minusRoot`
			   / `plusRoot` via stLoadRootSubs. *)
			Module[{algLetters = Quiet @ Check[stExtractAlgebraicLetters[], {}]},
				If[algLetters =!= {} && !FreeQ[result, (Wm | Wp)[_Integer]],
					nr["algebraicLetters"] = algLetters]];
			(* Symbol fields *)
			Quiet[Check[
				sf = stComputeSymbolFields[result];
				nr["symbolTeX"] = sf[[1]];
				nr["alphabet"] = sf[[2]];
				nr["symbolWeight"] = sf[[3]];
				nr["symbolTerms"] = sf[[4]],
				Null
			]];
			(* Normalized symbol *)
			Quiet[Check[
				nf = stComputeNormalizedSymbolFields[result];
				If[Length[nf] > 0,
					nr["normalizedSymbolTeX"] = nf["normalizedSymbolTeX"];
					nr["wDefinitions"] = nf["wDefinitions"];
					nr["normalizedAlphabet"] = nf["normalizedAlphabet"];
					nr["symbolScale"] = nf["symbolScale"];
					nr["normalizedSymbolTerms"] = nf["normalizedSymbolTerms"]],
				Null
			]];
			(* Leg order *)
			nr["legOrder"] = Quiet[Check[stComputeLegOrder[nr["stCommand"]], {}]];
			nr
		],
		Missing["NotComputed"]
	];

	(* 4. Numerical verification.
	   Always attempt every configured method; let STVerify + stMakeVerificationPoint
	   decide per-backend whether a point exists (Euclidean-region logic).  The old
	   pre-emptive shared-mass skip was removed: shared-mass configurations are
	   handled correctly by pySecDec / FIESTA / AMFlow (v1.0.297) and feyntrop
	   already skips itself internally. *)
	verif = <|"status" -> "not_attempted"|>;
	If[status === "OK" && TrueQ[OptionValue["Verify"]],
		Module[{methods, maxeval, tol},
			methods = OptionValue["VerifyMethods"];
			maxeval = OptionValue["MaxEval"];
			tol = OptionValue["Tolerance"];

			Do[
				Module[{rv, tv = AbsoluteTime[], dt, relErr},
					rv = Check[
						STVerify[{edges, nodes}, result,
							"MaxEval" -> maxeval,
							"Tolerance" -> tol,
							"Verbose" -> verbose,
							"Method" -> method,
							"Integrator" -> OptionValue["Integrator"],
							"NumberOfSubkernels" -> OptionValue["NumberOfSubkernels"],
							"NumberOfLinks" -> OptionValue["NumberOfLinks"]
						],
						<|"pass" -> False, "reason" -> "exception"|>
					];
					dt = AbsoluteTime[] - tv;
					relErr = Lookup[rv, "maxRelErr", 99.];
					If[!NumberQ[relErr], relErr = 99.];

					verif[method] = <|"relErr" -> relErr, "time" -> dt, "pass" -> rv["pass"]|>;

					If[rv["pass"] === True,
						verif["status"] = Switch[verif["status"],
							"not_attempted", "pass_" <> ToLowerCase[method],
							s_String /; StringStartsQ[s, "pass_"], "pass_both",
							_, "pass_" <> ToLowerCase[method]
						];
						If[verbose, Print["[STComputeAndVerify] ", method, ": PASS relErr=", relErr, " t=", Round[dt, 0.1], "s"]],
						If[verbose, Print["[STComputeAndVerify] ", method, ": FAIL reason=", Lookup[rv, "reason", "?"], " relErr=", relErr]]
					];

					(* Run all methods \[LongDash] do not short-circuit *)
				],
				{method, methods}
			];

			(* If still not_attempted after loop, mark as failed *)
			If[verif["status"] === "not_attempted", verif["status"] = "failed"]
		]
	];

	(* Record verification status and persist any resolved delta signs as
	   `deltaSign` on the structured algebraicLetters entries.  The legacy
	   rootSubstitutions string dual-write was removed in v1.0.455. *)
	If[AssociationQ[record],
		record["verificationStatus"] = verif["status"];
		If[KeyExistsQ[record, "algebraicLetters"] &&
		   ListQ[record["algebraicLetters"]] && $stRootSubstitutions =!= {},
			Module[{deltaRules, updated},
				deltaRules = Cases[$stRootSubstitutions,
					Rule[delta[i_Integer], s_Integer] :> {i, s}];
				updated = Map[
					Function[rec, Module[{idx = Lookup[rec, "index", 0],
					                      matched},
						matched = SelectFirst[deltaRules, #[[1]] === idx &, Null];
						If[matched === Null, rec, Append[rec, "deltaSign" -> matched[[2]]]]]],
					record["algebraicLetters"]];
				record["algebraicLetters"] = updated]]
	];

	(* 5. Return summary *)
	<|
		"cni"          -> cni,
		"status"       -> status,
		"result"       -> result,
		"byteCount"    -> byteCount,
		"elapsed"      -> elapsed,
		"methodLR"     -> methodLR,
		"verification" -> verif,
		"entryFile"    -> entryFile,
		"record"       -> record
	|>
];


(* ::Subsection::Closed:: *)
(*STNIntegrate: numerical Feynman integral evaluation via sector decomposition*)


STNIntegrate::nofiesta = "FIESTA not found. Set $FIESTAPath or ConfigureSubTropica[FIESTAPath->\"...\"].";
STNIntegrate::noamflow = "AMFlow not found at `1`. Set $AMFlowPath or ConfigureSubTropica[AMFlowPath->\"...\"].";
STNIntegrate::nofeyntrop = "feyntrop binary not found at `1`. Build it with `make` in $FeyntropPath or set $FeyntropPath / ConfigureSubTropica[FeyntropPath->\"...\"].";
STNIntegrate::feyntropfail = "feyntrop returned non-JSON output or an error. Raw stdout/stderr: `1`";
STNIntegrate::badmethod = "Unknown method `1`. Expected \"pySecDec\", \"FIESTA\", \"AMFlow\", or \"feyntrop\".";
STNIntegrate::nokin = "\"KinematicPoint\" required. Expected numeric values for kinematic invariants.";
STNIntegrate::scaleless = "Scaleless integral detected (all internal masses zero, all external on-shell massless, `1` external legs). Returning 0 (dim-reg value).";
STNIntegrate::badsub = "Unrecognized left-hand side in Substitutions: `1`. Expected m, m[i], Subscript[m,i], mi, mm[i], mmi (internal mass); M, M[i], Subscript[M,i], Mi, MM[i], MMi (external mass); s[i,j,...], Subscript[s,i,j,...], or s<digits> (Mandelstam, up to 5 indices); or Dot/Times of p[i] factors (scalar product).";
STNIntegrate::nonrule = "Entry in Substitutions is not a rule: `1`. Expected a List of Rule or RuleDelayed objects, or Automatic.";
STNIntegrate::conflictsubs = "Both \"Substitutions\" and \"KinematicPoint\" were supplied. The legacy \"KinematicPoint\" name is kept as an alias; passing both is ambiguous. Using \"Substitutions\".";
STNIntegrate::deprKinPoint = "The \"KinematicPoint\" option is deprecated; use \"Substitutions\" instead. The legacy name is still honoured but will be removed in a future release. (This notice fires once per kernel session.)";
STNIntegrate::incomplete = "Substitutions do not fix all kinematic symbols. Unfixed: `1`. Add rules for these symbols, or set \"Substitutions\" -> Automatic.";
STNIntegrate::conflictrules = "Conflicting substitution rules after canonicalisation: `1` was supplied more than once with different values.";

(* ---- Substitutions normaliser ----

   User-facing: a List of rules (or Automatic).  Accepted left-hand sides are
   liberal; see the ::badsub message.  Values are assumed to be MASSES (not
   mass-squareds) unless the symbol name ends in "sq" or starts with "MM"
   (SubTropica's F-polynomial convention where MM/MMi = mass-squared).

   Canonical output: a List of rules keyed by FLAT symbols (no Subscripts),
   matching the lookup convention used by every STNIntegrate backend
   (stMmaExprToPython + "sq" for external mass-squareds, stMmaExprToPython
   for internal masses and Mandelstams).  Scalar-product rules are kept in
   Dot form and emitted as separate rules; individual backends translate
   them against GenerateKinematics.
*)

(* Recognise the "flat digit" notations m1, M12, mm1, MM12, s12, s123, p1.
   Returns the canonical flat symbol name (as a String) plus a kind tag
   ("intmass", "extmass", "extmasssq", "mandelstam", "momentum"), or
   $Failed if the input isn't one of those forms. *)
stParseFlatSubName[name_String] := Module[{digitPart, indices, nDigits},
    Which[
        (* "Msq" / "M1sq" / "MMsq" / "MM1sq": external mass-squared, explicit. *)
        StringMatchQ[name, ("M" | "MM") ~~ DigitCharacter... ~~ "sq"],
            digitPart = StringDrop[StringDrop[name, If[StringStartsQ[name, "MM"], 2, 1]], -2];
            If[digitPart === "",
                {"Msq", "extmasssq"},
                {"M" <> digitPart <> "sq", "extmasssq"}
            ],
        (* "MM1" -> "M1sq", "MM" -> "Msq": MM is mass-squared in SubTropica's F-polynomial. *)
        StringMatchQ[name, "MM" ~~ DigitCharacter..],
            digitPart = StringDrop[name, 2];
            {"M" <> digitPart <> "sq", "extmasssq"},
        name === "MM",
            {"Msq", "extmasssq"},
        (* "M1", "M12", ...; "M" alone is the bare external-mass scale. *)
        StringMatchQ[name, "M" ~~ DigitCharacter..],
            {name, "extmass"},
        name === "M",
            {"M", "extmass"},
        (* "mm1", "mm12", "mm" alone. *)
        StringMatchQ[name, "mm" ~~ DigitCharacter..],
            digitPart = StringDrop[name, 2];
            {"m" <> digitPart, "intmass"},
        name === "mm",
            {"m", "intmass"},
        (* "m1", "m12", "m" alone. *)
        StringMatchQ[name, "m" ~~ DigitCharacter..],
            {name, "intmass"},
        name === "m",
            {"m", "intmass"},
        (* "s12", "s123", ..., with 2..5 digit indices. *)
        StringMatchQ[name, "s" ~~ DigitCharacter..],
            digitPart = StringDrop[name, 1];
            nDigits = StringLength[digitPart];
            If[nDigits >= 2 && nDigits <= 5,
                {name, "mandelstam"},
                $Failed
            ],
        (* "p1", "p2", "q1", "k1", "l1", ...: momentum symbols (used
           inside Dot/Times).  v1.0.425: extend to q, k, l (in addition
           to p) so flat-form subs like {q1.q1 -> -1} \[LongDash] which arise
           after the first normalization pass flattens q[1] -> q1 \[LongDash]
           survive the second pass through stParseFlatSubName
           (called from stNormalizeSubLHS's bare-symbol branch). *)
        StringMatchQ[name, ("p" | "q" | "k" | "l") ~~ DigitCharacter..],
            {name, "momentum"},
        True,
            $Failed
    ]
];

(* Normalise a single substitution LHS to a canonical form.
   Returns {canonicalLhs, kind} where `kind` is one of
   "intmass" | "extmass" | "extmasssq" | "mandelstam" | "momentum" |
   "dotproduct" | "bare" | "explicit",
   or $Failed if unrecognised. *)
stNormalizeSubLHS[lhs_] := Module[{parsed, parts, inner},
    Which[
        (* Explicit power: Subscript[M,i]^2, M[i]^2, Mi^2, ... \[LongDash] external mass squared. *)
        MatchQ[lhs, Power[_, 2]],
            Module[{base = lhs[[1]], baseN},
                baseN = stNormalizeSubLHS[base];
                If[baseN === $Failed, $Failed,
                    Which[
                        baseN[[2]] === "extmass",
                            {Symbol[SymbolName[baseN[[1]]] <> "sq"], "extmasssq"},
                        baseN[[2]] === "intmass",
                            {Symbol[SymbolName[baseN[[1]]] <> "sq"], "intmasssq"},
                        True, $Failed
                    ]
                ]
            ],

        (* Subscript[head, indices...] *)
        MatchQ[lhs, Subscript[_Symbol, __Integer]],
            Module[{h = lhs[[1]], args = List @@ Rest[lhs]},
                Which[
                    h === m, {Symbol["m" <> StringJoin[ToString /@ args]], "intmass"},
                    h === M, {Symbol["M" <> StringJoin[ToString /@ args]], "extmass"},
                    h === s && Length[args] >= 2 && Length[args] <= 5,
                        {Symbol["s" <> StringJoin[ToString /@ args]], "mandelstam"},
                    h === p && Length[args] == 1,
                        {Symbol["p" <> ToString[args[[1]]]], "momentum"},
                    True, {lhs, "explicit"}  (* unknown head: keep verbatim *)
                ]
            ],

        (* Function form: head[indices...] *)
        MatchQ[lhs, _Symbol[__Integer]],
            Module[{h = Head[lhs], args = List @@ lhs, hName},
                hName = SymbolName[h];
                Which[
                    hName === "m",
                        {Symbol["m" <> StringJoin[ToString /@ args]], "intmass"},
                    hName === "mm",
                        {Symbol["m" <> StringJoin[ToString /@ args]], "intmass"},
                    hName === "M",
                        {Symbol["M" <> StringJoin[ToString /@ args]], "extmass"},
                    hName === "MM",
                        {Symbol["M" <> StringJoin[ToString /@ args] <> "sq"], "extmasssq"},
                    hName === "s" && Length[args] >= 2 && Length[args] <= 5,
                        {Symbol["s" <> StringJoin[ToString /@ args]], "mandelstam"},
                    (* Momentum letters: p, q, k (external) and l (loop).
                       v1.0.422: accept all of them so user-supplied subs
                       like q[1].q[1] -> -1 or k[1].k[2] -> 5 normalize
                       correctly.  Previously only p[i] was recognized,
                       which rejected all the q[i]-form conventions used
                       in SubTropica's paper examples. *)
                    MemberQ[{"p", "q", "k", "l"}, hName] && Length[args] == 1,
                        {Symbol[hName <> ToString[args[[1]]]], "momentum"},
                    True, {lhs, "explicit"}
                ]
            ],

        (* Bare Symbol: try flat-name parsing; else keep. *)
        MatchQ[lhs, _Symbol],
            (parsed = stParseFlatSubName[SymbolName[lhs]];
             If[parsed === $Failed,
                {lhs, "bare"},
                {Symbol[parsed[[1]]], parsed[[2]]}
             ]),

        (* CenterDot: scalar product. *)
        MatchQ[lhs, CenterDot[__]],
            parts = stNormalizeSubLHS /@ (List @@ lhs);
            If[MemberQ[parts, $Failed] || !AllTrue[parts, #[[2]] === "momentum" &],
                $Failed,
                {Dot @@ Sort[parts[[All, 1]]], "dotproduct"}
            ],

        (* Dot: scalar product. *)
        MatchQ[lhs, Dot[__]],
            parts = stNormalizeSubLHS /@ (List @@ lhs);
            If[MemberQ[parts, $Failed] || !AllTrue[parts, #[[2]] === "momentum" &],
                $Failed,
                {Dot @@ Sort[parts[[All, 1]]], "dotproduct"}
            ],

        (* Times: treat as commutative scalar product if every factor is a
           momentum symbol.  Otherwise fail \[LongDash] a generic Times product on the
           LHS of a substitution is probably a user error. *)
        MatchQ[lhs, _Times],
            parts = stNormalizeSubLHS /@ (List @@ lhs);
            If[MemberQ[parts, $Failed] || !AllTrue[parts, #[[2]] === "momentum" &],
                $Failed,
                {Dot @@ Sort[parts[[All, 1]]], "dotproduct"}
            ],

        True, $Failed
    ]
];

(* Normalise a full list of substitution rules.  Returns a canonical List of
   rules, or $Failed on the first unrecognised LHS.  Wrapped in Catch so
   Throw[$Failed] inside the Do propagates past the final expression. *)
stNormalizeSubstitutions[Automatic] := Automatic;
stNormalizeSubstitutions[subs_List] := Catch[Module[
    {normalized = <||>, order = {}, rule, lhs, rhs, entry, lhsN, kind, canonLhs},
    Do[
        rule = subs[[k]];
        If[!MatchQ[rule, (Rule | RuleDelayed)[_, _]],
            Message[STNIntegrate::nonrule, rule]; Throw[$Failed]
        ];
        lhs = rule[[1]];
        rhs = rule[[2]];
        entry = stNormalizeSubLHS[lhs];
        If[entry === $Failed,
            Message[STNIntegrate::badsub, lhs]; Throw[$Failed]
        ];
        {lhsN, kind} = entry;
        canonLhs = lhsN;
        If[KeyExistsQ[normalized, canonLhs] && normalized[canonLhs] =!= rhs,
            Message[STNIntegrate::conflictrules, canonLhs]; Throw[$Failed]
        ];
        If[!KeyExistsQ[normalized, canonLhs], AppendTo[order, canonLhs]];
        normalized[canonLhs] = rhs,
        {k, Length[subs]}
    ];
    (# -> normalized[#]) & /@ order
]];
stNormalizeSubstitutions[other_] := (Message[STNIntegrate::nonrule, other]; $Failed);

(* One-shot deprecation flag for the "KinematicPoint" alias.  Shared across
   parallel subkernels when they exist so the user does not see the message
   N times during a parallel run. *)
If[!ValueQ[$stKinPtDeprecationShown], $stKinPtDeprecationShown = False];
If[Length[Kernels[]] > 0,
    Quiet[SetSharedVariable[$stKinPtDeprecationShown], {SetSharedVariable::nosub}]];

(* Option-reader that honours both "Substitutions" (preferred) and legacy
   "KinematicPoint".  Returns Automatic | a normalised List of rules | $Failed.
   `opts` is the options list as produced by {OptionsPattern[]} at the caller,
   i.e. already a List of Rule objects.

   Fires STNIntegrate::deprKinPoint once per session when the user supplies
   only the legacy name; suppressed when Substitutions is also present
   (conflictsubs takes precedence) or when the two values are identical
   (harmless echo). *)
stReadSubstitutions[opts_List] := Module[{newVal, oldVal},
    newVal = "Substitutions"  /. opts /. "Substitutions"  -> $stSubsNotSet;
    oldVal = "KinematicPoint" /. opts /. "KinematicPoint" -> $stSubsNotSet;
    Which[
        newVal === $stSubsNotSet && oldVal === $stSubsNotSet, Automatic,
        newVal === $stSubsNotSet,
            (* Legacy name only -> fire once-per-session deprecation. *)
            If[!TrueQ[$stKinPtDeprecationShown],
                Message[STNIntegrate::deprKinPoint];
                $stKinPtDeprecationShown = True];
            stNormalizeSubstitutions[oldVal],
        oldVal === $stSubsNotSet,  stNormalizeSubstitutions[newVal],
        newVal === oldVal,
            (* Both supplied but identical (dispatcher re-emit).  Silent. *)
            stNormalizeSubstitutions[newVal],
        True,
            (* Both supplied with different values.  Warn and use Substitutions. *)
            Message[STNIntegrate::conflictsubs];
            stNormalizeSubstitutions[newVal]
    ]
];

(* Backend-handler helper: pick the kinematic-subs rule list from a raw
   options sequence, preferring non-empty "Substitutions", else falling
   back to "KinematicPoint".  Used by the four backend bottom-half functions
   (stPySecDecFromQuadruple, stFIESTAEvaluate/run, stAMFlowEvaluate,
   stFeyntropEvaluate) which receive opts via the three-arg `opts___` head.

   Semantics: direct callers may pass either option name; the dispatcher
   (graph-form STNIntegrate) passes both with "KinematicPoint" holding the
   resolved rules and "Substitutions" -> {} (to avoid mis-applying kinematic
   rules to STToPySecDec's integrand-level "Substitutions" semantic).  The
   "prefer non-empty Substitutions" rule means:
     - Direct user passing Substitutions -> {...}:  takes precedence
     - Dispatcher path Substitutions -> {}, KinPt -> {rules}: falls through
       to KinematicPoint
     - Only Substitutions (possibly {}):  use it
     - Only KinematicPoint:  use it
     - Neither:  {} *)
stPickKinPointOpts[optsList_List] := With[{
    sVal = "Substitutions"  /. optsList /. "Substitutions"  -> Missing["NotSupplied"],
    kVal = "KinematicPoint" /. optsList /. "KinematicPoint" -> Missing["NotSupplied"]},
    Which[
        ListQ[sVal] && sVal =!= {}, sVal,
        ListQ[kVal],                kVal,
        ListQ[sVal],                sVal,
        True,                       {}]];

(* Flatten a user-supplied canonical rule into backend form by appending the
   legacy "sq" suffix for external masses where needed.  Inputs: canonRules
   as produced by stNormalizeSubstitutions (flat symbols, kind-tagged).
   Outputs: a plain List of rules that existing backend kinLookup machinery
   can consume.  For each "extmass" rule `M<i> -> v` the output includes
   `M<i>sq -> v^2` so FIESTA/pySecDec backends (which look up "Msq") still
   work; the "M<i>" rule is also kept so backends that read mass directly can. *)
stExpandSubsForBackends[canonRules_List] := Module[{out = {}, rule, lhs, rhs, name},
    Do[
        rule = canonRules[[k]];
        lhs = rule[[1]];
        rhs = rule[[2]];
        If[MatchQ[lhs, _Symbol],
            name = SymbolName[lhs];
            Which[
                (* External mass M / M<i>: derive squared. *)
                StringMatchQ[name, "M" ~~ (EndOfString | DigitCharacter..)],
                    AppendTo[out, lhs -> rhs];
                    AppendTo[out, Symbol[name <> "sq"] -> rhs^2],
                (* External squared M<i>sq: keep; derive unsquared too. *)
                StringMatchQ[name, "M" ~~ DigitCharacter... ~~ "sq"],
                    AppendTo[out, lhs -> rhs];
                    AppendTo[out, Symbol[StringDrop[name, -2]] -> Sqrt[rhs]],
                (* Everything else: keep as-is. *)
                True, AppendTo[out, rule]
            ],
            (* Non-Symbol LHS (e.g. Dot[...]): keep. *)
            AppendTo[out, rule]
        ],
        {k, Length[canonRules]}
    ];
    DeleteDuplicates[out]
];

(* Completeness check.  `exprs` is a list of expressions (propagators, U/F
   polynomials, integrand, ...) that must be fully numeric after substitutions.
   `allowedFree` is the list of symbols permitted to remain symbolic
   (integration variables, loop momenta, Feynman parameters, eps, ...).
   Returns the sorted list of unfixed symbols (empty list = complete). *)
stFreeSymbolsAfterSubs[exprs_, canonRules_List, allowedFree_List] := Module[
    {residual, subRules, cand, blocked},
    subRules = canonRules;
    residual = exprs //. subRules;
    blocked = Join[allowedFree,
        {eps, Pi, E, I, EulerGamma, Infinity, ComplexInfinity, DirectedInfinity,
         SeriesData, List, Plus, Times, Power, Log, Hlog, zeta, mzv, Rational,
         Complex, Sqrt, True, False, Null}];
    cand = Union @ Cases[residual,
        sym_Symbol /; !NumericQ[sym] && !MemberQ[blocked, sym],
        {0, Infinity}];
    cand
];

(* Resolve "Substitutions" for Feynman-graph input: expand Automatic via
   stMakeVerificationPoint (Euclidean preferred), normalise user-supplied
   rules, then expand to backend-legacy form.  Returns {canonRules, expandedRules}
   or $Failed. *)
stResolveGraphSubstitutions[subs_, {edges_List, nodes_List}, opts:OptionsPattern[]] :=
Module[{resolved, expanded, seed},
    resolved = subs;
    If[resolved === Automatic,
        seed = OptionValue[{"Seed" -> 0}, {opts}, "Seed"];
        seed = If[NumericQ[seed], seed, Hash[{edges, nodes}, "CRC32"]];
        resolved = stNormalizeSubstitutions[
            stMakeVerificationPoint[edges, nodes, seed]]
    ];
    If[resolved === $Failed, Return[$Failed]];
    expanded = stExpandSubsForBackends[resolved];
    {resolved, expanded}
];

(* For generic Euler integrals (no graph): Automatic picks random prime-ratio
   values for every free symbol in `coeffs`.  `exprs` is the list of
   expressions whose symbols must be fixed (usually {integrand, prefactor}). *)
stResolveEulerSubstitutions[subs_, coeffs_List, exprs_] := Module[
    {resolved, primes, seed, pickPrime, rules, sym, name, idx, primeIdx = 0},
    resolved = subs;
    If[resolved === Automatic,
        primes = Prime /@ Range[PrimePi[100]];
        seed = Hash[{coeffs, exprs}, "CRC32"];
        pickPrime[] := Module[{i},
            i = Mod[BitXor[seed, Hash[primeIdx, "CRC32"]], Length[primes]] + 1;
            primeIdx++; primes[[i]]];
        rules = {};
        Do[
            sym = coeffs[[k]];
            Module[{p1 = pickPrime[], p2 = pickPrime[]},
                While[p1 === p2, p2 = pickPrime[]];
                AppendTo[rules, sym -> p1/p2]],
            {k, Length[coeffs]}];
        resolved = stNormalizeSubstitutions[rules]
    ];
    If[resolved === $Failed, Return[$Failed]];
    {resolved, stExpandSubsForBackends[resolved]}
];

(* Sufficient condition for a Feynman integral to be scaleless (and hence
   identically zero in dim-reg).  All internal propagators massless + all
   external on-shell massless + nExt <= 3 forces every Mandelstam s_{ij}
   to vanish (by p_i^2=0 and momentum conservation), leaving no kinematic
   scale.  pySecDec rejects such integrands at the sector-decomposition
   stage with a build-time error; we short-circuit to 0 instead.
   For nExt >= 4 the Mandelstams can be independent and non-zero even with
   massless legs, so we don't claim scaleless there. *)
stIsScalelessGraph[edges_List, nodes_List] := Module[
	{intMasses = edges[[All, 2]],
	 extMasses = nodes[[All, 2]]},
	AllTrue[intMasses, # === 0 || # === 0. &] &&
		AllTrue[extMasses, # === 0 || # === 0. &] &&
		Length[nodes] <= 3
];

STNIntegrate::baddim   = "Invalid Dimension `1` for method `2`. Expected D0 - 2*eps with D0 numeric and the expression linear in eps.";
STNIntegrate::dimslope = "Method `2` requires Dimension of the form D0 - 2*eps. Got `1` with coefficient `3` on eps (expected -2).";
STNIntegrate::dimint   = "Method `2` requires an integer D0 in Dimension = D0 - 2*eps. Got `1` with D0 = `3`.";
STNIntegrate::dimrat   = "Method `2` requires a rational D0 in Dimension = D0 - 2*eps. Got `1` with D0 = `3`.";

(* Validate the Dimension option for a given numerical backend.
   Returns <|"D0" -> D0, "slope" -> slope, "expr" -> dim|> on success
   (the "slope" key is omitted for pySecDec, since dim may be nonlinear
   there), or $Failed with a Message issued on failure.

   - pySecDec:  pass-through.  The expression is handed to pySecDec's
     sympy parser as a string, so arbitrary symbolic forms are fine.
   - FIESTA / AMFlow / feyntrop:  dim must be exactly D0 - 2*eps with D0
     an integer (FIESTA, feyntrop) or rational (AMFlow).  Those backends
     hard-wire the -2*eps slope internally; see FIESTA's d0 option,
     AMFlow's SetAMFOptions["D0" -> ...], and feyntrop's integer
     "dimension" JSON field. *)
stParseDimension[dim_, method_String] := Module[
	{D0, residual, slope, degree},
	D0 = dim /. eps -> 0;
	If[method === "pySecDec",
		Return[<|"D0" -> D0, "expr" -> dim|>]
	];
	residual = dim - D0;
	If[!PolynomialQ[residual, eps],
		Message[STNIntegrate::baddim, dim, method]; Return[$Failed]];
	degree = Exponent[residual, eps];
	(* degree is -Infinity when residual === 0 (dim is just D0); accept
	   that and let the slope check below reject it as slope = 0. *)
	If[NumericQ[degree] && degree > 1,
		Message[STNIntegrate::baddim, dim, method]; Return[$Failed]];
	slope = -Coefficient[residual, eps, 1];
	If[slope =!= 2,
		Message[STNIntegrate::dimslope, dim, method, -slope];
		Return[$Failed]];
	Switch[method,
		"FIESTA" | "feyntrop",
			If[!IntegerQ[D0],
				Message[STNIntegrate::dimint, dim, method, D0];
				Return[$Failed]],
		"AMFlow",
			If[!(IntegerQ[D0] || Head[D0] === Rational),
				Message[STNIntegrate::dimrat, dim, method, D0];
				Return[$Failed]]
	];
	<|"D0" -> D0, "slope" -> slope, "expr" -> dim|>
];

Options[STNIntegrate] = {
	"Method"             -> "pySecDec",
	"Order"              -> 0,
	"Accuracy"           -> 1*^-4,
	"MaxEval"            -> 10^7,
	"KinematicPoint"     -> {},           (* legacy alias of "Substitutions"; honored for back-compat *)
	"Substitutions"      -> Automatic,    (* preferred name; Automatic = auto-generated Euclidean / Minkowski+i\[CurlyEpsilon] point *)
	"NumSamples"         -> 1,            (* >1: re-evaluate at that many independent prime-ratio kinematic points; returned as "samples" *)
	"Seed"               -> Automatic,    (* integer: override the default Hash[{edges,nodes}]-based seed; Automatic = graph-hash *)
	"Verbose"            -> False,
	"ContourDeformation" -> True,
	"CacheDirectory"     -> Automatic,
	"Normalization"      -> Automatic,
	"Dimension"          -> 4 - 2 eps,
	"Exponents"          -> Automatic,
	"LoopMomenta"        -> Automatic,
	"Integrator"         -> Automatic,
	(* FIESTA-specific *)
	"NumberOfSubkernels" -> 4,
	"NumberOfLinks"      -> 4,
	"Strategy"           -> "S2",
	"ComplexMode"        -> Automatic,
	(* AMFlow-specific *)
	"AMFlowIBPReducer"   -> "FiniteFlow+LiteRed",
	"AMFlowPrecision"    -> 16,
	"AMFlowFamily"       -> Automatic,
	"AMFlowNThread"      -> 4,
	(* feyntrop-specific *)
	"FeyntropLambda"     -> 0,            (* contour deformation param; 0 = Euclidean. Nonzero for physical-region integrals. *)
	"FeyntropSeed"       -> 0,
	"FeyntropNThread"    -> Automatic,    (* OMP_NUM_THREADS env var; Automatic = all cores *)
	"MaxTime"            -> Automatic     (* unified wall-clock cap; Automatic in this layer is a pass-through (the verify layer resolves it).  Infinity disables every timer in the chain (Mma TimeConstrained, Python signal.alarm, subprocess.run timeout). *)
};

(* --- Form 1: graph topology {edges, nodes} --- *)
STNIntegrate[g:{_List, _List}, opts:OptionsPattern[]] := Module[
	{method, verbose, dim, t0, result, edges = g[[1]], nodes = g[[2]],
	 subsRaw, subsCanonical, subsExpanded, optsResolved, optsList},
	method = OptionValue["Method"];
	verbose = TrueQ[OptionValue["Verbose"]];
	dim = OptionValue["Dimension"];
	If[stParseDimension[dim, method] === $Failed, Return[$Failed]];
	t0 = AbsoluteTime[];

	(* Flatten Subscript notation in edges, nodes, and substitutions so
	   that Subscript[m, 1] matches the flat symbol m1 in user-supplied
	   kinematic rules.  Same rules as STIntegrate's local subscriptsToBrackets. *)
	Module[{stb = {
		Subscript[x_, args__Integer] :> Symbol["Global`" <> ToString[x] <> StringJoin[ToString /@ {args}]],
		Subscript[x_, i_] :> x[i]}},
	edges = edges /. stb;
	nodes = nodes /. stb;
	optsList = {opts} /. stb];

	(* Short-circuit scaleless integrals (zero in dim-reg).  pySecDec/FIESTA
	   would error out at sector decomposition; here we return 0 cleanly. *)
	If[stIsScalelessGraph[edges, nodes],
		Message[STNIntegrate::scaleless, Length[nodes]];
		Module[{scalelessSubs = stReadSubstitutions[optsList]},
			If[scalelessSubs === Automatic || scalelessSubs === $Failed,
				scalelessSubs = {}];
			Return[<|
				"Value" -> 0, "Error" -> 0,
				"Method" -> method, "Timing" -> AbsoluteTime[] - t0,
				"Substitutions"  -> scalelessSubs,
				"KinematicPoint" -> scalelessSubs,
				"Scaleless" -> True,
				"Note" -> "All internal/external masses zero with " <>
					ToString[Length[nodes]] <>
					" external legs - scaleless in dim-reg; not numerically integrated."|>]]];

	(* Multi-sample dispatch: when NumSamples > 1 AND the user didn't pin
	   the kinematic point, re-invoke self numSamples times with different
	   Seed values and return the list of per-sample associations. *)
	Module[{numSamples, userSeed, subsOpt, kinOpt, isAuto},
		numSamples = OptionValue["NumSamples"];
		userSeed   = OptionValue["Seed"];
		subsOpt    = OptionValue["Substitutions"];
		kinOpt     = OptionValue["KinematicPoint"];
		isAuto     = (subsOpt === Automatic) &&
			(kinOpt === {} || kinOpt === Automatic);
		If[IntegerQ[numSamples] && numSamples > 1 && isAuto,
			Module[{baseSeed, samples},
				baseSeed = If[NumericQ[userSeed], userSeed,
					Hash[{edges, nodes}, "CRC32"]];
				samples = Table[
					If[verbose, Print["[STNIntegrate] ---- sample ", k,
						" / ", numSamples, " ----"]];
					STNIntegrate[{edges, nodes}, Sequence @@ Join[
						DeleteCases[optsList,
							Rule[("NumSamples" | "Seed"), _]],
						{"NumSamples" -> 1, "Seed" -> baseSeed + 1009 k}]],
					{k, 0, numSamples - 1}];
				Return[<|
					"numSamples" -> numSamples,
					"samples"    -> samples,
					"Method"     -> method,
					"Timing"     -> AbsoluteTime[] - t0|>]]]];

	(* Resolve Substitutions / KinematicPoint to canonical + backend-expanded form.
	   Automatic -> auto-generated verification point (Euclidean preferred). *)
	subsRaw = stReadSubstitutions[optsList];
	If[subsRaw === $Failed, Return[$Failed]];
	{subsCanonical, subsExpanded} = stResolveGraphSubstitutions[subsRaw, {edges, nodes},
		"Seed" -> OptionValue["Seed"]];
	If[subsCanonical === $Failed, Return[$Failed]];
	If[verbose,
		Print["[STNIntegrate] Substitutions (canonical): ", subsCanonical];
		Print["[STNIntegrate] Dimension: ", dim];
	];

	(* Override the options list so every backend sees the expanded form
	   under "KinematicPoint".  STToPySecDec uses its own "Substitutions"
	   option for integrand-level replacements (distinct semantics), so we
	   pass an empty list there to avoid mis-applying kinematic rules to
	   the Python-side integrand.  "Dimension" is injected explicitly from
	   the resolved value so every backend sees it even when the user didn't
	   pass one (fallback to Options[STNIntegrate]'s default 4 - 2 eps). *)
	optsResolved = Join[
		{"KinematicPoint" -> subsExpanded, "Substitutions" -> {}, "Dimension" -> dim},
		DeleteCases[optsList,
			Rule[("KinematicPoint" | "Substitutions" | "Dimension"), _]]];

	(* Pass the Subscript-flattened graph to backends. *)
	Module[{gFlat = {edges, nodes}},
	result = Switch[method,
		"pySecDec",
			stNIntegratePySecDec[gFlat, Sequence @@ FilterRules[optsResolved, Options[STNIntegrate]]],
		"FIESTA",
			stNIntegrateFIESTA[gFlat, Sequence @@ FilterRules[optsResolved, Options[STNIntegrate]]],
		"AMFlow",
			stNIntegrateAMFlow[gFlat, Sequence @@ FilterRules[optsResolved, Options[STNIntegrate]]],
		"feyntrop",
			stNIntegrateFeyntrop[gFlat, Sequence @@ FilterRules[optsResolved, Options[STNIntegrate]]],
		_,
			Message[STNIntegrate::badmethod, method]; Return[$Failed]
	]];

	If[result === $Failed, Return[$Failed]];

	(* Wrap raw {value, error} in an Association *)
	If[MatchQ[result, {_, _}],
		<|
			"Value"     -> result[[1]],
			"Error"     -> result[[2]],
			"Method"    -> method,
			"Integrator" -> If[OptionValue["Integrator"] === Automatic,
				Switch[method,
					"pySecDec", "Qmc",
					"FIESTA",   "vegasCuba",
					"AMFlow",   OptionValue["AMFlowIBPReducer"],
					"feyntrop", "tropicalMC",
					_,          "unknown"],
				OptionValue["Integrator"]],
			"KinematicPoint" -> subsCanonical,
			"Substitutions"  -> subsCanonical,
			"Timing"    -> AbsoluteTime[] - t0
		|>,
		(* Already an Association *)
		result
	]
];

(* --- Form 2: propagator list --- *)
STNIntegrate[props_List, opts:OptionsPattern[]] /;
    !MatchQ[props, {_List, _List}] &&
    !MatchQ[props, {_, _, _List, _}] &&
    !MatchQ[props, {_, _, _List, _, _String}] := Module[
	{method, dim, subsRaw, subsCanonical, subsExpanded, optsResolved, freeSyms},
	method = OptionValue["Method"];
	dim = OptionValue["Dimension"];
	If[stParseDimension[dim, method] === $Failed, Return[$Failed]];

	(* Resolve Substitutions.  Propagator-list form has no graph, so Automatic
	   falls back to "pick random prime ratios over every free symbol in the
	   propagators + masses" via stResolveEulerSubstitutions. *)
	subsRaw = stReadSubstitutions[{opts}];
	If[subsRaw === $Failed, Return[$Failed]];
	freeSyms = Union @ Cases[props, _Symbol, {0, Infinity}] //
		DeleteCases[_?(MemberQ[{eps, Pi, E, I, EulerGamma, Infinity}, #]&)];
	{subsCanonical, subsExpanded} = stResolveEulerSubstitutions[subsRaw, freeSyms, props];
	If[subsCanonical === $Failed, Return[$Failed]];

	optsResolved = Join[
		{"KinematicPoint" -> subsExpanded, "Substitutions" -> {}, "Dimension" -> dim},
		DeleteCases[{opts},
			Rule[("KinematicPoint" | "Substitutions" | "Dimension"), _]]];

	Switch[method,
		"pySecDec",
			Module[{t0 = AbsoluteTime[], result},
				result = STToPySecDec[props,
					FilterRules[optsResolved, Options[STToPySecDec]]];
				If[result === $Failed, Return[$Failed]];
				<|"Value" -> result[[1]], "Error" -> result[[2]],
				  "Method" -> "pySecDec", "Timing" -> AbsoluteTime[] - t0,
				  "Substitutions" -> subsCanonical|>
			],
		"FIESTA",
			stNIntegrateFIESTA[props, Sequence @@ FilterRules[optsResolved, Options[STNIntegrate]]],
		"AMFlow",
			stNIntegrateAMFlow[props, Sequence @@ FilterRules[optsResolved, Options[STNIntegrate]]],
		"feyntrop",
			stNIntegrateFeyntrop[props, Sequence @@ FilterRules[optsResolved, Options[STNIntegrate]]],
		_,
			Message[STNIntegrate::badmethod, method]; $Failed
	]
];

STNIntegrate::noneuler = "Method `1` does not support generic Euler/quadruple integrand input. Use \"pySecDec\" for that (only Feynman graph / propagator-list input is supported by FIESTA, AMFlow, and feyntrop).";
STNIntegrate::badlimits = "Integration bounds for variable `1` are {`2`, `3`}. Bounds must be 0, 1, or Infinity (Feynman-parameter convention).";
STNIntegrate::badinput = "Input format not recognized. STNIntegrate accepts: {edges, nodes} | propagator list | CNI string | {pref, integrand, xvars, coeffs} | integrand with NIntegrate-style limits or bare symbols.";

(* --- Form 4: pre-built Euler integrand quadruple {pref, integrand, xvars, coeffs} --- *)
STNIntegrate[{pref_, integrand_, xvars_List, coeffs_}, opts:OptionsPattern[]] /;
    VectorQ[xvars, (Head[#] === Symbol) &] && !MatchQ[pref, _List] :=
    stNIntegrateEuler[{pref, integrand, xvars, coeffs}, opts];

(* --- Form 4b: 5-tuple with checkpoint ID --- *)
STNIntegrate[{pref_, integrand_, xvars_List, coeffs_, checkpoint_String}, opts:OptionsPattern[]] /;
    VectorQ[xvars, (Head[#] === Symbol) &] :=
    stNIntegrateEuler[{pref, integrand, xvars, coeffs, checkpoint}, opts];

(* --- Form 5: Mathematica-style integration limits
       STNIntegrate[integrand, {x,0,1}, {y,0,Infinity}, ..., opts]
       Form 6: bare symbols
       STNIntegrate[integrand, x, y, ..., opts]  -- defaults to {0, Infinity}.  *)
STNIntegrate[integrand_, args__] /;
    !MatchQ[integrand, _List | _String] &&
    ({args}[[1]] === Automatic || MatchQ[{args}[[1]], _Symbol | {_Symbol, _, _}]) :=
Module[{argList = {args}, limSpecs = {}, opts = {}, xvars, coeffs,
        limSpec, validLimits = {0, 1, Infinity}, quadruple},
    Do[
        Which[
            MatchQ[argList[[i]], {_Symbol, _, _}],
                AppendTo[limSpecs, argList[[i]]],
            MatchQ[argList[[i]], _Symbol],
                AppendTo[limSpecs, {argList[[i]], 0, Infinity}],
            True,
                opts = Join[opts, argList[[i ;;]]]; Break[]
        ],
        {i, Length[argList]}
    ];

    If[limSpecs === {},
        Message[STNIntegrate::badinput]; Return[$Failed]];

    Do[
        limSpec = limSpecs[[j]];
        If[!MemberQ[validLimits, limSpec[[2]]] || !MemberQ[validLimits, limSpec[[3]]],
            Message[STNIntegrate::badlimits,
                limSpec[[1]], limSpec[[2]], limSpec[[3]]];
            Return[$Failed]
        ],
        {j, Length[limSpecs]}
    ];

    xvars = limSpecs[[All, 1]];
    (* Split xi-free factors (e.g. Gamma[n eps]) into pref so pySecDec's FORM
       step never sees them.  Then extract kinematic coefficients from the
       xi-dependent part only, excluding built-in constants and eps. *)
    Module[{factors, pref5, intPart},
        factors = If[Head[integrand] === Times, List @@ integrand, {integrand}];
        pref5   = Times @@ Select[factors,  FreeQ[#, Alternatives @@ xvars] &];
        intPart = Times @@ Select[factors, !FreeQ[#, Alternatives @@ xvars] &];
        coeffs = Complement[
            Union @ Cases[intPart, _Symbol, {0, Infinity}],
            xvars, {eps, E, Pi, I, EulerGamma, Infinity, ComplexInfinity}] // Sort;
        quadruple = {pref5, intPart, xvars, coeffs}
    ];

    stNIntegrateEuler[quadruple, Sequence @@ opts, "IntegrationLimits" -> limSpecs]
];

(* Dispatcher for Euler-integral forms.  Only pySecDec supports them;
   other backends error out cleanly. *)
stNIntegrateEuler[quadrupleOrFive_List, opts___] := Module[
    {method, t0 = AbsoluteTime[], result,
     pref, integrand, xvars, coeffs, checkpointId = None,
     subsRaw, subsCanonical, subsExpanded, optsResolved, limits},
    method = "Method" /. {opts} /. "Method" -> "pySecDec";

    If[!MemberQ[{"pySecDec"}, method],
        Message[STNIntegrate::noneuler, method]; Return[$Failed]
    ];

    (* Unpack quadruple vs 5-tuple *)
    Which[
        Length[quadrupleOrFive] == 4,
            {pref, integrand, xvars, coeffs} = quadrupleOrFive,
        Length[quadrupleOrFive] == 5,
            {pref, integrand, xvars, coeffs, checkpointId} = quadrupleOrFive,
        True,
            Message[STNIntegrate::badinput]; Return[$Failed]
    ];

    (* Pull IntegrationLimits directly from the options list (it's not a
       registered STNIntegrate Option).  Default is [0,Inf) for each variable.
       stPySecDecFromQuadruple selects decomposition_method based on limits:
         all [0,1]    -> geometric_no_primary  (pySecDec default)
         all [0,Inf)  -> geometric_infinity_no_primary  (native support) *)
    limits = "IntegrationLimits" /. {opts} /.
        "IntegrationLimits" -> ({#, 0, Infinity} & /@ xvars);

    (* Resolve Substitutions: Automatic -> prime-ratio point over `coeffs`. *)
    subsRaw = stReadSubstitutions[{opts}];
    If[subsRaw === $Failed, Return[$Failed]];
    {subsCanonical, subsExpanded} =
        stResolveEulerSubstitutions[subsRaw, coeffs, {integrand, pref}];
    If[subsCanonical === $Failed, Return[$Failed]];

    optsResolved = Join[
        {"KinematicPoint" -> subsExpanded, "Substitutions" -> {}},
        DeleteCases[{opts},
            Rule[("KinematicPoint" | "Substitutions" | "IntegrationLimits"), _]]];

    result = stPySecDecFromQuadruple[
        {pref, integrand, xvars, coeffs}, limits, checkpointId,
        Sequence @@ FilterRules[optsResolved, Options[STToPySecDec]]];

    If[result === $Failed, Return[$Failed]];

    <|
        "Value"           -> result[[1]],
        "Error"           -> result[[2]],
        "Method"          -> "pySecDec",
        "Integrator"      -> "Qmc",
        "Substitutions"   -> subsCanonical,
        "IntegrationLimits" -> limits,
        "Timing"          -> AbsoluteTime[] - t0
    |>
];

(* --- Form 3: CNI string (library lookup) --- *)
STNIntegrate[cni_String, opts:OptionsPattern[]] := Module[
	{allFiles, entryFile, entry, edges, nodes},
	allFiles = FileNames["entry.json", "library-bundled", Infinity];
	entryFile = SelectFirst[allFiles, Module[{e},
		e = Quiet[Import[#, "RawJSON"]];
		e =!= $Failed && e["CNickelIndex"] === cni
	] &, None];

	If[entryFile === None,
		(* Try library-local *)
		allFiles = FileNames["entry.json", "library-local", Infinity];
		entryFile = SelectFirst[allFiles, Module[{e},
			e = Quiet[Import[#, "RawJSON"]];
			e =!= $Failed && e["CNickelIndex"] === cni
		] &, None];
	];

	If[entryFile === None,
		Message[STNIntegrate::nokin, "No entry found for CNI: " <> cni];
		Return[$Failed]
	];

	entry = Import[entryFile, "RawJSON"];
	edges = ToExpression[entry["edges"]];
	nodes = ToExpression[entry["nodes"]];
	STNIntegrate[{edges, nodes}, opts]
];


(* ---- pySecDec backend ---- *)

STNIntegrate::eulerbounds = "Mixed integration limits are not supported: all limits must be either {var,0,1} (uses geometric_no_primary) or {var,0,Infinity} (uses geometric_infinity_no_primary). Got `1`.";
STNIntegrate::psdquadbuild = "pySecDec make_package generation failed (exit `1`): `2`";
STNIntegrate::psdquadeval  = "pySecDec evaluation failed (exit `1`): `2`";

(* Implementation of the pySecDec make_package path for generic Euler-type
   integrands {pref, integrand, xvars, coeffs} with substitutions for `coeffs`.

   Strategy:
     1. Factor the integrand: integrand = num / Product[factor_i^e_i].
     2. polynomials_to_decompose = [(factor_i, -e_i)] for each non-trivial factor.
     3. remainder_expression = num                  (treated as polynomial of unit exponent).
     4. prefactor = stMmaExprToPython[pref]          (may carry eps-dependent Gamma).
     5. real_parameters = stringified `coeffs`; values from canonical kinPoint.
     6. Cache: pySecDec/euler_<hash>/.

   Restrictions in v1:
     - Integration domain must be [0, 1]^n (pySecDec native).  [0, Infinity]
       support requires a Jacobian transform; flagged for follow-up.
     - All `coeffs` must be REAL parameters (no complex_parameters).
*)

(* Decompose integrand into pySecDec form:
     integrand = remainder * Product[ base_i ^ exp_i ]
   where each Power factor with a NEGATIVE OR SYMBOLIC exponent goes into
   polys_to_decompose (so pySecDec sector-decomposes it), and the rest is
   collected into remainder_expression.
*)
stPySecDecFactorIntegrand[integrand_, xvars_List, coeffs_List] := Module[
    {expanded, factors, polys, rem, factor, base, exp, isDecomposable},
    (* Apart over xvars to expose Power factors clearly; fall back if Apart
       errors. *)
    expanded = Quiet @ Check[Apart[integrand], integrand];

    factors = If[Head[expanded] === Times, List @@ expanded, {expanded}];

    polys = {};
    rem   = 1;
    Do[
        factor = factors[[k]];
        Which[
            (* Pure power factor with possibly symbolic exponent. *)
            MatchQ[factor, Power[_, _]],
                base = factor[[1]];
                exp  = factor[[2]];
                isDecomposable =
                    !(NumericQ[exp] && IntegerQ[exp] && exp >= 0);
                (* Non-negative integer exponents = polynomial; multiply
                   into the remainder. Everything else (negative, fractional,
                   or eps-dependent) must be sector-decomposed. *)
                If[isDecomposable,
                    AppendTo[polys, {base, exp}],
                    rem = rem * factor
                ],
            (* Plain numerical / symbolic factor: into remainder. *)
            True,
                rem = rem * factor
        ],
        {k, Length[factors]}
    ];

    (* Pure-polynomial integrand with no decomposable Power factors: insert
       a dummy regulator (xvars[[1]])^eps to give pySecDec something to
       expand around. *)
    If[polys === {},
        Message[STNIntegrate::psdpurelyfinite];
        polys = {{xvars[[1]], eps}}  (* = x_1^eps; \[CurlyEpsilon]->0 limit recovers integrand *)
    ];

    {polys, Expand[rem]}
];

STNIntegrate::psdpurelyfinite = "Integrand has no Power factors with negative or symbolic exponents. pySecDec needs at least one decomposable factor; injecting a dummy regulator x_1^eps. Set Order high enough to read off the value at eps^0.";

stBuildPySecDecQuadScript[pkgDir_String, pkgName_String, intVarStrs_List,
    polysDecomposeStrs_List, remainderStr_String, prefactorStr_String,
    realParamStrs_List, kinValues_List, orderInt_Integer,
    epsrel_Real, maxeval_Integer, verbose_, integrator_String,
    decompositionMethod_String:"geometric_no_primary",
    maxTimeSec_:3600] := Module[
    {polyListPyStr, intVarsPyStr, realParamsPyStr, kinValuesPyStr, evalBlock,
     intVarPyList, polyPyList, realParamPyList, kinValPyList, timeoutStr},

    (* See stBuildPySecDecScript for the Python None / int convention. *)
    timeoutStr = If[maxTimeSec === Infinity || !NumericQ[maxTimeSec] ||
			N[maxTimeSec] >= 2^31 - 1,
		"None", ToString[Round[maxTimeSec]]];

    (* Each xvar / coeff name as a Python string, e.g. "'x'" *)
    intVarsPyStr   = "[" <> StringRiffle["'" <> # <> "'" & /@ intVarStrs, ", "] <> "]";
    realParamsPyStr = "[" <> StringRiffle["'" <> # <> "'" & /@ realParamStrs, ", "] <> "]";
    (* pySecDec expects each entry as a string '(<polynomial>)**(<exponent>)'
       (an SymPy-parseable Pow), not a (poly, exp) tuple. *)
    polyListPyStr  = "[" <>
        StringRiffle[("'((" <> #[[1]] <> ")**(" <> #[[2]] <> "))'") & /@ polysDecomposeStrs, ", "] <>
        "]";
    kinValuesPyStr = ExportString[kinValues, "JSON"];

    evalBlock = Switch[integrator,
        "Vegas",
"        if VERBOSE: print('pySecDec: evaluating (Vegas)...', file=sys.stderr, flush=True)
        from pySecDec.integral_interface import IntegralLibrary, series_to_mathematica
        lib = IntegralLibrary(SO_PATH)
        lib.use_Vegas(epsrel=EPSREL, maxeval=MAXEVAL)
        _, _, result = lib(real_parameters=KIN_VALUES)
        val, err = series_to_mathematica(result)
        print('PYSECDEC_RESULT:' + json.dumps({'value': val, 'error': err}))",

        _,  (* default: Qmc *)
"        if VERBOSE: print('pySecDec: evaluating (QMC)...', file=sys.stderr, flush=True)
        from pySecDec.integral_interface import IntegralLibrary, series_to_mathematica
        lib = IntegralLibrary(SO_PATH)
        lib.use_Qmc(epsrel=EPSREL, maxeval=MAXEVAL, lattice_candidates=11,
                    verbosity=1 if VERBOSE else 0)
        _, _, result = lib(real_parameters=KIN_VALUES)
        val, err = series_to_mathematica(result)
        print('PYSECDEC_RESULT:' + json.dumps({'value': val, 'error': err}))"
    ];

    "#!/usr/bin/env python3
import os, sys, json, subprocess, signal, traceback, shutil, glob

# Prefer brew GNU make >= 4 over macOS /usr/bin/make (GNU 3.81, broken).
for _d in ('/opt/homebrew/opt/make/libexec/gnubin',
           '/usr/local/opt/make/libexec/gnubin'):
    if os.path.isdir(_d):
        os.environ['PATH'] = _d + os.pathsep + os.environ.get('PATH', '')
        break

PKG_DIR  = r'" <> pkgDir <> "'
PKG_NAME = '" <> pkgName <> "'
EPSREL   = " <> ToString[CForm[N[epsrel]]] <> "
MAXEVAL  = " <> ToString[maxeval] <> "
VERBOSE  = " <> If[verbose, "True", "False"] <> "
KIN_VALUES = " <> kinValuesPyStr <> "
REAL_PARAMS = " <> realParamsPyStr <> "
TIMEOUT  = " <> timeoutStr <> "  # seconds; None = no cap (MaxTime->Infinity)

def _timeout_handler(signum, frame):
    print('EVAL_TIMEOUT', file=sys.stderr); sys.exit(3)

# IMPORTANT: must guard make_package() in `if __name__ == '__main__':`
# because it spawns multiprocessing workers that re-execute the script.
def main():
    if TIMEOUT is not None:
        signal.signal(signal.SIGALRM, _timeout_handler)
        signal.alarm(TIMEOUT)

    pkg_root = os.path.join(PKG_DIR, PKG_NAME)
    integral_name = PKG_NAME + '_integral'
    integral_dir  = os.path.join(pkg_root, integral_name)
    top_disteval  = os.path.join(pkg_root, 'disteval')
    top_json      = os.path.join(top_disteval, PKG_NAME + '.json')
    int_disteval  = os.path.join(integral_dir, 'disteval')
    int_distsrc   = os.path.join(integral_dir, 'distsrc')
    int_so        = os.path.join(int_disteval, integral_name + '.so')
    builtin_so    = os.path.join(top_disteval, 'builtin.so')
    int_so_top    = os.path.join(top_disteval, integral_name + '.so')

    # Step 1: code generation (idempotent \[LongDash] skip if disteval json already exists).
    if not os.path.exists(top_json):
        if VERBOSE: print('pySecDec: generating make_package code...',
                           file=sys.stderr, flush=True)
        os.makedirs(PKG_DIR, exist_ok=True)
        os.chdir(PKG_DIR)
        if os.path.exists(pkg_root): shutil.rmtree(pkg_root)
        try:
            from pySecDec import make_package
        except ImportError as e:
            print(f'IMPORT_ERROR: {e}', file=sys.stderr); sys.exit(2)
        try:
            make_package(
                name                              = PKG_NAME,
                integration_variables             = " <> intVarsPyStr <> ",
                regulators                        = ['eps'],
                requested_orders                  = [" <> ToString[orderInt] <> "],
                polynomials_to_decompose          = " <> polyListPyStr <> ",
                remainder_expression              = '" <> remainderStr <> "',
                prefactor                         = '" <> prefactorStr <> "',
                real_parameters                   = REAL_PARAMS,
                complex_parameters                = [],
                contour_deformation_polynomial    = None,
                decomposition_method              = '" <> decompositionMethod <> "',
            )
        except Exception as e:
            print(f'BUILD_ERROR: {e}', file=sys.stderr)
            traceback.print_exc(file=sys.stderr); sys.exit(2)

    # Step 2: compile distsrc -> .so manually.  System make on macOS is GNU
    # 3.81 with a pattern-specificity bug that drops the disteval -I flag,
    # so we don't trust `make disteval` here \[LongDash] invoke c++ ourselves.
    if not os.path.exists(int_so_top):
        import pySecDecContrib
        contrib_dir = pySecDecContrib.dirname
        disteval_inc = os.path.join(contrib_dir, 'disteval')

        # Step 2a: trigger FORM via `make codegen/sector<N>.done` for every
        # sector header.  make_package writes only the scaffolding; FORM
        # populates src/ and distsrc/ on demand.
        sector_hs = sorted(glob.glob(os.path.join(integral_dir, 'codegen', 'sector*.h')))
        if not sector_hs:
            print(f'NO_SECTOR_HEADERS in codegen/', file=sys.stderr); sys.exit(2)
        if VERBOSE: print(f'pySecDec: running FORM on {len(sector_hs)} sectors...',
                           file=sys.stderr, flush=True)
        for h in sector_hs:
            sname = os.path.basename(h)[:-len('.h')]  # 'sector1'
            r = subprocess.run(['make', f'codegen/{sname}.done'],
                cwd=integral_dir, capture_output=True, text=True, timeout=TIMEOUT)
            if r.returncode != 0:
                print(f'FORM step failed for {sname}:', file=sys.stderr)
                print(r.stderr[-1000:], file=sys.stderr); sys.exit(2)

        if VERBOSE: print('pySecDec: compiling distsrc sectors...',
                           file=sys.stderr, flush=True)
        sector_cpps = sorted(glob.glob(os.path.join(int_distsrc, 'sector_*.cpp')))
        if not sector_cpps:
            print(f'NO_SECTORS in {int_distsrc} after FORM', file=sys.stderr); sys.exit(2)
        for f in sector_cpps:
            o = f.replace('.cpp', '.o')
            r = subprocess.run(['c++', '-c', '-fPIC', '-std=c++17', '-O3',
                '-funsafe-math-optimizations', '-I', disteval_inc,
                '-o', o, f],
                capture_output=True, text=True, timeout=TIMEOUT)
            if r.returncode != 0:
                print(f'sector compile failed: {f}', file=sys.stderr)
                print(r.stderr[-1000:], file=sys.stderr); sys.exit(2)
        # Link the integral .so.
        os.makedirs(int_disteval, exist_ok=True)
        sector_objs = [f.replace('.cpp', '.o') for f in sector_cpps]
        r = subprocess.run(['c++', '-shared', '-o', int_so] + sector_objs,
            capture_output=True, text=True, timeout=120)
        if r.returncode != 0:
            print('integral .so link failed:', file=sys.stderr)
            print(r.stderr[-1000:], file=sys.stderr); sys.exit(2)

        # Compile + link builtin.so.
        builtin_o = os.path.join(int_distsrc, 'builtin.o')
        r = subprocess.run(['c++', '-c', '-fPIC', '-std=c++17', '-O3',
            '-funsafe-math-optimizations', '-I', disteval_inc, '-o', builtin_o,
            os.path.join(disteval_inc, 'builtin.cpp')],
            capture_output=True, text=True, timeout=120)
        if r.returncode != 0:
            print('builtin compile failed:', file=sys.stderr)
            print(r.stderr[-1000:], file=sys.stderr); sys.exit(2)
        builtin_so_int = os.path.join(int_disteval, 'builtin.so')
        r = subprocess.run(['c++', '-shared', '-o', builtin_so_int, builtin_o],
            capture_output=True, text=True, timeout=120)
        if r.returncode != 0:
            print('builtin .so link failed:', file=sys.stderr)
            print(r.stderr[-1000:], file=sys.stderr); sys.exit(2)

        # Copy / link .so up to top-level disteval/.
        os.makedirs(top_disteval, exist_ok=True)
        shutil.copy2(int_so, int_so_top)
        shutil.copy2(builtin_so_int, builtin_so)
        # Top-level integral.json (if not already symlinked).
        int_json_src = os.path.join(int_disteval, integral_name + '.json')
        int_json_dst = os.path.join(top_disteval, integral_name + '.json')
        if os.path.exists(int_json_src) and not os.path.exists(int_json_dst):
            shutil.copy2(int_json_src, int_json_dst)

    # Step 3: evaluate via DistevalLibrary.
    if VERBOSE: print('pySecDec: evaluating (Disteval)...',
                       file=sys.stderr, flush=True)
    from pySecDec.integral_interface import DistevalLibrary
    lib = DistevalLibrary(top_json)
    parameters = dict(zip(REAL_PARAMS, KIN_VALUES))
    result_str = lib(parameters=parameters,
                     epsrel=EPSREL, epsabs=1e-10, format='mathematica')
    print('PYSECDEC_RESULT:' + json.dumps({'value_raw': result_str}))

if __name__ == '__main__':
    main()
"
];

(* Parse the Disteval `format='mathematica'` string into {valueSeries, errorSeries}.
   The actual format from pySecDec 1.6 looks like (whitespace-irrelevant):
       {
         (
           +eps^<k>*(+<rv>*10^<rexp>+<iv>*10^<iexp>*I)
           +eps^<k>*(+<re>*10^<rexp>+<ie>*10^<iexp>*I)*plusminus
           ... (one value+plusminus pair per \[CurlyEpsilon] order)
         )
       }
   The "*plusminus" suffix tags the error term for that order; without it,
   the term is the central value. *)
stParseDistevalMathematica[s_String, requestedOrder_Integer] := Module[
    {clean, chunks, valCoeffs = <||>, errCoeffs = <||>, minOrder, maxOrder,
     parseChunk, parsed, isErr, k, rv},
    (* Strip braces/newlines.  Keep `*` and `+` and `^` raw. *)
    clean = StringReplace[s, {"\n" -> " ", "\r" -> " ",
        "{" -> " ", "}" -> " "}];
    (* Split on "+eps^" boundaries. The first split chunk is empty/garbage; the
       rest are individual terms. *)
    chunks = StringSplit[clean, "+eps^"];

    parseChunk[chunk_String] := Module[{m, kStr, rest},
        (* Match: "<k>*(+<rv>*10^<rexp><isign><iv>*10^<iexp>*I)" optionally
           followed by "*plusminus". *)
        m = StringCases[chunk,
            RegularExpression["^\\s*([\\-\\+]?\\d+)\\s*\\*\\s*\\(\\s*([\\-\\+]?\\d+\\.\\d+)\\s*\\*\\s*10\\^([\\-\\+]?\\d+)\\s*([\\-\\+])\\s*([\\-\\+]?\\d+\\.\\d+)\\s*\\*\\s*10\\^([\\-\\+]?\\d+)\\s*\\*\\s*I\\s*\\)"]
              :> {"$1", "$2", "$3", "$4", "$5", "$6"}];
        If[m === {}, Return[None]];
        Module[{kk, rv0, rexp, isign, iv0, iexp, isErr0},
            {kk, rv0, rexp, isign, iv0, iexp} = m[[1]];
            isErr0 = StringContainsQ[chunk, "plusminus"];
            {ToExpression[kk],
             ToExpression[rv0] * 10^ToExpression[rexp] +
                If[isign === "-", -1, 1] *
                ToExpression[iv0] * 10^ToExpression[iexp] * I,
             isErr0}
        ]
    ];

    Do[parsed = parseChunk[chunk];
       If[parsed =!= None,
           {k, rv, isErr} = parsed;
           If[isErr,
               errCoeffs[k] = Abs[Re[rv]] + Abs[Im[rv]] I,
               valCoeffs[k] = rv]],
       {chunk, chunks}];

    If[valCoeffs === <||>, Return[$Failed]];

    minOrder = Min[Keys[valCoeffs]];
    maxOrder = requestedOrder;
    If[maxOrder < minOrder, maxOrder = Max[Keys[valCoeffs]]];

    Module[{vL, eL},
        vL = Table[Lookup[valCoeffs, kk, 0], {kk, minOrder, maxOrder}];
        eL = Table[Lookup[errCoeffs, kk, 0], {kk, minOrder, maxOrder}];
        {SeriesData[eps, 0, vL, minOrder, maxOrder + 1, 1],
         SeriesData[eps, 0, eL, minOrder, maxOrder + 1, 1]}
    ]
];

(* Main quadruple-form integrator.  Builds the Python script via
   stBuildPySecDecQuadScript, runs it, parses Disteval output. *)
stPySecDecFromQuadruple[{pref_, integrand_, xvars_List, coeffs_},
    limits_List, checkpointId_, opts___] := Module[
    {order, verbose, kinPoint, integrator, maxeval, accuracy, cacheDir,
     maxTime,
     decompositionMethod,
     polysDecompose, remainder, prefactorStr, remainderStr,
     polyDecomposeStrs, intVarStrs, realParamStrs, kinLookup, kinValues,
     hashHex, pkgDir, pkgName, scriptPath, script, proc, stderr, stdout,
     resultLine, jsonResult, valRaw, parsed},

    order      = "Order"          /. {opts} /. "Order"          -> 0;
    verbose    = TrueQ["Verbose"  /. {opts} /. "Verbose"        -> False];
    kinPoint   = stPickKinPointOpts[{opts}];
    integrator = "Integrator"     /. {opts} /. "Integrator"     -> Automatic;
    If[integrator === Automatic, integrator = "Qmc"];
    maxeval    = "MaxEval"        /. {opts} /. "MaxEval"        -> 10^7;
    accuracy   = "Accuracy"       /. {opts} /. "Accuracy"       -> 1*^-4;
    cacheDir   = "CacheDirectory" /. {opts} /. "CacheDirectory" -> Automatic;
    (* Same resolution as stPySecDecEvaluate: Automatic -> 3600 s legacy
       default; Infinity -> Python None (no cap); explicit number wins. *)
    maxTime    = "MaxTime"        /. {opts} /. "MaxTime"        -> Automatic;
    If[maxTime === Automatic, maxTime = 3600];
    If[cacheDir === Automatic,
        cacheDir = FileNameJoin[{$SubTropicaInstallDir, "pySecDec"}]];

    (* Choose pySecDec decomposition method based on integration limits:
         all [0,1]   -> geometric_no_primary          (standard Feynman parameter domain)
         all [0,Inf) -> geometric_infinity_no_primary (Lee-Pomeransky / projective domain)
       Mixed limits are not yet supported. *)
    Which[
        AllTrue[limits, MatchQ[#, {_, 0, 1}] &],
            decompositionMethod = "geometric_no_primary",
        AllTrue[limits, MatchQ[#, {_, 0, Infinity}] &],
            decompositionMethod = "geometric_infinity_no_primary",
        True,
            Message[STNIntegrate::eulerbounds, limits]; Return[$Failed]
    ];

    {polysDecompose, remainder} =
        stPySecDecFactorIntegrand[integrand, xvars, coeffs];

    prefactorStr = stMmaExprToPython[pref];
    remainderStr = stMmaExprToPython[Expand[remainder]];
    polyDecomposeStrs = ({stMmaExprToPython[Expand[#[[1]]]],
                          stMmaExprToPython[#[[2]]]}) & /@ polysDecompose;
    intVarStrs    = stMmaExprToPython /@ xvars;
    realParamStrs = stMmaExprToPython /@ coeffs;

    kinLookup = Association[(ToString[#[[1]]] -> #[[2]]) & /@ kinPoint];
    Module[{missing},
        kinValues = Lookup[kinLookup, #, $Failed] & /@ realParamStrs;
        missing = Pick[realParamStrs, # === $Failed || !NumericQ[#] & /@ kinValues];
        If[Length[missing] > 0,
            Message[STToPySecDec::missingkin, StringRiffle[missing, ", "]];
            Return[$Failed]];
        kinValues = N /@ kinValues];

    hashHex = IntegerString[Hash[{prefactorStr, remainderStr,
        polyDecomposeStrs, intVarStrs, realParamStrs, order,
        decompositionMethod}, "SHA256"], 16, 12];
    pkgName = "psd_quad";
    pkgDir  = FileNameJoin[{cacheDir, "euler_" <> hashHex}];
    Quiet[CreateDirectory[pkgDir, CreateIntermediateDirectories -> True]];

    script = stBuildPySecDecQuadScript[pkgDir, pkgName, intVarStrs,
        polyDecomposeStrs, remainderStr, prefactorStr, realParamStrs,
        kinValues, order, N[accuracy], maxeval, verbose, integrator,
        decompositionMethod, maxTime];

    scriptPath = FileNameJoin[{pkgDir, "eval.py"}];
    Export[scriptPath, script, "Text"];

    If[verbose,
        Print["[STNIntegrate/Quad] cache: euler_", hashHex];
        Print["[STNIntegrate/Quad] integration_variables: ", intVarStrs];
        Print["[STNIntegrate/Quad] polys_to_decompose: ", polyDecomposeStrs];
        Print["[STNIntegrate/Quad] remainder: ", remainderStr];
        Print["[STNIntegrate/Quad] prefactor: ", prefactorStr];
        Print["[STNIntegrate/Quad] real_parameters: ", realParamStrs, " = ", kinValues]];

    proc = RunProcess[{$PythonCommand, scriptPath}];
    stderr = proc["StandardError"];
    stdout = proc["StandardOutput"];

    If[verbose && StringLength[stderr] > 0,
        Print["[STNIntegrate/Quad] stderr tail: ", StringTake[stderr, UpTo[800]]]];

    If[proc["ExitCode"] =!= 0,
        Message[STNIntegrate::psdquadeval, proc["ExitCode"],
            StringTake[stderr, UpTo[600]]];
        Return[$Failed]];

    resultLine = SelectFirst[StringSplit[stdout, "\n"],
        StringStartsQ[#, "PYSECDEC_RESULT:"] &, ""];
    If[resultLine === "",
        Message[STNIntegrate::psdquadeval, 0,
            "No PYSECDEC_RESULT marker. stdout tail: " <> StringTake[stdout, UpTo[400]]];
        Return[$Failed]];

    jsonResult = Quiet @ Check[
        ImportString[StringDrop[resultLine, StringLength["PYSECDEC_RESULT:"]],
            "RawJSON"], $Failed];
    If[jsonResult === $Failed,
        Message[STNIntegrate::psdquadeval, 0, "JSON parse failed"];
        Return[$Failed]];

    valRaw = jsonResult["value_raw"];
    If[verbose, Print["[STNIntegrate/Quad] raw mathematica string: ",
        StringTake[valRaw, UpTo[300]]]];

    parsed = stParseDistevalMathematica[valRaw, order];
    If[parsed === $Failed,
        Message[STNIntegrate::psdquadeval, 0,
            "Disteval parse failed on: " <> StringTake[valRaw, UpTo[300]]];
        Return[$Failed]];

    parsed
];


stNIntegratePySecDec[{edges_List, nodes_List}, opts___] := Module[{result, psdOpts},
	psdOpts = FilterRules[{opts}, Options[STToPySecDec]];
	(* Map Automatic integrator to Qmc.  Must drop the existing rule before
	   appending the replacement \[LongDash] otherwise the first (Automatic) rule wins
	   when OptionValue dereferences it, and STToPySecDec forwards Automatic
	   to stBuildPySecDecScript which requires a String and returns unevaluated. *)
	If[("Integrator" /. {opts}) === Automatic,
		psdOpts = DeleteCases[psdOpts, Rule["Integrator", _]];
		psdOpts = Join[psdOpts, {"Integrator" -> "Qmc"}]
	];
	result = STToPySecDec[{edges, nodes}, Sequence @@ psdOpts];
	If[result === $Failed, Return[$Failed]];
	result
];


(* ---- FIESTA backend ---- *)

(* Convert SubTropica {edges, nodes} graph to momentum-space propagators.
   Returns {loopMomenta, propagators, nLoops} where propagators are in
   FIESTA's -(q^2 - m^2) convention (negated inverse propagators).

   Algorithm: choose a spanning tree via BFS from the first external vertex,
   assign loop momenta to non-tree edges, then solve momentum conservation
   at each vertex to determine all edge momenta. *)
stGraphToFIESTAProps[{edges_, nodes_}] := Module[
	{nEdges, nExt, edgePairs, edgeMasses, extVerts, allVerts, nVerts, nLoops,
	 adj, tree, visited, queue, parent, treeEdges, loopEdgeIdx,
	 edgeMom, loopMomenta, p, l, props, v, e},

	nEdges = Length[edges];
	edgePairs = edges[[All, 1]];
	edgeMasses = edges[[All, 2]];
	extVerts = nodes[[All, 1]];
	nExt = Length[nodes];
	allVerts = Union[Flatten[edgePairs]];
	nVerts = Length[allVerts];
	nLoops = 1 + nEdges - nVerts;

	(* Build adjacency: for each vertex, list of {edgeIndex, otherVertex} *)
	adj = Association[# -> {} & /@ allVerts];
	Do[
		AppendTo[adj[edgePairs[[i, 1]]], {i, edgePairs[[i, 2]]}];
		AppendTo[adj[edgePairs[[i, 2]]], {i, edgePairs[[i, 1]]}],
		{i, nEdges}
	];

	(* BFS spanning tree from first external vertex *)
	visited = <||>;
	parent = <||>;
	treeEdges = {};
	queue = {extVerts[[1]]};
	visited[extVerts[[1]]] = True;
	While[Length[queue] > 0,
		v = queue[[1]]; queue = Rest[queue];
		Do[
			e = adj[v][[j]];
			If[!TrueQ[visited[e[[2]]]] && !MemberQ[treeEdges, e[[1]]],
				visited[e[[2]]] = True;
				AppendTo[treeEdges, e[[1]]];
				parent[e[[2]]] = {v, e[[1]]};
				AppendTo[queue, e[[2]]]
			],
			{j, Length[adj[v]]}
		]
	];

	(* Non-tree edges carry loop momenta *)
	loopEdgeIdx = Complement[Range[nEdges], treeEdges];
	(* If we have fewer loop edges than expected, fall back to index-based *)
	If[Length[loopEdgeIdx] != nLoops,
		loopEdgeIdx = Complement[Range[nEdges], Take[treeEdges, nVerts - 1]]
	];

	loopMomenta = Table[Global`l[i], {i, nLoops}];
	edgeMom = ConstantArray[0, nEdges];

	(* Assign loop momenta to non-tree edges *)
	Do[edgeMom[[loopEdgeIdx[[i]]]] = Global`l[i], {i, nLoops}];

	(* Assign external momenta: p[i] flows into extVerts[[i]].
	   Convention: sum of all external momenta = 0, so last is determined. *)
	Module[{extMom},
		extMom = Association[];
		Do[extMom[extVerts[[i]]] = If[i < nExt, Global`p[i], -Sum[Global`p[j], {j, nExt - 1}]],
			{i, nExt}];

		(* Propagate momenta through tree edges via BFS from leaves.
		   For each tree edge, the momentum is determined by conservation:
		   sum of momenta at each vertex = 0.
		   Process leaves first (reverse BFS order). *)
		Module[{order, vertexMom, processed},
			(* Reverse BFS order = process leaves first *)
			order = Keys[visited] // Reverse;
			vertexMom = Association[];
			processed = <||>;

			Do[
				(* For vertex v, sum of all edge momenta (oriented) plus external = 0 *)
				Module[{incoming, outgoing, knownSum, unknownEdges},
					(* External momentum at this vertex *)
					knownSum = Lookup[extMom, v, 0];

					(* Find edges incident to v *)
					unknownEdges = {};
					Do[
						Module[{ei = adj[v][[j, 1]], ov = adj[v][[j, 2]], sign},
							(* sign: +1 if momentum flows from v to ov (edge direction = edgePairs order) *)
							sign = If[edgePairs[[ei, 1]] === v, 1, -1];
							If[edgeMom[[ei]] =!= 0 || TrueQ[processed[ei]],
								knownSum += sign * edgeMom[[ei]],
								AppendTo[unknownEdges, {ei, sign}]
							]
						],
						{j, Length[adj[v]]}
					];

					(* If exactly one unknown edge, solve for it *)
					If[Length[unknownEdges] == 1,
						Module[{ei = unknownEdges[[1, 1]], sign = unknownEdges[[1, 2]]},
							edgeMom[[ei]] = -knownSum / sign // Expand;
							processed[ei] = True
						]
					]
				],
				{v, order}
			];

			(* Second pass: any remaining unresolved edges *)
			Do[
				If[edgeMom[[i]] === 0 && !TrueQ[processed[i]],
					(* This shouldn't happen for a connected graph *)
					edgeMom[[i]] = l[nLoops + i]  (* fallback *)
				],
				{i, nEdges}
			]
		]
	];

	(* Build propagators in FIESTA convention: -(q^2 - m^2) = m^2 - q^2 *)
	props = Table[
		Expand[edgeMasses[[i]]^2 - edgeMom[[i]]^2],
		{i, nEdges}
	];

	{loopMomenta, props, nLoops}
];

$stFIESTAUF = None;
$stFIESTASDEval = None;

stEnsureFIESTALoaded[] := If[!$FIESTALoaded,
	If[stRequireTool["FIESTA"] === $Failed, Return[$Failed]];
	If[$FIESTAPath =!= "" && DirectoryQ[$FIESTAPath],
		PrependTo[$Path, $FIESTAPath]
	];
	Check[
		Block[{$Context = "Global`", $ContextPath = {"FIESTA`", "System`", "Global`"}},
			Quiet[Get["FIESTA5.m"]];
		];
		$stFIESTAUF = ToExpression["FIESTA`UF"];
		$stFIESTASDEval = ToExpression["FIESTA`SDEvaluate"];
		$FIESTALoaded = True,
		Message[STNIntegrate::nofiesta]; Return[$Failed]
	]
];

stNIntegrateFIESTA[{edges_List, nodes_List}, opts___] := Module[
	{nEdges, nVerts, nLoops, edgeMasses, nodeMasses,
	 loops, props, nExt, kinPoint, subs, order, maxeval,
	 exponents, indices, verbose, normalization, complexMode,
	 nSubkernels, nLinks, strategy, integrator, dim, dimInfo, d0,
	 UFresult, Upoly, Fpoly, fiestaResult, cIntPath,
	 dataDir, dataPathPrefix},

	verbose = TrueQ["Verbose" /. {opts} /. "Verbose" -> False];
	order = "Order" /. {opts} /. "Order" -> 0;
	maxeval = "MaxEval" /. {opts} /. "MaxEval" -> 10^7;
	kinPoint = stPickKinPointOpts[{opts}];
	exponents = "Exponents" /. {opts} /. "Exponents" -> Automatic;
	normalization = "Normalization" /. {opts} /. "Normalization" -> Automatic;
	complexMode = "ComplexMode" /. {opts} /. "ComplexMode" -> Automatic;
	nSubkernels = "NumberOfSubkernels" /. {opts} /. "NumberOfSubkernels" -> 4;
	nLinks = "NumberOfLinks" /. {opts} /. "NumberOfLinks" -> 4;
	strategy = "Strategy" /. {opts} /. "Strategy" -> "S2";
	integrator = "Integrator" /. {opts} /. "Integrator" -> Automatic;

	(* Dimension: FIESTA's convention is D = d0 - 2*ep, so we validate that
	   the user's dim has the form D0 - 2*eps with D0 an integer, then pass
	   D0 as the "d0" option to FIESTA.  The dispatcher in STNIntegrate has
	   already validated and injected "Dimension"; this fallback to 4 - 2 eps
	   only kicks in for direct calls to stNIntegrateFIESTA. *)
	dim = "Dimension" /. {opts} /. "Dimension" -> 4 - 2 eps;
	dimInfo = stParseDimension[dim, "FIESTA"];
	If[dimInfo === $Failed, Return[$Failed]];
	d0 = dimInfo["D0"];

	(* Load FIESTA *)
	If[stEnsureFIESTALoaded[] === $Failed, Return[$Failed]];

	nEdges = Length[edges];
	edgeMasses = edges[[All, 2]];
	nodeMasses = nodes[[All, 2]];
	nVerts = Length[Union[Flatten[edges[[All, 1]]]]];
	nLoops = 1 + nEdges - nVerts;
	nExt = Length[nodes];

	(* Convert {edges, nodes} to momentum-space propagators in FIESTA's
	   -(q^2 - m^2) convention via the graph topology. *)
	{loops, props, nLoops} = stGraphToFIESTAProps[{edges, nodes}];

	(* Build substitution rules for FIESTA's UF.
	   FIESTA needs p[i]^2 -> value rules using the Global`p[i] symbols
	   from stGraphToFIESTAProps.  We build these from the KinematicPoint
	   using the same pySecDec-style parameter names. *)
	Module[{allSubs, intMassSyms, flattenSym},
		flattenSym = Function[sym, Symbol[stMmaExprToPython[sym]]];
		allSubs = {};

		(* External momentum squared: p[i]^2 -> value.
		   For n-point: p[1],...,p[n-1] independent; p[n] = -sum(p[1..n-1]).
		   The KinematicPoint uses Msq, M1sq, ... or s12, s13, ... *)
		(* Build name -> value lookup from kinematic point (context-safe) *)
		Module[{kinLookup},
			kinLookup = Association[
				(ToString[#[[1]]] -> #[[2]]) & /@ kinPoint
			];
			If[verbose, Print["[STNIntegrate/FIESTA] kinLookup: ", kinLookup, " nodeMasses: ", nodeMasses]];
			Do[Module[{nm, paramName, val},
				nm = nodeMasses[[i]];
				If[nm === 0,
					AppendTo[allSubs, Global`p[i]^2 -> 0],
					(* Use SymbolName to strip context prefix *)
					paramName = If[MatchQ[nm, _Symbol], SymbolName[nm], stMmaExprToPython[nm]] <> "sq";
					val = Lookup[kinLookup, paramName, None];
					If[verbose, Print["[STNIntegrate/FIESTA] leg ", i, ": nm=", nm, " paramName=", paramName, " val=", val]];
					If[NumericQ[val],
						AppendTo[allSubs, Global`p[i]^2 -> val]
					]
				]],
				{i, nExt}
			]
		];

		(* Mandelstam invariants for n >= 3: p[i]*p[j] -> value.
		   GenerateKinematics returns Dot products Subscript[p,i]\[CenterDot]Subscript[p,j].
		   FIESTA propagators use Times: Global`p[i]*Global`p[j].
		   We convert both the LHS and RHS to get numeric substitutions. *)
		If[nExt >= 3,
			Module[{genKin, massSqRules, kinLookupM},
				genKin = GenerateKinematics[nExt];
				kinLookupM = Association[(ToString[#[[1]]] -> #[[2]]) & /@ kinPoint];

				(* Map M[i]^2 -> numeric value from external mass substitutions *)
				massSqRules = Table[
					Subscript[M, i]^2 -> (Global`p[i]^2 /. allSubs /. Global`p[_]^2 -> 0),
					{i, nExt}
				];

				Do[Module[{lhs, rhs, pi, pj},
					(* Convert Dot[Subscript[p,i], Subscript[p,j]] to Times[p[i], p[j]] *)
					{pi, pj} = List @@ genKin[[r, 1]] /. Subscript[p, k_] :> Global`p[k];
					lhs = pi * pj;  (* Times, not Dot *)

					rhs = genKin[[r, 2]] /. massSqRules // Expand;
					(* Replace Subscript[s,i,j] with numeric value from KinematicPoint *)
					rhs = rhs /. Subscript[s, i_, j_] :> Module[{sName = "s" <> ToString[i] <> ToString[j]},
						Lookup[kinLookupM, sName, Symbol[sName]]
					];
					If[NumericQ[rhs], AppendTo[allSubs, lhs -> rhs]]
				], {r, Length[genKin]}]
			]
		];

		(* Internal mass substitutions *)
		intMassSyms = Cases[edgeMasses, _Symbol | _[_Integer], {0, Infinity}] // DeleteDuplicates;
		Module[{kinLookup2 = Association[(ToString[#[[1]]] -> #[[2]]) & /@ kinPoint]},
			Do[Module[{paramName = stMmaExprToPython[ms], val},
				val = Lookup[kinLookup2, paramName, None];
				If[NumericQ[val], AppendTo[allSubs, ms -> val]]
			], {ms, intMassSyms}]
		];

		subs = allSubs;
	];

	indices = If[exponents === Automatic, ConstantArray[1, nEdges], exponents];

	(* Auto-detect ComplexMode: needed when any invariant is positive real
	   (Minkowski threshold). Guard against imaginary entries: auto-kinematic
	   (stMakeVerificationPoint) populates both Msq -> -145/86 and M -> I*Sqrt[145/86]
	   for a Euclidean squared mass. Raw "# > 0" on I*Sqrt[...] stays unevaluated,
	   so AnyTrue returns the literal Greater[...] expression, which then ships
	   into FIESTA as ComplexMode and fires Greater::nord inside sector
	   decomposition. Positive+TrueQ collapses both imaginaries and indeterminate
	   signs to False, which is the correct answer for ComplexMode. *)
	If[complexMode === Automatic,
		complexMode = AnyTrue[kinPoint[[All, 2]],
			(NumericQ[#] && TrueQ[Positive[#]]) &]
	];

	Module[{fiestaIntegrator, fiestaOpts},
		fiestaIntegrator = Switch[integrator,
			Automatic, "vegasCuba",
			"Vegas", "vegasCuba",
			"Qmc" | "QMC" | "qmc", "quasiMonteCarlo",
			_, integrator
		];

		(* Resolve CIntegrate binary path *)
		cIntPath = FileNameJoin[{$FIESTAPath, "bin"}];

		(* Per-call DataPath: $FIESTAPath/temp/stnif_<PID>_<counter>/db .
		   The trailing "/db" is the prefix FIESTA appends "in.kch", "out.kch",
		   etc. to.  Using a fresh subdirectory per call isolates this
		   integrand's database files from prior calls in the same kernel,
		   so leftover task-prefixed kch / qhi / qho files cannot poison
		   the next FIESTA call. *)
		$stFIESTACallCounter += 1;
		dataDir = FileNameJoin[{$FIESTAPath, "temp",
			"stnif_" <> ToString[$ProcessID] <> "_" <>
				ToString[$stFIESTACallCounter]}];
		Quiet @ CreateDirectory[dataDir];
		dataPathPrefix = FileNameJoin[{dataDir, "db"}];

		If[verbose,
			Print["[STNIntegrate/FIESTA] L=", nLoops, " E=", nEdges, " legs=", nExt, " d0=", d0];
			Print["[STNIntegrate/FIESTA] subs: ", subs];
			Print["[STNIntegrate/FIESTA] CIntegratePath: ", cIntPath];
			Print["[STNIntegrate/FIESTA] DataPath: ", dataPathPrefix]
		];

		If[verbose, Print["[STNIntegrate/FIESTA] Calling FIESTA with ", Length[loops], " loops, ", Length[props], " props"]];

		(* Set FIESTA options BEFORE calling SDEvaluate, using the stored
		   FIESTA`SetOptions reference.  This avoids context collisions
		   when passing option symbols like Integrator -> ... *)
		Block[{$Context = "Global`"},
			ToExpression["SetOptions"][ToExpression["FIESTA"],
				"Integrator" -> fiestaIntegrator,
				"IntegratorOptions" -> {{"maxeval", ToString[maxeval]}},
				"NumberOfSubkernels" -> nSubkernels,
				"NumberOfLinks" -> nLinks,
				"Strategy" -> strategy,
				"ComplexMode" -> complexMode,
				"d0" -> d0,
				"DataPath" -> dataPathPrefix
			];

			UFresult = $stFIESTAUF[loops, props, subs];
			Upoly = UFresult[[1]];
			Fpoly = UFresult[[2]];

			If[verbose, Print["[STNIntegrate/FIESTA] U=", Short[Upoly, 2], "  F=", Short[Fpoly, 2]]];

			fiestaResult = CheckAbort[
				$stFIESTASDEval[{Upoly, Fpoly, nLoops}, indices, order],
				$Aborted];
		];

		(* Best-effort cleanup of the per-call DataPath subdirectory. *)
		Quiet @ DeleteDirectory[dataDir, DeleteContents -> True];
		If[fiestaResult === $Aborted, Return[$Failed]];
	];

	If[verbose, Print["[STNIntegrate/FIESTA] Raw: ", InputForm[fiestaResult]]];

	(* Parse FIESTA result into {value, error} pair.
	   FIESTA output format: expr + coeff*pmN/ep^k + err*pmM
	   where pmN are error symbols.  Extract value and error parts.

	   Convention match:
	   - FIESTA already includes (-1)^N_nu and exp(L*eps*gamma_E)
	   - With Normalization -> Automatic, this matches pySecDec (Norm=Auto)
	   - With Normalization -> 1, we need to divide out exp(L*eps*gamma_E)
	   - The ep variable in FIESTA output maps to our eps
	   - FIESTA includes (-1)^N_nu; the negated propagators from stGraphToFIESTAProps
	     introduce an additional (-1)^N_nu, giving (-1)^{2*N_nu} total. For odd N_nu
	     this means the result has an extra (-1). Correct by multiplying by (-1)^nEdges. *)
	Module[{parsed, signFix},
		parsed = stParseFIESTAResult[fiestaResult, order, nLoops, normalization];
		signFix = (-1)^nEdges;
		If[MatchQ[parsed, {_, _}],
			{signFix * parsed[[1]], Abs[signFix] * parsed[[2]]},
			parsed
		]
	]
];

(* Parse FIESTA output expression.
   FIESTA returns an expression like:
     2.66 + (1. + 0.00012*pm7)/ep^2 + (0.781 + 0.00123*pm8)/ep + 0.0028*pm9
   where ep may be Global`ep, and pmN are error symbols.
   We split value and error, convert ep -> eps, build SeriesData. *)
stParseFIESTAResult[result_, order_, nLoops_, normalization_] := Module[
	{expr, allSyms, pmSyms, epSym, valPart, errPart, normFactor,
	 valCoeffs, errCoeffs, minPow, maxPow},

	expr = result;

	(* Find all symbols in the expression *)
	allSyms = Cases[expr, _Symbol, {0, Infinity}] // DeleteDuplicates;

	(* Identify pm (error) symbols: any symbol whose name starts with "pm" *)
	pmSyms = Select[allSyms, StringMatchQ[SymbolName[#], "pm" ~~ __] &];

	(* Identify the epsilon symbol: any symbol named "ep" regardless of context *)
	epSym = SelectFirst[allSyms, SymbolName[#] === "ep" &, eps];

	(* Split: value = expr with all pm -> 0 *)
	valPart = expr /. Thread[pmSyms -> 0];

	(* Error: set all pm -> 1, subtract value part. The remainder is the error. *)
	errPart = If[Length[pmSyms] > 0,
		(expr /. Thread[pmSyms -> 1]) - valPart,
		0
	];

	(* Convert FIESTA's ep (any context) -> our eps *)
	valPart = valPart /. epSym -> eps;
	errPart = errPart /. epSym -> eps;

	(* Determine the pole structure and build SeriesData *)
	(* Find min and max eps powers present *)
	Module[{expanded = valPart // Expand, terms, powers},
		If[expanded === 0,
			{0, 0},
			(* Extract Laurent coefficients *)
			minPow = Exponent[expanded, eps, Min];
			maxPow = order;

			valCoeffs = Table[Coefficient[expanded, eps, k], {k, minPow, maxPow}];
			errCoeffs = Table[
				Module[{c = Coefficient[Expand[errPart], eps, k]},
					If[NumericQ[c], c, 0]
				], {k, minPow, maxPow}
			];

			(* Normalization adjustment:
			   FIESTA output already includes exp(L*eps*gamma_E).
			   - Normalization -> Automatic: no adjustment needed
			   - Normalization -> 1: divide out the exp factor *)
			If[normalization === 1,
				normFactor = Normal[Series[Exp[-nLoops eps EulerGamma], {eps, 0, order}]];
				valPart = Expand[valPart * normFactor];
				errPart = Expand[errPart * Abs[normFactor /. eps -> 0]];
				valCoeffs = Table[Coefficient[Expand[valPart], eps, k], {k, minPow, maxPow}];
				errCoeffs = Table[Coefficient[Expand[errPart], eps, k], {k, minPow, maxPow}];
			];

			{SeriesData[eps, 0, valCoeffs, minPow, maxPow + 1, 1],
			 SeriesData[eps, 0, errCoeffs, minPow, maxPow + 1, 1]}
		]
	]
];


(* ---- AMFlow backend ----

   AMFlow (Liu & Ma, arXiv:2201.11669) evaluates Feynman integrals numerically
   via the auxiliary mass flow method. Unlike sector-decomposition backends it
   is not Monte Carlo: it returns arbitrary-precision numerics (precision goal
   is user-controlled via "AMFlowPrecision").

   Convention mapping vs FIESTA:
     FIESTA propagators: m^2 - q^2   (negative kinetic term)
     AMFlow propagators: q^2 - m^2   (positive kinetic term)
   We reuse stGraphToFIESTAProps for the spanning-tree momentum assignment
   and flip the sign.

   Option mapping vs SubTropica STNIntegrate:
     "Order" (highest eps power K)  ->  AMFlow epsorder = K + 2*nLoops
       (AMFlow expands from eps^(-2L) to eps^(epsorder - 2L); see AMFlow.m
        SolveIntegrals definition: leading = -2 Length[Loop]; Series to
        order+leading.)
     "AMFlowIBPReducer"  -> "FiniteFlow+LiteRed" (default) or "FIRE+LiteRed"
     "AMFlowPrecision"   -> decimal-digit precision goal (default 16)
     "AMFlowNThread"     -> threads passed to AMFlowInfo["NThread"]
     "AMFlowFamily"      -> family symbol (Automatic => fresh Unique)
*)

stEnsureAMFlowLoaded[] := If[!$AMFlowLoaded,
	If[stRequireTool["AMFlow"] === $Failed, Return[$Failed]];
	(* Load AMFlow in Global context so its internal symbols (j, eps, eta, ...)
	   stay unprefixed \[LongDash] AMFlow builds integrals as j[family, n1, n2, ...] and
	   its SolveIntegrals references these in Global`. *)
	Block[{$Context = "Global`", $ContextPath = {"Global`", "System`"}},
		Get[FileNameJoin[{$AMFlowPath, "AMFlow.m"}]]
	];
	$AMFlowLoaded = True;
];

(* Override AMFlow's install.m backend paths with SubTropica's global config,
   but only when the SubTropica path actually points at a valid install.
   AMFlow's install.m sets these at SetReductionOptions[IBPReducer->...] time;
   we re-set them right after so SubTropica is the single source of truth. *)
stOverrideAMFlowPaths[reducer_String] := Module[{ok},
	ok[p_String, rel___String] := FileExistsQ[FileNameJoin[{p, rel}]];
	Switch[reducer,
		"FiniteFlow+LiteRed",
			(* $FFPath = FiniteFlow's mathlink dir (contains FiniteFlow.m);
			   $FFLibraryPath = its parent (contains libfflow.dylib). *)
			If[$FiniteFlowPath =!= "" && ok[$FiniteFlowPath, "FiniteFlow.m"],
				Symbol["FiniteFlow`$FFPath"]        = $FiniteFlowPath;
				Symbol["FiniteFlow`$FFLibraryPath"] = ParentDirectory[$FiniteFlowPath];
			];
			If[ok[$LiteIBPPath, "LiteIBP.m"],
				Symbol["FiniteFlow`$LiteIBPPath"] = $LiteIBPPath
			];
			(* LiteRed package file lives in <root>/Setup/LiteRed.m. *)
			If[ok[$LiteRedPath, "Setup", "LiteRed.m"],
				Symbol["FiniteFlow`$LiteRedPath"] = FileNameJoin[{$LiteRedPath, "Setup"}]
			],
		"FIRE+LiteRed",
			If[ok[$FIREPath, "FIRE6.m"],
				Symbol["FIRE`$FIREInstallationDirectory"] = $FIREPath
			],
		_,
			(* Blade, Kira, user-defined reducers: nothing to override here yet. *)
			Null
	];
];

(* Convert {edges, nodes} -> AMFlow-convention momentum-space data.
   Returns {loopMomenta, extLegs, conservation, propagators, nLoops, nExt}.

   Mirrors stGraphToFIESTAProps's spanning-tree momentum routing, but
   produces propagators in UNEXPANDED form q^2 - m^2, where q is a symbolic
   sum of loop and external momenta (e.g. l[1] + p[2] + p[3]). AMFlow's
   LiteIBP/LiteRed backend needs this structure; fully expanded polynomial
   form triggers "NewBasis::notb: Overdetermined set of denominators". *)
stGraphToAMFlowProps[{edges_, nodes_}] := Module[
	{nEdges, nVerts, nLoops, edgePairs, edgeMasses, extVerts, allVerts,
	 adj, visited, queue, parent, treeEdges, loopEdgeIdx, edgeMom,
	 loopMomenta, extLegs, nExt, conservation, amflowProps, v, e},

	nEdges     = Length[edges];
	edgePairs  = edges[[All, 1]];
	edgeMasses = edges[[All, 2]];
	extVerts   = nodes[[All, 1]];
	nExt       = Length[nodes];
	allVerts   = Union[Flatten[edgePairs]];
	nVerts     = Length[allVerts];
	nLoops     = 1 + nEdges - nVerts;

	adj = Association[# -> {} & /@ allVerts];
	Do[
		AppendTo[adj[edgePairs[[i, 1]]], {i, edgePairs[[i, 2]]}];
		AppendTo[adj[edgePairs[[i, 2]]], {i, edgePairs[[i, 1]]}],
		{i, nEdges}
	];

	visited    = <||>;
	parent     = <||>;
	treeEdges  = {};
	queue      = {extVerts[[1]]};
	visited[extVerts[[1]]] = True;
	While[Length[queue] > 0,
		v = queue[[1]]; queue = Rest[queue];
		Do[
			e = adj[v][[j]];
			If[!TrueQ[visited[e[[2]]]] && !MemberQ[treeEdges, e[[1]]],
				visited[e[[2]]] = True;
				AppendTo[treeEdges, e[[1]]];
				parent[e[[2]]] = {v, e[[1]]};
				AppendTo[queue, e[[2]]]
			],
			{j, Length[adj[v]]}
		]
	];

	loopEdgeIdx = Complement[Range[nEdges], treeEdges];
	If[Length[loopEdgeIdx] != nLoops,
		loopEdgeIdx = Complement[Range[nEdges], Take[treeEdges, nVerts - 1]]
	];

	(* Use flat symbol names l1, l2, ... p1, p2, ... \[LongDash] LiteIBP's NewBasis
	   flags indexed forms like p[i] with `sp::set: typically not what you
	   want` and then aborts the IBP reduction. *)
	loopMomenta = Table[Symbol["Global`l" <> ToString[i]], {i, nLoops}];
	edgeMom = ConstantArray[0, nEdges];
	Do[edgeMom[[loopEdgeIdx[[i]]]] = loopMomenta[[i]], {i, nLoops}];

	Module[{extMom, legSyms},
		legSyms = Table[Symbol["Global`p" <> ToString[i]], {i, nExt}];
		extMom = Association[];
		Do[extMom[extVerts[[i]]] = If[i < nExt,
			legSyms[[i]], -Sum[legSyms[[j]], {j, nExt - 1}]],
			{i, nExt}];

		Module[{order, processed},
			order = Keys[visited] // Reverse;
			processed = <||>;

			Do[
				Module[{knownSum, unknownEdges},
					knownSum = Lookup[extMom, v, 0];
					unknownEdges = {};
					Do[
						Module[{ei = adj[v][[j, 1]], ov = adj[v][[j, 2]], sign},
							sign = If[edgePairs[[ei, 1]] === v, 1, -1];
							If[edgeMom[[ei]] =!= 0 || TrueQ[processed[ei]],
								knownSum += sign * edgeMom[[ei]],
								AppendTo[unknownEdges, {ei, sign}]
							]
						],
						{j, Length[adj[v]]}
					];
					If[Length[unknownEdges] == 1,
						Module[{ei = unknownEdges[[1, 1]], sign = unknownEdges[[1, 2]]},
							edgeMom[[ei]] = -knownSum / sign // Simplify;
							processed[ei] = True
						]
					]
				],
				{v, order}
			];

			Do[
				If[edgeMom[[i]] === 0 && !TrueQ[processed[i]],
					edgeMom[[i]] = Symbol["Global`l" <> ToString[nLoops + i]]
				],
				{i, nEdges}
			]
		]
	];

	(* Build AMFlow-convention props: q^2 - m^2 (NOT expanded \[LongDash] LiteRed needs
	   the momentum-sum structure visible). *)
	amflowProps = Table[
		edgeMom[[i]]^2 - edgeMasses[[i]]^2,
		{i, nEdges}];

	extLegs = Table[Symbol["Global`p" <> ToString[i]], {i, nExt}];
	conservation = If[nExt >= 2,
		{extLegs[[nExt]] -> -Sum[extLegs[[i]], {i, nExt - 1}]},
		{}
	];

	{loopMomenta, extLegs, conservation, amflowProps, nLoops, nExt}
];

(* Build AMFlow {Replacement, Numeric} pair from a KinematicPoint.
   AMFlow expects Replacement in *symbolic* form (e.g. p1^2 -> M1sq,
   p1*p2 -> expr in M_i and s_ij) and numeric values delivered via Numeric.
   We use flat symbol names M_i_sq, s_ij to match the existing SubTropica
   naming (consistent with stMmaExprToPython). *)
stAMFlowReplacement[{edges_, nodes_}, kinPoint_] := Module[
	{nExt, nodeMasses, edgeMasses, kinLookup, replacement, numeric,
	 genKin, flatSubs, introduced},
	nExt       = Length[nodes];
	nodeMasses = nodes[[All, 2]];
	edgeMasses = edges[[All, 2]];
	kinLookup  = Association[(ToString[#[[1]]] -> #[[2]]) & /@ kinPoint];
	replacement = {};
	introduced  = {};  (* flat symbols that need numeric values *)

	(* Flatten Subscript[M,i] -> <flat-mass-squared symbol> and
	   Subscript[s,i,j] -> s<ij>.  Two regimes for the M_i^2 case:

	     1. Shared internal/external mass: the i-th external leg's mass
	        symbol also appears on some internal edge.  Substitute
	        M_i^2 -> sm^2 directly so AMFlow's family loses that
	        parameter and the IBP/DE reduction sees the constraint
	        analytically (v1.0.297).

	     2. Otherwise: use the SAME flat-square symbol that
	        stMakeVerificationPoint emits for this leg's node mass.
	        That generator deduplicates by node-mass symbol \[LongDash] e.g.
	        a bubble whose two external legs both carry mass M produces
	        a single "Msq" key, not "M1sq" / "M2sq".  The previous
	        implementation always emitted indexed "M<i>sq" symbols, so
	        the AMFlow lookup missed every shared-mass external and
	        silently defaulted M<i>sq -> 0 (B2 / B3). *)
	flatSubs = {
		Subscript[M, i_Integer]^2 :> With[
			{sm = stIsSharedMassLeg[{edges, nodes}, i],
			 nm = nodeMasses[[i]]},
			Which[
				(* Massless leg: the on-shell constraint is p_i^2 = 0, so
				   inject 0 directly rather than emitting an invalid
				   Symbol["0sq"]. *)
				nm === 0,
					0,
				(* Shared external/internal mass: substitute the internal
				   mass symbol so AMFlow's family loses that parameter. *)
				sm =!= None,
					sm^2,
				True,
					Symbol[StringReplace[stMmaExprToPython[nm], "**" -> ""] <> "sq"]]],
		Subscript[s, i_, j_] :> Symbol["s" <> ToString[i] <> ToString[j]]
	};

	(* Scalar products from GenerateKinematics cover both p[i]^2 and p[i]*p[j].
	   Flat leg symbols (p1, p2, ...) \[LongDash] see stGraphToAMFlowProps for the rule
	   about why indexed forms don't work with LiteIBP. *)
	If[nExt >= 2,
		genKin = GenerateKinematics[nExt];
		Do[Module[{pi, pj, lhs, rhs},
			{pi, pj} = List @@ genKin[[r, 1]] /.
				Subscript[p, k_] :> Symbol["Global`p" <> ToString[k]];
			lhs = pi * pj;
			rhs = genKin[[r, 2]] /. flatSubs;
			AppendTo[replacement, lhs -> rhs];
			introduced = Join[introduced,
				Cases[rhs, _Symbol, {0, Infinity}]]
		], {r, Length[genKin]}]
	];

	(* Collect numeric values for introduced symbols from KinematicPoint.
	   If a value is missing, fall back to 0 for mass-squareds and leave the
	   Mandelstam symbolic (AMFlow can still reduce symbolically). *)
	introduced = DeleteDuplicates[introduced];
	numeric = {};
	Do[Module[{val = Lookup[kinLookup, SymbolName[sym], None]},
		If[NumericQ[val],
			AppendTo[numeric, sym -> val],
			If[StringMatchQ[SymbolName[sym], "M" ~~ __ ~~ "sq"] ||
			   StringMatchQ[SymbolName[sym], "m" ~~ __ ~~ "sq"],
				AppendTo[numeric, sym -> 0]
			]
		]], {sym, introduced}];

	{replacement, numeric}
];

(* Extract the Laurent series coefficient list from an AMFlow SolveIntegrals
   result value (a SeriesData in Global`eps, at eps -> 0).
   Returns {minPow, maxPow, coeffs} ready for SeriesData in SubTropica's eps. *)
stAMFlowExtractSeries[jResult_, targetMaxOrder_Integer] := Module[
	{epsSym, expr, minPow, maxPow, coeffs},
	epsSym = Symbol["Global`eps"];
	expr = jResult;
	(* Convert SeriesData to Normal form, replace Global`eps with SubTropica`eps *)
	expr = Normal[expr] /. epsSym -> eps;
	expr = Expand[expr];
	If[expr === 0, Return[{0, targetMaxOrder, ConstantArray[0, targetMaxOrder + 1]}]];
	minPow = Exponent[expr, eps, Min];
	maxPow = targetMaxOrder;
	coeffs = Table[Coefficient[expr, eps, k], {k, minPow, maxPow}];
	{minPow, maxPow, coeffs}
];

stNIntegrateAMFlow[{edges_List, nodes_List}, opts___] := Module[
	{order, verbose, kinPoint, exponents, reducer, precision, nThread, family,
	 dim, dimInfo, d0, normalization,
	 nEdges, nLoops, nExt, loops, legs, cons, props, replacement, numericList,
	 indices, amflowOrder, target, sol, jResult, minPow, maxPow, coeffs,
	 valSeries, errSeries, normFactor, valExpr, errExpr,
	 t0 = AbsoluteTime[]},

	order         = "Order"         /. {opts} /. "Order"         -> 0;
	verbose       = TrueQ["Verbose" /. {opts} /. "Verbose"       -> False];
	kinPoint      = stPickKinPointOpts[{opts}];
	exponents     = "Exponents"     /. {opts} /. "Exponents"     -> Automatic;
	reducer       = "AMFlowIBPReducer" /. {opts} /. "AMFlowIBPReducer" -> "FiniteFlow+LiteRed";
	precision     = "AMFlowPrecision"  /. {opts} /. "AMFlowPrecision"  -> 16;
	nThread       = "AMFlowNThread"    /. {opts} /. "AMFlowNThread"    -> 4;
	family        = "AMFlowFamily"     /. {opts} /. "AMFlowFamily"     -> Automatic;
	normalization = "Normalization" /. {opts} /. "Normalization" -> Automatic;

	(* Dimension: AMFlow's convention is D = D0 - 2*eps, controlled via the
	   global option SetAMFOptions["D0" -> D0].  Validate that dim has the
	   form D0 - 2*eps (D0 integer or rational), then pass D0.  Fallback to
	   4 - 2 eps is only hit by direct callers; the STNIntegrate dispatcher
	   has already injected an explicit "Dimension". *)
	dim = "Dimension" /. {opts} /. "Dimension" -> 4 - 2 eps;
	dimInfo = stParseDimension[dim, "AMFlow"];
	If[dimInfo === $Failed, Return[$Failed]];
	d0 = dimInfo["D0"];

	If[stEnsureAMFlowLoaded[] === $Failed, Return[$Failed]];

	If[family === Automatic, family = Unique["subTropicaFam"]];

	{loops, legs, cons, props, nLoops, nExt} = stGraphToAMFlowProps[{edges, nodes}];
	nEdges = Length[edges];
	indices = If[exponents === Automatic, ConstantArray[1, nEdges], exponents];
	Module[{pair = stAMFlowReplacement[{edges, nodes}, kinPoint]},
		replacement = pair[[1]];
		numericList = pair[[2]]
	];

	(* Collect internal mass symbols from the propagators and add their
	   numeric values to Numeric as well. Internal masses stay symbolic in
	   the Propagator list. *)
	Module[{kinLookup = Association[(ToString[#[[1]]] -> #[[2]]) & /@ kinPoint],
		intMassSyms, extra},
		intMassSyms = Cases[edges[[All, 2]], _Symbol | _[_Integer],
			{0, Infinity}] // DeleteDuplicates;
		extra = {};
		Do[Module[{name = stMmaExprToPython[ms], val},
			val = Lookup[kinLookup, name, None];
			If[NumericQ[val], AppendTo[extra, ms -> val]]
		], {ms, intMassSyms}];
		numericList = Join[numericList, extra]
	];

	If[verbose,
		Print["[STNIntegrate/AMFlow] L=", nLoops, " E=", nEdges, " legs=", nExt, " D0=", d0];
		Print["[STNIntegrate/AMFlow] reducer=", reducer, " prec=", precision,
			" order=", order];
		Print["[STNIntegrate/AMFlow] props=", props];
		Print["[STNIntegrate/AMFlow] replacement=", replacement];
		Print["[STNIntegrate/AMFlow] numeric=", numericList];
	];

	(* Configure AMFlow. Resolve symbols explicitly in AMFlow` context; do not
	   touch $ContextPath, since AMFlow's reducers (FiniteFlow, LiteRed) need
	   their own contexts visible during IBP reduction. *)
	Module[{setRedOpts, setAMFOpts, amfInfo, solveInts, jHead},
		setRedOpts = Symbol["AMFlow`SetReductionOptions"];
		setAMFOpts = Symbol["AMFlow`SetAMFOptions"];
		amfInfo    = Symbol["AMFlow`AMFlowInfo"];
		solveInts  = Symbol["AMFlow`SolveIntegrals"];
		jHead      = Symbol["Global`j"];

		setRedOpts["IBPReducer" -> reducer];
		(* SetAMFOptions["D0" -> d0] mutates AMFlow's package-global $D0.
		   AMFlow convention: D = D0 - 2*eps.  This is global state, so
		   subsequent direct AMFlow calls outside STNIntegrate will inherit
		   the last value we set. *)
		setAMFOpts["D0" -> d0];
		(* SubTropica paths (from ConfigureSubTropica) override AMFlow's
		   install.m values, when they point at a valid install. *)
		stOverrideAMFlowPaths[reducer];
		amfInfo["Family"]       = family;
		amfInfo["Loop"]         = loops;
		amfInfo["Leg"]          = legs;
		amfInfo["Conservation"] = cons;
		amfInfo["Replacement"]  = replacement;
		amfInfo["Propagator"]   = props;
		amfInfo["Numeric"]      = numericList;
		amfInfo["NThread"]      = nThread;

		(* AMFlow's epsorder is the number of terms to expand beyond the
		   leading pole, which for a generic L-loop integral in D = 4 - 2 eps
		   can reach eps^(-2L).  For non-4 D0 the leading pole location shifts,
		   so this padding may be over- or under-generous; users wanting high
		   precision in non-4 dimensions should bump "Order" manually. *)
		amflowOrder = order + 2*nLoops;
		target = {jHead[family, Sequence @@ indices]};

		If[verbose, Print["[STNIntegrate/AMFlow] calling SolveIntegrals..."]];
		sol = solveInts[target, precision, amflowOrder];
	];

	If[verbose, Print["[STNIntegrate/AMFlow] raw: ", sol]];

	(* sol is a list of rules {j[fam, nu1, ..., nuE] -> SeriesData}. *)
	jResult = target[[1]] /. sol;
	If[jResult === target[[1]],
		Message[STNIntegrate::badmethod, "AMFlow returned no result for target"];
		Return[$Failed]
	];

	{minPow, maxPow, coeffs} = stAMFlowExtractSeries[jResult, order];
	valSeries = SeriesData[eps, 0, coeffs, minPow, maxPow + 1, 1];
	errSeries = SeriesData[eps, 0,
		ConstantArray[10^(-precision), Length[coeffs]],
		minPow, maxPow + 1, 1];

	(* AMFlow returns the bare Feynman integral with no MS-bar prefactor.
	   pySecDec and FIESTA both bake in exp(L*eps*EulerGamma) when
	   Normalization -> Automatic, so apply the same factor here for
	   cross-backend agreement.  For Normalization -> 1 leave AMFlow's
	   raw result alone; for an explicit expression, use it as the
	   prefactor. *)
	normFactor = Switch[normalization,
		Automatic, Exp[nLoops*eps*EulerGamma],
		1,         1,
		_,         normalization];
	If[normFactor =!= 1,
		valExpr = Normal[Series[Normal[valSeries] * normFactor,
			{eps, 0, maxPow}]];
		coeffs = Table[Coefficient[Expand[valExpr], eps, k],
			{k, minPow, maxPow}];
		valSeries = SeriesData[eps, 0, coeffs, minPow, maxPow + 1, 1];
		(* The error bound is an order-of-magnitude estimate; the constant
		   term of normFactor is 1 for Normalization -> Automatic so the
		   bound is unchanged.  errSeries left as-is. *)
	];

	{valSeries, errSeries}
];

(* Propagator-list form: convert to a fake graph via existing pipeline if
   available, otherwise error with a helpful message. *)
stNIntegrateAMFlow[props_List, opts___] /; !MatchQ[props, {_List, _List}] :=
	(Message[STNIntegrate::badmethod,
		"AMFlow backend currently accepts only the {edges, nodes} graph form. " <>
		"Pass a graph instead of a raw propagator list."];
	$Failed);


(* ---- feyntrop backend ----

   feyntrop (Borinsky, Munch, Tellander, arXiv:2302.08955) evaluates Feynman
   integrals by tropical Monte Carlo sampling of a manifestly i\[CurlyEpsilon]-free
   parametric representation. Works in the physical region with arbitrarily
   many kinematic scales, returns a complex-valued eps expansion with MC
   error estimates.

   IMPORTANT \[LongDash] feyntrop only returns the eps expansion starting from eps^0.
   The backend is therefore restricted to quasi-finite integrals (the
   parametric integrand is finite; any overall \[CapitalGamma]-function divergences from
   \[CapitalSigma]\[Nu] \[Minus] L\[CenterDot]D/2 \[LessEqual] 0 are NOT captured here). For integrals with \[CurlyEpsilon] poles, use
   Method -> "AMFlow", "FIESTA", or "pySecDec".

   Interface: feyntrop reads a JSON blob on stdin and writes a JSON blob to
   stdout.  Input fields:
     "graph"         : list of [[u,v], \[Nu]_e] with 0-indexed vertices,
                       externals numbered 0..n-1 first.
     "scalarproducts": V\[Times]V symmetric matrix of p_u \[CenterDot] p_v. Rows/cols must
                       sum to 0 (momentum conservation); internal-vertex
                       rows/cols are zero.
     "masses_sqr"    : list of m_e^2, one per edge.
     "dimension"     : integer D0 (constant term of Options["Dimension"]).
     "num_eps_terms" : number of expansion terms (Order + 1).
     "lambda"        : contour deformation parameter.
     "N"             : Monte Carlo sample count.
     "seed"          : RNG seed.

   Output "integral" field: [[[Re(I_k), \[CapitalDelta]Re], [Im(I_k), \[CapitalDelta]Im]], ...] for
   k = 0..num_eps_terms-1. feyntrop returns the Feynman-parametric integrand
   WITHOUT the \[CapitalGamma](\[CapitalSigma]\[Nu] \[Minus] L\[CenterDot]D/2) / \[CapitalPi] \[CapitalGamma](\[Nu]_e) prefactor; cross-backend comparison
   requires applying that prefactor by hand or via Normalization hooks.
*)

stEnsureFeyntropBinary[] := Module[{bin = FileNameJoin[{$FeyntropPath, "feyntrop"}]},
	If[stRequireTool["feyntrop"] === $Failed, Return[$Failed]];
	bin
];

(* Build feyntrop's V\[Times]V scalar-product matrix from a KinematicPoint.
   Returns a matrix of rationals/reals indexed 1..V in Mathematica but
   intended to be 0-indexed when serialized to JSON (natural for nested
   List -> array). The external vertices occupy slots 1..nExt; internals
   (slots nExt+1..V) get zero rows/cols \[LongDash] p = 0 at internal vertices. *)
stFeyntropSPMatrix[nodes_List, nInt_Integer, kinPoint_List] := Module[
	{nExt = Length[nodes], V, kinLookup, nodeMasses, mat, genKin, rules},
	V          = nExt + nInt;
	kinLookup  = Association[(ToString[#[[1]]] -> #[[2]]) & /@ kinPoint];
	nodeMasses = nodes[[All, 2]];
	mat        = ConstantArray[0, {V, V}];

	(* Rules that convert GenerateKinematics RHS to numeric values. *)
	rules = Join[
		(* External mass squareds: Subscript[M,i]^2 -> numeric. Use 0 if the
		   node mass is 0 or the named mass-squared is absent from kinPoint. *)
		Table[Module[{nm = nodeMasses[[i]], name, val},
			If[nm === 0,
				Subscript[M, i]^2 -> 0,
				name = If[MatchQ[nm, _Symbol], SymbolName[nm],
					stMmaExprToPython[nm]] <> "sq";
				val = Lookup[kinLookup, name, 0];
				Subscript[M, i]^2 -> val
			]], {i, nExt}],
		(* Mandelstam s_ij -> numeric from kinPoint; fall back to 0. *)
		Flatten @ Table[
			Subscript[s, i, j] -> Lookup[kinLookup,
				"s" <> ToString[i] <> ToString[j], 0],
			{i, nExt}, {j, nExt}]
	];

	If[nExt == 1,
		(* Tadpole: single external with p_1 = -p_1 impossible, so p_1 = 0. *)
		mat[[1, 1]] = 0,
		genKin = GenerateKinematics[nExt];
		Do[Module[{pi, pj, i0, j0, val},
			{pi, pj} = List @@ genKin[[r, 1]];
			i0 = pi[[2]]; j0 = pj[[2]];
			val = genKin[[r, 2]] /. rules;
			If[NumericQ[val],
				mat[[i0, j0]] = val;
				mat[[j0, i0]] = val
			]], {r, Length[genKin]}]
	];

	mat
];

(* Evaluate a symbolic edge mass (like Subscript[m,1] or m) at the
   kinematic point, returning the numeric mass squared.  Returns 0 when the
   mass is 0 or the named value is absent from kinPoint. *)
stFeyntropEdgeMassSq[mass_, kinLookup_] :=
	If[mass === 0,
		0,
		Module[{name = stMmaExprToPython[mass], val},
			val = Lookup[kinLookup, name, None];
			If[NumericQ[val], val^2, 0]
		]
	];

stNIntegrateFeyntrop[{edges_List, nodes_List}, opts___] := Module[
	{order, verbose, kinPoint, exponents, dim, dimInfo, d0,
	 nMC, lambda, seed, nThread,
	 binary, nEdges, nExt, nInt, extVerts, intVerts, allVerts, vertexMap,
	 edgeIndices, remappedEdges, spMatrix, massesSq, kinLookup,
	 jsonStr, rawOut, parsed, integralData, numTerms, coeffs, errs,
	 valSeries, errSeries, envAssoc,
	 t0 = AbsoluteTime[]},

	order     = "Order"           /. {opts} /. "Order"           -> 0;
	verbose   = TrueQ["Verbose"   /. {opts} /. "Verbose"         -> False];
	kinPoint  = stPickKinPointOpts[{opts}];
	exponents = "Exponents"       /. {opts} /. "Exponents"       -> Automatic;
	dim       = "Dimension"       /. {opts} /. "Dimension"       -> 4 - 2 eps;
	nMC       = "MaxEval"         /. {opts} /. "MaxEval"         -> 10^7;
	lambda    = "FeyntropLambda"  /. {opts} /. "FeyntropLambda"  -> 0;
	seed      = "FeyntropSeed"    /. {opts} /. "FeyntropSeed"    -> 0;
	nThread   = "FeyntropNThread" /. {opts} /. "FeyntropNThread" -> Automatic;

	(* Dimension: feyntrop takes an integer D_0 in its JSON; eps expansion
	   is handled internally via num_eps_terms.  The full symbolic `dim` is
	   also used later in the Gamma(omega) prefactor.  Validate upfront so
	   malformed dims (non-integer D0, slope other than -2, nonlinear in
	   eps) error cleanly instead of being silently rounded. *)
	dimInfo = stParseDimension[dim, "feyntrop"];
	If[dimInfo === $Failed, Return[$Failed]];
	d0 = dimInfo["D0"];

	binary = stEnsureFeyntropBinary[];
	If[binary === $Failed, Return[$Failed]];

	(* Vertex remap: nodes[[All,1]] get positions 0..nExt-1 (preserving the
	   user's external ordering); internal vertices get nExt..V-1. *)
	nEdges   = Length[edges];
	extVerts = nodes[[All, 1]];
	nExt     = Length[nodes];
	allVerts = Union[Flatten[edges[[All, 1]]]];
	intVerts = Complement[allVerts, extVerts];
	nInt     = Length[intVerts];
	vertexMap = Association @ Join[
		Thread[extVerts -> Range[0, nExt - 1]],
		Thread[intVerts -> Range[nExt, nExt + nInt - 1]]
	];

	edgeIndices = If[exponents === Automatic,
		ConstantArray[1, nEdges], exponents];
	remappedEdges = Table[
		{{vertexMap[edges[[i, 1, 1]]], vertexMap[edges[[i, 1, 2]]]},
		 edgeIndices[[i]]},
		{i, nEdges}];

	spMatrix = stFeyntropSPMatrix[nodes, nInt, kinPoint];

	kinLookup = Association[(ToString[#[[1]]] -> #[[2]]) & /@ kinPoint];
	massesSq  = Table[stFeyntropEdgeMassSq[edges[[i, 2]], kinLookup], {i, nEdges}];

	jsonStr = ExportString[<|
		"graph"          -> remappedEdges,
		"dimension"      -> d0,
		"scalarproducts" -> spMatrix,
		"masses_sqr"     -> massesSq,
		"num_eps_terms"  -> order + 1,
		"lambda"         -> N[lambda],
		"N"              -> nMC,
		"seed"           -> seed
	|>, "JSON"];

	If[verbose,
		Print["[STNIntegrate/feyntrop] V=", nExt + nInt, " (ext=", nExt,
			" int=", nInt, "), E=", nEdges, ", D_0=", d0,
			", num_eps_terms=", order + 1, ", N=", nMC, ", lambda=", lambda];
		Print["[STNIntegrate/feyntrop] masses_sqr=", massesSq];
		Print["[STNIntegrate/feyntrop] scalarproducts=", spMatrix];
	];

	(* Build env: inherit current env + OMP_NUM_THREADS override if set. *)
	envAssoc = If[nThread === Automatic, Inherited,
		<|"OMP_NUM_THREADS" -> ToString[nThread]|>];

	rawOut = RunProcess[binary, "StandardOutput", jsonStr,
		ProcessEnvironment -> envAssoc];

	parsed = Quiet @ ImportString[rawOut, "RawJSON"];
	If[!AssociationQ[parsed] || !KeyExistsQ[parsed, "integral"],
		Message[STNIntegrate::feyntropfail, rawOut]; Return[$Failed]
	];

	integralData = parsed["integral"];  (* length num_eps_terms *)
	numTerms     = Length[integralData];

	(* integralData[[k]] = {{Re, dRe}, {Im, dIm}}.  Build complex value and
	   error vectors. *)
	coeffs = Table[
		integralData[[k, 1, 1]] + I * integralData[[k, 2, 1]],
		{k, numTerms}];
	errs = Table[
		integralData[[k, 1, 2]] + I * integralData[[k, 2, 2]],
		{k, numTerms}];

	(* Apply the \[CapitalGamma](\[Omega]) / \[CapitalPi] \[CapitalGamma](\[Nu]_e) prefactor so the returned value matches the
	   momentum-space integral (same convention as pySecDec / FIESTA / AMFlow
	   backends). feyntrop's raw "integral" output omits this factor; the
	   shipped tutorial recovers it via eps_expansion(...). *)
	Module[{nLoops = 1 + nEdges - (nExt + nInt),
		nuTot = Total[edgeIndices],
		omegaEps, prefSer, prefCoeffs, minPref, kMax, newCoeffs, newErrs,
		prefErrCoeffs},
		omegaEps = nuTot - nLoops * dim / 2;  (* eps-dependent *)
		prefSer = Series[Gamma[omegaEps] / Product[Gamma[edgeIndices[[e]]],
				{e, nEdges}], {eps, 0, order}];
		(* Extract the Laurent-expanded coefficients of prefSer.  \[CapitalGamma] may have
		   a pole if \[Omega](0) \[LessEqual] 0 (a non-positive integer). *)
		minPref = prefSer[[4]];                  (* leading order *)
		prefCoeffs = prefSer[[3]];                (* coefficient list *)
		kMax = minPref + Length[prefCoeffs] - 1;  (* final order *)
		(* Cauchy product: newCoeffs[[k]] at eps^(k + minPref) for k = 1.. *)
		newCoeffs = Table[
			Sum[
				If[1 <= (k - j + 1) <= Length[prefCoeffs]
				   && 1 <= j <= numTerms,
					prefCoeffs[[k - j + 1]] * coeffs[[j]], 0],
				{j, 1, k}],
			{k, 1, numTerms + Length[prefCoeffs] - 1}];
		(* Errors propagate via |prefactor coefficient| multiplication. *)
		newErrs = Table[
			Sum[
				If[1 <= (k - j + 1) <= Length[prefCoeffs]
				   && 1 <= j <= numTerms,
					Abs[prefCoeffs[[k - j + 1]]] * errs[[j]], 0],
				{j, 1, k}],
			{k, 1, numTerms + Length[prefCoeffs] - 1}];
		(* Truncate to [minPref .. order]. feyntrop gave order+1 terms
		   starting at eps^0; after prefactor the series starts at
		   eps^minPref. Keep up to and including eps^order. *)
		Module[{lo = minPref, hi = order, idxHi},
			idxHi = Min[hi - lo + 1, Length[newCoeffs]];
			newCoeffs = Take[newCoeffs, idxHi];
			newErrs   = Take[newErrs, idxHi];
			valSeries = SeriesData[eps, 0, newCoeffs, lo, hi + 1, 1];
			errSeries = SeriesData[eps, 0, newErrs,   lo, hi + 1, 1];
		]
	];

	{valSeries, errSeries}
];

(* Propagator-list form: feyntrop fundamentally needs the graph topology to
   build the scalar-product matrix, so reject raw propagator lists for now. *)
stNIntegrateFeyntrop[props_List, opts___] /; !MatchQ[props, {_List, _List}] :=
	(Message[STNIntegrate::badmethod,
		"feyntrop backend requires the {edges, nodes} graph form; " <>
		"pass a graph instead of a raw propagator list."];
	$Failed);


