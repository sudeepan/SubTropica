  [em addItemWithTitle:@\"Cut\" action:@selector(cut:) keyEquivalent:@\"x\"];
  [em addItemWithTitle:@\"Copy\" action:@selector(copy:) keyEquivalent:@\"c\"];
  [em addItemWithTitle:@\"Paste\" action:@selector(paste:) keyEquivalent:@\"v\"];
  [em addItemWithTitle:@\"Select All\" action:@selector(selectAll:) keyEquivalent:@\"a\"];
  [ei setSubmenu:em];
  [a setMainMenu:mb];
  D*d=[[D alloc]init];[a setDelegate:d];[a run];}return 0;}
";

  plist = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>
<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">
<plist version=\"1.0\"><dict>
<key>CFBundleExecutable</key><string>STViewer</string>
<key>CFBundleIdentifier</key><string>com.subtropica.viewer</string>
<key>NSAppTransportSecurity</key><dict><key>NSAllowsLocalNetworking</key><true/></dict>
<key>NSHighResolutionCapable</key><true/>
</dict></plist>";

  Quiet[CreateDirectory[appDir]; CreateDirectory[contentsDir]; CreateDirectory[macosDir]];
  Export[plistPath, plist, "Text"];
  Export[srcPath, objcSrc, "Text"];

  stLog["[SubTropica] Compiling native viewer..."];
  res = RunProcess[{"clang", "-framework", "Cocoa", "-framework", "WebKit",
    "-fobjc-arc", "-o", binPath, srcPath}];
  If[res["ExitCode"] =!= 0,
    stErr["[SubTropica] Compile failed (will use browser)"];
    $Failed,
    Export[versionPath, ToString[$STViewerVersion], "Text"];
    stLog["[SubTropica] Viewer ready (v", $STViewerVersion, ")."]; appDir]
];


(* ================================================================== *)
(*  UI DIRECTORY                                                       *)
(* ================================================================== *)

locateUIDirectory[] := Module[{candidates, dir},
  candidates = {
    FileNameJoin[{$SubTropicaInstallDir, "ui"}],
    FileNameJoin[{DirectoryName[$InputFileName], "ui"}],
    FileNameJoin[{NotebookDirectory[], "ui"}],
    (* Flat layout: UI files alongside SubTropica.wl *)
    $SubTropicaInstallDir,
    DirectoryName[$InputFileName],
    NotebookDirectory[],
    Directory[]
  };
  Do[
    If[DirectoryQ[dir] &&
       FileExistsQ[FileNameJoin[{dir, "index.html"}]] &&
       FileExistsQ[FileNameJoin[{dir, "app.js"}]],
      stLog["[SubTropica] UI directory: ", dir];
      Return[dir, Module]],
  {dir, candidates}];
  stErr["[SubTropica] ERROR: Could not find UI directory (need index.html + app.js)"];
  $Failed
];


(* ================================================================== *)
(*  IPC: Process requests from Python server                           *)
(* ================================================================== *)

processOneRequest[reqFile_String] := Module[
  {reqData, action, body, responseBody, respFile, ipcDir},
  reqData = Quiet @ Check[Import[reqFile, "RawJSON"], $Failed];
  If[!AssociationQ[reqData], Return[]];
  action = reqData["action"];
  body = reqData["body"];
  respFile = StringReplace[reqFile, ".request" -> ".response"];
  ipcDir = DirectoryName[reqFile];
  stLog["[SubTropica] Processing: ", action];
  (* All handler Print/Echo output goes to <ipcDir>/kernel.log so the
     UI does not spam the user's notebook front-end. *)
  responseBody = stWithSuppressedOutput[ipcDir,
    Switch[action,
      "lock",           handleLock[body],
      "integrate",      handleIntegrate[body],
      "estimate",       handleEstimate[body],
      "autoMomenta",    handleAutoMomenta[body],
      "solveMomCons",   handleSolveMomCons[body],
      "refreshDiagram", handleRefreshDiagram[body],
      "kinematics",     handleKinematics[body],
      "deleteResult",   handleDeleteResult[body],
      "transformResult", handleTransformResult[body],
      "decodeResult",   handleDecodeResult[body],
      "sendToNotebook", handleSendToNotebook[body],
      "safeExit",       handleSafeExit[body],
      "syncLibrary",    handleSyncLibrary[body],
      "getContributor", handleGetContributor[body],
      "setContributor", handleSetContributor[body],
      _, ExportString[<|"status" -> "error",
           "error" -> "Unknown: " <> ToString[action]|>, "RawJSON"]
    ]];
  Export[respFile, responseBody, "Text", CharacterEncoding -> "UTF-8"];
];

processPendingRequests[ipcDir_String] := Module[{files},
  files = FileNames["*.request", ipcDir];
  Do[Quiet @ Check[processOneRequest[f], Null], {f, files}];
];


(* ================================================================== *)
(*  MAIN ENTRY POINT                                                   *)
(* ================================================================== *)

FeynmanIntegrate[OptionsPattern[]] := Module[{port, url, pythonCmd, scriptPath, uiDir,
    ipcDir, appPath, binPath, serverProc},

  $stVerbose = TrueQ[OptionValue["Verbose"]];
  $uiResult = None;
  $stCommandPrinted = False;

  (* Kill any leftover processes from a previous session *)
  If[$serverObj =!= None,
    Quiet @ KillProcess[$serverObj]; $serverObj = None];
  If[$viewerProcess =!= None,
    Quiet @ KillProcess[$viewerProcess]; $viewerProcess = None];

  (* Use a stable port so the WKWebView origin stays the same across
     sessions, which lets localStorage persist (tour-seen flag, UI
     preferences, etc.).  Fall back to a random port if the preferred
     one is already in use (e.g. another Mathematica session). *)
  port = 52846;
  Module[{sock},
    sock = Quiet[SocketOpen[port, "TCP"], {SocketOpen::zmqinvcmd}];
    If[Head[sock] === SocketObject,
      Quiet[Close[sock]],
      (* Port busy or SocketOpen not available \[LongDash] fall back to random *)
      port = RandomInteger[{49152, 65000}];
      stLog["[SubTropica] Preferred port 52846 busy, using ", port]]];

  If[stRequireTool["python3"] === $Failed, Return[$Failed]];
  pythonCmd = findPython[];
  If[pythonCmd === $Failed,
    stErr["[SubTropica] ERROR: Python 3 not found."];
    Return[$Failed]];

  stLog["[SubTropica] Step 1: Locating UI directory..."];
  uiDir = locateUIDirectory[];
  If[uiDir === $Failed, Return[$Failed]];

  stLog["[SubTropica] Step 2: Preparing directories..."];
  If[!DirectoryQ[$cacheDir], CreateDirectory[$cacheDir]];
  ipcDir = FileNameJoin[{$cacheDir, "ipc"}];
  If[!DirectoryQ[ipcDir], CreateDirectory[ipcDir]];
  (* Clean ALL stale files from previous sessions *)
  Quiet[DeleteFile /@ FileNames["*", ipcDir]];

  stLog["[SubTropica] Step 3: Writing Python server script..."];
  scriptPath = FileNameJoin[{$cacheDir, "server.py"}];
  Export[scriptPath, generatePythonServer[port, uiDir, ipcDir,
    FileNameJoin[{$SubTropicaInstallDir, "library-bundled"}],
    FileNameJoin[{$SubTropicaInstallDir, "library-local"}]], "Text"];
  stLog["[SubTropica]   Script at: ", scriptPath];

  stLog["[SubTropica] Step 4: Starting Python server on port ", port, "..."];
  serverProc = StartProcess[{pythonCmd, scriptPath}];
  $serverObj = serverProc;
  stLog["[SubTropica]   Process: ", serverProc];
  Pause[1.5];
  stLog["[SubTropica]   Status: ", ProcessStatus[serverProc]];
  If[ProcessStatus[serverProc] =!= "Running",
    stErr["[SubTropica] ERROR: Python server not running!"];
    stErr["[SubTropica]   stdout: ",
      Quiet @ Check[ReadString[ProcessConnection[serverProc, "StandardOutput"]], ""]];
    stErr["[SubTropica]   stderr: ",
      Quiet @ Check[ReadString[ProcessConnection[serverProc, "StandardError"]], ""]];
    Return[$Failed]];

  url = "http://127.0.0.1:" <> ToString[port];

  (* Capture the bare server origin (no query string) so STReview[] can
     append its own ?review=1 flag without inheriting theme/mag params. *)
  $stServerURL = url;
  $stServerPort = port;

  (* Detect Mathematica theme and magnification *)
  Module[{isDark, mag},
    isDark = Quiet @ Check[TrueQ[CurrentValue[$FrontEnd, "DarkMode"]], False];
    mag = Quiet @ Check[CurrentValue[$FrontEnd, Magnification], 1.0];
    If[!NumberQ[mag] || mag <= 0, mag = 1.0];
    url = url <> "?theme=" <> If[isDark, "dark", "light"] <>
      "&mag=" <> ToString[NumberForm[mag, {4, 2}]];
    stLog["[SubTropica] Step 5: Server at ", url,
      "  (theme=", If[isDark, "dark", "light"], ", mag=", mag, ")"];
  ];

  stLog["[SubTropica] Step 6: Launching viewer..."];
  appPath = compileNativeViewer[];
  If[appPath =!= $Failed,
    binPath = FileNameJoin[{appPath, "Contents", "MacOS", "STViewer"}];
    $viewerProcess = StartProcess[{binPath, url}];
    stLog["[SubTropica] Native window opened"],
    SystemOpen[url];
    stLog["[SubTropica] Opened in browser"]
  ];

  $integrationPending = False;
  $integrationConfig = None;
  $integrationResult = None;
  $stNotebook = Quiet @ Check[EvaluationNotebook[], $Failed];

  (* Pre-warm parallel kernels while the loading screen is visible.
     The viewer is already open showing the spinner, so the user sees
     "Connecting to kernel..." during this wait. Once kernels are up,
     the ping response carries the count and the status bar updates. *)
  stLog["[SubTropica] Launching parallel kernels..."];
  STSetupKernel[$ProcessorCount - 1];
  Quiet[Export[
    FileNameJoin[{ipcDir, "kernels.json"}],
    ExportString[<|"kernels" -> Length[Kernels[]]|>, "RawJSON"],
    "Text"
  ]];
  (* Write dependency status so the UI knows which verify backends are available *)
  Quiet[Export[
    FileNameJoin[{ipcDir, "deps.json"}],
    ExportString[
      Association @@ Table[
        name -> $STDependencies[name, "status"],
        {name, Keys[$STDependencies]}],
      "RawJSON"],
    "Text"
  ]];
  stLog["[SubTropica]   ", Length[Kernels[]], " kernel(s) ready."];

  stLog["[SubTropica] Ready."];
  While[$uiResult === None,
    processPendingRequests[ipcDir];

    (* Check if integration was requested *)
    If[$integrationPending,
      $integrationPending = False;

      (* Print ONE reproducible STIntegrate command BEFORE integration starts,
         so it survives a kernel crash. Use propagator form if non-unit exponents
         or numerators, otherwise graph form.
         Suppressed for internal calls like LR check. *)
      $stCommandPrinted = True;
      If[TrueQ[$integrationConfig["suppressCommand"]] ||
         !KeyExistsQ[$integrationConfig, "edges"],
        Goto["SkipCommandPrint"]];

      Module[{usePropsForm, numRows2, expList},
        numRows2 = Lookup[$integrationConfig, "numRows", {}];
        expList = Lookup[$integrationConfig, "propExponents", {}];
        usePropsForm = (Length[numRows2] > 0 || !AllTrue[expList, (# === 1) &]);

        If[usePropsForm,
          Module[{propList, momList, massList, nonDefaultOpts, argBoxes, boxes,
                  tempOpts, fullExps},
            tempOpts = KeyDrop[$integrationConfig,
              {"edges", "nodes", "edgeMomenta", "propExponents",
               "numRows", "chordEdges", "loopMomenta", "extMomLabels",
               "nickelIndex", "suppressCommand"}];
            nonDefaultOpts = Select[Normal[tempOpts],
              Function[rule, Module[{key = rule[[1]], val = rule[[2]], def},
                def = key /. Options[STIntegrate];
                def === key || val =!= def
              ]]];
            (* For propagator form: M[i] -> extm rules for STSymanzik.
               Internal masses are already baked into the propagators. *)
            Module[{propSubs, userSubs2},
              propSubs = Table[M[i] -> $extm[[i]], {i, $nl}];
              userSubs2 = Select[
                Lookup[tempOpts, "Substitutions", {}],
                !MatchQ[#, (Subscript[m, _] -> _) | (Subscript[M, _] -> _)] &];
              If[Length[userSubs2] > 0, propSubs = Join[propSubs, userSubs2]];
              nonDefaultOpts = DeleteCases[nonDefaultOpts, "Substitutions" -> _];
              If[Length[propSubs] > 0,
                AppendTo[nonDefaultOpts, "Substitutions" -> propSubs]]];
            momList = $edgeMomenta; massList = $intm;
            propList = Table[
              Module[{prop = momList[[i]]^2},
                If[massList[[i]] =!= 0, prop = prop - massList[[i]]^2]; prop
              ], {i, $ne}];
            fullExps = expList;
            If[Length[numRows2] > 0,
              Do[AppendTo[propList, numRows2[[j, 1]]];
                 AppendTo[fullExps, numRows2[[j, 2]]];
              , {j, Length[numRows2]}]];
            If[!AllTrue[fullExps, (# === 1) &],
              AppendTo[nonDefaultOpts, "Exponents" -> fullExps]];
            argBoxes = Riffle[ToBoxes /@ Join[{propList}, nonDefaultOpts], ","];
            boxes = RowBox[{"STIntegrate", "[", RowBox[argBoxes], "]"}];
            If[TrueQ[$stPrintCells],
              CellPrint[Cell[BoxData[boxes], "Input",
                Evaluatable -> False,
                CellGroupingRules -> "NormalGrouping"]]]
          ],
          (* Graph form *)
          Module[{graphOpts, nonDefaultGraphOpts, argBoxes, boxes},
            graphOpts = KeyDrop[$integrationConfig,
              {"edges", "nodes", "edgeMomenta", "propExponents",
               "numRows", "chordEdges", "loopMomenta", "extMomLabels",
               "nickelIndex", "suppressCommand"}];
            nonDefaultGraphOpts = Select[Normal[graphOpts],
              Function[rule, Module[{key = rule[[1]], val = rule[[2]], def},
                def = key /. Options[STIntegrate];
                def === key || val =!= def
              ]]];
            (* Strip auto-generated mass substitutions \[LongDash] in graph form,
               masses are already encoded in the edge data *)
            nonDefaultGraphOpts = nonDefaultGraphOpts /. ("Substitutions" -> subs_) :>
              ("Substitutions" -> Select[subs,
                !MatchQ[#, (Subscript[m, _] -> _) | (Subscript[M, _] -> _)] &]);
            nonDefaultGraphOpts = DeleteCases[nonDefaultGraphOpts, "Substitutions" -> {}];
            argBoxes = Riffle[ToBoxes /@ Join[
              {{$integrationConfig["edges"], $integrationConfig["nodes"]}},
              nonDefaultGraphOpts], ","];
            boxes = RowBox[{"STIntegrate", "[", RowBox[argBoxes], "]"}];
            If[TrueQ[$stPrintCells],
              CellPrint[Cell[BoxData[boxes], "Input",
                Evaluatable -> False,
                CellGroupingRules -> "NormalGrouping"]]]
          ]
        ]
      ];
      Label["SkipCommandPrint"];

      Module[{progressFile, progressJsonl, resultFile, result, edges, nodes,
              allOpts, resultStr, resolvedCmd, startedAt,
              capturedMsgs, cleanedMsgs},

        startedAt = AbsoluteTime[];
        resolvedCmd = "";
        (* B6: capture every message fired during STEvaluate so the JSON
           response can carry the underlying cause when result is $Failed
           or $Aborted, instead of the opaque "STEvaluate returned an
           error" / "Integration aborted" strings. *)
        capturedMsgs = {};

        progressFile = FileNameJoin[{ipcDir, "progress.log"}];
        progressJsonl = FileNameJoin[{ipcDir, "progress.jsonl"}];
        resultFile = FileNameJoin[{ipcDir, "result.json"}];

        (* Clear any old files *)
        Quiet[DeleteFile[progressFile]];
        Quiet[DeleteFile[progressJsonl]];
        Quiet[DeleteFile[resultFile]];

        (* \[HorizontalLine]\[HorizontalLine] Structured log substrate (axes 1 + 2 of the log redesign).
           progress.jsonl is a line-delimited JSON stream consumed by the UI's
           /api/progress_jsonl endpoint. Each record carries:
             t      - AbsoluteTime[] (Mathematica 1900 epoch)
             level  - "info" | "warn" | "error" (trace/debug reserved)
             kind   - "message" | future event types (stage/timing/setup/\[Ellipsis])
             source - "wrapper" (handler code), "stPrint" / "stEcho"
                      / "stCellPrint" / "stdout" (redirected from STEvaluate)
             text   - human-readable payload
           The plain progress.log stream is still written in parallel for
           backwards compatibility with existing readers and copy-paste. *)
        writeProgressRecord[level_String, kind_String, fields_Association] :=
          Quiet[Module[{s, record, json},
            record = Join[<|"t" -> AbsoluteTime[], "level" -> level,
                            "kind" -> kind|>, fields];
            json = Check[
              ExportString[record, "RawJSON", "Compact" -> True], Null];
            If[StringQ[json],
              s = OpenAppend[progressJsonl, CharacterEncoding -> "UTF-8"];
              WriteString[s,
                StringReplace[json, {"\r" -> " ", "\n" -> " "}] <> "\n"];
              Close[s]
            ]
          ]];

        (* Level-aware emitter: writes to progress.log AND progress.jsonl.
           writeProgress[\[Ellipsis]] delegates to this with level="info"; wrapper-side
           call sites that know their level (errors, warnings) call it
           directly. *)
        writeProgressAt[level_String, source_String, args___] :=
          Quiet[Module[{s, msg},
            msg = StringJoin[ToString[#, OutputForm]& /@ {args}];
            s = OpenAppend[progressFile, CharacterEncoding -> "UTF-8"];
            WriteString[s, msg <> "\n"];
            Close[s];
            writeProgressRecord[level, "message",
              <|"source" -> source, "text" -> msg|>]
          ]];

        (* Auto-level emitter for pass-through stdout/Print from deep inside
           STEvaluate. Sniffs the assembled message for error/warn keywords
           so the UI can color-code without per-call-site changes. *)
        writeProgressAuto[source_String, args___] :=
          Quiet[Module[{s, msg, lvl},
            msg = StringJoin[ToString[#, OutputForm]& /@ {args}];
            lvl = Which[
              StringContainsQ[msg, "ERROR"] ||
                StringContainsQ[msg, "Error:"] ||
                StringContainsQ[msg, "FAILED"] ||
                StringContainsQ[msg, "failed."], "error",
              StringContainsQ[msg, "WARNING"] ||
                StringContainsQ[msg, "Warning"], "warn",
              True, "info"];
            s = OpenAppend[progressFile, CharacterEncoding -> "UTF-8"];
            WriteString[s, msg <> "\n"];
            Close[s];
            writeProgressRecord[lvl, "message",
              <|"source" -> source, "text" -> msg|>]
          ]];

        (* Legacy entry point. Existing call sites keep working unchanged;
           they now dual-write as level="info", source="wrapper". *)
        writeProgress[args___] := writeProgressAt["info", "wrapper", args];

        writeProgress["[SubTropica] Starting integration..."];
        writeProgress[""];

        (* Build edges/nodes for STEvaluate *)
        edges = Table[{$efl[[i]], $intm[[i]]}, {i, $ne}];
        nodes = Table[{$n0r[[i]], $extm[[i]]}, {i, $nl}];
        allOpts = KeyDrop[$integrationConfig,
          {"edges", "nodes", "edgeMomenta", "propExponents",
           "numRows", "chordEdges", "loopMomenta", "extMomLabels",
           "nickelIndex"}];

        (* Default diagram name from Nickel index if auto *)
        If[allOpts["SetProblemID"] === Automatic,
          Module[{nick = $integrationConfig["nickelIndex"]},
            If[StringQ[nick] && StringLength[nick] > 0,
              allOpts = Append[allOpts,
                "SetProblemID" -> StringReplace[nick, {"|" -> "_", ":" -> "_"}]],
              allOpts = Append[allOpts, "SetProblemID" -> "diagram"]]]
        ];

        (* Create UIComms association for structured progress reporting to UI *)
        $stUIComms = <|"IPCDir" -> ipcDir|>;
        allOpts = Append[allOpts, "UIComms" -> $stUIComms];

        (* \[HorizontalLine]\[HorizontalLine] Print the full STEvaluate command to the progress log \[HorizontalLine]\[HorizontalLine] *)
        Module[{edgeStr, nodeStr, optStrs, cmdStr},
          edgeStr = ToString[{edges, nodes}, InputForm];
          optStrs = StringJoin[Riffle[
            (ToString[#[[1]]] <> " -> " <> ToString[#[[2]], InputForm]) & /@
              Normal[allOpts],
            ",\n    "]];
          cmdStr = "STEvaluate[\n  " <> edgeStr <> ",\n    " <> optStrs <> "\n]";
          (* The user-facing Copy button emits STIntegrate[...] (matches the
             library schema + strips default-matching options); the STEvaluate
             form above is still written to the progress log as the in-context
             trace of what the kernel actually ran. *)
          resolvedCmd = Quiet @ Check[stBuildSTCommand[$integrationConfig], ""];
          If[!StringQ[resolvedCmd] || resolvedCmd === "", resolvedCmd = cmdStr];
          writeProgress["[SubTropica] Command:"];
          writeProgress[""];
          writeProgress[cmdStr];
          writeProgress[""];
          writeProgress["==================================================================="];
          writeProgress[""];
        ];

        (* \[HorizontalLine]\[HorizontalLine] Structured "setup" record (axis 3 of the log redesign).
           Authoritative kernel-side snapshot of the integrand data: masses,
           propagator exponents, numerator insertions, topology counters,
           Nickel index, and the fully-resolved STEvaluate[...] command with
           every option expanded. The UI renders this as a collapsible
           "Full setup" panel so pros can verify post-hoc exactly what the
           kernel solved, without re-reading the payload the client sent. *)
        writeProgressRecord["info", "setup", <|
          "source" -> "wrapper",
          "diagramName" -> ToString[Lookup[allOpts, "SetProblemID", ""]],
          "dimension" -> ToString[Lookup[allOpts, "Dimension", Null], InputForm],
          "epsOrder" -> Lookup[allOpts, "EpsilonOrder", 0],
          "internalMasses" -> ToString[$intm, InputForm],
          "externalMasses" -> ToString[$extm, InputForm],
          "propExponents" ->
            ToString[Lookup[$integrationConfig, "propExponents", {}], InputForm],
          "numeratorRows" ->
            Length[Lookup[$integrationConfig, "numRows", {}]],
          "loops" -> $nloops,
          "numEdges" -> $ne,
          "numLegs" -> $nl,
          "nickel" -> ToString[Lookup[$integrationConfig, "nickelIndex", ""]],
          "stCommand" -> resolvedCmd
        |>];

        (* Run STEvaluate with Print AND Echo redirected to progress file.
           Internal`InheritedBlock creates local copies that auto-restore
           on ANY exit  - Abort, Throw, RecursionLimit, etc.
           We intercept Print, Echo, CellPrint, and WriteString to stdout. *)

        (* \[HorizontalLine]\[HorizontalLine] Always compute parametric integrand for Symanzik display in UI \[HorizontalLine]\[HorizontalLine] *)
        (* When there are non-trivial exponents or numerators, use STSymanzik
           directly (same path as the integration), so the displayed Schwinger
           integrand matches the actual computation. Otherwise fall back to
           STGenerateIntegrand for the graph form. *)
        Quiet[Module[{syResult, syTeX, syFile, syPref, syInt, syXvars, syCoeffs,
                       cleanExpr, rawTeX,
                       syPropExps, syNumRows, syUseAdvanced},

          syPropExps = Lookup[$integrationConfig, "propExponents", {}];
          syNumRows = Lookup[$integrationConfig, "numRows", {}];
          syUseAdvanced = (
            AnyTrue[syPropExps, (# =!= 1 && # =!= 1.) &] ||
            Length[syNumRows] > 0
          );

          If[syUseAdvanced,
            (* Advanced path: build propagator + numerator list, call STSymanzik *)
            Module[{syProps, syExps, sySubs, syInput},
              syProps = Table[$edgeMomenta[[i]]^2 - $intm[[i]]^2, {i, $ne}];
              syExps = syPropExps;
              Do[
                AppendTo[syProps, syNumRows[[j, 1]]];
                AppendTo[syExps, syNumRows[[j, 2]]];
              , {j, Length[syNumRows]}];
              sySubs = Table[M[i] -> $extm[[i]], {i, $nl}];
              If[KeyExistsQ[allOpts, "Substitutions"] && allOpts["Substitutions"] =!= {},
                sySubs = Join[sySubs, allOpts["Substitutions"]]];
              syResult = Check[
                SubTropica`STSymanzik[syProps,
                  "Exponents" -> syExps,
                  "Substitutions" -> sySubs,
                  "Dimension" -> allOpts["Dimension"],
                  "LoopMomenta" -> If[AllTrue[$loopMomenta,
                      MatchQ[#, _Symbol | _[_Integer]] &],
                    $loopMomenta, Automatic]],
                Null];
              (* STSymanzik returns {pref, integrand, xvars, coeffs} *)
              If[ListQ[syResult] && Length[syResult] >= 4,
                {syPref, syInt, syXvars, syCoeffs} = syResult;
              ];
            ],
            (* Standard path: graph form via STGenerateIntegrand *)
            syResult = Check[
              SubTropica`STGenerateIntegrand[{edges, nodes},
                "Gauge" -> {},
                FilterRules[Normal[allOpts], Options[SubTropica`STGenerateIntegrand]]],
              Null];
            If[ListQ[syResult] && Length[syResult] >= 4,
              {syPref, syInt, syXvars, syCoeffs} = syResult;
            ];
          ];

          If[ListQ[syXvars] && Length[syXvars] > 0,
            syTeX = Check[
              Module[{},
                (* pref * integrand/(Times@@xvars): same as echoed "Parametric integrand:" *)
                cleanExpr = syPref * syInt / (Times @@ syXvars);
                rawTeX = ToString[cleanExpr, TeXForm];
                (* Remove any remaining context prefixes *)
                StringReplace[rawTeX, RegularExpression["\\w+`"] -> ""]
              ], ""];
            syFile = FileNameJoin[{ipcDir, "symanzik_tex.json"}];
            Export[syFile,
              ExportString[<|"tex" -> syTeX, "nvars" -> Length[syXvars]|>, "RawJSON"],
              "Text", CharacterEncoding -> "UTF-8"];
            writeProgress["[SubTropica] Symanzik representation computed for display."];
          ];
        ], {General::shdw}];

        (* \[HorizontalLine]\[HorizontalLine] Box expression parser: convert Cell/BoxData to readable text \[HorizontalLine]\[HorizontalLine] *)
        boxToText[s_String] := s;
        boxToText[n_Integer] := ToString[n];
        boxToText[n_Real] := ToString[Round[n, 0.000001]];
        boxToText[n_?NumericQ] := ToString[n];
        boxToText[RowBox[items_List]] := StringJoin[boxToText /@ items];
        boxToText[TagBox[content_, EchoLabel|"EchoLabel"]] := boxToText[content];
        boxToText[TagBox[content_, _]] := boxToText[content];
        boxToText[SuperscriptBox[base_, exp_]] := boxToText[base] <> "^(" <> boxToText[exp] <> ")";
        boxToText[SubscriptBox[base_, sub_]] := boxToText[base] <> "_" <> boxToText[sub];
        boxToText[FractionBox[num_, den_]] := "(" <> boxToText[num] <> ")/(" <> boxToText[den] <> ")";
        boxToText[SqrtBox[content_]] := "Sqrt[" <> boxToText[content] <> "]";
        boxToText[StyleBox[content_, ___]] := boxToText[content];
        boxToText[FormBox[content_, ___]] := boxToText[content];
        boxToText[BoxData[content_]] := boxToText[content];
        boxToText[InterpretationBox[_, expr_]] := ToString[expr, InputForm];
        boxToText[TemplateBox[args_, tag_, ___]] := boxToText[RowBox[args]];
        boxToText[ButtonBox[content_, ___]] := boxToText[content];
        boxToText[UnderscriptBox[base_, sub_]] := boxToText[base] <> "_(" <> boxToText[sub] <> ")";
        boxToText[OverscriptBox[base_, over_]] := boxToText[base] <> "^(" <> boxToText[over] <> ")";
        boxToText[GridBox[rows_, ___]] := StringJoin[
          Riffle[boxToText[RowBox[#]]& /@ rows, ", "]];
        (* Fallback: try to convert to expression then InputForm *)
        boxToText[other_] := Quiet @ Check[
          ToString[ToExpression[other, StandardForm], InputForm],
          ToString[other]];

        cellToText[Cell[BoxData[content_], style_:None, ___]] := Module[{prefix, txt},
          prefix = Switch[style,
            Echo, ">> ",
            EchoTiming, "[timing] ",
            _, ""];
          txt = boxToText[content];
          (* Clean up excessive whitespace *)
          txt = StringReplace[txt, {
            RegularExpression["\\s{3,}"] -> " ",
            "  " -> " "}];
          prefix <> txt
        ];
        cellToText[Cell[content_String, ___]] := content;
        cellToText[other_] := ToString[other, OutputForm];

        (* \[HorizontalLine]\[HorizontalLine] Determine integration mode:
             Standard: all \[Nu]_i = 1, no numerators \[RightArrow] STEvaluate[{edges,nodes},...]
             Advanced: non-unit exponents or numerators \[RightArrow] STSymanzik \[RightArrow] STEvaluate \[HorizontalLine]\[HorizontalLine] *)
        Module[{propExps, numRows, useSymanzik, propagators, exponents,
                symResult, stInput, subs},

          propExps = $integrationConfig["propExponents"];
          numRows = $integrationConfig["numRows"];

          useSymanzik = (
            (* Any non-unit propagator exponent? *)
            AnyTrue[propExps, (# =!= 1 && # =!= 1.) &] ||
            (* Any numerator insertions? *)
            (Length[numRows] > 0)
          );

          If[useSymanzik,
            writeProgress["[SubTropica] Non-trivial exponents/numerators detected \[Rule] using STSymanzik"];

            (* Build propagator list: q_i^2 - m_i^2 for each internal edge *)
            propagators = Table[
              $edgeMomenta[[i]]^2 - $intm[[i]]^2,
              {i, $ne}];

            (* Build exponent list: positive for propagators *)
            exponents = propExps;

            (* Append numerator expressions and their (negative) exponents *)
            Do[
              AppendTo[propagators, numRows[[j, 1]]];
              AppendTo[exponents, numRows[[j, 2]]];
            , {j, Length[numRows]}];

            (* Build substitutions: M[i] -> extm for all external legs.
               Using M[i] (not p[i]^2) because STSymanzik internally uses
               M[i] for external masses via basis[n], and p[i]^2 bridging
               fails when p[i] doesn't appear in the propagators. *)
            subs = Table[M[i] -> $extm[[i]], {i, $nl}];
            (* Append user substitutions *)
            If[KeyExistsQ[allOpts, "Substitutions"] && allOpts["Substitutions"] =!= {},
              subs = Join[subs, allOpts["Substitutions"]]
            ];

            writeProgress["  Propagators: ", ToString[propagators, InputForm]];
            writeProgress["  Exponents: ", ToString[exponents, InputForm]];
            writeProgress["  Substitutions: ", ToString[subs, InputForm]];
            writeProgress[""];

            stInput = Quiet[
              SubTropica`STSymanzik[propagators,
                "Exponents" -> exponents,
                "Substitutions" -> subs,
                "Dimension" -> allOpts["Dimension"],
                "LoopMomenta" -> If[AllTrue[$loopMomenta, MatchQ[#, _Symbol | _[_Integer]] &],
                    $loopMomenta, Automatic]],
              General::shdw];

            (* STSymanzik returns integrand in internal convention (includes Times@@xvars measure factor).
               Divide by Times@@xvars to convert to user-facing convention before passing to
               STEvaluateEulerIntegral, which multiplies by Times@@xvars at its input boundary. *)
            If[ListQ[stInput] && Length[stInput] >= 4,
              stInput[[2]] = stInput[[2]] / (Times @@ stInput[[3]])];

            (* Apply normalization  - STSymanzik does not include it in its output,
               same logic as STEvaluateGraphFromPropagators (line 8501).
               LLinternal is set as a side-effect of STSymanzik. *)
            If[ListQ[stInput] && Length[stInput] >= 4,
              Module[{norm},
                norm = If[allOpts["Normalization"] === Automatic,
                  Exp[LLinternal * eps * EulerGamma],
                  allOpts["Normalization"]];
                stInput[[1]] = norm * stInput[[1]];
              ]];

            If[stInput === Null || !ListQ[stInput],
              writeProgressAt["error", "wrapper",
                "[SubTropica] ERROR: STSymanzik returned Null"];
              result = $Failed,
              writeProgress["[SubTropica] STSymanzik completed, piping to STEvaluate..."];
              writeProgress[""];

              (* Check for cancel between STSymanzik and STEvaluate *)
              If[FileExistsQ[FileNameJoin[{ipcDir, "CANCEL"}]],
                Quiet[DeleteFile[FileNameJoin[{ipcDir, "CANCEL"}]]];
                writeProgressAt["warn", "wrapper",
                  "[SubTropica] Cancelled before STEvaluate."];
                result = $Aborted,
              (* Pipe STSymanzik output to STEvaluate.  Drop the `Quiet`
                 here: HandlerBlock streams every message into
                 capturedMsgs so the response JSON can surface the
                 underlying cause when STEvaluate returns $Failed or the
                 kernel aborts (B6). *)
              result = Internal`InheritedBlock[{Print, Echo, CellPrint, WriteString},
                Unprotect[Print];
                Print[args___] := writeProgressAuto["stPrint", args];
                Protect[Print];
                Unprotect[Echo];
                Echo[expr_, rest___] := (writeProgressAuto["stEcho",
                  If[{rest} === {}, ToString[expr, OutputForm],
                     StringJoin[ToString[#]& /@ {rest}] <> ": " <> ToString[expr, OutputForm]]];
                  expr);
                Protect[Echo];
                Unprotect[CellPrint];
                CellPrint[cell_Cell] := writeProgressAuto["stCellPrint", cellToText[cell]];
                CellPrint[other_] := writeProgressAuto["stCellPrint", ToString[other, OutputForm]];
                Protect[CellPrint];
                Unprotect[WriteString];
                WriteString["stdout", args___] := writeProgressAuto["stdout", args];
                Protect[WriteString];

                Internal`HandlerBlock[
                  {"Message", Function[m, AppendTo[capturedMsgs, m]]},
                  CheckAbort[
                    SubTropica`STEvaluate[stInput,
                      Sequence @@ Normal[allOpts]],
                    $Aborted]]
              ]
              ] (* end CANCEL If *)
            ];
            (* Convert Subscript kinematics to plain symbols for consistency
               with the graph path (where homogeneizeKin2 is applied inside SOFIASymanzik).
               In the propagator path M and m are the mass, not mass-squared,
               so M -> Sqrt[MM] ensures M^2 -> MM, matching the graph-path convention.
               Bracket-notation rules (m[i], mm[i]) must come before the bare-symbol
               rules (m -> Sqrt[mm]) to prevent m :> Sqrt[mm] from firing on the head
               of m[i] and producing the nonsensical Sqrt[mm][i]. *)
            If[result =!= $Failed && result =!= $Aborted,
              result = result //. Subscript[s, a___] :> ToExpression["s" <> StringJoin[ToString /@ {a}]]
                             //. Subscript[M, i_] :> Sqrt[ToExpression["MM" <> ToString[i]]]
                             //. Subscript[m, i_] :> Sqrt[ToExpression["mm" <> ToString[i]]]
                             //. mm[i_Integer] :> ToExpression["mm" <> ToString[i]]
                             //. MM[i_Integer] :> ToExpression["MM" <> ToString[i]]
                             //. m[i_Integer] :> Sqrt[ToExpression["mm" <> ToString[i]]]
                             //. M[i_Integer] :> Sqrt[ToExpression["MM" <> ToString[i]]]
                             //. M :> Sqrt[MM] //. m :> Sqrt[mm]];

            (* Re-apply user substitutions after bracket->flat conversion.
               Inside STSymanzik, mass variables use bracket notation mm[i];
               user rules like mm1->xx cannot match there. After the mm[i]->mm<i>
               conversion above, the flat symbols are present and we apply again. *)
            If[result =!= $Failed && result =!= $Aborted &&
               KeyExistsQ[allOpts, "Substitutions"] && ListQ[allOpts["Substitutions"]] &&
               Length[allOpts["Substitutions"]] > 0,
              result = result /. allOpts["Substitutions"]
            ],

            (* Standard path: direct STEvaluate.  See B6 note above.
               HandlerBlock captures messages so the response JSON can
               carry the underlying cause when result is $Failed/$Aborted. *)
            result = Internal`InheritedBlock[{Print, Echo, CellPrint, WriteString},
              Unprotect[Print];
              Print[args___] := writeProgressAuto["stPrint", args];
              Protect[Print];
              Unprotect[Echo];
              Echo[expr_, rest___] := (writeProgressAuto["stEcho",
                If[{rest} === {}, ToString[expr, OutputForm],
                   StringJoin[ToString[#]& /@ {rest}] <> ": " <> ToString[expr, OutputForm]]];
                expr);
              Protect[Echo];
              Unprotect[CellPrint];
              CellPrint[cell_Cell] := writeProgressAuto["stCellPrint", cellToText[cell]];
              CellPrint[other_] := writeProgressAuto["stCellPrint", ToString[other, OutputForm]];
              Protect[CellPrint];
              Unprotect[WriteString];
              WriteString["stdout", args___] := writeProgressAuto["stdout", args];
              Protect[WriteString];

              Internal`HandlerBlock[
                {"Message", Function[m, AppendTo[capturedMsgs, m]]},
                CheckAbort[
                  SubTropica`STEvaluate[{edges, nodes},
                    Sequence @@ Normal[allOpts]],
                  $Aborted]]
            ]
          ];
        ];
        (* All intercepted functions are automatically restored here *)

        (* Check if user cancelled while we were computing *)
        If[FileExistsQ[FileNameJoin[{ipcDir, "CANCEL"}]],
          Quiet[DeleteFile[FileNameJoin[{ipcDir, "CANCEL"}]]];
          writeProgress[""];
          writeProgressAt["warn", "wrapper",
            "[SubTropica] Integration cancelled by user."];
          result = $Aborted;
        ];

        (* Append completion status *)
        writeProgress[""];
        Which[
          result === $Failed,
            writeProgressAt["error", "wrapper",
              "[SubTropica] Integration failed."],
          result === $Aborted,
            writeProgressAt["warn", "wrapper",
              "[SubTropica] Integration aborted."],
          True,
            writeProgressAt["info", "wrapper",
              "[SubTropica] Integration complete."]];

        (* ALWAYS write result.json, no matter what happened.
           B6: when STEvaluate reports failure, attach the cleaned message
           list and result head to the JSON so the UI can surface what
           actually went wrong instead of an opaque generic string. *)
        cleanedMsgs = SubTropica`stCleanupCapturedMessages[capturedMsgs];
        resultStr = Which[
          result === $Aborted,
            ExportString[<|"status" -> "error",
              "error" -> If[cleanedMsgs === {},
                "Integration aborted (RecursionLimit or user abort)",
                "Aborted: " <> StringTake[Last[cleanedMsgs], UpTo[300]]],
              "messages" -> cleanedMsgs,
              "raw" -> "$Aborted"|>, "RawJSON"],
          result === $Failed,
            ExportString[<|"status" -> "error",
              "error" -> If[cleanedMsgs === {},
                "STEvaluate returned an error",
                "Failed: " <> StringTake[First[cleanedMsgs], UpTo[300]]],
              "messages" -> cleanedMsgs,
              "raw" -> "$Failed"|>, "RawJSON"],
          !MatchQ[Head[result], SeriesData | List | Times | Plus | Power |
                  Integer | Rational | Real | Complex | Symbol],
            (* Unrecognized result head \[Dash] surface what we got. *)
            ExportString[<|"status" -> "error",
              "error" -> "STEvaluate returned " <> ToString[Head[result]],
              "messages" -> cleanedMsgs,
              "raw" -> StringTake[ToString[result, InputForm], UpTo[300]]|>,
              "RawJSON"],
          True,
            Module[{sf = stComputeSymbolFields[result], nf, payload},
            payload = <|
              "status" -> "ok",
              "result" -> ToString[result, InputForm],
              "resultDisplay" -> ToString[result, InputForm],
              "resultTeX" -> Quiet @ Check[
                ToString[result, TeXForm], ""],
              "byteCount" -> ByteCount[result],
              "symbolTeX" -> sf[[1]],
              "alphabet" -> sf[[2]],
              "symbolWeight" -> sf[[3]],
              "symbolTerms" -> sf[[4]]
            |>;
            nf = Quiet @ Check[stComputeNormalizedSymbolFields[result], <||>];
            If[Length[nf] > 0,
              payload["normalizedSymbolTeX"] = nf["normalizedSymbolTeX"];
              payload["wDefinitions"] = nf["wDefinitions"];
              payload["normalizedAlphabet"] = nf["normalizedAlphabet"];
              payload["symbolScale"] = nf["symbolScale"];
              payload["normalizedSymbolTerms"] = nf["normalizedSymbolTerms"]];
            ExportString[payload, "RawJSON"]]
        ];
        Export[resultFile, resultStr, "Text", CharacterEncoding -> "UTF-8"];

        stLog["[SubTropica] Integration finished, result.json written."];
        (* Build uiResult with the schema STSaveResult/STSubmitResult expect:
           $integrationConfig is missing internalMasses/externalMasses
           (they're in "edges"/"nodes" as pair lists). Inject sparse nonzero
           lists here so both save paths see the same shape as the
           notebook-invoked STIntegrate path (see line ~9339). *)
        $integrationResult = <|
          "uiResult" -> Join[$integrationConfig, <|
            "internalMasses" -> Select[$intm, # =!= 0 && # =!= 0. &],
            "externalMasses" -> Select[$extm, # =!= 0 && # =!= 0. &]
          |>],
          "result" -> result|>;

        (* Print result to notebook immediately (before user clicks Back) *)
        If[TrueQ[$stPrintCells] &&
           result =!= $Failed && result =!= $Aborted &&
           !TrueQ[$integrationConfig["suppressCommand"]],
          CellPrint[ExpressionCell[result, "Output",
            GeneratedCell -> True, CellAutoOverwrite -> False]]];

        (* Auto-save to local library *)
        If[result =!= $Failed && result =!= $Aborted,
          Quiet @ Check[STSaveResult[$integrationResult],
            stLog["[SubTropica] Warning: auto-save to library failed."]]];
      ]
    ];

    (* Detect viewer window closed (process exited) *)
    If[$viewerProcess =!= None &&
       Quiet[ProcessStatus[$viewerProcess]] =!= "Running",
      stLog["[SubTropica] Viewer window closed."];
      $viewerProcess = None;
      $uiResult = If[AssociationQ[$integrationResult], $integrationResult, $Canceled]];

    If[FileExistsQ[FileNameJoin[{ipcDir, "CANCEL"}]],
      Quiet[DeleteFile[FileNameJoin[{ipcDir, "CANCEL"}]]];
      $uiResult = $Canceled];

    (* Check for Submit button press (independent of DONE) *)
    If[FileExistsQ[FileNameJoin[{ipcDir, "SUBMIT"}]],
      Quiet[DeleteFile[FileNameJoin[{ipcDir, "SUBMIT"}]]];
      If[AssociationQ[$integrationResult] && $integrationResult["result"] =!= $Failed,
        Quiet[Check[STSubmitResult[$integrationResult],
          stLog["[SubTropica] Warning: library submission failed."]],
          {STSubmitResult::argx, General::stop}]
      ]
    ];

    (* --- Numerical verification sentinel --- *)
    If[FileExistsQ[FileNameJoin[{ipcDir, "VERIFY_REQUEST"}]],
      Module[{verifyBody, verifyParsed, method, tolerance, vResult,
              verifyResultFile, edges, nodes, result, order},
        verifyBody = Quiet @ Check[
          Import[FileNameJoin[{ipcDir, "VERIFY_REQUEST"}], "Text"], "{}"];
        Quiet[DeleteFile[FileNameJoin[{ipcDir, "VERIFY_REQUEST"}]]];
        verifyResultFile = FileNameJoin[{ipcDir, "verify_result.json"}];
        Quiet[DeleteFile[verifyResultFile]];

        verifyParsed = Quiet @ Check[ImportString[verifyBody, "RawJSON"], <||>];
        method    = Lookup[verifyParsed, "method", "pySecDec"];
        tolerance = Lookup[verifyParsed, "tolerance", 10^-3];

        stLog["[SubTropica] Verify requested (method=", method, ")"];

        If[!AssociationQ[$integrationResult] ||
           $integrationResult["result"] === $Failed,
          Export[verifyResultFile,
            ExportString[<|"status" -> "error",
              "error" -> "No integration result to verify"|>, "RawJSON"],
            "Text", CharacterEncoding -> "UTF-8"];
          Goto["VerifyDone"]];

        edges  = $integrationConfig["edges"];
        nodes  = $integrationConfig["nodes"];
        result = $integrationResult["result"];
        order  = Lookup[$integrationConfig, "Order", 0];

        (* B7: surface the real cause when STVerify fails.  We use
           Internal`HandlerBlock to stream every fired message into a
           captured list, then attach those to the result association.
           CheckAbort (rather than Check) avoids hijacking the return
           value just because a message fired \[LongDash] STVerify routinely
           Print[]s and Message[]s alongside a normal association
           return (e.g. the feyntropPoles refusal). *)
        vResult = stWithSuppressedOutput[ipcDir,
          Module[{captured = {}, r, msgs},
          Internal`HandlerBlock[
            {"Message", Function[m, AppendTo[captured, m]]},
            r = CheckAbort[
              STVerify[{edges, nodes}, result,
                "Order"     -> order,
                "Tolerance" -> tolerance,
                "Method"    -> method,
                "Verbose"   -> True],
              $Aborted]];
          msgs = stCleanupCapturedMessages[captured];
          Which[
            AssociationQ[r] && KeyExistsQ[r, "pass"],
              If[msgs =!= {}, r["messages"] = msgs]; r,
            r === $Aborted,
              <|"pass" -> False,
                "reason" -> If[msgs === {},
                  "STVerify aborted (no message)",
                  "Aborted: " <> StringTake[Last[msgs], UpTo[300]]],
                "messages" -> msgs|>,
            True,
              <|"pass" -> False,
                "reason" -> "STVerify returned " <> ToString[Head[r]],
                "raw" -> StringTake[ToString[r, InputForm], UpTo[300]],
                "messages" -> msgs|>]]];

        stLog["[SubTropica] Verify result: ",
          If[TrueQ[vResult["pass"]], "PASS", "FAIL"],
          " (relErr=", Lookup[vResult, "maxRelErr", "?"], ")"];

        (* Cache the pass on $integrationResult so STSubmitResult[]
           skips re-verification. Hash-bound: invalidated automatically
           if the user re-integrates with different params. *)
        If[TrueQ[vResult["pass"]] && AssociationQ[$integrationResult],
          $integrationResult["verification"] = <|
            "pass"       -> True,
            "method"     -> method,
            "tolerance"  -> tolerance,
            "maxRelErr"  -> N[Lookup[vResult, "maxRelErr", -1]],
            "kinPoint"   -> Lookup[vResult, "kinPoint",
                                Lookup[vResult, "kinematicPoint", {}]],
            "verifiedAt" -> DateString[],
            "resultHash" -> Hash[result]
          |>];

        Module[{coeffs, kinPoint, coeffsAsc, kinPointStrs, jsonNum},
          (* Per-eps-order comparison rows and the kinematic point used.
             Both power the hover-popup on the verified badge (UI). We
             stringify numeric values and rules so JSON round-trips
             cleanly even for SeriesData / complex numbers.

             jsonNum: STVerify can return maxRelErr / per-coefficient
             relErr as Infinity when the symbolic evaluation falls back
             to N and leaves unevaluated `Integrate\`V[i][j]` heads in
             the result (the comparison is then meaningless and quoted
             as Infinity).  ExportString[..., "RawJSON"] then chokes
             with `jsonstrictencoding: DirectedInfinity cannot be
             exported as JSON`, the entire export returns $Failed, and
             every caller (UI, harness, log) sees the literal string
             "$Failed" instead of a structured error.  Sanitize numeric
             fields here: finite numbers pass through; everything else
             becomes a stringified marker. *)
          jsonNum = Function[v,
            With[{nv = N[v]},
              Which[
                NumericQ[nv] && Abs[nv] < Infinity, nv,
                nv === DirectedInfinity[1] || v === Infinity, "Infinity",
                nv === DirectedInfinity[-1] || v === -Infinity, "-Infinity",
                Head[nv] === DirectedInfinity, "ComplexInfinity",
                nv === Indeterminate, "Indeterminate",
                True, ToString[v, InputForm]]]];
          coeffs = Lookup[vResult, "coefficients", {}];
          coeffsAsc = If[ListQ[coeffs],
            Map[Function[c, <|
              "order"    -> Lookup[c, "order", 0],
              "psd"      -> ToString[Lookup[c, "psd", ""], InputForm],
              "symbolic" -> ToString[Lookup[c, "symbolic", ""], InputForm],
              "relErr"   -> jsonNum[Lookup[c, "relErr", -1]]
            |>], coeffs],
            {}];
          kinPoint = Lookup[vResult, "kinPoint", Lookup[vResult, "kinematicPoint", {}]];
          kinPointStrs = If[ListQ[kinPoint],
            Map[Function[r, If[Head[r] === Rule,
              <|"var" -> ToString[r[[1]], InputForm],
                "value" -> ToString[r[[2]], InputForm]|>,
              <|"var" -> "?", "value" -> ToString[r, InputForm]|>]], kinPoint],
            {}];
          Export[verifyResultFile,
            ExportString[<|
              "status"        -> "ok",
              "pass"          -> TrueQ[vResult["pass"]],
              "reason"        -> Lookup[vResult, "reason", ""],
              "messages"      -> Lookup[vResult, "messages", {}],
              "raw"           -> Lookup[vResult, "raw", ""],
              "maxRelErr"     -> jsonNum[Lookup[vResult, "maxRelErr", -1]],
              "method"        -> method,
              "coefficients"  -> coeffsAsc,
              "kinematicPoint" -> kinPointStrs
            |>, "RawJSON"],
            "Text", CharacterEncoding -> "UTF-8"]];

        Label["VerifyDone"];
      ]
    ];

    If[FileExistsQ[FileNameJoin[{ipcDir, "DONE"}]],
      Quiet[DeleteFile[FileNameJoin[{ipcDir, "DONE"}]]];
      Pause[2.0];  (* Wait for PNG rasterization to complete before import *)

      Module[{pLog = FileNameJoin[{ipcDir, "progress.log"}], logText},
        logText = Quiet @ Check[Import[pLog, "Text"], ""];

        (* Check if this is a cached result from the library *)
        If[!AssociationQ[$integrationResult] || $integrationResult === None,
          Module[{cachedMatch, cachedJSON, cachedExpr},
            cachedMatch = StringCases[logText, "CACHED_RESULT=" ~~ rest__ :> rest];
            If[Length[cachedMatch] > 0,
              cachedJSON = Quiet @ Check[ImportString[cachedMatch[[1]], "RawJSON"], $Failed];
              If[AssociationQ[cachedJSON],
                cachedExpr = If[StringQ[Lookup[cachedJSON, "resultCompressed", None]] &&
                    StringLength[cachedJSON["resultCompressed"]] > 0,
                  Quiet @ Check[Uncompress[cachedJSON["resultCompressed"]], $Failed],
                  $Failed];
                If[cachedExpr === $Failed,
                  cachedExpr = Quiet @ Check[ToExpression[cachedJSON["result"]], cachedJSON["result"]]];
                $integrationResult = <|
                  "uiResult" -> ($integrationConfig /. None -> <||>),
                  "result" -> cachedExpr
                |>;
                stLog["[SubTropica] Using cached result from library."];
              ];
            ];
          ];
        ];

        (* Check if user requested library submission *)
        If[StringQ[logText] && StringContainsQ[logText, "SUBMIT_LIBRARY=1"] &&
           AssociationQ[$integrationResult] && $integrationResult["result"] =!= $Failed,
          Quiet[Check[STSubmitResult[$integrationResult],
            stLog["[SubTropica] Warning: library submission failed."]],
            {STSubmitResult::argx, General::stop}];
        ];
      ];
      $uiResult = $integrationResult];

    Pause[0.1]
  ];

  stLog["[SubTropica] Shutting down..."];
  Quiet @ KillProcess[serverProc];
  $serverObj = None;
  $stServerURL = None;
  $stServerPort = None;
  If[$viewerProcess =!= None,
    Quiet @ KillProcess[$viewerProcess]; $viewerProcess = None];

  (* Import summary card: try PNG first (summary card with result),
     then SVG (bare diagram) as fallback *)
  $diagramImage = Module[{svgPath, pngPath, img},
    svgPath = FileNameJoin[{ipcDir, "diagram.svg"}];
    pngPath = FileNameJoin[{ipcDir, "diagram.png"}];

    (* Try PNG summary card first (includes diagram + params + result) *)
    img = If[FileExistsQ[pngPath],
      stLog["[SubTropica] Found diagram.png: ", FileByteCount[pngPath], " bytes"];
      Quiet @ Import[pngPath],
      None];

    If[Head[img] === Image,
      stLog["[SubTropica] PNG summary card imported"];
      img,
      (* Fallback to SVG vector diagram *)
      img = If[FileExistsQ[svgPath],
        stLog["[SubTropica] Found diagram.svg: ", FileByteCount[svgPath], " bytes"];
        Quiet @ Check[Import[svgPath, "SVG"],
          Quiet @ Check[Import[svgPath, "XML"], None]],
        stLog["[SubTropica] No diagram files in ", ipcDir, " (normal if cancelled)"];
        None];
      If[MatchQ[img, _Graphics],
        stLog["[SubTropica] SVG imported as vector Graphics"];
        img, None]]
  ];

  (* Print tail of progress log for debugging *)
  Module[{pLog = FileNameJoin[{ipcDir, "progress.log"}], tail},
    If[FileExistsQ[pLog],
      tail = Quiet @ Check[Import[pLog, "Text"], ""];
      If[StringQ[tail] && StringLength[tail] > 0,
        Module[{lines = StringSplit[tail, "\n"], lastN},
          lastN = lines[[-Min[10, Length[lines]] ;;]];
          stLog["[SubTropica] Progress log tail:"];
          Do[stLog["  ", ln], {ln, lastN}];
        ]]]];

  Quiet[DeleteFile /@ FileNames["*", ipcDir]];
  stLog["[SubTropica] Done."];

  If[$uiResult === $Canceled, Return[$Failed]];

  stLog["[SubTropica] $uiResult type: ", Head[$uiResult]];
  stLog["[SubTropica] $diagramImage type: ", Head[$diagramImage]];
  If[AssociationQ[$uiResult], stLog["[SubTropica] $uiResult keys: ", Keys[$uiResult]]];

  (* Safe-exit path: user asked to close the GUI cleanly.  The handler
     (handleSafeExit) already sanitized the exported globals and flagged
     $uiResult.  Return a snapshot Association so the caller can inspect
     what survived.  Requested by Giulio, 2026-04-21.
     When silent is set (Save-and-exit button), return Null so no Out[]
     cell prints \[LongDash] the user still has $STGraph / $STQuadruple / etc. set. *)
  If[AssociationQ[$uiResult] && TrueQ[$uiResult["safeExit"]],
    stLog["[SubTropica] Safe-exit requested; kernel globals normalized."];
    If[TrueQ[$uiResult["silent"]], Return[Null]];
    Return[<|"safeExit" -> True,
      "STQuadruple"    -> $STQuadruple,
      "STGraph"        -> $STGraph,
      "STPropagators"  -> $STPropagators|>]];

  (* If integration was already performed via the UI, return stored result *)
  If[AssociationQ[$uiResult] && KeyExistsQ[$uiResult, "result"],
    Module[{ir = $uiResult, uiParams, edges, nodes, diagramName,
            momLabels, nE, chords, intm, extm, diagram},
      uiParams = ir["uiResult"];
      edges = uiParams["edges"]; nodes = uiParams["nodes"];
      momLabels = uiParams["edgeMomenta"]; nE = Length[edges];
      chords = uiParams["chordEdges"];
      intm = edges[[All, 2]]; extm = nodes[[All, 2]];

      (* Print diagram image if available *)
      If[$diagramImage =!= None,
        Quiet @ Check[Print[
          Which[
            Head[$diagramImage] === Image, Show[$diagramImage, ImageSize -> 600],
            MatchQ[$diagramImage, _Graphics], Show[$diagramImage, ImageSize -> 600],
            True, Nothing
          ]], Null]
      ];

      (* Print ONE reproducible STIntegrate command:
         - Propagator form if non-unit exponents, numerators, or non-standard masses
         - Graph form otherwise *)
      If[!TrueQ[$stCommandPrinted] && KeyExistsQ[uiParams, "edges"],
        Module[{usePropsForm, numRows2, expList},
          numRows2 = Lookup[uiParams, "numRows", {}];
          expList = Lookup[uiParams, "propExponents", {}];
          usePropsForm = (Length[numRows2] > 0 ||
            !AllTrue[expList, (# === 1) &]);

          If[usePropsForm,
            (* Propagator form: STIntegrate[{q^2-m^2, ...}, opts] *)
            Module[{allOpts2, propList, massList2, nonDefaultOpts, argBoxes, boxes, fullExps},
              allOpts2 = KeyDrop[uiParams, {"edges", "nodes", "edgeMomenta",
                  "propExponents", "numRows", "chordEdges", "loopMomenta",
                  "extMomLabels", "nickelIndex"}];
              nonDefaultOpts = Select[Normal[allOpts2],
                Function[rule, Module[{key = rule[[1]], val = rule[[2]], def},
                  def = key /. Options[STIntegrate];
                  def === key || val =!= def
                ]]];
              (* For propagator form: M[i] -> extm rules for STSymanzik *)
              Module[{propSubs, userSubs2},
                propSubs = Table[M[i] -> extm[[i]],
                  {i, Length[extm]}];
                userSubs2 = Select[
                  Lookup[allOpts2, "Substitutions", {}],
                  !MatchQ[#, (Subscript[m, _] -> _) | (Subscript[M, _] -> _)] &];
                If[Length[userSubs2] > 0, propSubs = Join[propSubs, userSubs2]];
                nonDefaultOpts = DeleteCases[nonDefaultOpts, "Substitutions" -> _];
                If[Length[propSubs] > 0,
                  AppendTo[nonDefaultOpts, "Substitutions" -> propSubs]]];
              massList2 = edges[[All, 2]];
              propList = Table[
                Module[{prop = momLabels[[i]]^2},
                  If[massList2[[i]] =!= 0, prop = prop - massList2[[i]]^2];
                  prop
                ], {i, Length[momLabels]}];
              fullExps = expList;
              If[Length[numRows2] > 0,
                Do[
                  AppendTo[propList, numRows2[[j, 1]]];
                  AppendTo[fullExps, numRows2[[j, 2]]];
                , {j, Length[numRows2]}]];
              If[!AllTrue[fullExps, (# === 1) &],
                AppendTo[nonDefaultOpts, "Exponents" -> fullExps]];
              argBoxes = Riffle[ToBoxes /@ Join[{propList}, nonDefaultOpts], ","];
              boxes = RowBox[{"STIntegrate", "[", RowBox[argBoxes], "]"}];
              If[TrueQ[$stPrintCells],
              CellPrint[Cell[BoxData[boxes], "Input",
                Evaluatable -> False,
                CellGroupingRules -> "NormalGrouping"]]]
            ],
            (* Graph form: STIntegrate[{edges, nodes}, opts] *)
            Module[{graphOpts, nonDefaultGraphOpts, argBoxes, boxes},
              graphOpts = KeyDrop[uiParams, {"edges", "nodes", "edgeMomenta",
                  "propExponents", "numRows", "chordEdges", "loopMomenta",
                  "extMomLabels", "nickelIndex"}];
              nonDefaultGraphOpts = Select[Normal[graphOpts],
                Function[rule, Module[{key = rule[[1]], val = rule[[2]], def},
                  def = key /. Options[STIntegrate];
                  def === key || val =!= def
                ]]];
              nonDefaultGraphOpts = DeleteCases[nonDefaultGraphOpts, "Substitutions" -> {}];
              argBoxes = Riffle[ToBoxes /@ Join[
                {{edges, nodes}},
                nonDefaultGraphOpts], ","];
              boxes = RowBox[{"STIntegrate", "[", RowBox[argBoxes], "]"}];
              If[TrueQ[$stPrintCells],
              CellPrint[Cell[BoxData[boxes], "Input",
                Evaluatable -> False,
                CellGroupingRules -> "NormalGrouping"]]]
            ]
          ];
        ]
      ];

      (* Result already printed to notebook via CellPrint during integration.
         Return Null to suppress duplicate Out[] cell. *)
      Null
    ],

    (* Fallback: no integration was run via UI, use config for manual evaluation *)
    Module[{result = $integrationConfig, edges, nodes, allOpts, diagramName,
            diagramNameFS, momLabels, nE, chords},
      edges = result["edges"]; nodes = result["nodes"];
      allOpts = KeyDrop[result, {"edges", "nodes", "edgeMomenta",
        "propExponents", "numRows", "chordEdges", "loopMomenta",
        "extMomLabels", "nickelIndex"}];
      momLabels = result["edgeMomenta"]; nE = Length[edges];
      chords = result["chordEdges"];
      diagramName = If[result["SetProblemID"] =!= Automatic,
        result["SetProblemID"], result["nickelIndex"]];
      diagramNameFS = If[StringQ[diagramName],
        StringReplace[diagramName, {"|" -> "_", ":" -> "_"}], diagramName];
      allOpts = Append[allOpts, "SetProblemID" -> diagramNameFS];

      (* Print diagram *)
      Quiet @ Check[Print[Show[
        SubTropica`FeynmanPlot[{edges, nodes},
          SubTropica`EdgesLabel -> If[Length[momLabels] == nE && !MatchQ[momLabels, {Null ..}],
            momLabels /. {h_Symbol[n_Integer] :> Subscript[h, n]}, Range[nE]],
          If[Length[chords] > 0, SubTropica`HighlightedEdges -> chords, Sequence @@ {}]],
        ImageSize -> 350,
        PlotLabel -> If[diagramName =!= "" && diagramName =!= Null,
          Style[diagramName, Bold, 14], None]]], Null];

      (* Print ONE STIntegrate command *)
      If[!TrueQ[$stCommandPrinted] && KeyExistsQ[result, "edges"],
        Module[{usePropsForm, numRows2, expList},
          numRows2 = Lookup[result, "numRows", {}];
          expList = Lookup[result, "propExponents", {}];
          usePropsForm = (Length[numRows2] > 0 ||
            !AllTrue[expList, (# === 1) &]);

          If[usePropsForm,
            Module[{propList, massList2, nonDefaultOpts, argBoxes, boxes, fullExps2},
              massList2 = edges[[All, 2]];
              nonDefaultOpts = Select[Normal[allOpts],
                Function[rule, Module[{key = rule[[1]], val = rule[[2]], def},
                  def = key /. Options[STIntegrate];
                  def === key || val =!= def
                ]]];
              (* For propagator form: M[i] -> extm rules for STSymanzik *)
              Module[{propSubs, userSubs2, extm2},
                extm2 = nodes[[All, 2]];
                propSubs = Table[M[i] -> extm2[[i]],
                  {i, Length[extm2]}];
                userSubs2 = Select[
                  Lookup[allOpts, "Substitutions", {}],
                  !MatchQ[#, (Subscript[m, _] -> _) | (Subscript[M, _] -> _)] &];
                If[Length[userSubs2] > 0, propSubs = Join[propSubs, userSubs2]];
                nonDefaultOpts = DeleteCases[nonDefaultOpts, "Substitutions" -> _];
                If[Length[propSubs] > 0,
                  AppendTo[nonDefaultOpts, "Substitutions" -> propSubs]]];
              propList = Table[
                Module[{prop = momLabels[[i]]^2},
                  If[massList2[[i]] =!= 0, prop = prop - massList2[[i]]^2];
                  prop
                ], {i, nE}];
              fullExps2 = expList;
              If[Length[numRows2] > 0,
                Do[
                  AppendTo[propList, numRows2[[j, 1]]];
                  AppendTo[fullExps2, numRows2[[j, 2]]];
                , {j, Length[numRows2]}]];
              If[!AllTrue[fullExps2, (# === 1) &],
                AppendTo[nonDefaultOpts, "Exponents" -> fullExps2]];
              argBoxes = Riffle[ToBoxes /@ Join[{propList}, nonDefaultOpts], ","];
              boxes = RowBox[{"STIntegrate", "[", RowBox[argBoxes], "]"}];
              If[TrueQ[$stPrintCells],
              CellPrint[Cell[BoxData[boxes], "Input",
                Evaluatable -> False,
                CellGroupingRules -> "NormalGrouping"]]]
            ],
            (* Graph form *)
            Module[{nonDefaultGraphOpts, argBoxes, boxes},
              nonDefaultGraphOpts = Select[Normal[allOpts],
                Function[rule, Module[{key = rule[[1]], val = rule[[2]], def},
                  def = key /. Options[STIntegrate];
                  def === key || val =!= def
                ]]];
              nonDefaultGraphOpts = DeleteCases[nonDefaultGraphOpts, "Substitutions" -> {}];
              argBoxes = Riffle[ToBoxes /@ Join[
                {{edges, nodes}},
                nonDefaultGraphOpts], ","];
              boxes = RowBox[{"STIntegrate", "[", RowBox[argBoxes], "]"}];
              If[TrueQ[$stPrintCells],
              CellPrint[Cell[BoxData[boxes], "Input",
                Evaluatable -> False,
                CellGroupingRules -> "NormalGrouping"]]]
            ]
          ];
        ]
      ];
      SubTropica`STEvaluate[{edges, nodes}, Sequence @@ Normal[allOpts]]
    ]
  ]
];

(* ================================================================== *)
(*  LIBRARY: Save, Submit, Rebuild                                     *)
(* ================================================================== *)

(* Sanitize Nickel index for use as directory name: | -> _ *)
stSanitizeNickel[s_String] := StringReplace[s, {"|" -> "_", ":" -> "_"}];

(* Count independent kinematic scales in a config:
   n(n-3)/2 Mandelstam invariants + distinct masses - substitutions *)
stCountScales[config_Association] := Module[
    {nLegs, nMandelstam, masses, nDistinctMasses, subs, nSubs},
    nLegs = If[KeyExistsQ[config, "nodes"], Length[config["nodes"]], 0];
    nMandelstam = Max[0, nLegs (nLegs - 3) / 2];
    masses = DeleteDuplicates @ DeleteCases[
        Join[
            If[KeyExistsQ[config, "edges"], config["edges"][[All, 2]], {}],
            If[KeyExistsQ[config, "nodes"], config["nodes"][[All, 2]], {}]
        ], 0 | 0.];
    nDistinctMasses = Length[masses];
    subs = Lookup[config, "Substitutions", {}];
    nSubs = If[ListQ[subs], Length[subs], 0];
    Max[0, nMandelstam + nDistinctMasses - nSubs]
];

(* Reconstruct the STIntegrate command string for reproducibility *)
stBuildSTCommand[config_Association] := Module[{edges, nodes, opts, defaults, nonDefault},
    edges = Lookup[config, "edges", {}];
    nodes = Lookup[config, "nodes", {}];
    opts = KeyDrop[config, {"edges", "nodes", "edgeMomenta", "propExponents",
        "numRows", "chordEdges", "loopMomenta", "extMomLabels", "nickelIndex",
        "suppressCommand"}];
    (* Strip options that match STIntegrate defaults at save time,
       so the stored command stays correct even if defaults change later *)
    defaults = Association[Options[STIntegrate]];
    nonDefault = Select[Normal[opts],
        Function[rule, Module[{key = rule[[1]], val = rule[[2]]},
            !KeyExistsQ[defaults, key] || val =!= defaults[key]]]];
    If[Length[nonDefault] == 0,
        "STIntegrate[" <> ToString[{edges, nodes}, InputForm] <> "]",
        "STIntegrate[" <> ToString[{edges, nodes}, InputForm] <> ", " <>
            StringJoin[Riffle[
                (* InputForm on keys too, so string keys render as
                   "Substitutions" (with quotes) rather than a bare
                   Substitutions symbol -- matches Options[STIntegrate]. *)
                (ToString[#[[1]], InputForm] <> " -> " <>
                    ToString[#[[2]], InputForm]) & /@
                    nonDefault, ", "]] <> "]"
    ]
];

(* \[HorizontalLine]\[HorizontalLine] STSaveResult \[HorizontalLine]\[HorizontalLine] *)

Options[STSaveResult] = {
    (* Root directory under which the <topology>/<massconfig>/entry.json tree
       lives.  Default Automatic \[RightArrow] $SubTropicaInstallDir/library-local
       (user's private staging area).  Pass an absolute path to redirect,
       e.g. for release-prep writes into the shipped library-bundled tree. *)
    "LibraryPath" -> Automatic};

(* Helper: compute the library MassConfig association from a graph's
   edges and nodes (Mathematica lists, not strings).  Port of
   scripts/library_audit/compute_mass_config.py so new-entry saves
   produce the field inline without shelling out. *)
stComputeMassConfigFromGraph[edges_List, nodes_List] := Module[
    {edgeMasses, nodeMasses, distinct, edgeIdx, pattern, nEdges,
     nMassive, nMassless, extLabels, nExt, nExtOff, nExtMassless, sig},
    edgeMasses = edges[[All, 2]];
    nodeMasses = If[Length[nodes] > 0, nodes[[All, 2]], {}];
    nEdges = Length[edges];

    distinct = {};
    edgeIdx = Table[
        Module[{m = edgeMasses[[k]]},
            If[m === 0 || m === 0., 0,
                If[!MemberQ[distinct, m], AppendTo[distinct, m]];
                FirstPosition[distinct, m][[1]]]],
        {k, nEdges}];
    pattern = StringJoin[ToString /@ edgeIdx];
    nMassive = Count[edgeIdx, n_Integer /; n > 0];
    nMassless = nEdges - nMassive;

    extLabels = nodeMasses;
    nExt = Length[extLabels];
    nExtOff = Count[extLabels, m_ /; m =!= 0 && m =!= 0.];
    nExtMassless = nExt - nExtOff;
    sig = StringJoin @ Table[
        If[extLabels[[k]] === 0 || extLabels[[k]] === 0., "0", "M"],
        {k, nExt}];

    <|
        "numEdges" -> nEdges,
        "numMassiveEdges" -> nMassive,
        "numMasslessEdges" -> nMassless,
        "distinctInternalMasses" -> Length[distinct],
        "internalMassLabels" -> (ToString[#, InputForm] & /@ distinct),
        "edgeMassPattern" -> pattern,
        "numExtLegs" -> nExt,
        "numOnshellMassiveExtLegs" -> nExtOff,
        "numMasslessExtLegs" -> nExtMassless,
        "extLegSignature" -> sig
    |>];

(* Helper: compute the un-gauged quadruple integrand string.  Used to
   stamp the `quadruple` field on new library entries.  Returns Null
   on hard failure so the caller can write `quadruple -> null` without
   blowing up.

   The UI-driven integration path stringifies Dimension / Substitutions
   for JSON serialization (see line ~12981 and ~13330); parse those
   back to Mathematica expressions before forwarding so
   STGenerateIntegrand receives the right types. *)
stComputeQuadrupleForLibrary[edges_List, nodes_List, opts_List] := Module[
    {raw, filteredOpts, dim, subs, parsed},
    dim  = "Dimension"     /. opts /. "Dimension"     -> (4 - 2 eps);
    subs = "Substitutions" /. opts /. "Substitutions" -> {};
    dim  = If[StringQ[dim],
        Quiet @ Check[ToExpression[dim], 4 - 2 eps], dim];
    subs = If[StringQ[subs],
        Quiet @ Check[ToExpression[subs], {}], subs];
    If[!ListQ[subs], subs = {}];
    raw = Quiet[STGenerateIntegrand[{edges, nodes}, "Gauge" -> {},
        "Dimension" -> dim, "Substitutions" -> subs]];
    (* STGenerateIntegrand returns a 4-list on success, or $Failed / 0
       (scaleless) on failure.  Only accept the 4-list shape. *)
    If[MatchQ[raw, {_, _, _List, _List}],
        ToString[raw, InputForm],
        Null]];

(* Helper: after writing a fresh entry.json, shell out to the
   diagram-naming pipeline.  Best-effort \[LongDash] failures are logged but
   don't break the save. *)
stStampCanonicalName[entryPath_String] := Module[
    {script, py, proc},
    script = FileNameJoin[{$SubTropicaInstallDir,
        "scripts", "library_audit", "compute_diagram_name.py"}];
    If[!FileExistsQ[script], Return[$Failed]];
    py = If[ValueQ[$PythonCommand] && StringQ[$PythonCommand],
        $PythonCommand, "python3"];
    proc = Quiet @ Check[
        RunProcess[{py, script, "--write", entryPath},
            "ExitCode", ProcessEnvironment -> Inherited],
        $Failed];
    If[proc === 0, Null, $Failed]];

STSaveResult[opts:OptionsPattern[]] := STSaveResult[$integrationResult, opts];

STSaveResult[ir_Association, opts:OptionsPattern[]] := Module[
    {config, result, nickel, topoNickel, massNickel,
     libRoot, topoDir, configDir, topoPath, entryPath,
     existingEntry, newRecord, timestamp},

    libRoot = OptionValue["LibraryPath"];
    If[libRoot === Automatic,
        libRoot = FileNameJoin[{$SubTropicaInstallDir, "library-local"}]];
    If[!StringQ[libRoot],
        stErr["[SubTropica] STSaveResult: LibraryPath must be Automatic or a path string."];
        Return[$Failed]];

    If[!AssociationQ[ir] || !KeyExistsQ[ir, "result"] || !KeyExistsQ[ir, "uiResult"],
        stErr["[SubTropica] STSaveResult: no valid integration result to save."];
        Return[$Failed]];

    config = ir["uiResult"];
    result = ir["result"];

    If[result === $Failed || result === $Aborted,
        stErr["[SubTropica] STSaveResult: result is ", result, ", nothing to save."];
        Return[$Failed]];

    nickel = Lookup[config, "nickelIndex", ""];
    If[!StringQ[nickel] || StringLength[nickel] == 0,
        stErr["[SubTropica] STSaveResult: empty Nickel index, using \"unknown\"."];
        nickel = "unknown"];

    (* Split CNickelIndex into topology + mass config for directory paths.
       Massless topologies (no colon) use an all-zeros config with matching
       pipe structure (e.g. "ee12|e2|e|" \[RightArrow] "0000|00|0|"). *)
    If[StringContainsQ[nickel, ":"],
        {topoNickel, massNickel} = StringSplit[nickel, ":", 2],
        topoNickel = nickel;
        massNickel = StringReplace[nickel, c:Except["|"] :> "0"]];

    topoDir = FileNameJoin[{libRoot, stSanitizeNickel[topoNickel]}];
    configDir = FileNameJoin[{topoDir, stSanitizeNickel[massNickel]}];

    timestamp = DateString[{"Year", "-", "Month", "-", "Day", "T",
        "Hour", ":", "Minute", ":", "Second"}];

    (* Result record schema (shared with STSubmitResult and submit.yml). *)
    (* $integrationConfig stores numerators under "numRows" as a list of
       {expression, integer} pairs; the stored format is a list of
       {InputForm_string, integer} pairs to match STIntegrate's own
       uiResult schema. Look up both keys and convert as needed. *)
    newRecord = <|
        "resultCompressed" -> Compress[result],
        "resultTeX" -> stResultToTeX[result][[1]],
        "dimension" -> Module[{d = Lookup[config, "Dimension", "4-2*eps"]},
            If[StringQ[d], d, ToString[d, InputForm]]],
        "epsOrder" -> Lookup[config, "Order", 0],
        "propExponents" -> Lookup[config, "propExponents", {}],
        (* Propagator list entries are typically expressions (p[1]^2-m^2
           etc.) -- stringify to InputForm for JSON-safety. *)
        "propagators" -> Map[
            Function[p, If[NumericQ[p] || StringQ[p], p,
                ToString[p, InputForm]]],
            Lookup[config, "propagators", {}]],
        "numerators" -> Module[{nr},
            nr = Lookup[config, "numRows", Lookup[config, "numerators", {}]];
            If[ListQ[nr] && Length[nr] > 0,
                {ToString[#[[1]], InputForm], #[[2]]} & /@ nr,
                {}]],
        (* Stringify non-numeric mass expressions so RawJSON doesn't
           choke on symbols like Subscript[m,1]. safeToExpr round-trips
           each element on load; plain numbers pass through unchanged. *)
        "internalMasses" -> Map[
            Function[m, If[NumericQ[m] || StringQ[m], m,
                ToString[m, InputForm]]],
            Lookup[config, "internalMasses", {}]],
        "externalMasses" -> Map[
            Function[m, If[NumericQ[m] || StringQ[m], m,
                ToString[m, InputForm]]],
            Lookup[config, "externalMasses", {}]],
        "substitutions" -> Module[{s = Lookup[config, "Substitutions", {}]},
            If[StringQ[s], s, ToString[s, InputForm]]],
        "normalization" -> Module[{n = Lookup[config, "Normalization", Automatic]},
            If[StringQ[n], n, ToString[n, InputForm]]],
        "stVersion" -> "SubTropica v" <> $SubTropicaVersion,
        "stCommand" -> stBuildSTCommand[config],
        "contributor" -> stGetContributorField[],
        "timestamp" -> timestamp,
        "byteCount" -> ByteCount[result]
    |>;

    (* FindRoots algebraic letters: structured metadata per surviving index.
       The list is empty when no Wm/Wp atoms appear in `result`.  Legacy
       rootSubstitutions string dual-write was removed in v1.0.455. *)
    Module[{algLetters = stExtractAlgebraicLetters[]},
      If[algLetters =!= {} && !FreeQ[result, (Wm | Wp)[_Integer]],
        newRecord["algebraicLetters"] = algLetters]];

    (* Compute symbol and alphabet *)
    Module[{sf = stComputeSymbolFields[result]},
      newRecord["symbolTeX"] = sf[[1]];
      newRecord["alphabet"] = sf[[2]];
      newRecord["symbolWeight"] = sf[[3]];
      newRecord["symbolTerms"] = sf[[4]]];

    (* Compute normalized symbol with W_i labels *)
    Module[{nf = stComputeNormalizedSymbolFields[result]},
      If[Length[nf] > 0,
        newRecord["normalizedSymbolTeX"] = nf["normalizedSymbolTeX"];
        newRecord["wDefinitions"] = nf["wDefinitions"];
        newRecord["normalizedAlphabet"] = nf["normalizedAlphabet"];
        newRecord["symbolScale"] = nf["symbolScale"];
        newRecord["normalizedSymbolTerms"] = nf["normalizedSymbolTerms"];
      ]];

    (* Compute canonical leg ordering *)
    newRecord["legOrder"] = Quiet @ Check[
      stComputeLegOrder[newRecord["stCommand"]], {}];

    (* Create topology directory + topology.json if needed *)
    topoPath = FileNameJoin[{topoDir, "topology.json"}];
    If[!FileExistsQ[topoPath],
        Quiet[CreateDirectory[topoDir, CreateIntermediateDirectories -> True]];
        Module[{nEdges, nLegs, nLoopsCalc},
          nEdges = Length[Lookup[config, "edges", {}]];
          nLegs = Length[Lookup[config, "nodes", {}]];
          (* L = E - V + 1 where V = number of distinct vertices in edges *)
          nLoopsCalc = Quiet @ Check[
            Module[{verts = DeleteDuplicates[Flatten[Lookup[config, "edges", {}][[All, 1]]]]},
              nEdges - Length[verts] + 1], $nloops];
          Export[topoPath, <|
              "NickelIndex" -> topoNickel,
              "Loops" -> nLoopsCalc,
              "Legs" -> nLegs,
              "Propagators" -> nEdges,
              "LoopediaURL" -> ""
          |>, "RawJSON"];
        ];
        stLog["[SubTropica] Created topology: ", topoPath];
    ];

    (* Create config directory + entry.json, or update existing *)
    entryPath = FileNameJoin[{configDir, "entry.json"}];
    If[FileExistsQ[entryPath],
        (* Update existing entry: append to Results *)
        existingEntry = Quiet @ Check[Import[entryPath, "RawJSON"], $Failed];
        If[existingEntry === $Failed || !AssociationQ[existingEntry],
            (* Corrupt file: back up and recreate *)
            CopyFile[entryPath,
                entryPath <> ".bak-" <> DateString[{"Year","Month","Day","-","Hour","Minute","Second"}]];
            existingEntry = <|
                "CNickelIndex" -> nickel,
                "MassScales" -> stCountScales[config],
                "FunctionClass" -> "MPL",
                "EpsilonOrder" -> ToString[Lookup[config, "Order", 0]],
                "References" -> {},
                "Records" -> {},
                "Source" -> "SubTropica",
                "Results" -> {}
            |>;
        ];
        (* Check for duplicate. The match key is every result-altering field \[LongDash]
           keep this in sync with lookupLibraryResult() in ui/app.js so that
           whatever gets saved here can later be found on exact-match lookup.
           TODO: when soft-transform lookup is re-added (see TODO in app.js),
           revisit whether substitutions/normalization should drop out of the
           dedup key so rewrite-equivalent results collapse to one entry. *)
        Module[{existingResults, isDuplicate},
          existingResults = Lookup[existingEntry, "Results", {}];
          isDuplicate = AnyTrue[existingResults, Function[r,
            Lookup[r, "dimension", ""] === newRecord["dimension"] &&
            Lookup[r, "epsOrder", -999] === newRecord["epsOrder"] &&
            Lookup[r, "propExponents", {}] === newRecord["propExponents"] &&
            Lookup[r, "numerators", {}] === newRecord["numerators"] &&
            Lookup[r, "internalMasses", {}] === newRecord["internalMasses"] &&
            Lookup[r, "externalMasses", {}] === newRecord["externalMasses"] &&
            Lookup[r, "substitutions", ""] === newRecord["substitutions"] &&
            Lookup[r, "normalization", "Automatic"] === newRecord["normalization"]
          ]];
          If[isDuplicate,
            stLog["[SubTropica] STSaveResult: duplicate result, skipping."];
            Return[newRecord],
            existingEntry["Results"] = Append[existingResults, newRecord];
            Export[entryPath, existingEntry, "RawJSON"]
          ]
        ],
        (* New entry: write the full schema so no library-audit pass is
           needed to bring the entry up to parity with the rest of
           library-bundled/.  Fields:
             - CNickelIndex, MassScales, FunctionClass, EpsilonOrder,
               References, Records, Source  \[LongDash] the original minimal set.
             - edges, nodes, Loops, NumPropagators \[LongDash] structural fields
               needed by compute_mass_config.py and the naming pipeline.
             - MassConfig  \[LongDash] inline via stComputeMassConfigFromGraph
               (port of compute_mass_config.py).
             - quadruple   \[LongDash] inline via STGenerateIntegrand with the
               same {Dimension, Substitutions, MethodLR, FindRoots}
               options the integration ran with.
             - Names, ParentSectors, Subsectors, commonNames \[LongDash] set to
               sensible defaults ({}, {}, {}, null); library-wide
               passes can later fill them.
             - CanonicalName \[LongDash] initially null; after writing, shell out
               to compute_diagram_name.py to stamp the canonical name
               from data/topology_names.json. *)
        Quiet[CreateDirectory[configDir, CreateIntermediateDirectories -> True]];
        Module[{graphEdges, graphNodes, graphLoops, graphNumProps,
                graphMassConfig, graphQuadruple, integrationOpts,
                allOpts, newEntry},
            graphEdges = Lookup[config, "edges", {}];
            graphNodes = Lookup[config, "nodes", {}];
            graphNumProps = Length[graphEdges];
            graphLoops = Module[{verts},
                verts = DeleteDuplicates[Flatten[
                    If[graphNumProps > 0, graphEdges[[All, 1]], {}]]];
                graphNumProps - Length[verts] + 1];
            graphMassConfig = stComputeMassConfigFromGraph[graphEdges, graphNodes];
            (* Reconstruct the option list STIntegrate was called with so
               STGenerateIntegrand produces a matching integrand. *)
            integrationOpts = {
                "Dimension"     -> Lookup[config, "Dimension", 4 - 2 eps],
                "Substitutions" -> Lookup[config, "Substitutions", {}],
                "MethodLR"      -> Lookup[config, "MethodLR", Automatic],
                "FindRoots"     -> Lookup[config, "FindRoots", False]};
            graphQuadruple = stComputeQuadrupleForLibrary[
                graphEdges, graphNodes, integrationOpts];

            newEntry = <|
                "CNickelIndex" -> nickel,
                "MassScales" -> stCountScales[config],
                "FunctionClass" -> "MPL",
                "EpsilonOrder" -> ToString[Lookup[config, "Order", 0]],
                "Loops" -> graphLoops,
                "NumPropagators" -> graphNumProps,
                "MassConfig" -> graphMassConfig,
                "CanonicalName" -> Null,
                "Names" -> {},
                "References" -> {},
                "Records" -> {},
                "Source" -> "SubTropica",
                "ParentSectors" -> {},
                "Subsectors" -> {},
                "commonNames" -> Null,
                "edges" -> ToString[graphEdges, InputForm],
                "nodes" -> ToString[graphNodes, InputForm],
                "quadruple" -> graphQuadruple,
                "Results" -> {newRecord}
            |>;
            Export[entryPath, newEntry, "RawJSON"]];

        (* Best-effort CanonicalName stamp via the Python naming pipeline.
           Only runs when compute_diagram_name.py can resolve \[LongDash] if the
           topology is missing from data/topology_names.json the field
           stays null, which is the same default downstream code already
           handles. *)
        Quiet @ Check[stStampCanonicalName[entryPath], Null];
    ];

    stLog["[SubTropica] Result saved to: ", entryPath];

    (* Rebuild library.json so the UI picks up the new entry *)
    Quiet @ Check[STBuildLibraryJSON[], Null];

    newRecord
];


(* \[HorizontalLine]\[HorizontalLine] STSubmitResult \[HorizontalLine]\[HorizontalLine] *)

$STSubmitURL = "https://subtropica-submit.subtropica.workers.dev/submit";
$STManifestURL = "https://raw.githubusercontent.com/SubTropica/SubTropica/main/library-bundled/manifest.json";
$STRawBaseURL = "https://raw.githubusercontent.com/SubTropica/SubTropica/main/library-bundled/";

(* Verification gate: every STSubmitResult must carry a passing STVerify
   record bound to the exact result expression by Hash. Either the caller
   ran STVerify earlier (UI verify button or notebook) and the handler
   stashed a record on $integrationResult["verification"], or we run
   STVerify inline here with the library default (1 kinematic point,
   pySecDec, Tolerance 10^-3). Backend failure aborts submission and
   suggests alternates (AMFlow / FIESTA / feyntrop) rather than retrying
   automatically \[LongDash] a different numerical backend may succeed where
   the default fails (shared mass, non-Euclidean, etc.). Returns the
   verification Association on success or $Failed on failure. *)
stGateVerification[ir_Association, opts___] := Module[
    {cachedV, result, config, edges, nodes, order, vResult, method, tol,
     numSamples, fwdOpts, rec},
    result = ir["result"];
    config = ir["uiResult"];

    (* 1. Cache hit: pass + bound to *this* exact result expression. *)
    cachedV = Lookup[ir, "verification", None];
    If[AssociationQ[cachedV] && TrueQ[cachedV["pass"]] &&
       cachedV["resultHash"] === Hash[result],
        stLog["[SubTropica] STSubmitResult: reusing cached verification (",
            Lookup[cachedV, "method", "?"], ", maxRelErr=",
            Lookup[cachedV, "maxRelErr", "?"], ")."];
        Return[cachedV]];

    (* 2. No cache hit. Need edges/nodes to run STVerify in graph form.
         Prefer the uiResult association we already have on $integrationResult
         (populated by notebook STIntegrate[{edges,nodes}, ...]); fall back to
         $integrationConfig for the UI/HTTP path (populated in stSubmitHandler).
         If both are missing, the user must call STVerify explicitly. *)
    edges = Lookup[config, "edges",
        If[AssociationQ[$integrationConfig], Lookup[$integrationConfig, "edges", None], None]];
    nodes = Lookup[config, "nodes",
        If[AssociationQ[$integrationConfig], Lookup[$integrationConfig, "nodes", None], None]];
    If[edges === None || nodes === None,
        stErr["[SubTropica] STSubmitResult: no cached verification and ",
            "no edges/nodes available. Run STVerify on this result before ",
            "submitting (pass is cached on $integrationResult)."];
        Return[$Failed]];

    order      = Lookup[config, "Order", 0];
    method     = Lookup[{opts}, "Method", "pySecDec"];
    numSamples = Lookup[{opts}, "NumSamples", 1];
    tol        = 10^-3;
    (* Forward only options that don't weaken or desync the gate (see
       Options[STSubmitResult]).  Order and Tolerance are inlined below
       and locked; Method and NumSamples are user-overridable but always
       inlined so the cache record reports the actual values used. *)
    fwdOpts    = FilterRules[{opts}, Options[STSubmitResult]];

    stLog["[SubTropica] STSubmitResult: verification required. ",
        "Running STVerify (", numSamples, " sample",
        If[numSamples > 1, "s", ""], ", ", method, ", Tolerance ", tol, ")..."];
    (* B7: surface the real cause on failure.  See note on
       Internal`HandlerBlock at the verify-handler call site above. *)
    vResult = Module[{captured = {}, r, msgs},
      Internal`HandlerBlock[
        {"Message", Function[m, AppendTo[captured, m]]},
        r = CheckAbort[
          STVerify[{edges, nodes}, result,
            "Order"      -> order,
            "Tolerance"  -> tol,
            Sequence @@ fwdOpts,
            "NumSamples" -> numSamples,
            "Method"     -> method],
          $Aborted]];
      msgs = stCleanupCapturedMessages[captured];
      Which[
        AssociationQ[r] && KeyExistsQ[r, "pass"],
          If[msgs =!= {}, r["messages"] = msgs]; r,
        r === $Aborted,
          <|"pass" -> False,
            "reason" -> If[msgs === {},
              "STVerify aborted (no message)",
              "Aborted: " <> StringTake[Last[msgs], UpTo[300]]],
            "messages" -> msgs|>,
        True,
          <|"pass" -> False,
            "reason" -> "STVerify returned " <> ToString[Head[r]],
            "raw" -> StringTake[ToString[r, InputForm], UpTo[300]],
            "messages" -> msgs|>]];

    If[!AssociationQ[vResult] || !TrueQ[vResult["pass"]],
        stErr["[SubTropica] STSubmitResult: verification FAILED (",
            Lookup[vResult, "reason", "unknown"],
            ", maxRelErr=", Lookup[vResult, "maxRelErr", "?"], "). ",
            "Try a different backend, e.g. ",
            "STVerify[{edges, nodes}, result, \"Method\" -> \"AMFlow\"] ",
            "(\"FIESTA\" or \"feyntrop\" also available), then retry ",
            "submission."];
        Return[$Failed]];

    rec = <|
        "pass"       -> True,
        "method"     -> method,
        "tolerance"  -> tol,
        "numSamples" -> numSamples,
        "maxRelErr"  -> N[Lookup[vResult, "maxRelErr", -1]],
        "kinPoint"   -> Lookup[vResult, "kinPoint",
                            Lookup[vResult, "kinematicPoint", {}]],
        "verifiedAt" -> DateString[],
        "resultHash" -> Hash[result]
    |>;

    (* Cache on $integrationResult so a subsequent STSubmitResult[] call
       in this session (e.g. retry after a transient network failure)
       skips re-verification. *)
    If[AssociationQ[$integrationResult],
        $integrationResult["verification"] = rec];

    stLog["[SubTropica] STSubmitResult: verification PASS (maxRelErr=",
        rec["maxRelErr"], ")."];
    rec
];

(* User-overridable subset of Options[STVerify].  Excluded options either
   weaken the gate (Tolerance lowers the bar; Substitutions lets the user
   hand-pick a passing kinematic point) or must equal what the result is
   recorded as (Order / Dimension / Exponents).  ResultIndex / LibraryPath
   are cni-string-form-only and meaningless for the graph-form verification
   used here. *)
Options[STSubmitResult] = FilterRules[
    Options[STVerify],
    Except[{"Tolerance", "Substitutions", "Order", "Dimension",
            "Exponents", "ResultIndex", "LibraryPath"}]];

STSubmitResult[opts:OptionsPattern[]] :=
    STSubmitResult[$integrationResult, opts];

STSubmitResult[ir_Association, opts:OptionsPattern[]] := Module[
    {config, result, nickel, topoNickel, massNickel,
     entryPath, existingEntry, existingResults,
     payload, jsonStr, tmpFile, curlResult, resp,
     verification, kinPointStrs},

    If[!AssociationQ[ir] || !KeyExistsQ[ir, "result"] || !KeyExistsQ[ir, "uiResult"],
        stErr["[SubTropica] STSubmitResult: no valid integration result."];
        Return[$Failed]];

    config = ir["uiResult"];
    result = ir["result"];

    If[result === $Failed || result === $Aborted,
        stErr["[SubTropica] STSubmitResult: result is ", result, ", nothing to submit."];
        Return[$Failed]];

    (* Local dedup: skip if the central library already has a result with the
       same full exact-match key. Only check library-bundled/ (not library-local/)
       \[LongDash] local saves should not block central submission. Match key
       mirrors STSaveResult and lookupLibraryResult() in ui/app.js; see the
       TODO there about soft-transform lookup. The Worker's KV store is the
       authoritative dedup layer for remote submissions. *)
    nickel = Lookup[config, "nickelIndex", ""];
    If[StringQ[nickel] && StringLength[nickel] > 0,
        If[StringContainsQ[nickel, ":"],
            {topoNickel, massNickel} = StringSplit[nickel, ":", 2],
            topoNickel = nickel;
            massNickel = StringReplace[nickel, c:Except["|"] :> "0"]];
        entryPath = FileNameJoin[{$SubTropicaInstallDir, "library-bundled",
            stSanitizeNickel[topoNickel], stSanitizeNickel[massNickel], "entry.json"}];
        If[FileExistsQ[entryPath],
            existingEntry = Quiet @ Check[Import[entryPath, "RawJSON"], <||>];
            existingResults = Lookup[existingEntry, "Results", {}];
            Module[{cfgDim, cfgEps, cfgPropExps, cfgNums,
                    cfgIntM, cfgExtM, cfgSubs, cfgNorm,
                    normStr, normSubs},
              (* Dedup-key canonicalization: JSON-stored values and in-memory
                 config values can differ in type (epsOrder 0 vs "0"), in
                 whitespace (dimension "4-2*eps" vs "4 - 2*eps"), or in the
                 empty placeholder (substitutions "" vs "{}"). Normalize both
                 sides before === so genuine duplicates are caught locally
                 and don't reach the Worker. *)
              normStr[x_] := StringReplace[
                  If[StringQ[x], x, ToString[x, InputForm]],
                  Whitespace -> ""];
              normSubs[x_] := With[{s = normStr[x]},
                  If[MemberQ[{"", "{}"}, s], "", s]];
              cfgDim = normStr[Lookup[config, "Dimension", ""]];
              cfgEps = normStr[Lookup[config, "Order", 0]];
              cfgPropExps = Lookup[config, "propExponents", {}];
              (* numRows (integration config) \[RightArrow] numerators (stored schema):
                 convert expression-pair list to InputForm-string-pair list *)
              cfgNums = Module[{nr = Lookup[config, "numRows", Lookup[config, "numerators", {}]]},
                  If[ListQ[nr] && Length[nr] > 0,
                      {ToString[#[[1]], InputForm], #[[2]]} & /@ nr,
                      {}]];
              cfgIntM = Lookup[config, "internalMasses", {}];
              cfgExtM = Lookup[config, "externalMasses", {}];
              cfgSubs = normSubs[Lookup[config, "Substitutions", {}]];
              cfgNorm = normStr[Lookup[config, "Normalization", Automatic]];
              If[AnyTrue[existingResults, Function[r,
                  normStr[Lookup[r, "dimension", ""]] === cfgDim &&
                  normStr[Lookup[r, "epsOrder", -999]] === cfgEps &&
                  Lookup[r, "propExponents", {}] === cfgPropExps &&
                  Lookup[r, "numerators", {}] === cfgNums &&
                  Lookup[r, "internalMasses", {}] === cfgIntM &&
                  Lookup[r, "externalMasses", {}] === cfgExtM &&
                  normSubs[Lookup[r, "substitutions", ""]] === cfgSubs &&
                  normStr[Lookup[r, "normalization", "Automatic"]] === cfgNorm
                ]],
                stLog["[SubTropica] STSubmitResult: duplicate result, skipping submission."];
                Return["duplicate"]
              ]
            ];
        ];
    ];

    (* --- Verification gate --- *)
    (* Require a passing STVerify record bound to this exact result.
       See stGateVerification above. Aborts on failure with a hint to
       try an alternate backend. Placed after local dedup so we don't
       pay for verification on an already-submitted result. *)
    verification = stGateVerification[ir, opts];
    If[verification === $Failed, Return[$Failed]];

    (* Stringify kinematic-point rules for JSON transport (symbols on LHS
       and e.g. Rational / rationalized expressions on RHS). *)
    kinPointStrs = Module[{kp = Lookup[verification, "kinPoint", {}]},
        If[ListQ[kp],
            Map[Function[r, If[Head[r] === Rule,
                <|"var" -> ToString[r[[1]], InputForm],
                  "value" -> ToString[r[[2]], InputForm]|>,
                <|"var" -> "?", "value" -> ToString[r, InputForm]|>]], kp],
            {}]];

    payload = <|
        "cnickelIndex" -> Lookup[config, "nickelIndex", ""],
        "resultCompressed" -> Compress[result],
        "resultTeX" -> stResultToTeX[result][[1]],
        "dimension" -> Module[{d = Lookup[config, "Dimension", "4-2*eps"]},
            If[StringQ[d], d, ToString[d, InputForm]]],
        "epsOrder" -> Lookup[config, "Order", 0],
        "propExponents" -> Lookup[config, "propExponents", {}],
        (* Propagator list entries are typically expressions (p[1]^2-m^2
           etc.) -- stringify to InputForm for JSON-safety. *)
        "propagators" -> Map[
            Function[p, If[NumericQ[p] || StringQ[p], p,
                ToString[p, InputForm]]],
            Lookup[config, "propagators", {}]],
        "numerators" -> Module[{nr = Lookup[config, "numRows", Lookup[config, "numerators", {}]]},
            If[ListQ[nr] && Length[nr] > 0,
                {ToString[#[[1]], InputForm], #[[2]]} & /@ nr,
                {}]],
        (* Stringify non-numeric mass expressions so RawJSON doesn't
           choke on symbols like Subscript[m,1]. safeToExpr round-trips
           each element on load; plain numbers pass through unchanged. *)
        "internalMasses" -> Map[
            Function[m, If[NumericQ[m] || StringQ[m], m,
                ToString[m, InputForm]]],
            Lookup[config, "internalMasses", {}]],
        "externalMasses" -> Map[
            Function[m, If[NumericQ[m] || StringQ[m], m,
                ToString[m, InputForm]]],
            Lookup[config, "externalMasses", {}]],
        "substitutions" -> Module[{s = Lookup[config, "Substitutions", {}]},
            If[StringQ[s], s, ToString[s, InputForm]]],
        "normalization" -> Module[{n = Lookup[config, "Normalization", Automatic]},
            If[StringQ[n], n, ToString[n, InputForm]]],
        "stVersion" -> "SubTropica v" <> $SubTropicaVersion,
        "stCommand" -> stBuildSTCommand[config],
        "contributor" -> stGetContributorField[],
        "timestamp" -> DateString[],
        "byteCount" -> ByteCount[result],
        "loops" -> $nloops,
        "legs" -> $nl,
        "propagators" -> $ne,
        "massScales" -> stCountScales[config],
        (* Graph spec, JSON-safe via InputForm. submit.yml writes these
           into entry.json's top-level edges/nodes when creating a brand
           new entry (existing entries already carry them). Mirrors the
           on-disk encoding so CocoTropica's renderer can use them
           directly without needing to re-parse from stCommand. *)
        "edges" -> ToString[Lookup[config, "edges", {}], InputForm],
        "nodes" -> ToString[Lookup[config, "nodes", {}], InputForm],
        (* Numerical verification record. submit.yml copies these into
           entry.json Results[[i]]; the UI badge (app.js
           revealVerifiedBadge) reads verifiedMethod/MaxRelErr/At from
           cached library entries. *)
        "verified" -> True,
        "verifiedMethod" -> Lookup[verification, "method", "pySecDec"],
        "verifiedTolerance" -> N[Lookup[verification, "tolerance", 10^-3]],
        "verifiedMaxRelErr" -> N[Lookup[verification, "maxRelErr", -1]],
        "verifiedAt" -> Lookup[verification, "verifiedAt", DateString[]],
        "verifiedKinPoint" -> kinPointStrs
    |>;
    (* FindRoots algebraic letters (structured).  Legacy rootSubstitutions
       string dual-write was removed in v1.0.455. *)
    Module[{algLetters = stExtractAlgebraicLetters[]},
      If[algLetters =!= {} && !FreeQ[result, (Wm | Wp)[_Integer]],
        payload["algebraicLetters"] = algLetters]];
    (* Add symbol and alphabet *)
    Module[{sf = stComputeSymbolFields[result]},
      payload["symbolTeX"] = sf[[1]];
      payload["alphabet"] = sf[[2]];
      payload["symbolWeight"] = sf[[3]];
      payload["symbolTerms"] = sf[[4]]];
    Module[{nf = Quiet @ Check[stComputeNormalizedSymbolFields[result], <||>]},
      If[Length[nf] > 0,
        payload["normalizedSymbolTeX"] = nf["normalizedSymbolTeX"];
        payload["wDefinitions"] = nf["wDefinitions"];
        payload["normalizedAlphabet"] = nf["normalizedAlphabet"];
        payload["symbolScale"] = nf["symbolScale"];
        payload["normalizedSymbolTerms"] = nf["normalizedSymbolTerms"]]];
    jsonStr = Quiet @ Check[
        ExportString[payload, "RawJSON"], $Failed];

    (* RawJSON strict-encoding failure: a field still contains an
       un-stringified Mathematica expression (e.g. Subscript[_,_]).
       Fail visibly with the keys we know we've touched, so a future
       bug is easier to localize than "JSON export failed". *)
    If[!StringQ[jsonStr],
        stErr["[SubTropica] STSubmitResult: could not JSON-encode the ",
            "payload. A field still contains a non-scalar Mathematica ",
            "expression. Payload keys: ", Keys[payload]];
        Return[$Failed]];

    If[StringLength[jsonStr] > 1000000,
        stErr["[SubTropica] STSubmitResult: payload too large (",
            StringLength[jsonStr], " bytes). Max 1 MB."];
        Return[$Failed]];

    stLog["[SubTropica] Submitting result for: ", payload["cnickelIndex"], " ..."];

    tmpFile = FileNameJoin[{$TemporaryDirectory,
        "st_submit_" <> ToString[$SessionID] <> ".json"}];
    Export[tmpFile, jsonStr, "Text", CharacterEncoding -> "UTF-8"];

    curlResult = Quiet @ Check[
        RunProcess[{"curl", "-s", "-X", "POST",
            "-H", "Content-Type: application/json",
            "-d", "@" <> tmpFile,
            "--max-time", "30",
            $STSubmitURL}, "StandardOutput"],
        $Failed];
    Quiet[DeleteFile[tmpFile]];

    If[curlResult === $Failed || !StringQ[curlResult],
        stErr["[SubTropica] STSubmitResult: network request failed."];
        Return[$Failed]];

    resp = Quiet @ Check[ImportString[curlResult, "RawJSON"], $Failed];
    If[!AssociationQ[resp],
        stErr["[SubTropica] STSubmitResult: invalid response: ", curlResult];
        Return[$Failed]];

    If[resp["status"] === "ok",
        stLog["[SubTropica] Result submitted successfully."];
        resp,
    If[resp["status"] === "duplicate",
        stLog["[SubTropica] STSubmitResult: duplicate (already submitted to central library)."];
        "duplicate",
        stLog["[SubTropica] STSubmitResult failed: ", resp];
        $Failed
    ]]
];


(* \[HorizontalLine]\[HorizontalLine] STBuildLibraryJSON \[HorizontalLine]\[HorizontalLine] *)

STBuildLibraryJSON[outputPath_String : Automatic] := Module[
    {outFile, libRoot, buildScript, indexScript, validateScript, proc},

    (* Thin wrapper around the production library.json pipeline used by
       scripts/publish-release.sh.  Delegates to the python scripts so that
       STSubmitResult / STSyncLibrary auto-rebuilds and release cuts produce
       byte-identical output (single source of truth).

       Earlier versions of this function reimplemented the rollup in
       Mathematica with a divergent lowercase-v3 schema and derived
       `numericallyVerified` rollup; that schema was never actually shipped
       (release tooling has always run the python scripts), and the
       Loopedia auto-verify it performed at runtime is now baked into
       entry.json by scripts/_migrate_loopedia_verified.py. *)

    libRoot = $SubTropicaInstallDir;
    outFile = If[outputPath === Automatic,
        FileNameJoin[{libRoot, "ui", "library.json"}],
        outputPath];

    buildScript    = FileNameJoin[{libRoot, "scripts", "_build_library_json.py"}];
    indexScript    = FileNameJoin[{libRoot, "ui", "build_subtopology_index.py"}];
    validateScript = FileNameJoin[{libRoot, "scripts", "library_audit",
        "validate_library.py"}];

    If[!FileExistsQ[buildScript],
        stErr["[SubTropica] STBuildLibraryJSON: missing ", buildScript];
        Return[$Failed]];

    (* Run python scripts from libRoot so their relative-path defaults
       (library-bundled, ui/library.json) resolve correctly and the
       _meta.sourceDir value matches what publish-release.sh produces. *)

    (* Stage 1: rollup library-bundled/ -> outFile (compact passthrough). *)
    proc = RunProcess[{"python3", buildScript, "--out", outFile},
        ProcessDirectory -> libRoot];
    If[proc["ExitCode"] =!= 0,
        stErr["[SubTropica] STBuildLibraryJSON: rollup failed (exit ",
            proc["ExitCode"], "): ",
            StringTake[proc["StandardError"], UpTo[500]]];
        Return[$Failed]];

    (* Stage 2: append subtopologies + canonicalize formatting (tab indent). *)
    If[FileExistsQ[indexScript],
        proc = RunProcess[{"python3", indexScript,
            "--quiet", "--library", outFile},
            ProcessDirectory -> libRoot];
        If[proc["ExitCode"] =!= 0,
            stErr["[SubTropica] STBuildLibraryJSON: subtopology indexer ",
                "failed (exit ", proc["ExitCode"], "): ",
                StringTake[proc["StandardError"], UpTo[500]]]
        ],
        stErr["[SubTropica] STBuildLibraryJSON: subtopology indexer missing ",
            "at ", indexScript, " -- the UI won't show subtopology matches ",
            "until this is restored."]
    ];

    stLog["[SubTropica] library.json rebuilt -> ", outFile];

    (* Validate naming invariants (T1-T8, E1-E5).  Non-fatal: prints a warning
       and the offending rule-IDs if any violation is found, but does not
       abort so one-off calls still succeed. *)
    If[FileExistsQ[validateScript],
        proc = RunProcess[{"python3", validateScript, "--quiet"}];
        If[proc["ExitCode"] =!= 0,
            stLog["[SubTropica] \:26a0 library validation FAILED -- naming "
                <> "invariants violated. Run `python3 "
                <> "scripts/library_audit/validate_library.py` for "
                <> "details. First issues:\n"
                <> StringTake[proc["StandardOutput"], UpTo[800]]]
        ]
    ];

    outFile
];


(* \[HorizontalLine]\[HorizontalLine] stEnsureServer \[HorizontalLine]\[HorizontalLine]
   Idempotent helper: starts the local Python server if it isn't already
   running, otherwise returns the existing $stServerURL. Used by STReview[]
   so users don't have to launch STIntegrate[] just to access the review tool.

   Lighter than FeynmanIntegrate's startup: no native viewer, no parallel
   kernels, no Mathematica main loop. The server runs as a detached child
   process and survives until STStop[] (or kernel exit). Only the pure-Python
   /api/* and /api/review/* endpoints are functional in this mode \[LongDash] anything
   that requires Mathematica IPC (the catch-all /api/<action> -> call_mma)
   will hang because no main loop is processing requests.
*)

stEnsureServer[] := Module[
    {port, pythonCmd, scriptPath, serverProc, ipcDir, uiDir, status},

    (* Reuse if a server is already up *)
    If[$serverObj =!= None,
        status = Quiet @ Check[ProcessStatus[$serverObj], "Failed"];
        If[status === "Running",
            Return[$stServerURL]];
        (* Stale handle \[LongDash] reset *)
        $serverObj = None;
        $stServerURL = None;
        $stServerPort = None];

    pythonCmd = findPython[];
    If[pythonCmd === $Failed,
        stErr["[SubTropica] ERROR: Python 3 not found."];
        Return[$Failed]];

    uiDir = locateUIDirectory[];
    If[uiDir === $Failed, Return[$Failed]];

    If[!DirectoryQ[$cacheDir], CreateDirectory[$cacheDir]];
    ipcDir = FileNameJoin[{$cacheDir, "ipc"}];
    If[!DirectoryQ[ipcDir], CreateDirectory[ipcDir]];
    Quiet[DeleteFile /@ FileNames["*", ipcDir]];

    port = RandomInteger[{49152, 65000}];
    scriptPath = FileNameJoin[{$cacheDir, "server.py"}];
    Export[scriptPath, generatePythonServer[port, uiDir, ipcDir,
        FileNameJoin[{$SubTropicaInstallDir, "library-bundled"}],
        FileNameJoin[{$SubTropicaInstallDir, "library-local"}]], "Text"];

    serverProc = StartProcess[{pythonCmd, scriptPath}];
    Pause[1.5];
    If[ProcessStatus[serverProc] =!= "Running",
        stErr["[SubTropica] ERROR: Python server failed to start."];
        Return[$Failed]];

    $serverObj = serverProc;
    $stServerURL = "http://127.0.0.1:" <> ToString[port];
    $stServerPort = port;
    Print["[SubTropica] Server running at ", $stServerURL];
    $stServerURL
];


(* \[HorizontalLine]\[HorizontalLine] STReview \[HorizontalLine]\[HorizontalLine]
   Opens the internal review toolkit (?review=1) against the local
   SubTropica server. Auto-starts the server if it isn't already running.
*)

STReview[] := Module[{reviewURL, ensured},
    ensured = stEnsureServer[];
    If[ensured === $Failed, Return[$Failed]];
    reviewURL = $stServerURL <> "/?review=1";
    Print["[SubTropica] Opening review tool at ", reviewURL];
    Print["[SubTropica] Localhost-only \[LongDash] not exposed publicly. Call STStop[] when done."];
    SystemOpen[reviewURL];
    reviewURL
];


(* \[HorizontalLine]\[HorizontalLine] STBrowser \[HorizontalLine]\[HorizontalLine]
   User-facing wrapper around stEnsureServer[].  Starts the local Python
   server (without the native viewer, parallel kernels, or the main polling
   loop) and opens the URL in the default system browser.  The evaluation
   cell returns immediately and prints nothing on success; $Failed is still
   surfaced on error so scripts can branch on it.  The URL is available as
   $stServerURL for callers that need it.
*)

STBrowser[] := Module[{url},
    (* Silence stEnsureServer's "Server running at ..." print; the browser
       window opening is enough feedback. *)
    Block[{Print = (Null &)}, url = stEnsureServer[]];
    If[url === $Failed, Return[$Failed]];
    SystemOpen[url];
    (* Return Null on success so the notebook cell stays clean. $Failed is
       still surfaced on error so scripts can branch on it. *)
    Null
];


(* \[HorizontalLine]\[HorizontalLine] STStop \[HorizontalLine]\[HorizontalLine]
   Shuts down the local SubTropica server (if running). Safe to call
   multiple times. The server is also auto-killed at kernel exit.
*)

STStop[] := Module[{},
    If[$serverObj === None,
        Print["[SubTropica] STStop: server not running."];
        Return[Null]];
    Quiet @ KillProcess[$serverObj];
    $serverObj = None;
    $stServerURL = None;
    $stServerPort = None;
    Print["[SubTropica] Server stopped."];
];


(* \[HorizontalLine]\[HorizontalLine] STSyncLibrary \[HorizontalLine]\[HorizontalLine] *)

Options[STSyncLibrary] = {"DryRun" -> False};

STSyncLibrary[opts:OptionsPattern[]] := Module[
    {dryRun, libDir, manifestPath, remoteJSON, remoteManifest,
     localManifest, remoteFiles, localFiles, toDownload, toDelete,
     downloaded, deleted, errors, file, remoteSHA, localSHA,
     url, targetPath, curlOut, parentDir, dirPath, hashCheck},

    dryRun = OptionValue["DryRun"];
    libDir = FileNameJoin[{$SubTropicaInstallDir, "library-bundled"}];
    manifestPath = FileNameJoin[{libDir, "manifest.json"}];

    (* Step 1: Fetch remote manifest *)
    Print["[SubTropica] Fetching library manifest..."];
    remoteJSON = Quiet @ Check[
        RunProcess[{"curl", "-s", "--max-time", "30", $STManifestURL},
                   "StandardOutput"],
        $Failed];
    If[remoteJSON === $Failed || !StringQ[remoteJSON] || StringLength[remoteJSON] < 10,
        Print["[SubTropica] Could not reach the central library. Check your internet connection."];
        Return[$Failed]];

    (* Check for 404 / HTML error pages *)
    If[StringContainsQ[remoteJSON, "404" | "<html" | "Not Found", IgnoreCase -> True],
        Print["[SubTropica] Central library manifest not available yet. The library may not have been published."];
        Return[$Failed]];

    remoteManifest = Quiet @ Check[ImportString[remoteJSON, "RawJSON"], $Failed];
    If[!AssociationQ[remoteManifest] || !KeyExistsQ[remoteManifest, "files"],
        Print["[SubTropica] Unexpected manifest format from central library. Try again later."];
        Return[$Failed]];

    remoteFiles = remoteManifest["files"];

    (* Step 2: Load local manifest, or bootstrap from file hashes *)
    If[FileExistsQ[manifestPath],
        localManifest = Quiet @ Check[Import[manifestPath, "RawJSON"], <|"files" -> <||>|>],
        (* Bootstrap: compute hashes of existing local files *)
        If[DirectoryQ[libDir],
            Print["[SubTropica] No local manifest found, computing file hashes..."];
            localManifest = <|"files" -> <||>|>;
            Do[Module[{rel, h, sz},
                rel = StringDrop[file, StringLength[libDir] + 1];
                rel = StringReplace[rel, $PathnameSeparator -> "/"];
                h = FileHash[file, "SHA256", "HexString"];
                sz = FileByteCount[file];
                localManifest["files"][rel] = <|"sha256" -> h, "size" -> sz|>;
            ], {file, Select[FileNames["*", libDir, Infinity],
                    !DirectoryQ[#] && FileNameTake[#] =!= ".DS_Store" &]}],
            localManifest = <|"files" -> <||>|>
        ]
    ];
    localFiles = Lookup[localManifest, "files", <||>];

    (* Step 3: Diff *)
    toDownload = {};
    Do[
        remoteSHA = remoteFiles[file]["sha256"];
        localSHA = Lookup[Lookup[localFiles, file, <||>], "sha256", ""];
        If[remoteSHA =!= localSHA,
            AppendTo[toDownload, file]],
        {file, Keys[remoteFiles]}
    ];

    toDelete = Complement[Keys[localFiles], Keys[remoteFiles]];

    Print["[SubTropica] Sync: ", Length[toDownload], " to download, ",
          Length[toDelete], " to remove (",
          Lookup[Lookup[remoteManifest, "stats", <||>], "totalConfigs", Length[remoteFiles]],
          " configs in remote library)."];

    If[dryRun,
        If[Length[toDownload] > 0,
            Print["  Would download: ", toDownload]];
        If[Length[toDelete] > 0,
            Print["  Would delete: ", toDelete]];
        Return[<|"toDownload" -> toDownload, "toDelete" -> toDelete|>]
    ];

    If[Length[toDownload] == 0 && Length[toDelete] == 0,
        Print["[SubTropica] Library is up to date."];
        Return["up-to-date"]];

    (* Step 4: Download changed files *)
    downloaded = 0; errors = 0;
    Do[
        url = $STRawBaseURL <> file;
        targetPath = FileNameJoin[{libDir,
            Sequence @@ StringSplit[file, "/"]}];
        parentDir = DirectoryName[targetPath];
        If[!DirectoryQ[parentDir],
            Quiet[CreateDirectory[parentDir,
                CreateIntermediateDirectories -> True]]];

        curlOut = Quiet @ Check[
            RunProcess[{"curl", "-s", "--max-time", "60",
                       "-o", targetPath, url}],
            $Failed];
        If[curlOut === $Failed || curlOut["ExitCode"] =!= 0,
            errors++;
            stErr["  FAILED: ", file];
            Continue[]];

        (* Verify SHA-256 *)
        hashCheck = FileHash[targetPath, "SHA256", "HexString"];
        If[hashCheck =!= remoteFiles[file]["sha256"],
            errors++;
            Quiet[DeleteFile[targetPath]];
            stErr["  HASH MISMATCH: ", file];
            Continue[]];

        downloaded++;
        Print["  \[Checkmark] ", file],
        {file, toDownload}
    ];

    (* Step 5: Delete removed files and clean empty directories *)
    deleted = 0;
    Do[
        targetPath = FileNameJoin[{libDir,
            Sequence @@ StringSplit[file, "/"]}];
        If[FileExistsQ[targetPath],
            Quiet[DeleteFile[targetPath]];
            deleted++;
            dirPath = DirectoryName[targetPath];
            While[DirectoryQ[dirPath] &&
                  FileNames["*", dirPath] === {} &&
                  dirPath =!= libDir,
                Quiet[DeleteDirectory[dirPath]];
                dirPath = DirectoryName[dirPath]]],
        {file, toDelete}
    ];

    (* Step 6: Save remote manifest as new local baseline *)
    Export[manifestPath, remoteManifest, "RawJSON"];

    (* Step 7: Report *)
    Print["[SubTropica] Sync complete: ", downloaded, " downloaded, ",
          deleted, " deleted, ", errors, " errors."];
    If[errors > 0,
        stErr["[SubTropica] ", errors,
              " files failed. Run STSyncLibrary[] again to retry."]];

    <|"downloaded" -> downloaded, "deleted" -> deleted, "errors" -> errors,
      "commitSHA" -> Lookup[remoteManifest, "commitSHA", "unknown"]|>
];


(* Backward compatibility *)
SubTropica[opts:OptionsPattern[]] := FeynmanIntegrate[opts];
Options[SubTropica] = Options[FeynmanIntegrate];

(* USAGE:
   Get["SubTropica`"]; ConfigureSubTropica[];
   result = FeynmanIntegrate[]
   result = FeynmanIntegrate["Verbose" -> True]  (* debug output *)
   result = STIntegrate[]                         (* equivalent *)

   Requirements: Python 3, UI directory with index.html + app.js.
   Cross-platform: macOS (native window), Linux/Windows (system browser). *)


(*(* ================================================================ *)
(*  SubTropica  - Unified Interactive Feynman Diagram Tool          *)
(*                                                                   *)
(*  Single-window workflow:                                          *)
(*    Phase 1 (Draw): interactive canvas, Lock when ready            *)
(*    Phase 2 (Configure): TabView with two tabs                     *)
(*      Tab 1: Diagram preview, topology, settings, masses           *)
(*      Tab 2: All STEvaluate options in two columns                 *)
(*    Click "Integrate" to call STEvaluate                           *)
(*                                                                   *)
(*  Requires: FeynmanPlot, STEvaluate (SubTropica)                   *)
(* ================================================================ *)

ClearAll[feynmanAnalyzeTopology, buildFeynmanPreview, SubTropica]

SubTropica := Module[
  {passedOpts = {}, result, edges, nodes, allOpts},

  result = DialogInput[
    DynamicModule[
      { (* Drawing state *)
        pts = {},  edgeList = {},  mode = "auto",
        sel = None,  dragV = None,  dragging = False,
        snapOn = False,  snapStep = 0.5,
        hitR = 0.18,  vRadius = 0.08,
        xlo = -3.5,  xhi = 3.5,  ylo = -2.0,  yhi = 2.0,
        multiEdgeSep = 0.18,

        (* Auto mode state *)
        autoSrc = None,  autoRubber = None,  autoDragging = False,

        (* Undo / Redo stacks (snapshots of {pts, edgeList}) *)
        undoStack = {},  redoStack = {},

        (* Phase control *)
        topologyLocked = False,

        (* Analysis (persist as DM vars) *)
        anResult = <||>,
        ne = 0, nl = 0, nloops = 0, efl = {}, n0r = {},
        previewGraphic = Graphics[{}, ImageSize -> 250],

        (* Core parameters (Tab 1) *)
        intm = {},  extm = {},
        dim = 4 - 2 eps,  dlabel = "MyDiagram",  autoName = True,  optOrder = Automatic,

        (* STEvaluate options (Tab 2, left column) *)
        optRepresentation = "Schwinger",
        autoNormalization = True,   optNormalization = 1,
        optSubstitutions = {},
        optSimplifyOutput = Simplify,
        optCleanOutput = False,
        optVerbose = False,
        optShowTimings = True,
        optShowIntegrands = False,
        optSaveSlowest = False,
        optSaveAll = False,

        (* STEvaluate options (Tab 2, right column) *)
        autoGauge = True,           optGauge = {x1 -> 1},
        optIncludeGauges = All,
        optHeuristic = "LeafCountLinear",
        optScanScoreInterval = {1, 3},
        optScoreInParallel = All,
        optSetupInParallel = Automatic,
        optTimeUpperBound = 10^17,
        optMemoryCutOff = None,
        optScoringMemFrac = 0.5,
        optParallelization = All,
        optKernels = $ProcessorCount - 1,
        optClearCaches = False,
        optReuseResults = True,
        optSelectFaces = All,
        optStopAt = Automatic,
        optStartAt = None
      },

      Column[{

        (* ========================================================= *)
        (* TOOLBAR                                                    *)
        (* ========================================================= *)
        Dynamic[
          Framed[
            Row[{
              Button[
                Dynamic @ Style[" \[Pencil] Auto ",
                  If[mode === "auto", Bold, Plain], 12,
                  If[mode === "auto", White, GrayLevel[0.3]]],
                mode = "auto"; sel = None,
                Background -> Dynamic @ If[mode === "auto",
                  RGBColor[0.18, 0.55, 0.46], GrayLevel[0.92]],
                Appearance -> "Frameless", ImageSize -> {75, 28},
                Enabled -> Dynamic[!topologyLocked]
              ],
              Spacer[2],
              Button[
                Dynamic @ Style[" \[FilledSmallCircle] Vertex ",
                  If[mode === "vertex", Bold, Plain], 12,
                  If[mode === "vertex", White, GrayLevel[0.3]]],
                mode = "vertex"; sel = None,
                Background -> Dynamic @ If[mode === "vertex",
                  RGBColor[0.22, 0.48, 0.87], GrayLevel[0.92]],
                Appearance -> "Frameless", ImageSize -> {85, 28},
                Enabled -> Dynamic[!topologyLocked]
              ],
              Spacer[2],
              Button[
                Dynamic @ Style[" \[UndirectedEdge] Edge ",
                  If[mode === "edge", Bold, Plain], 12,
                  If[mode === "edge", White, GrayLevel[0.3]]],
                mode = "edge"; sel = None,
                Background -> Dynamic @ If[mode === "edge",
                  RGBColor[0.9, 0.45, 0.05], GrayLevel[0.92]],
                Appearance -> "Frameless", ImageSize -> {75, 28},
                Enabled -> Dynamic[!topologyLocked]
              ],
              Spacer[2],
              Button[
                Dynamic @ Style[" \[Times] Delete ",
                  If[mode === "delete", Bold, Plain], 12,
                  If[mode === "delete", White, GrayLevel[0.3]]],
                mode = "delete"; sel = None,
                Background -> Dynamic @ If[mode === "delete",
                  RGBColor[0.8, 0.2, 0.2], GrayLevel[0.92]],
                Appearance -> "Frameless", ImageSize -> {80, 28},
                Enabled -> Dynamic[!topologyLocked]
              ],

              Spacer[10],
              Style["|", GrayLevel[0.75]], Spacer[10],

              Checkbox[Dynamic[snapOn], Enabled -> Dynamic[!topologyLocked]],
              Style[" Snap", 10, GrayLevel[0.4]],

              Spacer[10],
              Style["|", GrayLevel[0.75]], Spacer[10],

              Tooltip[Button[
                Style[FromCharacterCode[8634], 14],
                If[Length[undoStack] > 0,
                  AppendTo[redoStack, {pts, edgeList}];
                  {pts, edgeList} = Last[undoStack];
                  undoStack = Most[undoStack]; sel = None],
                ImageSize -> {28, 25}, Appearance -> "Frameless",
                Enabled -> Dynamic[!topologyLocked && Length[undoStack] > 0]
              ], "Undo"],
              Tooltip[Button[
                Style[FromCharacterCode[8635], 14],
                If[Length[redoStack] > 0,
                  AppendTo[undoStack, {pts, edgeList}];
                  {pts, edgeList} = Last[redoStack];
                  redoStack = Most[redoStack]; sel = None],
                ImageSize -> {28, 25}, Appearance -> "Frameless",
                Enabled -> Dynamic[!topologyLocked && Length[redoStack] > 0]
              ], "Redo"],
              Button[Style[" Clear ", 10, RGBColor[0.7, 0.1, 0.1]],
                pushUndo[]; pts = {}; edgeList = {}; sel = None,
                ImageSize -> {50, 25},
                Enabled -> Dynamic[!topologyLocked]
              ],

              Spacer[10],
              Dynamic @ Style[
                "V=" <> ToString[Length[pts]] <>
                "  E=" <> ToString[Length[edgeList]],
                10, GrayLevel[0.45]]
            }],
            Background -> GrayLevel[0.97],
            RoundingRadius -> 5,
            FrameStyle -> GrayLevel[0.85],
            FrameMargins -> {{6, 6}, {3, 3}}
          ],
          TrackedSymbols :> {mode, topologyLocked, pts, edgeList}
        ],

        Spacer[3],

        (* ========================================================= *)
        (* DRAWING CANVAS                                             *)
        (* ========================================================= *)
        EventHandler[
          Dynamic[
            Module[
              {edgeCounts, edgeCopyIdx, getOffset},

              edgeCounts = Counts[Sort /@ edgeList];
              edgeCopyIdx = Module[{tally = <||>},
                Table[
                  Module[{key = Sort[edgeList[[k]]]},
                    If[KeyExistsQ[tally, key],
                      tally[key] = tally[key] + 1,
                      tally[key] = 1];
                    tally[key]
                  ],
                  {k, Length[edgeList]}
                ]
              ];
              getOffset[k_] := Module[
                {key = Sort[edgeList[[k]]], n, j, offsets},
                n = edgeCounts[key];
                j = edgeCopyIdx[[k]];
                If[n == 1, 0,
                  offsets = Range[n] - (n + 1)/2.;
                  offsets[[j]] * multiEdgeSep
                ]
              ];

              Graphics[{
                GrayLevel[0.93], AbsoluteThickness[0.5],
                Table[Line[{{x, ylo}, {x, yhi}}], {x, xlo, xhi, snapStep}],
                Table[Line[{{xlo, y}, {xhi, y}}], {y, ylo, yhi, snapStep}],
                GrayLevel[0.84], AbsoluteThickness[1],
                Line[{{xlo, 0}, {xhi, 0}}],
                Line[{{0, ylo}, {0, yhi}}],

                RGBColor[0.9, 0.45, 0.05], AbsoluteThickness[3.5],
                CapForm["Round"],
                If[Length[edgeList] > 0 && Length[pts] > 0,
                  Table[With[{e = edgeList[[k]]},
                    If[Max[e] <= Length[pts],
                      Module[{p1, p2, d, perp, off, mp1},
                        p1 = pts[[e[[1]]]]; p2 = pts[[e[[2]]]];
                        d = p2 - p1;
                        perp = Normalize[{-d[[2]], d[[1]]}];
                        off = getOffset[k];
                        If[off == 0,
                          Line[{p1, p2}],
                          mp1 = (p1 + p2)/2 + off * perp;
                          BezierCurve[{p1, mp1, p2}]
                        ]
                      ], {}
                    ]
                  ], {k, Length[edgeList]}], {}],

                (* Rubber-band line for auto-mode drag *)
                If[autoDragging && autoSrc =!= None && autoRubber =!= None &&
                   autoSrc <= Length[pts],
                  {Dashed, GrayLevel[0.4], AbsoluteThickness[2],
                   Line[{pts[[autoSrc]], autoRubber}]},
                  {}],

                Table[With[{idx = k}, {
                  If[sel === idx,
                    {RGBColor[0.2, 0.55, 1.0], AbsoluteThickness[2.5],
                     Circle[pts[[idx]], vRadius + 0.05]}, {}],
                  EdgeForm[{AbsoluteThickness[1.5], RGBColor[0.15, 0.15, 0.15]}],
                  FaceForm[GrayLevel[0.12]],
                  Disk[pts[[idx]], vRadius]
                }], {k, Length[pts]}],

                If[!topologyLocked,
                  Text[Style[
                    Switch[mode,
                      "auto", "Click: vertex \[CenterDot] Drag: edge",
                      "vertex", "Click to add \[CenterDot] Drag to move",
                      "edge", If[sel === None,
                        "Click first vertex",
                        "Now click second vertex"],
                      "delete", "Click vertex or edge to delete", _, ""],
                    10, Italic, GrayLevel[0.5]],
                    {(xlo + xhi)/2, yhi - 0.12}],
                  Text[Style[
                    FromCharacterCode[16^^1F512] <>
                    "  Topology locked  - configure below",
                    11, Bold, RGBColor[0.2, 0.5, 0.2]],
                    {(xlo + xhi)/2, yhi - 0.12}]
                ]
              },
              PlotRange -> {{xlo, xhi}, {ylo, yhi}},
              ImageSize -> {660, 370},
              Background -> White,
              Frame -> True,
              FrameStyle -> Directive[GrayLevel[0.65], AbsoluteThickness[1.5]],
              FrameTicks -> None
              ]
            ],
            TrackedSymbols :> {pts, edgeList, sel, mode, topologyLocked, autoRubber, autoSrc}
          ],

          {
            "MouseDown" :> If[!topologyLocked,
              Module[{mp = MousePosition["Graphics"],
                      v = None, dists, bestIdx, eDists, bestE},
                If[mp =!= None,
                  If[Length[pts] > 0,
                    dists = EuclideanDistance[mp, #] & /@ pts;
                    bestIdx = First[Ordering[dists, 1]];
                    If[dists[[bestIdx]] < hitR, v = bestIdx]];
                  Switch[mode,
                    "auto",
                      If[v === None,
                        pushUndo[];
                        AppendTo[pts, If[snapOn, Round[mp, snapStep], mp]],
                        autoSrc = v; autoDragging = True; autoRubber = mp],
                    "vertex",
                      If[v === None,
                        pushUndo[];
                        AppendTo[pts, If[snapOn, Round[mp, snapStep], mp]],
                        pushUndo[]; dragV = v; dragging = True],
                    "edge",
                      If[v =!= None,
                        If[sel === None, sel = v,
                          If[sel =!= v,
                            pushUndo[];
                            AppendTo[edgeList, Sort[{sel, v}]];
                            sel = None,
                            sel = None]],
                        sel = None],
                    "delete",
                      If[v =!= None,
                        pushUndo[];
                        edgeList = Select[edgeList, FreeQ[#, v] &];
                        pts = Delete[pts, v];
                        edgeList = edgeList /. n_Integer /; n > v :> n - 1;
                        sel = None,
                        If[Length[edgeList] > 0 && Length[pts] > 0,
                          eDists = Table[With[{e = edgeList[[k]]},
                            If[Max[e] <= Length[pts],
                              EuclideanDistance[mp,
                                (pts[[e[[1]]]] + pts[[e[[2]]]])/2],
                              Infinity]], {k, Length[edgeList]}];
                          bestE = First[Ordering[eDists, 1]];
                          If[eDists[[bestE]] < 0.35,
                            pushUndo[];
                            edgeList = Delete[edgeList, bestE]]]]
                  ]
                ]
              ]
            ],
            "MouseDragged" :> If[!topologyLocked,
              Module[{mp = MousePosition["Graphics"]},
                If[mp =!= None,
                  If[autoDragging && autoSrc =!= None,
                    autoRubber = mp];
                  If[dragging && dragV =!= None && dragV <= Length[pts],
                    pts[[dragV]] = If[snapOn, Round[mp, snapStep], mp]]
                ]]
            ],
            "MouseUp" :> (
              If[autoDragging && autoSrc =!= None && autoSrc <= Length[pts],
                Module[{mp = MousePosition["Graphics"],
                        v2 = None, dists2, bestIdx2},
                  If[mp =!= None,
                    If[Length[pts] > 0,
                      dists2 = EuclideanDistance[mp, #] & /@ pts;
                      bestIdx2 = First[Ordering[dists2, 1]];
                      If[dists2[[bestIdx2]] < hitR && bestIdx2 =!= autoSrc,
                        v2 = bestIdx2]];
                    If[v2 =!= None,
                      (* Dragged to existing vertex -> create edge *)
                      pushUndo[];
                      AppendTo[edgeList, Sort[{autoSrc, v2}]],
                      (* Dragged to empty space -> new vertex + edge *)
                      If[EuclideanDistance[mp, pts[[autoSrc]]] >= hitR,
                        pushUndo[];
                        AppendTo[pts, If[snapOn, Round[mp, snapStep], mp]];
                        AppendTo[edgeList, Sort[{autoSrc, Length[pts]}]]
                      ]
                    ]
                  ]
                ]
              ];
              autoDragging = False; autoSrc = None; autoRubber = None;
              dragging = False; dragV = None
            )
          }
