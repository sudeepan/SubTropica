Clear[STGetKinematics];
STGetKinematics[n_,symbolsQ_:True,masslessQ_:False]:=Module[{kin},
kin=Flatten[
Table[If[i==j,
p[i] p[i]->X[i,Mod[i+1-1,n]+1],
p[i] p[j]->1/2 (-X[Mod[i+1-1,n]+1,Mod[j+1-1,n]+1]-X[i,j]+X[Mod[i+1-1,n]+1,j]+X[i,Mod[j+1-1,n]+1])
]/. X[a_,b_]/;a>b:>X[b,a]/. X[a_,a_]->0
,{i,1,n},{j,1,n}]
];
If[masslessQ,kin=kin/. (X[a_,b_]/;Abs[a-b]===1)|X[1,n]->0];If[symbolsQ,kin/. X[a_,b_]:>Symbol["X"<>ToString[a]<>ToString[b]],kin]
]


(*Given loop variables xx, and propagators yy^2, compute Laplacian, Current and Constant*)
Clear[STmatrixData];STmatrixData[xx_, yy_] := Module[{A,B,coef,pol,const,lin,symU}, 
pol=Table[\[Alpha][i],{i,1,yy//Length}] . yy;
A=Table[
coef=Coefficient[pol, v1 v2];
If[Not[v1===v2],coef=coef/2];
coef
,{v1,xx},{v2,xx}
];
const=pol/.Alternatives@@xx-> 0;
B= Table[Coefficient[pol, v1 ]/.Alternatives@@xx-> 0,{v1,xx}];
{A,B,const}
]




