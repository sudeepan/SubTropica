(* ::Subsection::Closed:: *)
(*Evaluate Subtractions*)


(* ::Text:: *)
(* A more elaborate interface between Mathematica and Maple.*)
(**)
(*A subtraction formula is assigned to a directory. The directory contains a sub-directory for each eps-order and face contributing to the subtraction.*)
(*For each term in the subtraction the sub-directory containing the following: *)
(* 1) files vars.mpl, polys.mpl, integrands.mpl containing the data: variables, polysAndPairs and integrands.*)
(* 2) files findOrders.mpl and integrate.mpl which are expansion-independent and pre-written, containing the instruction to find orders and integrate. *)
(**)


(* ::Text:: *)
(*Available methods:*)
(**)
(*findOrders.mpl: vanilla, loop through polys and intersect orders as  find them. save in orders.txt*)
(*integrate.mpl: 	vanilla, loop through found orders  and integrands and attempt to integrate. save in result.txt*)
(**)
(*findOrdersParScores.mpl: work on polys in parallel. intersect all found orders and report score of each. save in ordersScore.txt*)
(*integratePar1.mpl: loop through orders, attempt to integrate all integrands in parallel. save in result.txt*)
(*integratePar2.mpl : sequentially loop through orders and integrands, attempt to parallel-integrate each. save in result.txt*)
(**)


(* ::Subsubsection::Closed:: *)
(*Basic Functions*)


(* Prepare data to run HyperInt's polynomial reduction *)
(* Construct a list of the polynomial and pairs appearing in the terms of a locally finite integrand *)
Clear[STpreparePolysAndPairsMaple];
STpreparePolysAndPairsMaple[totintegrand_,vars_]:=Module[{prefix,letters,den,toIntegrate,toInt,expanded,listsOflistsPolys,pairsOfPolys,factors},

	(* If the integrand is 0, nothing to do. This will be recognized later when finding linearly reducible orders *)
	If[totintegrand===0,Return["polysAndPairs:={};\n"]];

	(* Expand into terms of the form R0 Log[R1]^n1 Log[R2]^n2 ... , with rational functions Ri *)
	expanded=totintegrand//Expand;
	(* Produce a list of the various terms *)
	If[Not[Head[expanded]===Plus],expanded={expanded},expanded=List@@expanded];
	(* Loop over individual terms, extract polynomial factors appearing in Ri (i>0) and in the denominator of R0 *)
	listsOflistsPolys=Table[
		(* Arguments of the logs *)
		letters=Cases[integrand,Log[a_]:> a,\[Infinity]]//DeleteDuplicates;
		(* Ignore constants *)
		letters//DeleteCases[ #,v_/;Count[v,Alternatives@@vars]===0]&;
		(* Denominator of prefactor *)
		den=Denominator[integrand/.Log[___]->1];
		(* Extract irreducible factors *)
		(**)
		If[letters==={},letters={{}}];
		factors=Join[letters,{den}]//STgetIrreducibleFacs//DeleteDuplicates//DeleteCases[ #,v_/;Count[{v},Alternatives@@vars,\[Infinity]]===0]&;
		factors
		,
		{integrand,expanded}
	]//DeleteDuplicates;
	(* Write pairs of polys for each integrand *)
	pairsOfPolys=(Table[{polys,Subsets[polys,{2}]},{polys,listsOflistsPolys}]//ToString[#,InputForm]&//stStripMmaContexts//StringReplace[#,"\n"|"\ " | "\""-> ""]&);
	(* Find an order which works for all integrands, if none available find order that works for some of the first *)
	"polysAndPairs:=FromMma(`"<>pairsOfPolys<>"`);\n"
]



(* Build a string in maple to declare terms of a locally finite integrand provided as a list of terms *)
Clear[STprepareIntegrandsMaple];STprepareIntegrandsMaple[totintegrand_]:=Module[
{prefix,letters,den,toIntegrate,toInt,expanded,listsOflistsPolys,pairsOfPolys,factors}
,
(* Vanishing case *)
If[totintegrand==={},Return["integrands:={};\n"]];

(* Loop over terms, formatting them and adding them to the string*)
prefix="integrands:=[";
Do[
	toInt="FromMma(`"<>ToString[term,InputForm]<>"`),";
	prefix=prefix<>toInt;
	,
	{term,totintegrand}
];
(* Drop trailing comma*)
prefix=StringDrop[prefix,-1];
prefix=prefix<>"];\n";
prefix
]


(* ::Subsubsection::Closed:: *)
(*Setup directory for single subtraction*)


(* ::Text:: *)
(* Construct a directory to evaluate a subtraction formula at a given order.*)
(**)
(* Optional arguments : *)
(*	 A string identifier for the directory*)
(*	format integrand by launching maple to explicitly evaluate "FromMma"?*)
(*	construct polynomial and pairs for cg reduction?*)


Clear[STsetupDirectoryExpansionMaple];
STsetupDirectoryExpansionMaple[expansion_,order_,coeffs_,id_:"subtraction",formatQ_:False,polysAndPairsQ_:True]:=Module[
{prefix,i,renintegrands,integrands,rnint,
variablesAndCoeffs,nfaces,polysAndPairs,directoryName,
dataFile,oldDirectory,messageFunction,
fromSetToList}
,

	messageFunction=If[$Notebooks,PrintTemporary,Print];
	
	(* We treat the renormalized integrand of each face individually *)
	renintegrands= Table[SeriesCoefficient[e[[1]],{eps,0,order}],{e,expansion}];
	nfaces=renintegrands//Length;

	(* Variables & coeffs of each ren-integrand *)
	fromSetToList={"{"->"[","}"->"]"};
	variablesAndCoeffs = Table["vars:="<>StringReplace[ToString[e[[2]]],fromSetToList]<>";\n"<>"cfs:="<>StringReplace[ToString[coeffs],fromSetToList]<>";\n",{e,expansion}];
	(* Polys and pairs of each ren-integrand *)
	If[polysAndPairsQ,
		polysAndPairs=Table[
			rnint=renintegrands[[i]];
			rnint//Total//STpreparePolysAndPairsMaple[#, expansion[[i,2]] ]&
			,
			{i,1,expansion//Length}
		];
	];
	
	
	(* integrands of each ren-integrand *)
	integrands=Table[rnint//STprepareIntegrandsMaple,{rnint,renintegrands}];
	
	(* Prepare Face sub-Directories *)
	(* Loop over faces *)
	Do[
		directoryName="integrands/"<>id<>"/ord_"<>ToString[order]<>"_face_"<>ToString[i];
		(* Creating sub-directory.  Use CreateIntermediateDirectories so the
		   integrands/<id>/ parent is built on demand; without it, a fresh
		   CWD hits CreateDirectory silently failing (parent absent), and
		   the downstream OpenWrite/WriteString/Close on vars.mpl etc. emits
		   OpenWrite::noopen / WriteString::strml / Close::stream. *)
		If[Not[FileExistsQ[directoryName]],
			CreateDirectory[directoryName, CreateIntermediateDirectories -> True];
		];
		(* Directory to store results of this face *)
		If[Not[FileExistsQ[directoryName<>"/results"]],
			CreateDirectory[directoryName<>"/results", CreateIntermediateDirectories -> True];
		];
		(* prefix pointing to the directory and face*)
		prefix=directoryName<>"/";
		(* Variables & Coefficients *)
		dataFile=prefix<>"vars.mpl";
		If[FileExistsQ[dataFile],DeleteFile[dataFile]];
		OpenWrite[dataFile];
		WriteString[dataFile,variablesAndCoeffs[[i]]];
		Close[dataFile];
		(* Polys and pairs *)
		If[polysAndPairsQ,
		dataFile=prefix<>"polys.mpl";
		If[FileExistsQ[dataFile],DeleteFile[dataFile]];
		OpenWrite[dataFile];
		WriteString[dataFile,polysAndPairs[[i]]];
		Close[dataFile];
		];
		(* Integrands *)
		dataFile=prefix<>"integrands.mpl";
		If[FileExistsQ[dataFile],DeleteFile[dataFile]];
		OpenWrite[dataFile];
		WriteString[dataFile,integrands[[i]]];
		Close[dataFile];

		(* From now on, mapleCommands are in the parent hyperInt directory only *)
		(*If[Not[FileExistsQ[directoryName<>"/mapleCommands"]],
			CreateDirectory[directoryName<>"/mapleCommands"];
		];*)
		(* If requested, evaluating the FromMma's running a lite maple script *)
		
		If[formatQ,
			(* Copy format maple script *)
			Run["cp hyperInt/mapleCommands/format.mpl "<>directoryName<>"/format.mpl"];
			(* Move to face sub-directory *)
			oldDirectory=Directory[];
			SetDirectory[directoryName];
			(* Run maple script *)
			If[FileExistsQ["format.mpl"],
				Run[$MapleCommand<>" -c 'read \\\"format.mpl\\\":' -c 'quit:'"];
				,
				messageFunction["error: format.mpl missing!"];
			];
			(* Go back to notebook running directory *)
			SetDirectory[oldDirectory];
			(* Remove format maple script *)
			If[FileExistsQ[directoryName<>"/format.mpl"], DeleteFile[directoryName<>"/format.mpl"]];
		];
		
	,
	{i,1,nfaces}
	];
]


(* ::Subsubsection::Closed:: *)
(*Launch HyperInt for single subtraction*)


(**)
Clear[STlaunchHyperIntMaple];
STlaunchHyperIntMaple[id_,order_, mode_:"All", startOrder_:1]:=Module[
{proc,line,fileLog,mapleScript}
	,
	(* Mode: all\[Florin], no orders, only orders? *)
	Switch[mode,
		"All",mapleScript="./recComputeIntegrand "<>id<>" "<>ToString[order]<>" -1 1 "<>ToString[startOrder];
		,
		"NoOrders",mapleScript="./recComputeIntegrandNoOrders "<>id<>" "<>ToString[order]<>" -1 1 "<>ToString[startOrder];
		,
		"OnlyOrders",mapleScript="./recFindOrders "<>id<>" "<>ToString[order];
	];
	
	(* Moving to hyperInt directory *)
	SetDirectory["hyperInt"];
	(* set up log file if necessary *)
	(*If[Not[logQ==={}],
		fileLog=logQ;
		If[FileExistsQ[fileLog],DeleteFile[fileLog]];
	];*)
	(* Start process and read output *)
	Print[mapleScript];
	proc=StartProcess[{"bash","-c", mapleScript}];
	(*ReadString[proc, EndOfBuffer]//Print;*)
	While[ProcessStatus[proc]==="Running",
		line=ReadString[proc, EndOfBuffer];
		If[StringLength@StringTrim@line>0,
			line//Print;
		];
	];
	(*While[ProcessStatus[proc]==="Running"||StringLength@StringTrim@ReadLine[proc["StandardOutput"]]>0,
		line=StringTrim@ReadLine[proc["StandardOutput"]];
		If[line=!="",
			Print[line]
			(*If[logQ==={},Print[line],AppendTo[line,logQ]];*)
		];
	];*)
	KillProcess[proc];
	(* Go back to SubTropica directory *)
	SetDirectory["../"];
]



(* ::Subsubsection::Closed:: *)
(*Read Results for single subtraction*)


(* Format Maple Output in Mathematica Input *)

ClearAll[STbalancedBracesQ]
STbalancedBracesQ[str_String]:=StringCount[str,"("]===StringCount[str,")"];
STXStringReplace=Shortest["X("~~body:___~~")"]/;(Not@StringContainsQ[body,"X"]&&STbalancedBracesQ[body]):>"X["<>body<>"]";
STzetaStringReplace=Shortest["zeta("~~body:___~~")"]/;(Not@StringContainsQ[body,"zeta"]&&STbalancedBracesQ[body]):>"zeta["<>body<>"]";
STZetaStringReplace=Shortest["Zeta("~~body:___~~")"]/;(Not@StringContainsQ[body,"Zeta"]&&STbalancedBracesQ[body]):>"Zeta["<>body<>"]";
STlnStringReplace=Shortest["ln("~~body:___~~")"]/;(Not@StringContainsQ[body,"ln"]&&STbalancedBracesQ[body]):>"ln["<>body<>"]";
STHlogStringReplace1=Shortest["Hlog("~~body:___~~")"]/;(Not@StringContainsQ[body,"Hlog"]&&STbalancedBracesQ[body]):>"Hlog["<>body<>"]";
STHlogStringReplace2="Hlog["~~Shortest[a___]~~",["~~Shortest[b___]~~"]":> "Hlog["<>a<>",{"<>b<>"}";
(*zetaStringReplace={"delta["~~Shortest[a___]~~"]" :> "delta("<>a<>")","zeta["~~Shortest[a___]~~"]" :> "zeta("<>a<>")"};*)

STFormatString[string_]:=(string//StringReplace[#,{STzetaStringReplace,STZetaStringReplace,STlnStringReplace,STHlogStringReplace1,XStringReplace}]&//StringReplace[#,STHlogStringReplace1]&//StringReplace[#,STHlogStringReplace2]&);
STEvaluateII[string_]:=(string//STFormatString//ToExpression)/. ln->Log;


(* Read the result of a single subtraction *)
Clear[STreadSubtractionResultMaple];
STreadSubtractionResultMaple[order_,id_:"",asAStringQ_:False]:=Module[
{
prefix,origDirectory,results
},
	(*origDirectory=Directory[];*)
	prefix="integrands/"<>id;
	If[asAStringQ,
		results=ReadString[prefix<>"/result_"<>ToString[order]<>".txt"],
		results=STEvaluateII[ ReadString[prefix<>"/result_"<>ToString[order]<>".txt"]];
	];
	results
]


(* ::Subsubsection::Closed:: *)
(*Assemble Results*)


(* Combine evaluation of several subtractions into the final eps-expansion *)
STCombineResultsMaple[results_,order_]:=Module[
	{
	formatted
	}
	,
	Sum[
		(* results are passed in the form {prefactor, {{eps^i, A^i}, ... } *)
		cnt[[1]](cnt[[2, ;; , 1]] . cnt[[2, ;; , 2]])
		,
		{cnt,results}
	]//Series[#,{eps,0,order}]&
]


(* ::Subsubsection::Closed:: *)
(*Evaluate Subtractions*)


Clear[STEvaluateSubtractionNPMaple];
STEvaluateSubtractionNPMaple[expansions_, order_, vars_ , coeffs_ , id_:"euler" , mode_:"All",startOrder_:1]:=Module[
{
messageFunction,
minOrder, maxOrder,
results,
ord, cnt, 
cntId,
cntIdlast,safeLoop,minOrderLast,maxOrderLast,fileLastResult,
dummy
},
	messageFunction=If[$Notebooks,Print,Print];
	
	(* If we only want to read the results, no need to recompute it! *)
	If[Not[mode==="Read"],
	
		(* Set up subtraction directory *)
		If[(mode==="Setup")||(mode==="All"),
			Print["---------------------------------"];
			Print["Setting up subtraction directory! "];
			Do[
				cntId=id<>"cnt"<>ToString[cnt];
				messageFunction["cnt: "<>ToString[cnt]];
				minOrder=(expansions[[cnt,2,-1,2]]//Length)-(vars//Length);
				maxOrder=order + Max[0,-Series[expansions[[cnt,1]]dummy^eps,{eps,0,0}][[4]]];
				Do[
					
					messageFunction["eps-order: "<>ToString[ord]];
					STsetupDirectoryExpansionMaple[expansions[[cnt,2]] , ord, coeffs , cntId, True]
					,
					{ord,minOrder,maxOrder}
				]
				,
				{cnt,1,expansions//Length}
			];
		];
		
		If[mode==="Setup",Return[" All done!, Goodbye!"]];
		
		
		Print["---------------------------------"];
		Print["Launch Hyper-Int in mode "<>ToString[mode]<>"!"];
		
		Do[
			cntId=id<>"cnt"<>ToString[cnt];
			messageFunction["cnt: "<>ToString[cnt]];
			minOrder=(expansions[[cnt,2,-1,2]]//Length)-(vars//Length);
			maxOrder=order + Max[0,-Series[expansions[[cnt,1]] dummy^eps,{eps,0,0}][[4]]];
			STlaunchHyperIntMaple[cntId,maxOrder,mode,startOrder];
			,
			{cnt,1,expansions//Length}
		];
	
	];
	
	If[(mode==="OnlyOrders")||(mode==="NoOrders"),Return[]];
	
	
	Print["---------------------------------"];
	Print["Read Results!"];
	results=Table[
		cntId=id<>"cnt"<>ToString[cnt];
		minOrder=(expansions[[cnt,2,-1,2]]//Length)-(vars//Length);
		maxOrder=order + Max[0,-Series[expansions[[cnt,1]]dummy^eps,{eps,0,0}][[4]]];
		{
			expansions[[cnt,1]]
			,
			Table[
				{eps^ord , STreadSubtractionResultMaple[ord, cntId, False]}
				,
				{ord,minOrder,maxOrder}
			]
		}
		,
		{cnt,1,expansions//Length}
	];
	(* Combine Results *)
	Print["Math: done!"];
	STCombineResultsMaple[results,order]
]


