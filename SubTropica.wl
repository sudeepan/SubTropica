(* ::Subsection::Closed:: *)
(*Evaluation*)


STtoZetas[v_]:=v/.PolyGamma[n_,1]:> Zeta[n+1](-1)^(n+1) n!


(* Map a function over a series *)
STMapSeries[ function_, series_ ] := SeriesData@Sequence[series[[1]], series[[2]], function/@ series[[3]], series[[4]], series[[5]], series[[6]]]


STToGinsh[exprOrig_] := Module[
{
expr,
Hlogs,Gs,zetas,HsAndZetas,
ginshInFile,ginshOut,
curlyTocurvy,squareToCurvy,
stringQnts
}
	,
	If[stRequireTool["ginsh"] === $Failed, Return[$Failed]];
	(* Normalise multiple-zeta-value head: STIntegrate results variously
	   use HyperInt`mzv (Maple backend), HyperIntica`mzv (in-process
	   HyperIntica), or Global`mzv (after a mzv -> zeta rewrite lost the
	   target context).  Map all three to the same in-context `zeta`
	   symbol the ginsh bridge collects via Cases[expr, zeta[a___], ...];
	   also flip to Mathematica's Zeta for built-in single-integer cases,
	   so zeta[2] -> \[Pi]\.b2/6 at display time. *)
	expr=exprOrig
	    //.HyperInt`Mpl->HyperInt`MplAsHlog
	    /.{HyperInt`mzv->zeta, HyperIntica`mzv->zeta, Global`mzv->zeta};
	(* Preparing Files *)
	ginshInFile="tempGinshIn";
	
	curlyTocurvy={ "{"->  "(" , "}" -> ")"};
	(*curlyToSquare={ "{"\[Rule]  "[" , "}" \[Rule] "]"};*)
	(*squareToCurly={ "["\[Rule]  "{" , "]" \[Rule] "}"};*)
	squareToCurvy={ "["->  "(" , "]" -> ")"};
	If[FileExistsQ[ginshInFile],DeleteFile[ginshInFile]];
	
	(* Gathering Hlogs, Logs, and zetas for ginsh evaluation.
	   - Hlogs become G({indices}, z) for ginsh.
	   - Plain Log[a] is sent as log(a) to ginsh \[LongDash] NOT as G({0},a), which
	     ginsh cannot evaluate when a is complex (GiNaC limitation).
	   - zeta[n] is sent as zeta(n).
	   This ensures all branch-cut handling is done consistently by ginsh. *)
	Hlogs=Cases[expr, Hlog[a_,b_],{0,\[Infinity]}]//DeleteDuplicates;
	Module[{logExprs, logStrs, ginshStringSubs},
	(* Map Mathematica syntax that ginsh doesn't understand to its own:
	   Sqrt[x] -> sqrt(x), Complex[] -> complex(). Must be applied AFTER
	   squareToCurvy (to match the already-transformed "Sqrt(" substring),
	   via a second StringReplace pass \[LongDash] StringReplace does not iterate
	   rules within a single pass. *)
	(* "*^-6" is Mathematica's short scientific notation (= 10^-6); ginsh would
	   parse the "^" as an exponent operator. Rewrite to explicit "*10^-6". *)
	ginshStringSubs = {"Sqrt(" -> "sqrt(", "Complex(" -> "complex(", "*^" -> "*10^"};
	logExprs = Cases[expr, Log[a_], Infinity] // DeleteDuplicates;
	logStrs = ("log(" <> ToString[#[[1]], InputForm] <> ")") & /@ logExprs;
	logStrs = StringReplace[StringReplace[#, squareToCurvy], ginshStringSubs] & /@ logStrs;
	Gs=Hlogs/.Hlog[a_,b_]:> G[b,a];
	Gs= ToString[#,InputForm]&/@Gs;
	Gs= StringReplace[StringReplace[#, squareToCurvy], ginshStringSubs] & /@ Gs;
	zetas=Cases[expr//List,zeta[a___],\[Infinity]]//DeleteDuplicates;
	HsAndZetas=Join[Hlogs,logExprs,zetas];
	If[HsAndZetas==={},Return[expr]];
	(* GiNaC's ginsh uses zeta(n) for Riemann zeta and zeta({n1, n2, ...}) for
	   multiple zeta values (curly braces are required for the MZV index list).
	   The previous implementation applied curlyTocurvy to the whole zeta string,
	   which destroyed the {} on multi-arg zetas and silently caused ginsh to
	   return zeta(n1) (Riemann zeta of the first arg only) for any depth >= 2.
	   Build each zeta string with the correct syntax for its depth. *)
	zetas = zetas /. {
		zeta[a_] :> "zeta(" <> ToString[a, InputForm] <> ")",
		zeta[args__] :> "zeta({" <> StringRiffle[ToString[#, InputForm] & /@ {args}, ", "] <> "})"
	};
	zetas = StringReplace[#, squareToCurvy] & /@ zetas;

	(* B19 guard: ginsh can only evalf() arguments whose free symbols are
	   bound to numbers.  If the substituted Hlog/Log/zeta arguments still
	   carry an unbound kinematic symbol (mm, MM1, MMn, sij, ...), ginsh
	   either errors out and prints a parse-error caret, or returns the
	   expression unevaluated.  Either way, the output stream contains
	   tokens that ToExpression then mangles \[LongDash] previously the caller
	   silently fell back to plain N[..] on the unevaluated Hlog, which
	   leaks Integrate\[Backquote]V[..][..] heads (B18).  Detect the unbound-symbol
	   case up front and bail with $Failed.
	*)
	Module[{knownAtoms, freeSyms},
		knownAtoms = {Pi, E, EulerGamma, I, Complex, Rational, Real,
			Integer, Plus, Times, Power, List, Hlog, Log, zeta,
			HyperInt`Hlog, HyperInt`Mpl, HyperInt`mzv, HyperIntica`mzv,
			Sqrt, Times, Plus, Minus};
		freeSyms = Cases[Join[Hlogs, logExprs, zetas],
			s_Symbol /; !MemberQ[knownAtoms, s], {0, Infinity}] // DeleteDuplicates;
		If[freeSyms =!= {},
			Message[STToGinsh::unbound, freeSyms];
			Return[$Failed]]];

	stringQnts=StringJoin@@Table[
		"evalf("<>qnt<>");\n"
		,
		{qnt,Join[Gs,logStrs,zetas]}
	];
	stringQnts=stringQnts<>"exit;";
	WriteString[ginshInFile,stringQnts];
	ginshOut=ReadString["! "<>$GinshCommand<>" "<>ginshInFile];
	ginshOut=(ginshOut//StringSplit);
	(* Sometimes the logo is read as well. This detects it and removes it *)
	If[ginshOut[[1]]==="ginsh" , ginshOut=ginshOut[[57;;]]
	 ];

	ginshOut=ginshOut//StringReplace[#,"E"-> "*10^"]&//ToExpression[#]&;

	(* B19 post-check: every parsed token must be numeric.  A non-numeric
	   token means ginsh emitted a G(...)/log(...)/zeta(...) expression
	   verbatim instead of an evalf number, or echoed a parse-error
	   diagnostic with its "^" cursor.  Either way the result is unsafe. *)
	If[!AllTrue[ginshOut, NumericQ],
		Message[STToGinsh::nonNumeric,
			Select[ginshOut, !NumericQ[#] &]];
		Return[$Failed]];
	];
	(* Final N[] on the substituted expression.  Two subtleties:
	   (a) The huge-integer rational arithmetic kinematic substitutions produce
	       (primes^2 / rationalised Sqrt denominators over each other) hits
	       $MaxExtraPrecision on many library entries.  Lift the ceiling
	       AND ask for 30-digit arbitrary-precision N so evaluation tracks
	       significance adaptively instead of hitting the machine-precision
	       meprec path.
	   (b) Even with the ceiling raised, N::meprec can still print a message
	       after the result is produced (N is permissive about reporting but
	       still returns the best available value).  Quiet that specific
	       message so the caller's Check[STToGinsh[...], $Failed] does not
	       misinterpret a benign precision warning as a hard failure. *)
	Quiet[
		Block[{$MaxExtraPrecision = 10000},
			N[expr /. Table[HsAndZetas[[i]] -> ginshOut[[i]], {i, 1, Length[HsAndZetas]}], 30]
		],
		N::meprec
	]
]


(* ::Subsection::Closed:: *)
(*Shared-mass detection (used by all numerical backends)*)


(* stSharedMassLegs[{edges, nodes}] returns {sharedSyms, sharedLegIndices}
   where sharedSyms are the mass symbols that appear on BOTH an internal
   edge and an external leg, and sharedLegIndices are the (1-indexed)
   external-leg positions whose node-mass symbol is in that set.

   At a shared-mass point the F polynomial factors, and sector decomposition
   / IBP reduction compiled against generic (m, msq) will miss the extra
   \[CurlyEpsilon]-pole.  Each numerical backend uses this helper to bake
   the constraint p_i^2 = m^2 into its substitutions up front. *)
stSharedMassLegs[{edges_List, nodes_List}] := Module[
	{edgeMasses, nodeMasses, intMassSyms, extMassSyms, shared, legs},
	edgeMasses = edges[[All, 2]];
	nodeMasses = nodes[[All, 2]];
	intMassSyms = Cases[edgeMasses, _Symbol | _[_Integer], {0, Infinity}]
		// DeleteDuplicates;
	extMassSyms = Cases[nodeMasses, _Symbol | _[_Integer], {0, Infinity}]
		// DeleteDuplicates;
	shared = Intersection[intMassSyms, extMassSyms];
	legs = Flatten[Position[nodeMasses,
		_?(MatchQ[#, _Symbol | _[_Integer]] && MemberQ[shared, #] &)]];
	{shared, legs}
];

(* stIsSharedMassLeg[{edges, nodes}, i] returns the mass symbol on external
   leg i iff that symbol also appears on an internal edge; else None. *)
stIsSharedMassLeg[{edges_List, nodes_List}, i_Integer] := Module[
	{nm = nodes[[i, 2]], edgeMasses = edges[[All, 2]]},
	If[MatchQ[nm, _Symbol | _[_Integer]] && MemberQ[edgeMasses, nm], nm, None]
];


