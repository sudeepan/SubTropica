   Use STSymanzik[..., "Output" -> "UF"] or "UFNu" for equivalent functionality. *)


Clear[STMapIntoLoop];
STMapIntoLoop[loops_,props_,exponents_,kinematics_]:=Module[{pinched,nonpinched,\[CapitalLambda],J,z},
pinched=Position[exponents,0]//Flatten;
nonpinched=DeleteCases[Range[exponents//Length],Alternatives@@pinched];
{\[CapitalLambda],J,Z}=matrixData[loops,props[[nonpinched]]];
{loops,Det[\[CapitalLambda]],-1/2 Inverse[\[CapitalLambda]] . J,\[CapitalLambda],J,kinematics}
]


(* ::Subsubsection::Closed:: *)
(*Feynman Parametric Integrand Data*)


(* Build Feynman Integrands in Feynman Parametrization *)
STGetIntegrandData[dim_,loops_,props_,exponents_,kinematics_]:=Module[
{pinched,nonpinched,
symU,symF,xvars,
\[Nu],L,eF,eU,integrand},
	pinched=Position[exponents,0]//Flatten;
	nonpinched=DeleteCases[Range[exponents//Length],Alternatives@@pinched];
	Module[{extMom, nExt, massRules, subs},
		(* Build mass rules: STSymanzik introduces M[i]^2 for external masses via basis[n].
		   Map these to the corresponding p[i]^2 values from kinematics.
		   nExt = number of visible external momenta + 1 (for momentum conservation). *)
		extMom = Complement[Cases[Variables[props[[nonpinched]]], p[_]], loops] // Sort;
		nExt = Length[extMom] + 1;
		massRules = Join[
			Table[M[i]^2 -> (extMom[[i]]^2 /. kinematics), {i, Length[extMom]}],
			{M[nExt]^2 -> (Expand[(-Total[extMom])^2] //. kinematics)}
		];
		subs = Join[kinematics, massRules];
		(* STSymanzik "UF" mode returns U > 0, F \[LessEqual] 0 (Euclidean) *)
		{symU, symF} = STSymanzik[props[[nonpinched]], "Substitutions" -> subs,
			"Dimension" -> dim, "LoopMomenta" -> loops, "Output" -> "UF"];
	];
	xvars=Table[Symbol["x"<>ToString[i]],{i,nonpinched}];
	\[Nu]=exponents//Total;
	L=loops//Length;
	eF=-(\[Nu]-(L)(dim-2 eps)/2)//Simplify;
	eU=(\[Nu]-(L+1)(dim-2 eps)/2)//Simplify;
	(* Use (-F)^eF: the Feynman branch where -F >= 0 in Euclidean.
	   This is the correct branch from the Schwinger parametrization
	   (see normalization.tex Eq. 6). Using F^eF instead would introduce
	   a spurious e^{i pi omega} phase at every order in eps. *)
	integrand=(Times@@(xvars^exponents[[nonpinched]]))symU^eU (-symF)^eF;
	(* Declare Positive Variables *)
	xvars//STDeclarePositiveVariables;
	kinematics[[;;,2]]//Variables//DeleteDuplicates//STDeclarePositiveVariables;
	{{dim,\[Nu],L,eF,eU,xvars},{Gamma[-eF]/Product[Gamma[exponents[[np]]],{np,nonpinched}],integrand}}//Return;
]

STGetIntegrandData2[dim_,loops_,props_,exponents_,kinematics_]:=Module[
{pinched,nonpinched,symU,symF,xvars,\[Nu],L,eF,eU,integrand,gA},
	pinched=Position[exponents,0]//Flatten;
	nonpinched=DeleteCases[Range[exponents//Length],Alternatives@@pinched];
	Module[{extMom, nExt, massRules, subs},
		extMom = Complement[Cases[Variables[props[[nonpinched]]], p[_]], loops] // Sort;
		nExt = Length[extMom] + 1;
		massRules = Join[
			Table[M[i]^2 -> (extMom[[i]]^2 /. kinematics), {i, Length[extMom]}],
			{M[nExt]^2 -> (Expand[(-Total[extMom])^2] //. kinematics)}
		];
		subs = Join[kinematics, massRules];
		{symU, symF} = STSymanzik[props[[nonpinched]], "Substitutions" -> subs,
			"Dimension" -> dim, "LoopMomenta" -> loops, "Output" -> "UF"];
	];
	xvars=Table[Symbol["x"<>ToString[i]],{i,nonpinched}];
	\[Nu]=exponents//Total;
	L=loops//Length;
	eF=-(\[Nu]-(L)(dim-2 eps)/2)//Simplify;
	eU=(\[Nu]-(L+1)(dim-2 eps)/2)//Simplify;
	(* Feynman branch: (-F)^eF, see normalization.tex Eq. 6 *)
	integrand=(Times@@(xvars^exponents[[nonpinched]]))symU^eU (-symF)^eF;
	(* Declare Positive Variables *)
	xvars//STDeclarePositiveVariables;
	kinematics[[;;,2]]//Variables//DeleteDuplicates//STDeclarePositiveVariables;
	{{dim,\[Nu],L,eF,eU,xvars},{Gamma[-eF]/Product[Gamma[exponents[[np]]],{np,nonpinched}],{symU,symF}}}//Return;
]

(* Currently no exponents are implemented *)
STGetIntegrandDataNumerators[dim_,loops_,props_,numerators_,kinematics_]:=Module[
{exponents,pinched,nonpinched,
xvars,coeffs,
symU,symF,symN,
\[Nu],L,eF,eU,eN,integrand,gA},
	(*Currently all propagators are assumed to have exponent 1 *)
	(*In the future denominators may have exponents:
	>0 mean a denominator;
	0 means pinched propagator (as if it was dropped from list);
	<0 means a numerator;
	*)
	exponents=Table[1,props//Length];
	pinched=Position[exponents,0]//Flatten;
	nonpinched=DeleteCases[Range[exponents//Length],Alternatives@@pinched];
	(**)
	xvars=Table[Symbol["x"<>ToString[i]],{i,nonpinched}];
	coeffs=kinematics[[;;,2]]//Variables//DeleteDuplicates//Sort;
	\[Nu]=exponents//Total;
	L=loops//Length;

	(**)
	(* Use STSymanzik with numerator exponents to compute U, F, and N *)
	Module[{allProps, allExps, ufnRaw, extMom, nExt, massRules, subs},
		allProps = Join[props[[nonpinched]], numerators];
		allExps = Join[Table[1, Length[nonpinched]], Table[-1, Length[numerators]]];
		(* Build mass rules: map M[i]^2 to p[i]^2 values from kinematics *)
		extMom = Complement[Cases[Variables[props[[nonpinched]]], p[_]], loops] // Sort;
		nExt = Length[extMom] + 1;
		massRules = Join[
			Table[M[i]^2 -> (extMom[[i]]^2 /. kinematics), {i, Length[extMom]}],
			{M[nExt]^2 -> (Expand[(-Total[extMom])^2] //. kinematics)}
		];
		subs = Join[kinematics, massRules];
		(* STSymanzik "UFNu" mode returns physical signs: U > 0, F = kin - mass *)
		ufnRaw = STSymanzik[allProps,
			"Exponents" -> allExps,
			"Substitutions" -> subs,
			"Dimension" -> dim,
			"LoopMomenta" -> loops,
			"Output" -> "UFNu"];
		(* Negate U and F to match old convention used by the integrand formula below *)
		symU = Expand[-ufnRaw[[1]]];
		symF = Expand[-ufnRaw[[2]]];
		symN = ufnRaw[[3]];
	];
	{symU,symF,symN,eU,eF,eN}={symU,symF,symN,eU,eF,eN}//Expand;
	(*{symU,symF,symN,eU,eF,eN}//Return;*)
	
	eU=(\[Nu]-(L+1)dim/2)-2 Length[numerators]//Collect[#,eps,Factor]&;
	eF=-(\[Nu]-(L)dim/2)//Collect[#,eps,Factor]&;
	(* gA is the argument of the leading Gamma function.
	   For NN=0 this must match the no-numerator formula Gamma[-eF] (see STGetIntegrandData).
	   For NN genuine ISP insertions the correct Schwinger formula gives Gamma[nu_total - L*D/2]
	   = Gamma[-eF - NN].  The previous sign of eF was flipped (eF - NN instead of -eF - NN),
	   causing an incorrect Gamma prefactor for all cases. *)
	gA=-eF-Length[numerators]//Collect[#,eps,Factor]&;
	
	{symU,symF,symN,eU,eF,eN}={symU,symF,symN,eU,eF,eN}//Expand;
	(* Feynman branch: (-F)^eF, see normalization.tex Eq. 6 *)
	integrand=(Times@@(xvars^exponents[[nonpinched]]))symU^eU (-symF)^eF symN;
	(* Declare Positive Variables *)
	xvars//STDeclarePositiveVariables;
	kinematics[[;;,2]]//Variables//DeleteDuplicates//STDeclarePositiveVariables;
	{{dim,\[Nu],L,eF,eU,eN,xvars,coeffs},{Gamma[gA]/Product[Gamma[exponents[[np]]],{np,nonpinched}],integrand}}//Return;
]



STSymanzik::zeroF = "The F (second Symanzik) polynomial is zero. Check your kinematics or propagator input.";
STSymanzik::vacuumPeriod = "The F polynomial vanishes but the superficial degree of divergence is zero (vacuum period). Proceeding with U polynomial only.  ($STLastVacuumPeriod set to True.)";

(* Flag set to True when the vacuum-period F=1 shortcut is triggered
   during the most recent STSymanzik / STIntegrate call.  Consumers
   (library saver, STVerify, UI) should read this immediately after the
   call to distinguish a period from a standard dim-reg integral \[LongDash] the
   dim-reg value for a fully scaleless integrand is 0, but the period is
   the finite Kontsevich-Zagier graph period built from U alone.  Reset
   by the top-level STIntegrate dispatch. *)
$STLastVacuumPeriod = False;
STSymanzik::badDot = "Dot expression `1` has more than two arguments; scalar products are binary. Treating as an iterated Times product.";
STSymanzik::propNoLoop = "The following propagator(s) do not depend on any loop momentum: `1`. Every positive-exponent entry must contain at least one of the loop momenta `2`. Move loop-independent factors into the prefactor or drop them from the propagator list.";
STSymanzik::zeroProp = "Propagator(s) at position(s) `1` evaluate to zero. A zero propagator raised to a positive power yields an ill-defined integrand.";
STSymanzik::loopUnused = "Loop momentum (momenta) `1` do not appear in any propagator or numerator. Such a momentum integrates to a vacuous scaleless zero, which is indistinguishable from a physical scaleless diagram. Remove it from \"LoopMomenta\", or add a propagator that depends on it.";
STSymanzik::zeroU = "The first Symanzik polynomial U is identically zero. This means the Schwinger-weighted quadratic form Sum[alpha_i * P_i] is singular in the loop momenta, so no Gaussian completion exists and the Symanzik parametric representation does not apply. Typical cause: every positive-exponent propagator is at most linear in some loop momentum (e.g., only eikonal / Wilson-line / HQET propagators, with no standard (...)^2 - m^2 propagator to regulate that direction).";

(*- Options- *)
Options[STSymanzik] = {
	"Exponents" -> Automatic,
	"Substitutions" -> {},
	"Dimension" -> 4 - 2 eps,
	"LoopMomenta" -> Automatic,
	"Output" -> "Integrand"
};

(* SyntaxInformation removed \[LongDash] triggers SetFunctionInformation FE error *)

(*- Main function- *)
STSymanzik[
	propagators_List,
	OptionsPattern[]
] :=

Module[{
	integrand, xvars, coeffs, pref,
	propagatorsParsed, numeratorsParsed,
	propagatorExponents, numeratorExponents,
	EE, NN, LL, dd, sum,
	Q\[Beta], L\[Beta], c\[Beta], U\[Beta], F\[Beta], U, F, \[CapitalNu],
	adj, subscriptsToBrackets, loops, loopDegrees,
	combinedPropagators, combinedExponents, DD, \[Alpha],
	useCenterDot, processedPropagators, processedSubstitutions,
	originalSubstitutions, dotCanon,
	momentaSymbols, linearCoeffs, cdRules, xSymbols,
	Ucd, Fcd, \[CapitalNu]cd, aU, aF
},


(* ============================================================ *)
(*  0. Auto-detect scalar-product mode and preprocess            *)
(* ============================================================ *)

subscriptsToBrackets = {
	Subscript[x_, args__Integer] :> Symbol["Global`" <> ToString[x] <> StringJoin[ToString /@ {args}]],
	Subscript[x_, i_] :> x[i]
};

(* Accept three spellings for a scalar product: p*q, p CenterDot q, and p.q.
   Canonicalize to Times at input; post-processing (Step 7) then reintroduces
   CenterDot[p_i, p_j] for display.  Dot is Flat, so chains like p.q.r collapse
   to Dot[p,q,r]; warn, then degrade to an iterated Times.  The HoldPattern
   wrapper is required around Dot patterns because of its Flat attribute. *)
If[!FreeQ[propagators, HoldPattern[Dot[_, _, _, ___]]],
	Message[STSymanzik::badDot,
		FirstCase[propagators, d_Dot /; Length[d] > 2, None, Infinity]]];

(* HoldPattern is required for Dot because Dot has Flat attribute: a bare
   `Dot[a__] :> Times[a]` rule silently fails to fire on Dot[x,x]. *)
dotCanon = {CenterDot[a_, b_] :> a b, HoldPattern[Dot[a__]] :> Times[a]};

useCenterDot = !FreeQ[propagators, CenterDot | Dot];

(* Normalize Dot to CenterDot on substitution LHSs so the later display-path
   substitution into CenterDot-form U/F/\[CapitalNu] matches.  Dot[p,q] becomes
   CenterDot[p,q], which is Orderless (line 11232), so p[2].p[1] -> v
   correctly matches CenterDot[p[1], p[2]]. *)
originalSubstitutions = OptionValue["Substitutions"] /. subscriptsToBrackets /.
	Dot[a_, b_] :> CenterDot[a, b];

If[useCenterDot,
	processedPropagators =
		(propagators /. subscriptsToBrackets) /. dotCanon;
	processedSubstitutions =
		originalSubstitutions /. dotCanon;
,
	processedPropagators = propagators;
	processedSubstitutions = OptionValue["Substitutions"];
];


(* ============================================================ *)
(*  1. Parse exponents                                           *)
(* ============================================================ *)

propagatorsParsed = {};
numeratorsParsed = {};
propagatorExponents = {};
numeratorExponents = {};

If[OptionValue["Exponents"] === Automatic,

	propagatorsParsed = processedPropagators;
	propagatorExponents = 1 + 0 processedPropagators;

, (* else *)

If[VectorQ[OptionValue["Exponents"]],

	If[Length[OptionValue["Exponents"]] != Length[processedPropagators],
		"The number of exponents should be the same as the number of propagators and numerators" // Print;
		(*Return[];*)Abort[];
	];

	Do[
		If[OptionValue["Exponents"][[i]] > 0,
			AppendTo[propagatorsParsed,
				processedPropagators[[i]] /. subscriptsToBrackets];
			AppendTo[propagatorExponents,
				OptionValue["Exponents"][[i]]];
		];
		If[OptionValue["Exponents"][[i]] < 0,
			AppendTo[numeratorsParsed,
				processedPropagators[[i]] /. subscriptsToBrackets];
			AppendTo[numeratorExponents,
				OptionValue["Exponents"][[i]]];
		];
	, {i, Length[processedPropagators]}];

, (* else *)

If[MatchQ[OptionValue["Exponents"], {{___}, {___}}],

	If[Length[OptionValue["Exponents"] // Flatten] != Length[processedPropagators],
		"The number of exponents should be the same as the number of propagators and numerators" // Print;
		(*Return[];*)Abort[];
	];

	propagatorsParsed = processedPropagators[[;; Length[OptionValue["Exponents"][[1]]]]];
	propagatorExponents = OptionValue["Exponents"][[1]];
	numeratorsParsed = processedPropagators[[Length[OptionValue["Exponents"][[1]]] + 1 ;;]];
	numeratorExponents = OptionValue["Exponents"][[2]];

	If[AnyTrue[propagatorExponents, # < 0 &],
		"All inverse propagator exponents should be non-negative" // Print;
		Return[];
	];
	If[AnyTrue[numeratorExponents, # > 0 &],
		"All numerator exponents should be non-positive" // Print;
		Return[];
	];

,
	"Incorrect formatting of the Exponents option" // Print;
	Return[];

];
];
];

If[propagatorsParsed === {},
	"No propagators found. All exponents are zero or negative (numerators only). At least one positive exponent is required." // Print;
	(*Return[];*)Abort[];
];


(* ============================================================ *)
(*  2. Combine and identify loop momenta                         *)
(* ============================================================ *)

combinedPropagators = Join[propagatorsParsed, numeratorsParsed] /. subscriptsToBrackets;
combinedExponents = Join[propagatorExponents, numeratorExponents];

loops = If[OptionValue["LoopMomenta"] === Automatic,
	combinedPropagators // Variables // Cases[#, l[_]] & // Sort
,
	OptionValue["LoopMomenta"] /. subscriptsToBrackets
];

If[loops === {} || loops === Automatic,
	Print["No loop momenta detected. The automatic detection recognizes l[1], l[2], ... only."];
	Print["For bare symbols (e.g. l, k) or non-standard labels (e.g. \[ScriptL][1]), specify \"LoopMomenta\" explicitly."];
	Return[$Failed];
];

(* Per-propagator sanity: every positive-exponent entry must depend on at
   least one loop momentum, and none may be identically zero. Without this
   guard, a loop-independent "propagator" silently survives into the Symanzik
   pipeline (producing a misleading result), and a zero propagator triggers a
   cascade of downstream errors (Table::nliter, Part::partw, ...). *)
Module[{zeroPos, badProps},
	zeroPos = Flatten @ Position[propagatorsParsed, _?PossibleZeroQ, {1}, Heads -> False];
	If[zeroPos =!= {},
		Message[STSymanzik::zeroProp, zeroPos];
		Return[$Failed]
	];
	badProps = Select[propagatorsParsed, FreeQ[#, Alternatives @@ loops] &];
	If[badProps =!= {},
		Message[STSymanzik::propNoLoop, badProps, loops];
		Return[$Failed]
	];
];

(* Reverse check: every loop momentum must appear in at least one entry
   (prop or numerator). An unused loop integrates to a vacuous scaleless
   zero, which the existing F=0 path reports as "scaleless" and masks the
   user's typo. Only meaningful when "LoopMomenta" is user-supplied; auto-
   detection at line 1802 guarantees the check passes. *)
Module[{unusedLoops},
	unusedLoops = Select[loops, FreeQ[combinedPropagators, #] &];
	If[unusedLoops =!= {},
		Message[STSymanzik::loopUnused, unusedLoops];
		Return[$Failed]
	];
];

LL = LLinternal = loops // Length;
EE = EEinternal =  propagatorsParsed // Length;
NN = NNinternal = numeratorsParsed // Length;
DD = DDinternal = OptionValue["Dimension"];

loopDegrees = combinedPropagators // CoefficientList[#, loops] & // Map[Length];
If[Max[loopDegrees] > 3,
	"All inverse propagators and numerators must be at most quadratic in the loop momenta" // Print;
	Return[];
];

(* Auto-apply basis[n] kinematic substitutions (momentum conservation,
   on-shell conditions) before any user-supplied substitutions *)
Module[{extMom, nExt, basisRules, basisVarRules},
	extMom = Complement[Cases[Variables[combinedPropagators], p[_]], loops] // Sort;
	nExt = nExtInternal = Length[extMom]+1;
	If[nExt >= 2,
		basisRules = basis[nExt] /. Subscript[M, i_] :> Subscript[M, i]^2;

		(* basis[n] maps all p[i].p[j] -> f(M[i], Subscript[s,i,j]).
		   We build bridge rules so the user can specify kinematics in any format:
		   - p[i]^2 -> val  (bridged to Subscript[M,i]^2 -> val)
		   - M[i] -> val or Subscript[M,i] -> val  (applied directly)
		   - p[i] p[j] -> val  (used to resolve Subscript[s,i,j] via inversion)
		   - Subscript[s,i,j] -> val  (applied directly) *)
		Module[{allMom,
		        (* Canonicalize Dot/CenterDot on LHS of user subs into Times
		           so pattern matching in the Mandelstam-bridge loop below
		           (which operates on Expand[...] polynomials) is consistent
		           across the three accepted spellings. *)
		        userSubs = OptionValue["Substitutions"] /. dotCanon,
		        massBridge = {}, mandelBridge = {}, cyclicS, hasDotSubs},
			allMom = Join[extMom, {-Total[extMom]}];
			hasDotSubs = !FreeQ[userSubs, Rule[_p _p, _] | Rule[p[_]^2, _]];

			If[hasDotSubs,
				(* Bridge p[i]^2 -> val to Subscript[M,i]^2 -> val *)
				Do[
					If[!FreeQ[userSubs, Rule[extMom[[i]]^2, _]],
						AppendTo[massBridge, Subscript[M, i]^2 -> (extMom[[i]]^2 /. userSubs)];
					];
				, {i, Length[extMom]}];
				(* Bridge last mass via momentum conservation *)
				AppendTo[massBridge,
					Subscript[M, nExt]^2 -> (Expand[Total[extMom]^2] //. userSubs //. massBridge)];
				(* Bridge Subscript[s,i,j] -> (p[i]+...+p[j])^2, resolved via user subs *)
				cyclicS = Cases[basisRules, Subscript[s, __], Infinity] // DeleteDuplicates;
				mandelBridge = Table[
					Module[{indices = sv /. Subscript[s, idx__] :> {idx}},
						sv -> (Expand[Total[allMom[[#]] & /@ indices]^2] //. userSubs //. massBridge)
					]
				, {sv, cyclicS}];
			];

			Module[{stRename = {},
			        (* Bridge M[i] -> val to M1 -> val (symbol form) for user convenience *)
			        mSymBridge = Cases[userSubs, Rule[M[i_Integer], v_] :> Rule[Symbol["M" <> ToString[i]], v]],
			        (* Split user subs: "early" subs involve momentum-level objects (p, M, Subscript)
			           and are safe to apply to basis RHS. "Late" subs involve output symbols
			           (s, t, s12, M1, ...) and must be applied after subscriptsToBrackets/stRename. *)
			        earlySubs, lateSubs},
				earlySubs = Select[userSubs, !FreeQ[#[[1]], p | M | Subscript] &];
				lateSubs = Complement[userSubs, earlySubs];
				originalSubstitutions = Join[
					basisRules /. Rule[a_,b_] :> Rule[a, b //. earlySubs //. massBridge //. mandelBridge],
					earlySubs,
					massBridge,
					mandelBridge,
					mSymBridge,
					lateSubs
				] (* Preserve external-momentum Subscripts as indexed p[i] so that
				     basis-rule LHSs (e.g., CenterDot[p[1], p[2]]) match F[\[Beta]],
				     which carries user-typed p[1]. The global subscriptsToBrackets
				     otherwise flattens Subscript[p,1] to Global`p1. *)
				/. {Subscript[p, i_Integer] :> p[i]}
				/. subscriptsToBrackets /. stRename;
			];
		];
		processedSubstitutions = Join[
			originalSubstitutions /. dotCanon,
			processedSubstitutions];
	];
];


(* ============================================================ *)
(*  3. Build the quadratic form                                  *)
(* ============================================================ *)

dd = ddInternal = (Total[combinedExponentsInternal = combinedExponents] - LL DD/2) // Expand;
sum = Table[\[Alpha][e], {e, EE + NN}] . combinedPropagators // Expand;

Q\[Beta] = Table[
	If[i == j, 1, 1/2] Coefficient[sum, loops[[i]] loops[[j]]]
, {i, LL}, {j, LL}] // Expand;

L\[Beta] = (
	1/2 Table[Coefficient[sum, loops[[i]]], {i, LL}]
		/. Table[loopMomentum -> 0, {loopMomentum, loops}]
) // Expand;

c\[Beta] = (sum /. Table[loopMomentum -> 0, {loopMomentum, loops}]) // Expand;


(* ============================================================ *)
(*  4. Symanzik polynomials U and F                              *)
(* ============================================================ *)

adj[m_] := Map[Reverse,
	Minors[m // Transpose, Length[m] - 1],
	{0, 1}
] Table[(-1)^(i + j), {i, Length[m]}, {j, Length[m]}];

U\[Beta] = Det[Q\[Beta]] // Expand;
F\[Beta] = (
	(c\[Beta] U\[Beta]
		- ({L\[Beta]} . adj[Q\[Beta]] . Transpose[{L\[Beta]}])[[1, 1]]
		// Expand)
	//. processedSubstitutions
) /. subscriptsToBrackets;

{U, F} = ({U\[Beta], F\[Beta]} /. {\[Alpha][e_] /; e > EE :> 0}) // Expand;

(* Bulletproof Gaussian-completion check: U = Det(Q_beta) is the determinant
   of the collective quadratic form. U identically zero <=> the form is
   singular in the loop momenta <=> no Gaussian integration possible. This
   catches inputs like purely-linear propagator sets (eikonal-only) that
   the per-entry degree heuristic cannot, with no false positives. *)
If[SameQ[U, 0],
	Message[STSymanzik::zeroU];
	Return[$Failed]
];

If[F === 0,
	Module[{aFtest = Expand[Total[combinedExponents] - LL DD/2 - Total[numeratorExponents]]},
		If[SameQ[Simplify[aFtest /. eps -> 0], 0],
			(* F=0 but F-power is O(eps): vacuum period \[LongDash] F drops out *)
			Message[STSymanzik::vacuumPeriod];
			$STLastVacuumPeriod = True;
			F = 1;  (* so that F^aF = 1^aF = 1; integral depends on U only *)
		,
			(* F=0 and F-power is nonzero: truly scaleless, vanishes in dim reg *)
			Message[STSymanzik::zeroF]; Return[0];
		];
	];
];

(* Early return: "UF" mode \[LongDash] return {U, F} directly.
   U = Det(Q_\[Beta]) > 0  (Q_\[Beta] is positive-definite since
   propagators use D_e = q_e^2 - m_e^2).
   F = c_\[Beta] * U - L_\[Beta] . Adj(Q_\[Beta]) . L_\[Beta]^T \[LessEqual] 0
   for Euclidean kinematics (all Minkowski invariants spacelike,
   c_\[Beta] = \[CapitalSigma] \[Alpha]_e (r_e^2 - m_e^2) < 0).
   F = F_kin - U \[CenterDot] \[CapitalSigma] m_e^2 \[Alpha]_e, with F_kin \[LessEqual] 0 in Euclidean. *)
If[SameQ[OptionValue["Output"], "UF"],
	Return[{U, F} /. \[Alpha][i_] :> Symbol["x" <> ToString[i]] // Expand];
];


(* ============================================================ *)
(*  5. Numerator polynomial N                                    *)
(* ============================================================ *)

If[NN > 0,
	\[CapitalNu] = (
		U^Expand[DD/2 - dd - Total[numeratorExponents]]
		F^(dd - Total[numeratorExponents])
		D[
			1 / (U\[Beta]^Expand[DD/2 - dd] F\[Beta]^dd),
			Sequence @@ Table[
				{\[Alpha][EE + e], -numeratorExponents[[e]]}
			, {e, NN}]
		]
		/. {\[Alpha][e_] /; e > EE :> 0}
	);

	\[CapitalNu] = If[useCenterDot,
		\[CapitalNu] // Expand,
		\[CapitalNu] // Simplify
	];

	\[CapitalNu] = \[CapitalNu] //. processedSubstitutions;
,
	\[CapitalNu] = 1;
];

(* Early return: "UFNu" mode \[LongDash] return {U, F, Nu} directly.
   U is positive-definite, F has physical sign. No correction needed. *)
If[SameQ[OptionValue["Output"], "UFNu"],
	Return[{U, F, \[CapitalNu]} /. \[Alpha][i_] :> Symbol["x" <> ToString[i]] // Expand];
];


(* ============================================================ *)
(*  6. Assemble the output                                       *)
(* ============================================================ *)

(* Sign conventions for the integrand:
   U = Det(Q_\[Beta]) > 0.
   F = c * U - L . Adj(Q) . L^T \[LessEqual] 0 (Euclidean kinematics).
   Integrand uses the Feynman branch: x^nu * Nu / (U^aU * (-F)^aF).
   The minus sign on F ensures the integrand is real in the Euclidean
   region where -F >= 0.  See normalization.tex Eq. 6 and App. A of
   arXiv:2204.02988. *)
Module[{Uphys, Fphys},
	Uphys = U;
	Fphys = -F;  (* Feynman branch: use -F >= 0 in Euclidean *)

	aU = Expand[DD/2 - dd - Total[numeratorExponents]];
	aF = dd - Total[numeratorExponents];

	pref = Gamma[dd] Product[
		1 / Gamma[propagatorExponents[[e]]]
	, {e, EE}] /. \[Alpha][i_] :> Symbol["x" <> ToString[i]];

	Module[{\[CapitalNu]phys = \[CapitalNu]},

	xvars = Table[Symbol["x" <> ToString[e]], {e, EE}];
	xSymbols = xvars;

	If[useCenterDot,

		(* ======================================================== *)
		(*  7. CenterDot postprocessing                              *)
		(* ======================================================== *)

		linearCoeffs = Flatten @ Table[
			Coefficient[combinedPropagators[[e]], loops[[i]]]
				/. Table[lm -> 0, {lm, loops}]
		, {e, Length[combinedPropagators]}, {i, LL}];

		momentaSymbols = Variables[linearCoeffs] // Sort;

		cdRules = Join[
			Table[
				With[{sym = momentaSymbols[[i]]},
					sym^n_ /; n >= 2 :> CenterDot[sym, sym] sym^(n - 2)
				]
			, {i, Length[momentaSymbols]}],
			Flatten @ Table[
				momentaSymbols[[i]] momentaSymbols[[j]]
					-> CenterDot[momentaSymbols[[i]], momentaSymbols[[j]]]
			, {i, Length[momentaSymbols]}
			, {j, i + 1, Length[momentaSymbols]}]
		];

		Ucd = Expand[Uphys] //. cdRules //. originalSubstitutions;
		Fcd = Expand[Fphys] //. cdRules //. originalSubstitutions;
		\[CapitalNu]cd = If[NN > 0,
			\[CapitalNu]phys //. cdRules //. originalSubstitutions // Simplify,
			1
		];

		integrand = (
			Product[\[Alpha][e]^propagatorExponents[[e]], {e, EE}]
			\[CapitalNu]cd / (Ucd^aU Fcd^aF)
		) /. \[Alpha][i_] :> Symbol["x" <> ToString[i]];

		integrand = integrand //. originalSubstitutions;

		coeffs = Complement[
			Variables[{Ucd, Fcd, \[CapitalNu]cd}],
			{eps} ~Join~ Table[\[Alpha][e], {e, EE}]
		] // Sort;

	, (* else: standard polynomial mode *)

		integrand = (
			Product[\[Alpha][e]^propagatorExponents[[e]], {e, EE}]
			\[CapitalNu]phys / (Uphys^aU Fphys^aF)
		) /. \[Alpha][i_] :> Symbol["x" <> ToString[i]];

		integrand = integrand //. processedSubstitutions;

		coeffs = Complement[
			Variables[{Uphys, Fphys, \[CapitalNu]phys}],
			{eps} ~Join~ Table[\[Alpha][e], {e, EE}]
		] // Sort;
	];

	Return[{pref, integrand, xvars, coeffs}];
	]; (* end Nuphys Module *)
]; (* end sign Module *)

] (* end Module *)



