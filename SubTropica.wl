STInstallAutocompletion::usage = "STInstallAutocompletion[] installs option-value autocompletion files \
for STIntegrate and STSymanzik into the Mathematica frontend. \
STInstallAutocompletion[\"Remove\"] removes them. Requires write access to $InstallationDirectory.";

STInstallAutocompletion[] := Module[{targetDir, tmpDir, file, stream, optData, lines,
        installed = {}, needsSudo = False},
    targetDir = FileNameJoin[{$InstallationDirectory,
        "SystemFiles", "Components", "AutoCompletionData", "Main", "OptionValues"}];
    If[!DirectoryQ[targetDir],
        Print["[SubTropica] OptionValues directory not found: ", targetDir];
        Print["[SubTropica] This Mathematica installation may not support option-value completion."];
        Return[$Failed]
    ];
    (* Try writing directly; if blocked (macOS SIP), stage in temp dir *)
    tmpDir = FileNameJoin[{$TemporaryDirectory, "SubTropicaAutocompletion"}];
    Do[
        optData = $STAutocompletionData[funcName];
        lines = Table[
            " " <> k <> " -> {" <> StringRiffle[optData[k], ", "] <> "}",
            {k, Keys[optData]}
        ];
        (* Try direct write first *)
        file = FileNameJoin[{targetDir, funcName <> ".m"}];
        stream = Quiet[OpenWrite[file]];
        If[Head[stream] === OutputStream,
            WriteString[stream, "{\n" <> StringRiffle[lines, ",\n"] <> "\n}\n"];
            Close[stream];
            AppendTo[installed, funcName];
        ,
            (* Direct write failed; stage in temp dir *)
            needsSudo = True;
            Quiet[CreateDirectory[tmpDir]];
            file = FileNameJoin[{tmpDir, funcName <> ".m"}];
            stream = OpenWrite[file];
            WriteString[stream, "{\n" <> StringRiffle[lines, ",\n"] <> "\n}\n"];
            Close[stream];
            AppendTo[installed, funcName];
        ];
    , {funcName, Keys[$STAutocompletionData]}];
    If[needsSudo,
        Print["[SubTropica] Files staged in ", tmpDir];
        Print["[SubTropica] macOS blocks direct writes to $InstallationDirectory."];
        Print["[SubTropica] Run this in Terminal to install:\n"];
        Print["  sudo cp ", tmpDir, "/*.m ", targetDir, "/"];
        Print["\n[SubTropica] Then restart Mathematica for changes to take effect."];
    ,
        If[installed =!= {},
            Print["[SubTropica] Installed option-value completion for: ", StringRiffle[installed, ", "]];
            Print["[SubTropica] Restart the frontend (Quit[] + relaunch) for changes to take effect."];
        ];
    ];
];

STInstallAutocompletion["Remove"] := Module[{dir, file, removed = {}},
    dir = FileNameJoin[{$InstallationDirectory,
        "SystemFiles", "Components", "AutoCompletionData", "Main", "OptionValues"}];
    Do[
        file = FileNameJoin[{dir, funcName <> ".m"}];
        If[FileExistsQ[file],
            DeleteFile[file];
            AppendTo[removed, funcName];
        ];
    , {funcName, Keys[$STAutocompletionData]}];
    If[removed =!= {},
        Print["[SubTropica] Removed option-value completion for: ", StringRiffle[removed, ", "]];
        Print["[SubTropica] Restart the frontend for changes to take effect."];
    ,
        Print["[SubTropica] No autocompletion files found to remove."];
    ];
];


(* Form 0: no arguments \[RightArrow] interactive GUI *)
(* Guard: warn if called in a non-interactive context (e.g., inside a loop or script) *)
STIntegrate[] := Module[{},
  If[TrueQ[$BatchInput] || !TrueQ[$Notebooks],
    stErr["[SubTropica] WARNING: STIntegrate[] opens an interactive GUI."];
    stErr["[SubTropica]   It appears you are running in a non-interactive context (batch/script mode)."];
    stErr["[SubTropica]   If this is intentional, use FeynmanIntegrate[] directly."];
    Return[$Failed]
  ];
  FeynmanIntegrate[]
];

(* Form 1: graph topology {edges_List, nodes_List} *)
STIntegrate[g:{_List, _List}, opts:OptionsPattern[]] :=
    Module[{r, nodes = g[[2]], nLegs, vertexLabels, labels,
            frOpt, intOpt, rewrittenOpts, edgesBare, nodesBare,
            uRaw, fRaw, ufXrule, U, F, kinSubs, masssubs, xvarsAll,
            integSch, searchRes},
        (* DEVELOPER-ONLY FindRoots -> "AnTropica" intercept.
           Uses STFubiniWithAnTropica as the LR-search backend
           (consistent with the option name) rather than the older
           post-HF-letter intercept.  If the search succeeds, reports
           the discovered order and substitutions; the full pipeline
           (apply substitutions to the actual integrand and dispatch
           to Form 3 with FindRoots -> False) is not yet wired and is
           a follow-up.  Set $STAnTropicaHookActive = False so the
           older HF letter intercept does not also fire. *)
        frOpt  = FindRoots /. {opts} /. {FindRoots -> Automatic};
        intOpt = "Integrator" /. {opts} /. {"Integrator" -> "HyperFLINT"};
        If[frOpt === "AnTropica",
            If[intOpt =!= "HyperFLINT",
                Message[STIntegrate::antropicaNeedsHF, intOpt];
                Return[$Failed]];
            (* RETIRED 2026-05-27: the raw-{U,F} STFubiniWithAnTropica path
               asked an ill-posed question -- linear reducibility of the
               UN-decomposed Symanzik {U,F}.  That is NOT the object the
               integration pipeline reduces: STIntegrate sector-decomposes
               into faces first, and raw {U,F} is generically NOLR even when
               the integral is linearly reducible face by face (verified: the
               massless pentagon is NOLR on raw {U,F} but all 33 faces are LR).
               AnTropica is now an IN-PIPELINE LR engine (STFubiniAT2,
               "MethodLR" -> "AnTropica") dispatched at the per-face LR-scoring
               point alongside Lungo/Espresso.  Route FindRoots -> "AnTropica"
               through the real per-face pipeline so the sector decomposition,
               faces, gauge fixing and boundary augmentation are all set up and
               AnTropica only rationalizes the genuinely-NOLR faces.  The inner
               call uses FindRoots -> True, so this intercept does not re-fire
               and the recursion terminates. *)
            If[stEnsureAnTropicaLoaded[] === $Failed, Return[$Failed]];
            Return[STIntegrate[g,
                Sequence @@ DeleteCases[{opts},
                    (FindRoots -> _) | ("MethodLR" -> _)],
                FindRoots -> True, "MethodLR" -> "AnTropica"]]];
        (* \[HorizontalLine]\[HorizontalLine] Momentum conservation sanity check \[HorizontalLine]\[HorizontalLine]
           Every external leg in `nodes` carries a label (0 or symbolic
           momentum/mass). Conservation \[CapitalSigma] p\:1d62 = 0 at the diagram boundary
           constrains those labels:

             \[Bullet] 1-pt (tadpole): p\:2081 = 0. Any non-zero label is inconsistent.
             \[Bullet] 2-pt:           p\:2082 = -p\:2081, so p\:2081\.b2 = p\:2082\.b2. Both external labels
                               must be identical (either both 0 or the same
                               symbol). Writing M\:2081 \[NotEqual] M\:2082 is inconsistent.

           For n \[GreaterEqual] 3 externals, each p\:1d62\.b2 is independent so no simple check
           fires. Multiple legs at the same vertex are combined into a
           single effective leg carrying their summed momentum (see
           computeNickelIndex); the per-vertex labels then must also be
           consistent with that combination, which we don't enforce here.
        *)
        nLegs = Length[nodes];
        vertexLabels = GroupBy[nodes, First -> Last];
        labels = nodes[[All, 2]];
        Which[
            nLegs == 1 && !TrueQ[labels[[1]] === 0 || labels[[1]] === 0.],
                Message[STIntegrate::momCons1pt, labels[[1]]];
                Return[$Failed],
            nLegs == 2 && Length[vertexLabels] == 2 &&
                !(labels[[1]] === labels[[2]]),
                Message[STIntegrate::momCons2pt, labels[[1]], labels[[2]]];
                Return[$Failed]
        ];
        $STLastVacuumPeriod = False;
        (* Guard: Dimension must involve eps.  The pipeline computes a
           Laurent expansion in eps (dimensional regularization); with an
           integer-valued Dimension, no expansion variable exists and the
           pipeline silently returns the bare integer-D integral, which
           is DirectedInfinity[] whenever that integral is UV-divergent
           (e.g. D=4 tadpole). *)
        Module[{dimOpt = "Dimension" /. {opts} /. "Dimension" -> (4 - 2 eps)},
            If[FreeQ[dimOpt, eps],
                Message[STIntegrate::dimNoEps, dimOpt];
                Return[$Failed]
            ]
        ];
        (* v1.0.453: guard against silently-dropped "Exponents" option.
           STEvaluateGraph does NOT accept "Exponents"; its propagator
           powers are all fixed to 1 (use propagator-list input or the
           "Numerator" option for non-standard powers).  If the user
           passes a non-trivial Exponents list to the graph form, the
           FilterRules call silently drops it and the integral comes out
           as if powers were {1,...,1} \[LongDash] same symbolic answer regardless
           of user input, which confused downstream verification.  Emit
           a message and fail cleanly. *)
        Module[{expsOpt = "Exponents" /. {opts} /. "Exponents" -> Automatic},
            If[ListQ[expsOpt] && ! AllTrue[expsOpt, # === 1 &],
                Message[STIntegrate::graphFormExponents, expsOpt];
                Return[$Failed]]];
        r = STEvaluateGraph[g,
            FilterRules[{opts}, Options[STEvaluateGraph]]];
        r
    ];

STIntegrate::graphFormExponents = StringJoin[
    "Graph-form STIntegrate[{edges, nodes}, ...] does not honour the ",
    "\"Exponents\" option (got `1`).  All internal propagators are taken ",
    "to power 1; for non-trivial powers (squared propagators, numerator ",
    "insertions) use the propagator-list form ",
    "STIntegrate[{prop_1, ..., prop_n}, \"Exponents\" -> {nu_1, ..., nu_n}]."];

STIntegrate::dimNoEps = StringJoin[
    "Dimension `1` does not involve eps. The pipeline computes a Laurent ",
    "expansion in eps (dimensional regularization), which requires Dimension ",
    "to be eps-dependent (e.g. 4 - 2 eps). For a bare integer-dimension ",
    "Feynman integral there is no expansion variable; at integer D the ",
    "pipeline would either return DirectedInfinity[] (UV-divergent cases) ",
    "or the integer-D value without regulation. Use Dimension -> D - 2 eps ",
    "with the D you intend, or call HyperIntica directly for a bare integer-D ",
    "Feynman integral."];

STIntegrate::momCons1pt = StringJoin[
    "Momentum conservation at a 1-point function forces the external ",
    "momentum to vanish: a single external leg can only be massless. ",
    "Got label `1`. Use 0 for the external node label, or add more ",
    "external legs if you intended a higher-point function."];
STIntegrate::momCons2pt = StringJoin[
    "Momentum conservation at a 2-point function forces p\:2082 = -p\:2081 and ",
    "hence p\:2081\.b2 = p\:2082\.b2, so both external leg labels must be identical. ",
    "Got `1` and `2`. Use the same symbol (for example both M, or both 0) ",
    "on the two external legs."];

(* Form 2: propagator list *)
STIntegrate[propagators_List, opts:OptionsPattern[]] :=
    Module[{r},
        $STLastVacuumPeriod = False;
        (* Same Dimension-must-involve-eps guard as the graph form above. *)
        Module[{dimOpt = "Dimension" /. {opts} /. "Dimension" -> (4 - 2 eps)},
            If[FreeQ[dimOpt, eps],
                Message[STIntegrate::dimNoEps, dimOpt];
                Return[$Failed]
            ]
        ];
        r = STEvaluateGraphFromPropagators[propagators,
            FilterRules[{opts}, Options[STEvaluateGraphFromPropagators]]];
        r
    ];

(* Helper: translate "Gauge" -> {} to "ScanGauges" -> False for STEvaluateEulerIntegral,
   which does not have a "Gauge" option but uses "ScanGauges" instead. *)
stTranslateGaugeOpt[optList_List] := Module[{translated},
    translated = optList /. ("Gauge" -> {}) :> ("ScanGauges" -> False);
    (* Remove any remaining "Gauge" -> _ rules that STEvaluateEulerIntegral would not understand *)
    DeleteCases[translated, "Gauge" -> _]
];

(* Form 3: pre-built Euler integrand tuple {pref, integrand, xvars_List, coeffs} *)
STIntegrate[{prefArg_, integrandArg_, xvarsArg_List, coeffsArg_}, opts:OptionsPattern[]] :=
    Module[{gaugeOpt, gaugeRule, integ, xv, translatedOpts},
        gaugeOpt = ("Gauge" /. {opts});
        If[MatchQ[gaugeOpt, {(_ -> 1) ..}],
            (* Explicit gauge: apply substitution, remove gauged variable, force no-scan *)
            gaugeRule = gaugeOpt;
            integ = integrandArg /. gaugeRule;
            xv = DeleteCases[xvarsArg, Alternatives @@ (First /@ gaugeRule)];
            translatedOpts = Join[
                DeleteCases[{opts}, "Gauge" -> _],
                {"ScanGauges" -> False}
            ];
            STEvaluateEulerIntegral[
                {prefArg, integ, xv, coeffsArg},
                FilterRules[translatedOpts, Options[STEvaluateEulerIntegral]]
            ]
        ,
            STEvaluateEulerIntegral[
                {prefArg, integrandArg, xvarsArg, coeffsArg},
                FilterRules[stTranslateGaugeOpt[{opts}], Options[STEvaluateEulerIntegral]]
            ]
        ]
    ];

(* Form 3b: same with checkpoint ID as 5th element *)
STIntegrate[{prefArg_, integrandArg_, xvarsArg_List, coeffsArg_, checkpointId_String}, opts:OptionsPattern[]] :=
    Module[{gaugeOpt, gaugeRule, integ, xv, translatedOpts},
        gaugeOpt = ("Gauge" /. {opts});
        If[MatchQ[gaugeOpt, {(_ -> 1) ..}],
            gaugeRule = gaugeOpt;
            integ = integrandArg /. gaugeRule;
            xv = DeleteCases[xvarsArg, Alternatives @@ (First /@ gaugeRule)];
            translatedOpts = Join[
                DeleteCases[{opts}, "Gauge" -> _],
                {"ScanGauges" -> False}
            ];
            STEvaluateEulerIntegral[
                {prefArg, integ, xv, coeffsArg},
                "StartAt" -> checkpointId,
                FilterRules[translatedOpts, Options[STEvaluateEulerIntegral]]
            ]
        ,
            STEvaluateEulerIntegral[
                {prefArg, integrandArg, xvarsArg, coeffsArg},
                "StartAt" -> checkpointId,
                FilterRules[stTranslateGaugeOpt[{opts}], Options[STEvaluateEulerIntegral]]
            ]
        ]
    ];

(* stBoundedToInfinity: change-of-variables that maps each bounded
   integration interval to (0, Infinity), so the bounded form
   STIntegrate[integrand, {x,0,1}, ..., opts] tail-recurses into the
   standard projective pipeline (STEvaluateEulerIntegral /
   STExpandIntegral), which correctly sector-decomposes endpoint
   regulators and recovers any 1/eps poles emerging from the
   integration.  Returns {newIntegrand, newLimSpecs} where each new
   limit is {t_i, 0, Infinity}.  Maps:
     {x, 0, 1}        ->  x = t/(1+t),  dx = dt/(1+t)^2
     {x, 1, Infinity} ->  x = 1 + t,    dx = dt
     {x, 0, Infinity} ->  no change
   Returns $Failed on any other (lo, hi) combination (the upstream
   validator already restricts lo/hi to {0, 1, Infinity}, so this
   only fires on inverted bounds like {1, 0} or zero-measure ones
   like {1, 1}, which the caller surfaces as STIntegrate::badlimits).
   Replaces the pre-v1.1.11.2 stIntegrateBoundedEps, which eps-
   expanded the integrand BEFORE integrating and silently dropped
   1/eps poles emerging from endpoint regulators (Beta-like
   integrands x^(eps-1) (1-x)^eps returned 0 instead of 1/eps + ...). *)
stBoundedToInfinity[integrand_, limSpecs_List] := Module[
    {newIntegrand = integrand, newLims = {}, x, lo, hi, t},
    Do[
        {x, lo, hi} = limSpecs[[i]];
        Which[
            lo === 0 && hi === Infinity,
                AppendTo[newLims, {x, 0, Infinity}],
            lo === 0 && hi === 1,
                t = Unique["x$"];
                newIntegrand = (newIntegrand /. x -> t/(1 + t)) / (1 + t)^2;
                AppendTo[newLims, {t, 0, Infinity}],
            lo === 1 && hi === Infinity,
                t = Unique["x$"];
                newIntegrand = newIntegrand /. x -> 1 + t;
                AppendTo[newLims, {t, 0, Infinity}],
            True,
                Return[$Failed, Module]
        ],
        {i, Length[limSpecs]}
    ];
    {newIntegrand, newLims}
];

(* Form 4: Mathematica-style integration limits
   STIntegrate[integrand, {x,0,1}, {y,0,Infinity}, ..., opts]
   Also accepts bare symbols: STIntegrate[integrand, x, y, ..., opts]
   which default to {0, Infinity}. *)
STIntegrate[integrand_, args__] := Module[
    {argList, limSpecs, opts, xvars, coeffs, limSpec, validLimits,
     boundedQ, order},

    argList = {args};

    (* Separate limit specifications from options *)
    limSpecs = {};
    opts = {};
    Do[
        Which[
            (* {var, lo, hi} form *)
            MatchQ[argList[[i]], {_Symbol, _, _}],
                AppendTo[limSpecs, argList[[i]]],
            (* bare symbol form: default to {0, Infinity} *)
            MatchQ[argList[[i]], _Symbol],
                AppendTo[limSpecs, {argList[[i]], 0, Infinity}],
            (* everything else is treated as an option *)
            True,
                opts = Join[opts, argList[[i ;;]]]; Break[]
        ],
        {i, Length[argList]}
    ];

    (* Validate: we need at least one integration variable *)
    If[limSpecs === {},
        Message[STIntegrate::badinput]; Return[$Failed]
    ];

    (* Validate limits: each bound must be 0, 1, or Infinity *)
    validLimits = {0, 1, Infinity};
    Do[
        limSpec = limSpecs[[j]];
        If[!MemberQ[validLimits, limSpec[[2]]] || !MemberQ[validLimits, limSpec[[3]]],
            Message[STIntegrate::badlimits, limSpec[[1]], limSpec[[2]], limSpec[[3]]];
            Return[$Failed]
        ],
        {j, Length[limSpecs]}
    ];

    (* Extract variable list *)
    xvars = limSpecs[[All, 1]];

    (* Reject inputs where an integration variable is absent from the integrand.
       Over [0, Infinity) the integral is literally divergent; the downstream
       projective pipeline would silently gauge-fix x_i = 1 and report the
       integrand's VALUE at that point, which is not an integral. Matches the
       STSymanzik "unused loop momentum" guard at :1811 for the graph path. *)
    Module[{unusedXvars = Select[xvars, FreeQ[integrand, #] &]},
        If[unusedXvars =!= {},
            Message[STIntegrate::xvarUnused, unusedXvars];
            Return[$Failed]
        ]
    ];

    (* Route to bounded-domain path when any variable has a non-(0,Infinity)
       bound: apply a change of variables that sends every bounded interval
       to (0, Infinity), then tail-recurse into the standard projective
       pipeline (STEvaluateEulerIntegral -> STExpandIntegral) which
       sector-decomposes endpoint regulators correctly and recovers any
       1/eps poles emerging from the integration.  Pre-v1.1.11.2 this
       branch eps-expanded the integrand BEFORE integrating and silently
       lost the pole on Beta-like integrands (e.g. x^(eps-1)(1-x)^eps over
       {x,0,1} returned 0 instead of 1/eps - (Pi^2/6) eps + O(eps^2)). *)
    boundedQ = AnyTrue[limSpecs, #[[2]] =!= 0 || #[[3]] =!= Infinity &];
    If[boundedQ,
        With[{cov = stBoundedToInfinity[integrand, limSpecs]},
            If[cov === $Failed,
                Message[STIntegrate::badlimits,
                    limSpecs[[1, 1]], limSpecs[[1, 2]], limSpecs[[1, 3]]];
                Return[$Failed]];
            Return[STIntegrate[First[cov],
                Sequence @@ Last[cov], Sequence @@ opts]]]];

    (* Auto-compute coefficients: only the variables in the integrand that
       are FreeQ of both xvars and eps. A Complement[Variables[...], ...]
       would incorrectly pull in pseudo-atoms produced by Mathematica's
       auto-split of base^(integer+eps) into base^integer * base^eps;
       classifying that base^eps as a "coefficient" strips the eps regulator
       out of the integrand and the pipeline silently returns 0. The FreeQ
       filter only keeps genuine xvars-free and eps-free symbols (like
       kinematic invariants s12, s23), which matches what the form-3 entry
       point expects and what the graph path produces. *)
    coeffs = Sort @ Select[
        Variables[integrand],
        FreeQ[#, Alternatives @@ (xvars ~Join~ {eps})] &
    ];

    (* Delegate to STEvaluateEulerIntegral with prefactor = 1 *)
    STEvaluateEulerIntegral[
        {1, integrand, xvars, coeffs},
        FilterRules[stTranslateGaugeOpt[opts], Options[STEvaluateEulerIntegral]]
    ]
];

STIntegrate::badinput = StringJoin[
    "Input format not recognized. STIntegrate accepts:\n",
    "  (1) STIntegrate[]  \[RightArrow]  interactive GUI\n",
    "  (2) STIntegrate[{edges, nodes}, opts]  \[RightArrow]  graph topology\n",
    "  (3) STIntegrate[{propagators}, opts]  \[RightArrow]  propagator list\n",
    "  (4) STIntegrate[integrand, {x,0,1}, {y,0,Infinity}, ..., opts]  \[RightArrow]  Mathematica-style\n",
    "  (5) STIntegrate[integrand, x, y, ..., opts]  \[RightArrow]  bare symbols (bounds default to {0,Infinity})\n",
    "  (6) STIntegrate[{pref, integrand, xvars, coeffs}, opts]  \[RightArrow]  pre-built tuple (advanced)"
];

STIntegrate::badlimits = "Integration bounds for variable `1` are {`2`, `3`}. Bounds must be 0, 1, or Infinity.";

STIntegrate::xvarUnused = "Integration variable(s) `1` do not appear in the integrand. Over [0, Infinity) the integral is divergent; the projective gauge-fix the pipeline would otherwise apply silently evaluates the integrand at x_i = 1 and reports that value instead of an actual integral.";


(* ::Section::Closed:: *)
(*Benchmarking & Diagnostics*)


(* ==================================================================
   STDependencies / STBenchmark

   Step 1 of STBenchmark is a dependency table: every external tool
   that SubTropica can talk to is smoke-tested once, with polymake as
   the only required dependency.  Step 2 then runs the STIntegrate /
   STNIntegrate cases catalogued in mgExamples/mgDiagrams.wl, each
   with caches cleared so results are order-independent.

   A successful run writes a record to $STBenchmarkDataFile which feeds
   two things on subsequent sessions: (a) the welcome-banner nudge that
   suggests re-running the benchmark when $SubTropicaVersion has changed,
   and (b) regression tracking (result-hash and per-case time diffs
   against the prior run).
   ================================================================== *)


(* ---- STDependencies --------------------------------------------- *)

(* Row renderer shared by notebook and terminal output.  Returns a list
   of {tool, statusCell, version, required, path, hint} cells. *)
stDependencyRows[] := Module[
  {names, rows, dep, statusCell, versionCell, pathCell, requiredCell,
   hintCell},
  names = Keys[$STDependencies];

  statusCell[status_, required_] := Switch[status,
    "ok",      If[$Notebooks, Style["\[Checkmark] ok", Darker[Green], Bold],
                              "[\[Checkmark]] ok"],
    "missing", If[TrueQ[required],
                 If[$Notebooks, Style["\[Times] MISSING", Red, Bold],
                                "[\[Times]] MISSING"],
                 If[$Notebooks, Style["- missing", RGBColor[0.8, 0.6, 0]],
                                "[-] missing"]],
    "error",   If[$Notebooks, Style["\[Times] error", Red, Bold],
                              "[\[Times]] error"],
    _,         If[$Notebooks, Style["? untested", Gray],
                              "[?] untested"]];

  rows = Table[
    dep = $STDependencies[name];
    versionCell = If[StringQ[dep["version"]] && dep["version"] =!= "",
      StringTake[dep["version"], UpTo[32]], "\[LongDash]"];
    pathCell = Which[
      StringQ[dep["resolvedPath"]] && dep["resolvedPath"] =!= "",
        dep["resolvedPath"],
      True,
        ToString[dep["getPath"][]]];
    If[StringLength[pathCell] > 52,
      pathCell = "\[Ellipsis]" <> StringTake[pathCell, -51]];
    requiredCell = Module[
      {tier = Lookup[dep, "tier",
        If[TrueQ[dep["required"]], "required", "optional"]]},
      Switch[tier,
        "required",
          If[$Notebooks, Style["required", Bold], "required"],
        "recommended",
          If[$Notebooks, Style["recommended", Italic], "recommended"],
        _,
          "optional"]];
    hintCell = If[dep["status"] === "ok", "",
      Module[{msg = dep["statusMsg"], hint = dep["installHint"],
              conf = dep["configHint"], parts, s},
        (* Stitch statusMsg, installHint, and configHint into a single
           cell.  Use "  ||  " as a visible separator so the three steps
           (what failed / how to install / how to point SubTropica at it)
           read as distinct clauses in both the Grid (notebook) and the
           ASCII table (terminal). *)
        parts = Select[{msg, hint, conf},
          StringQ[#] && # =!= "" &];
        s = StringRiffle[parts, "  ||  "];
        If[$Notebooks, Style[s, Italic, GrayLevel[0.4]], s]]];
    {name, statusCell[dep["status"], dep["required"]], versionCell,
     requiredCell, pathCell, hintCell},
    {name, names}];
  rows
];

STDependencies[] := Module[
  {rows, headerNames, header, nMissingReq, nOk, nOpt},
  stRunDependencyTests[];
  rows = stDependencyRows[];
  headerNames = {"tool", "status", "version", "required", "path", "hint"};

  nOk          = Count[Values[$STDependencies], KeyValuePattern["status" -> "ok"]];
  nMissingReq  = Count[Values[$STDependencies],
    a_ /; TrueQ[a["required"]] && a["status"] =!= "ok"];

  If[$Notebooks,
    header = Style[#, Bold, FontFamily -> "Helvetica", FontColor -> Black] & /@ headerNames;
    (* Fixed light backgrounds + BaseStyle FontColor -> Black make the
       table readable on both light and dark notebook themes.  Explicit
       per-cell Style[] color directives (checkmarks, MISSING, etc.)
       override the base black, so status badges stay green/red. *)
    Print[Grid[Prepend[rows, header],
      Alignment   -> {{Left, Left, Left, Left, Left, Left}, Center},
      Background  -> {None,
        Prepend[Table[If[EvenQ[i], GrayLevel[0.97], White],
          {i, Length[rows]}], GrayLevel[0.92]]},
      Dividers    -> {None, {1 -> Gray, 2 -> Gray, -1 -> Gray}},
      Spacings    -> {2.2, 0.7},
      ItemStyle   -> {FontFamily -> "Helvetica", FontSize -> 12, FontColor -> Black},
      BaseStyle   -> {FontFamily -> "Helvetica", FontSize -> 12, FontColor -> Black}]];
    Print[Style[
      ToString[nOk] <> "/" <> ToString[Length[rows]] <> " dependencies OK" <>
      If[nMissingReq > 0,
        ", " <> ToString[nMissingReq] <> " required missing",
        ""],
      Italic, GrayLevel[0.4]]],
    (* Terminal: Unicode box-drawing table *)
    stDependencyPrintTerminal[headerNames, rows];
    Print[ToString[nOk] <> "/" <> ToString[Length[rows]] <> " dependencies OK" <>
      If[nMissingReq > 0,
        ", " <> ToString[nMissingReq] <> " required missing", ""]];
  ];

  $STDependencies
];

(* Terminal table renderer: plain ASCII.  Mathematica's \[ ... ] box-
   drawing long-names are inconsistent across platforms, and the
   FullForm escapes leak into the output in wolframscript, so we stick
   to portable "+--+" style borders. *)
stDependencyPrintTerminal[headerNames_List, rows_List] := Module[
  {cellText, colWidths, sep, fmtRow, border},
  cellText[cell_] := Switch[Head[cell],
    Style, cellText[First[cell]],
    String, cell,
    _, ToString[cell]];

  colWidths = Table[
    Max @@ (StringLength[cellText[#]] & /@ Append[rows[[All, c]], headerNames[[c]]]),
    {c, Length[headerNames]}];

  fmtRow[r_List] := "| " <> StringRiffle[
    Table[StringPadRight[cellText[r[[c]]], colWidths[[c]]], {c, Length[r]}],
    " | "] <> " |";

  border = "+" <> StringRiffle[
    Table[StringJoin @@ Table["-", {colWidths[[c]] + 2}], {c, Length[colWidths]}],
    "+"] <> "+";

  Print[border];
  Print[fmtRow[headerNames]];
  Print[border];
  Do[Print[fmtRow[r]], {r, rows}];
  Print[border];
];


