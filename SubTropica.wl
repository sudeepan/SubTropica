Clear[STIntegrandTropicalData];STIntegrandTropicalData[integrand_,vars_,coeffs_:{}]:=Module[{trData,trop,newInt,mons,pols},
(*newInt=integrand/.Alternatives@@coeffs\[Rule]1;*)
newInt=integrand ;
{mons,pols}=newInt//STtoMonPols[#,vars]&;
monPolsTropicalData[mons,pols,vars,coeffs]
]


Clear[monPolsTropicalData];monPolsTropicalData[\[Nu]_,{pols_,exps_},vars_,coeffs_:{}]:=Module[{trData,trop,integrand,rays,cones,polsNoCoeffs,cacheKey},
(*polsNoCoeffs=FromCoefficientRules[CoefficientRules[(Times@@pols),vars]/.Rule\[Rule] tRule/.tRule[a_,b_]\[RuleDelayed] tRule[a,1]/.tRule\[Rule]Rule,vars];*)
polsNoCoeffs=STforgetCoeffs[#,vars]&/@pols;
polsNoCoeffs=DeleteCases[polsNoCoeffs,1];(* coeff^eps may give a polynomial 1 *)
(*  cache polymake tropical fan by (coefficient-free poly product, vars).
   The tropical fan is determined solely by the Newton polytope of the integrand,
   which depends only on the monomial structure (no symbolic coefficients). *)
cacheKey = {Times@@polsNoCoeffs, vars};
If[KeyExistsQ[$STTropicalDataCache, cacheKey],
    $STTropicalDataCache[cacheKey]
,
    trData = (Times@@polsNoCoeffs)//STtropicalData[#,vars,STtropicalDataMaxTime]&;
    $STTropicalDataCache[cacheKey] = trData;
    trData
]
]


(* Apply the standard MZV cleanup chain to an expression.
   The trailing Expand[...] was dropped (v1.0.407): it forced a fully
   distributed form that undid the preceding `Collect[..., eps^___, Simplify]`
   step in the post-integration pipeline, inflating the 5-Wm/Wp-pair pentagon
   result from 174 KB back up to 1.2 MB. The `/.` rules do the actual
   cleanup; the distributed shape `Expand` produced wasn't needed by any
   downstream consumer. *)
CleanZeroInf[expr_] := expr /. zeroInfRules /. (ZeroInfPeriod[A_] /; ContainsOnly[A, {0, -1}] :> 0) /. zeroInfRulesHALF /.  zeroInfRulesTWO;


(* Compute divergent rays *)
STTropicalAnalysis[integrand_,vars_,coeffs_:{},refineQ_:False]:=Module[{trData,trop,newInt,mons,pols},
newInt=integrand;
newInt=newInt ;
{mons,pols}=newInt//STtoMonPols[#,vars]&;
STtropicalAnalysisMonsPols2[mons,pols,vars,coeffs,refineQ]//First//Simplify//MatrixForm
]



STtropicalAnalysisMonsPols[\[Nu]_,{pols_,exps_},vars_,coeffs_,refineQ_:False]:=Module[{trData,trop,integrand,rays,cones,conesVals},
trData=(Times@@pols)//STforgetCoeffs[#,vars]&//STtropicalData[#,60]&;
trop=\[Nu] . vars+exps . (STtropicalize/@(STforgetCoeffs[#,vars]&/@(pols)));
(*{\[Nu],exps,pols,(STforgetCoeffs[#,vars]&/@(pols)),(STtropicalize/@(STforgetCoeffs[#,vars]&)/@(pols)),trop}//Print;*)
rays=Table[{r,STEvalRay[trop,r,vars]},{r,trData["rays"]}];
cones=Table[cn->Abs[Times@@ rays[[cn,2]]],{cn,trData["cones"]}]//Simplify;
If[refineQ,
cones=Table[
conesVals=Table[cn-> (Times@@(STEvalRay[trop,#1,vars]&/@cn)),{cn,trData["refinement"][[j]]}];
trData["cones"][[j]]->conesVals
,{j,1,trData["refinement"]//Length}]//Simplify
];
{rays,cones/.Abs-> Identity}
]
STtropicalAnalysisMonsPols2[\[Nu]_,{pols_,exps_},vars_,coeffs_:{},refineQ_:True]:=Module[{trData,trop,integrand,rays,cones,conesVals},
trData=(Times@@pols)//STforgetCoeffs[#,vars]&//STtropicalData[#,vars,STtropicalDataMaxTime]&;
trop=\[Nu] . vars+exps . (STtropicalize/@(STforgetCoeffs[#,vars]&/@(pols)));
rays=Table[{r,STEvalRay[trop,r,vars]},{r,trData["rays"]}];
(*cones=Table[cn\[Rule]Abs[Total[Max[0,rays[[cn,2]] /.eps\[Rule]0]]],{cn,trData["cones"]}]//Simplify;*)
If[refineQ,
cones=Table[
conesVals=Table[Total[(If[#>= 0,1,0])&/@((STEvalRay[trop,#1,vars]&/@cn)/.eps->0)],{cn,trData["refinement"][[j]]}];
trData["cones"][[j]]->conesVals
,{j,1,trData["refinement"]//Length}]//Simplify
];
{rays,cones/.Abs-> Identity}
]


STTropicalizeIntegrand[integrand_,vars_,coeffs_:{}]:=Module[{trData,trop,newInt,mons,pols},newInt=integrand;{mons,pols}=(STtoMonPols[#1,vars]&)[newInt];
trop=mons . vars+pols[[2]] . (STtropicalize/@(STforgetCoeffs[#,vars]&/@pols[[1]]))
]


(* Compute \tau_\rho acting on a Euler integrand *)
STPuiseux2[integrand_,vars_, ray_, order_:0]:=Module[
{rescaled, prefactor, monomials, polynomials, series},
	rescaled=integrand/.Table[vars[[i]]-> vars[[i]]\[Lambda]^(-ray[[i]]),{i,1,vars//Length}]//STFactor;
	{prefactor, monomials, polynomials} =STtoCoeffMonPols[rescaled,vars];
	monomials=Times@@(vars^monomials);
	series=(Times@@(polynomials[[1]]^polynomials[[2]]))//Series[#,{\[Lambda],0,order}]&;
	(*series=series//STMapSeries[If[Head[#]===Plus,List@@#,{#}]&,#]& ;*)
	series=series//STMapSeries[(# monomials) &,#]& ;
	{prefactor/. \[Lambda]^a_:> \[Lambda]^Expand[a], series}
]

STPuiseux[integrand_,vars_, ray_, order_:0]:=Module[
{rescaled, prefactor, monomials, polynomials, series},
	rescaled=integrand/.Table[vars[[i]]-> vars[[i]]\[Lambda]^(-ray[[i]]),{i,1,vars//Length}]//STFactor;
	{prefactor, monomials, polynomials} =STtoCoeffMonPols[rescaled,vars];
	monomials=Times@@(vars^monomials);
	series=(Times@@(polynomials[[1]]^polynomials[[2]]))//Series[#,{\[Lambda],0,order}]&;
	series=series//STMapSeries[If[Head[#]===Plus,List@@#,{#}]&,#]& ;
	series=series//STMapSeries[(# monomials) &,#]& ;
	{prefactor/. \[Lambda]^a_:> \[Lambda]^Expand[a], series}
]


STPuiseuxM[integrand_,vars_, rays_, order_:0]:=Module[
{rescaled, prefactor, monomials, polynomials, series, puiseuxVars, rescalings},
	puiseuxVars=Table[\[Lambda][i],{i,1,rays//Length}];
	STDeclarePositiveVariables[puiseuxVars];
	rescalings=Table[vars[[i]]-> vars[[i]]Product[\[Lambda][j]^(-rays[[j,i]]),{j,1,rays//Length}],{i,1,vars//Length}];
	rescaled=integrand/.rescalings//STFactor;
	{prefactor, monomials, polynomials}=STtoCoeffMonPols[rescaled,vars];
	monomials=Times@@(vars^monomials);
	series=monomials(Times@@(polynomials[[1]]^polynomials[[2]]));
	Do[series=series//Series[#,{\[Lambda][i],0,order}]&,{i,1,rays//Length}];
	(*series=series//STMapSeries[If[Head[#]===Plus,List@@#,{#}]&,#]& ;*)
	{prefactor/. \[Lambda][j_]^a_:> \[Lambda][j]^Expand[a], series//Normal}
]

STPuiseuxR[integrand_,vars_, rays_, order_:0]:=Module[
{rescaled, prefactor, monomials, polynomials, series, puiseuxVars, rescalings},
	puiseuxVars=Table[\[Lambda][i],{i,1,rays//Length}];
	STDeclarePositiveVariables[puiseuxVars];
	rescalings=Table[vars[[i]]-> vars[[i]]Product[\[Lambda][j]^(-rays[[j,i]]),{j,1,rays//Length}],{i,1,vars//Length}];
	rescaled=integrand/.rescalings//STFactor;
	{prefactor, monomials, polynomials}=STtoCoeffMonPols[rescaled,vars];
	monomials=Times@@(vars^monomials);
	series=monomials(Times@@(polynomials[[1]]^polynomials[[2]]));
	{prefactor,series}//Return;
]

STPuiseuxOld[integrand_,vars_, ray_, order_:0]:=Module[
{rescaled, leading},
	rescaled=integrand/.Table[vars[[i]]-> vars[[i]] \[Lambda]^(-ray[[i]]),{i,1,vars//Length}]//STFactor;
	leading =STtoCoeffMonPols[rescaled,vars][[1]];
	{leading, Series[(rescaled/leading),{\[Lambda],0,order}]}
]


