stBenchmarkLoadCases[suite_String] := Module[
  {path, diagramSymbol, diagrams, propagators, eulerIntegrands,
   nIntDiagrams, nIntEuler, labelsByCat, records, ctx},
  (* Benchmark cases are embedded as $stBenchmarkCasesSource (below)
     and loaded via a stream so the lazy-load semantics of the prior
     file-based path are preserved. *)
  path = "<inlined: $stBenchmarkCasesSource>";

  diagramSymbol = Switch[suite,
    "Short", "diagramsShort",
    "Long",  "diagramsLong",
    _,       "diagramsShort"];

  (* Load the case lists in Global` with a restricted $ContextPath so the
     file's bare symbols (diagramsShort, diagramsLong, m, M, Subscript[M,i],
     eps, z, zb, ...) land in Global` rather than being captured by
     already-loaded packages on $ContextPath (SubTropica` defines a
     no-value `diagrams` that would otherwise shadow the file's
     assignment).  Keeping the symbols in Global` is important because
     STIntegrate's Substitutions / Gauge / KinematicPoint matching
     compares user-supplied symbols by full Global` name \[LongDash] loading into
     a scratch context would break it. *)
  ctx = "Global`";
  Block[{$Context = ctx, $ContextPath = {"System`", ctx}},
    Off[General::shdw];
    Module[{stream = StringToStream[$stBenchmarkCasesSource]},
      Quiet[Get[stream], {General::shdw}];
      Close[stream]];
    On[General::shdw]];
  (* Remap file-local Global` mass / dim-reg symbols back onto their
     SubTropica` counterparts.  STIntegrate's internal pattern matching
     (Series/Coefficient on eps, mass canonicalization against M/m/MM
     in node and edge slots) compares by full context-qualified name \[LongDash]
     a differently-rooted Global`M slips past those matches, leaves the
     Symanzik polynomial with un-substituted symbols, and triggers the
     NOLR path / Complement::heads / Det::matsq cascade downstream.  The
     remap preserves user kinematic dummies (z, zb, w, wb, MM1, mm1, ...)
     as Global` so Substitutions / KinematicPoint matching by literal
     user-symbol name keeps working. *)
  With[{remap = {
      Global`eps -> SubTropica`eps,
      Global`M   -> SubTropica`M,
      Global`m   -> SubTropica`m,
      Global`MM  -> SubTropica`MM,
      Global`mm  -> SubTropica`mm
    }},
    diagrams        = Symbol[ctx <> diagramSymbol]     /. remap;
    propagators     = Symbol[ctx <> "propagators"]     /. remap;
    eulerIntegrands = Symbol[ctx <> "eulerIntegrands"] /. remap;
    nIntDiagrams    = Symbol[ctx <> "nIntDiagrams"]    /. remap;
    nIntEuler       = Symbol[ctx <> "nIntEuler"]       /. remap];

  labelsByCat = stBenchmarkParseLabels[path, diagramSymbol];

  records = Flatten @ {
    MapIndexed[stBenchmarkMakeRecord["diagrams",        First[#2], #1, labelsByCat] &, diagrams],
    MapIndexed[stBenchmarkMakeRecord["propagators",     First[#2], #1, labelsByCat] &, propagators],
    MapIndexed[stBenchmarkMakeRecord["eulerIntegrands", First[#2], #1, labelsByCat] &, eulerIntegrands],
    MapIndexed[stBenchmarkMakeRecord["nIntDiagrams",    First[#2], #1, labelsByCat] &, nIntDiagrams],
    MapIndexed[stBenchmarkMakeRecord["nIntEuler",       First[#2], #1, labelsByCat] &, nIntEuler]
  };
  records
];

SetAttributes[stBenchmarkMakeRecord, HoldFirst];  (* (redundant; first arg is string) *)
stBenchmarkMakeRecord[cat_String, n_Integer, input_, labels_] := <|
  "category" -> cat,
  "index"    -> n,
  "id"       -> cat <> "[" <> ToString[n] <> "]",
  "label"    -> Lookup[labels, cat <> "/" <> ToString[n], ""],
  "input"    -> input
|>;

(* Parse horizontal-line section headers out of mgDiagrams.wl.  Labels are
   associated with the immediately-following case in the same category.
   Falls back silently to empty labels if the parse misfires.

   `diagramSymbol` names which of the two `diagrams`-category splits we
   are loading ("diagramsShort" or "diagramsLong"); matches against it
   are keyed under the common "diagrams" category so downstream code
   never needs to know which split is active. *)
stBenchmarkParseLabels[path_String, diagramSymbol_String] := Module[
  {lines, labels = <||>, cat = "", idx = 0, currentLabel = "",
   hLine, inList = False},
  lines = Quiet[ReadList[path, String]];
  If[!ListQ[lines], Return[<||>]];

  (* The file stores \[HorizontalLine] as a literal 18-char escape
     sequence, not as the Unicode glyph, because ReadList[..., String]
     returns raw bytes without expanding box-form escapes.  Double-escape
     here so hLine matches what we see on disk. *)
  hLine = "\\[HorizontalLine]\\[HorizontalLine]";

  (* Top-level case entries in the file are indented exactly 2 spaces
     followed by `{`; nested braces and option rules use deeper indents.
     That pattern is more robust than trying to balance braces across
     comment bodies. *)
  Do[
    Which[
      StringMatchQ[StringTrim[line], diagramSymbol ~~ Whitespace... ~~ "=" ~~ ___],
        cat = "diagrams"; idx = 0; inList = True; currentLabel = "",
      StringMatchQ[StringTrim[line], "propagators" ~~ Whitespace... ~~ "=" ~~ ___],
        cat = "propagators"; idx = 0; inList = True; currentLabel = "",
      StringMatchQ[StringTrim[line], "eulerIntegrands" ~~ Whitespace... ~~ "=" ~~ ___],
        cat = "eulerIntegrands"; idx = 0; inList = True; currentLabel = "",
      StringMatchQ[StringTrim[line], "nIntDiagrams" ~~ Whitespace... ~~ "=" ~~ ___],
        cat = "nIntDiagrams"; idx = 0; inList = True; currentLabel = "",
      StringMatchQ[StringTrim[line], "nIntEuler" ~~ Whitespace... ~~ "=" ~~ ___],
        cat = "nIntEuler"; idx = 0; inList = True; currentLabel = "",
      inList && StringContainsQ[line, hLine],
        Module[{m = StringCases[line, hLine ~~ Whitespace... ~~ t__ ~~ Whitespace... ~~ hLine :> t, 1]},
          If[Length[m] > 0, currentLabel = StringTrim[First[m]]]],
      inList && StringMatchQ[StringTrim[line], "};"],
        inList = False; cat = "",
      inList && cat =!= "" &&
        StringMatchQ[line, "  {" ~~ Except["}"] ~~ ___],
        idx++;
        labels = Append[labels, cat <> "/" <> ToString[idx] -> currentLabel]
    ];
  , {line, lines}];

  labels
];

(* Filter records according to the user selector.  Accepts:
     All                      - all cases
     _String                  - a category name
     {category_String, n_Integer}             - single case
     {category_String, s_Span | l_List}       - multiple in one category
     _List of any of the above                - union *)
stBenchmarkApplySelector[records_List, All] := records;
stBenchmarkApplySelector[records_List, cat_String] :=
  Select[records, #["category"] === cat &];
stBenchmarkApplySelector[records_List, {cat_String, n_Integer}] :=
  Select[records, #["category"] === cat && #["index"] === n &];
stBenchmarkApplySelector[records_List, {cat_String, Span[a_, b_]}] :=
  Select[records, #["category"] === cat &&
    a <= #["index"] <= (If[b === All, Length[records], b]) &];
stBenchmarkApplySelector[records_List, {cat_String, ns_List}] :=
  Select[records, #["category"] === cat && MemberQ[ns, #["index"]] &];
stBenchmarkApplySelector[records_List, sels_List] :=
  DeleteDuplicatesBy[
    Flatten[stBenchmarkApplySelector[records, #] & /@ sels, 1],
    #["id"] &];
stBenchmarkApplySelector[records_List, _] := records;

(* Cache-clearing hook invoked inside each subkernel after a case finishes
   to keep subsequent cases independent.  Only clears caches we know about;
   unknown caches would need to be added here. *)
stBenchmarkClearCaches[] := Module[{},
  Quiet[
    If[ValueQ[HyperIntica`$LinearFactorsCache], HyperIntica`$LinearFactorsCache = <||>];
    If[ValueQ[$NoAlgebraicRootsContributions],  $NoAlgebraicRootsContributions = <||>];
    If[ValueQ[HyperIntica`$HyperAlgebraicLetterTable],
      HyperIntica`$HyperAlgebraicLetterTable = <||>];
    If[ValueQ[HyperIntica`$HyperAlgebraicLetterCounter],
      HyperIntica`$HyperAlgebraicLetterCounter = 0];
    Share[];
  ];
];

(* Execute a single case inside the subkernel that called us.  Returns an
   Association describing the outcome.  Wrapped in Check[] with silenced
   messages captured via $MessageList so we can report "warning" tier. *)
stBenchmarkRunOneInKernel[record_Association] := Module[
  {input, dispatcher, cat, t0, t1, memBefore, memAfter, result,
   msgList, status, tierBadges, hashStr, verifyResult, verifyPass,
   verifyRelErr},

  cat = record["category"];
  input = record["input"];
  dispatcher = Switch[cat,
    "diagrams" | "propagators" | "eulerIntegrands",           SubTropica`STIntegrate,
    "nIntDiagrams" | "nIntEuler",                             SubTropica`STNIntegrate,
    _,                                                        $Failed];

  If[dispatcher === $Failed,
    Return[<|"id" -> record["id"], "status" -> "fail", "time" -> 0.,
      "memory" -> 0, "messages" -> {"unknown category: " <> cat},
      "hash" -> "", "verified" -> Missing["NotApplicable"]|>]];

  (* Inject "CleanOutput" -> True on symbolic STIntegrate cases (keeps
     returned expressions compact so the hash is stable and the stream
     stays readable).  Skip numerical STNIntegrate cases \[LongDash] it doesn't
     accept the option and would emit an "unknown option" warning. *)
  If[dispatcher === SubTropica`STIntegrate &&
     !AnyTrue[input, MatchQ[#, Rule["CleanOutput", _] | RuleDelayed["CleanOutput", _]] &],
    input = Append[input, "CleanOutput" -> True]];

  (* HF LR-backend injection on symbolic STIntegrate cases.
       * "HyperFLINT" routes every LR-search step through HF.  Phase 7-vii
         (deg-2 polynomials accepted during the LR walk, with letter
         allocation deferred to integration time) means FindRoots -> True
         cases now run cleanly under HF \[LongDash] no skip, no FindRoots override.
       * "HyperIntica" forces the Mma path (overrides case defaults).
       * Automatic is a no-op (honor the case's own options).         *)
  If[dispatcher === SubTropica`STIntegrate &&
     ValueQ[$stBenchmarkLRBackend],
    Which[
      $stBenchmarkLRBackend === "HyperFLINT",
        input = Join[input, {"LROrderBackend" -> "HyperFLINT"}],
      $stBenchmarkLRBackend === "HyperIntica",
        input = Join[input, {"LROrderBackend" -> "HyperIntica"}],
      True, Null]];

  (* Phase \[Beta].3 + Integrator extension: inject the integrator backend.
     Phase 7-vi-b unlocked FindRoots -> True for "HyperFLINT" \[LongDash] HF now
     emits its algebraic-letter table and SubTropica merges it into
     HyperIntica`$HyperAlgebraicLetterTable.  FindRoots is left alone
     if explicitly set on the case; otherwise the case default applies. *)
  If[dispatcher === SubTropica`STIntegrate &&
     ValueQ[$stBenchmarkIntegrator],
    Which[
      $stBenchmarkIntegrator === "HyperFLINT",
        input = Join[input, {"Integrator" -> "HyperFLINT"}],
      $stBenchmarkIntegrator === "HyperInt",
        input = Join[input, {"Integrator" -> "HyperInt"}],
      $stBenchmarkIntegrator === "HyperIntica",
        input = Join[input, {"Integrator" -> "HyperIntica"}],
      True, Null]];

  msgList = {};
  memBefore = MemoryInUse[];
  t0 = AbsoluteTime[];
  (* Silence STIntegrate's progress banners and Dynamic timers so a
     notebook run doesn't accumulate live cells.  A case is a "fail" only
     if it returned $Aborted (via CheckAbort) or the dispatcher itself
     returned $Failed.  Messages are tracked in $MessageList so we can
     separately mark cases "warning" when non-fatal diagnostics fire;
     harmless ones (ParallelMap::nopar etc.) are filtered out below. *)
  (* Silence everything STIntegrate might print during a case:
       - $Output = {} / $Messages = {} catch Print / Write / Message.
       - Echo / PrintTemporary / CellPrint bypass $Output entirely when
         the front end is attached (they render as the orange "\[RightGuillemet]"
         bands or live Dynamic cells in a notebook).  Block-rebinding
         each to a silent function drops them without touching the
         global definitions.
       - Run shell-redirects polymake's subprocess stdout/stderr to
         /dev/null so polymake's "used package ppl" banner doesn't leak
         through.  The exit status still flows through unchanged so
         STIntegrate can detect real polymake failures.
     Messages are still tracked in $MessageList so the per-case record
     and the Failures dossier can surface them. *)
  result = Block[{
      $Output = {}, $Messages = {}, $MessageList = {},
      Echo           = (#1 &),
      PrintTemporary = (Null &),
      CellPrint      = (Null &),
      Run = Function[cmd, System`Run[cmd <> " > /dev/null 2>&1"]]
    },
    Module[{r},
      r = CheckAbort[
        Quiet[dispatcher @@ input,
          {ParallelMap::nopar, ParallelTable::nopar, ParallelDo::nopar,
           ParallelSum::nopar, ParallelProduct::nopar, ParallelCombine::nopar,
           General::stop,
           (* Silenced: a Symanzik-polynomial simplification chain in
              STIntegrate's D=6-2eps+Gauge path iterates past the 4096-step
              default cap when invoked via the benchmark harness (triggered
              by the loader's unvalued ghost Global`MM that coexists with
              SubTropica`MM after Get[mgDiagrams.wl]).  The iteration chain
              is circular, not merely long \[LongDash] raising $IterationLimit to
              Infinity hangs, while letting it cap returns the correct
              SeriesData (hash-stable, matches direct-call byte-for-byte). *)
           $IterationLimit::itlim}],
        $Aborted];
      (* Filter out harmless parallel-fallback diagnostics, then
         convert each MessageName[] wrapped in HoldForm to a short
         "Tag::name" string.  Strings serialize cleanly across
         subkernels; held expressions sometimes do not. *)
      msgList = Module[{raw},
        raw = Select[$MessageList,
          !MatchQ[#, HoldForm[
            MessageName[ParallelMap | ParallelTable | ParallelDo |
                        ParallelSum | ParallelProduct | ParallelCombine |
                        General, "nopar" | "stop"]]] &&
          !MatchQ[#, HoldForm[MessageName[$IterationLimit, "itlim"]]] &];
        Cases[raw, HoldForm[MessageName[h_, n_]] :>
          ToString[Unevaluated[h]] <> "::" <> n]];
      r]];
  t1 = AbsoluteTime[];
  memAfter = MemoryInUse[];

  status = Which[
    result === $Aborted, "fail",
    result === $Failed,  "fail",
    result === Null,     "warning",   (* returned but silent *)
    True,                If[Length[msgList] > 0, "warning", "pass"]
  ];

  hashStr = ToString[Hash[result, "SHA256", "HexString"]];

  (* Verified tier: for nIntDiagrams / nIntEuler cases we also check the
     shape of the numeric output. *)
  verifyPass = Missing["NotApplicable"];
  verifyRelErr = Missing["NotApplicable"];
  If[(cat === "nIntDiagrams" || cat === "nIntEuler") && status === "pass",
    Module[{v, e},
      Which[
        AssociationQ[result] && KeyExistsQ[result, "Value"] && KeyExistsQ[result, "Error"],
          v = result["Value"]; e = result["Error"];
          verifyPass = NumericQ[Chop[v]];
          verifyRelErr = If[NumericQ[v] && v =!= 0, Abs[e / v], e],
        MatchQ[result, {_?NumericQ, _?NumericQ}],
          {v, e} = result;
          verifyPass = True;
          verifyRelErr = If[v =!= 0, Abs[e / v], e],
        True,
          verifyPass = False;
          verifyRelErr = Missing["NoNumeric"]
      ]
    ]];

  stBenchmarkClearCaches[];

  <|
    "id"        -> record["id"],
    "category"  -> cat,
    "index"     -> record["index"],
    "label"     -> record["label"],
    "status"    -> status,
    "time"      -> N[t1 - t0],
    "memory"    -> memAfter - memBefore,
    "messages"  -> msgList,
    "hash"      -> hashStr,
    "verified"  -> verifyPass,
    "relError"  -> verifyRelErr
  |>
];

(* Glyph + color for a status string (context-sensitive for $Notebooks). *)
stBenchmarkStatusGlyph[status_String] := Switch[status,
  "pass",    If[$Notebooks, Style["\[Checkmark]", Darker[Green]], "\[Checkmark]"],
  "warning", If[$Notebooks, Style["\[WarningSign]", RGBColor[0.8, 0.6, 0]], "\[WarningSign]"],
  "fail",    If[$Notebooks, Style["\[Times]", Red], "\[Times]"],
  "pending", If[$Notebooks, Style["\[Ellipsis]", Gray], "..."],
  "running", If[$Notebooks, Style["\[RightTriangle]", RGBColor[0.2, 0.4, 0.8]], ">"],
  _,         If[$Notebooks, Style["?", Gray], "?"]
];

(* Short horizontal rule line for the streaming log. *)
stBenchmarkBanner[text_String] :=
  "\[LongDash]\[LongDash] " <> text <> " " <>
  StringJoin @@ Table["\[LongDash]", {Max[0, 60 - StringLength[text]]}];

(* ---- Step 2 results table -----------------------------------------
   Two renderers: a streaming ASCII box for the terminal/wolframscript
   (row-by-row so progress is visible on long runs), and a Grid for
   the notebook front end (one styled cell at the end of the loop,
   identical styling to the Step 1 dependency Grid).                   *)

$stBenchmarkColWidths = {18, 4, 10, 16, 48};


stBenchmarkTableBorder[] := Module[{widths = $stBenchmarkColWidths},
  "+" <> StringRiffle[
    Table[StringJoin @@ Table["-", {widths[[c]] + 2}], {c, Length[widths]}],
    "+"] <> "+"];

stBenchmarkTableRow[cells_List] := Module[
  {widths = $stBenchmarkColWidths, padCell},
  padCell[s_, w_, right_] := If[right,
    StringPadLeft[s, w], StringPadRight[s, w]];
  (* Right-align time + \[CapitalDelta] (cols 3-4); left-align everything else. *)
  "| " <> StringRiffle[
    Table[padCell[ToString[cells[[c]]], widths[[c]],
      MemberQ[{3, 4}, c]], {c, Length[widths]}],
    " | "] <> " |"];

stBenchmarkStreamHeader[] := (
  Print[stBenchmarkTableBorder[]];
  Print[stBenchmarkTableRow[
    {"case", "ok?", "time (s)", "\[CapitalDelta] baseline", "label"}]];
  Print[stBenchmarkTableBorder[]]);

stBenchmarkStreamFooter[] := Print[stBenchmarkTableBorder[]];

(* Plain-text glyph for a case status (used in terminal mode and as
   the unstyled content of the notebook Grid's status cell). *)
stBenchmarkStatusBadge[status_String] := Switch[status,
  "pass",    "[\[Checkmark]]",
  "warning", "[\[WarningSign]]",
  "skipped", "[-]",
  "fail",    "[\[Times]]",
  _,         "[?]"];

(* Notebook-only colored status glyph to match the Step 1 Grid's
   checkmark/cross styling. *)
stBenchmarkStatusCell[status_String] := Switch[status,
  "pass",    Style["\[Checkmark] ok",     Darker[Green],         Bold],
  "warning", Style["\[WarningSign] warn", RGBColor[0.8, 0.6, 0], Bold],
  "skipped", Style["- skip",              Gray,                  Bold],
  "fail",    Style["\[Times] fail",       Red,                    Bold],
  _,         Style["? ???", Gray]];

(* Format the \[CapitalDelta]-baseline cell as a plain ASCII string
   ("+2.10s +6.9%", "-0.50s -1.8%", or "\[LongDash]" when no baseline).
   Used by the terminal stream renderer.

   Uses NumberForm[N[x], {\[Infinity], f}] rather than {n, f} so small
   values (e.g. "0.09s") don't trigger NumberForm::reqsigz about
   insufficient precision. *)
stBenchmarkDeltaInfo[currTime_, baselineCases_Association, id_String] := Module[
  {prev, pt, dt, pct},
  prev = Lookup[baselineCases, id, None];
  If[!AssociationQ[prev] && !MatchQ[prev, {__Rule}], Return[None]];
  pt = Lookup[Association[prev], "time", Missing[]];
  If[!NumericQ[pt] || pt <= 0 || !NumericQ[currTime], Return[None]];
  dt  = N[currTime - pt];
  pct = 100. dt / pt;
  <|"dt" -> dt, "pct" -> pct|>];

stBenchmarkDeltaCell[currTime_, baselineCases_Association, id_String] := Module[
  {info, dt, pct, signS, signP, dtStr, pctStr},
  info = stBenchmarkDeltaInfo[currTime, baselineCases, id];
  If[info === None, Return["\[LongDash]"]];
  dt  = info["dt"];
  pct = info["pct"];
  signS = If[dt  >= 0, "+", ""];
  signP = If[pct >= 0, "+", ""];
  dtStr  = ToString[NumberForm[dt,  {Infinity, 2}]];
  pctStr = ToString[NumberForm[pct, {Infinity, 1}]];
  signS <> dtStr <> "s " <> signP <> pctStr <> "%"];

(* Notebook-only styled \[CapitalDelta]-baseline cell.  Muted green when we're faster
   than the baseline (dt<0), muted red when slower (dt>0), default
   automatic color when exactly matching.  Keeps the same padded text
   content as the ASCII version so alignment inside the Grid matches. *)
stBenchmarkDeltaCellStyled[currTime_, baselineCases_Association, id_String] :=
  Module[{info, dt, pct, signS, signP, dtStr, pctStr, text, color},
    info = stBenchmarkDeltaInfo[currTime, baselineCases, id];
    If[info === None, Return[Style["\[LongDash]", GrayLevel[0.5]]]];
    dt  = info["dt"];
    pct = info["pct"];
    signS = If[dt  >= 0, "+", ""];
    signP = If[pct >= 0, "+", ""];
    dtStr  = ToString[NumberForm[dt,  {Infinity, 2}]];
    pctStr = ToString[NumberForm[pct, {Infinity, 1}]];
    text = signS <> dtStr <> "s " <> signP <> pctStr <> "%";
    color = Which[
      dt < 0, RGBColor[0.15, 0.55, 0.20],  (* faster: deep muted green *)
      dt > 0, RGBColor[0.70, 0.30, 0.15],  (* slower: deep muted red   *)
      True,   Black];
    Style[text, color]];

stBenchmarkStreamRow[outcome_Association, baselineCases_Association] := Module[
  {id, badge, timeStr, deltaStr, label, widths = $stBenchmarkColWidths},
  id       = outcome["id"];
  badge    = stBenchmarkStatusBadge[outcome["status"]];
  timeStr  = ToString[PaddedForm[outcome["time"], {7, 2}]];
  deltaStr = stBenchmarkDeltaCell[outcome["time"], baselineCases, id];
  label    = StringTake[outcome["label"], UpTo[widths[[5]]]];
  Print[stBenchmarkTableRow[{id, badge, timeStr, deltaStr, label}]]];

(* Notebook rendering: emit the full case set as a single Grid matching
   the dependency Grid's style (Helvetica 12, alternating row bg, same
   divider + spacing rules).  Called once after the run completes. *)
stBenchmarkPrintGrid[results_List, baselineCases_Association] := Module[
  {headerNames, header, rows},
  headerNames = {"case", "status", "time (s)", "\[CapitalDelta] baseline", "label"};
  header = Style[#, Bold, FontFamily -> "Helvetica", FontColor -> Black] & /@ headerNames;
  rows = Table[
    {r["id"],
     stBenchmarkStatusCell[r["status"]],
     ToString[PaddedForm[r["time"], {7, 2}]],
     stBenchmarkDeltaCellStyled[r["time"], baselineCases, r["id"]],
     r["label"]},
    {r, results}];
  (* Fixed light backgrounds + FontColor -> Black in the BaseStyle so
     the table reads cleanly on both light and dark notebook themes.
     Per-cell Style[] color directives (status badges, delta green/red)
     override the base black, so colored content still shows. *)
  Print[Grid[Prepend[rows, header],
    Alignment  -> {{Left, Left, Right, Right, Left}, Center},
    Background -> {None,
      Prepend[Table[If[EvenQ[i], GrayLevel[0.97], White],
        {i, Length[rows]}], GrayLevel[0.92]]},
    Dividers   -> {None, {1 -> Gray, 2 -> Gray, -1 -> Gray}},
    Spacings   -> {2.2, 0.7},
    ItemStyle  -> {FontFamily -> "Helvetica", FontSize -> 12, FontColor -> Black},
    BaseStyle  -> {FontFamily -> "Helvetica", FontSize -> 12, FontColor -> Black}]]];


(* ---- STBenchmark ------------------------------------------------- *)

STBenchmark::nopoly   = "polymake is required but not available.  Install it (e.g. `brew install polymake`) before running STBenchmark.";
STBenchmark::noresult = "Case `1` returned $Failed.";

Options[STBenchmark] = {
  "Suite"            -> "Short",
  "Verify"           -> True,
  "Display"          -> "Stream",
  "Baseline"         -> Automatic,
  "UpdateBaseline"   -> Automatic,
  "Report"           -> None,
  "SkipPackageCheck" -> False,
  "LROrderBackend"   -> Automatic,  (* Automatic = honor per-case defaults;
                                        "HyperFLINT" = inject
                                        FindRoots -> False and
                                        "LROrderBackend" -> "HyperFLINT"
                                        on every compatible case; skip cases
                                        that explicitly set FindRoots -> True
                                        (Wm/Wp algebraic-letter path not yet
                                        in HF). *)
  "Integrator"       -> Automatic   (* Automatic = honor per-case defaults
                                        (HyperIntica default); "HyperFLINT"
                                        routes integration through HF's
                                        STHyperFlint; "HyperInt" routes
                                        through Maple SThyperIntMaple.
                                        Injected on every compatible case. *)
};

STBenchmark::badsuite = "Unknown value `1` for Suite option.  Use \"Short\" or \"Long\".";

STBenchmark[opts : OptionsPattern[]] := STBenchmark[All, opts];

(* Typo-tolerant alias.  STBeachmark[args] forwards verbatim to STBenchmark. *)
Options[STBeachmark] = Options[STBenchmark];
STBeachmark[args___] := STBenchmark[args];
STBenchmark[selector_, OptionsPattern[]] := Module[
  {records, displayMode, skipPkg, baselinePath, updateBaseline, reportPath,
   suite, results, startTime, endTime, totalDuration, baselineData,
   baselineCases, summary, failures, warnings, outcome, streamP,
   lrBackendChoice},

  suite           = OptionValue["Suite"];
  displayMode     = OptionValue["Display"];
  skipPkg         = TrueQ[OptionValue["SkipPackageCheck"]];
  baselinePath    = OptionValue["Baseline"];
  updateBaseline  = OptionValue["UpdateBaseline"];
  reportPath      = OptionValue["Report"];
  lrBackendChoice = OptionValue["LROrderBackend"];
  (* Propagate to the per-case runner via a module-scoped global so
     stBenchmarkRunOneInKernel can inject per-case options without
     threading an extra arg through every existing path. *)
  $stBenchmarkLRBackend = lrBackendChoice;
  $stBenchmarkIntegrator = OptionValue["Integrator"];

  If[!MatchQ[suite, "Short" | "Long"],
    Message[STBenchmark::badsuite, suite]; Return[$Failed]];

  If[baselinePath === Automatic, baselinePath = $STBenchmarkDataFile];

  streamP = displayMode =!= "Silent";

  (* ---- Step 1: package health check ---- *)
  If[!skipPkg,
    Print[stBenchmarkBanner["Step 1: dependencies"]];
    STDependencies[];
    If[$STDependencies["polymake", "status"] =!= "ok",
      Message[STBenchmark::nopoly];
      Return[$Failed]];
    Print[];
  ];

  (* ---- Step 2: load + select cases ---- *)
  records = stBenchmarkLoadCases[suite];
  If[records === $Failed, Return[$Failed]];
  records = stBenchmarkApplySelector[records, selector];
  If[records === {},
    Print["STBenchmark: no cases matched selector ", selector]; Return[Null]];

  (* Load baseline BEFORE the stream so each row can show a \[CapitalDelta] column.
     Empty association when no baseline is on disk, when the file can't
     be parsed, or when the recorded suite disagrees with this run. *)
  baselineData = If[baselinePath =!= None && FileExistsQ[baselinePath],
    Quiet[Check[Import[baselinePath, "JSON"], $Failed]],
    None];
  baselineCases = Which[
    !AssociationQ[baselineData] && !MatchQ[baselineData, {__Rule}],
      <||>,
    !MatchQ[
      Lookup[Association[baselineData], "suite", Missing[]],
      suite | _Missing],
      <||>,
    True,
      Association[Lookup[Association[baselineData], "cases", <||>]]];

  Print[stBenchmarkBanner[
    "Step 2: running " <> ToString[Length[records]] <>
    " cases (" <> suite <> " suite)"]];
  (* Terminal streams rows incrementally so progress stays visible;
     notebook mode renders one styled Grid at the end so its look matches
     the Step 1 dependency Grid.  During the notebook run, Monitor
     displays the currently-executing case in an auto-updating cell
     that vanishes when the Table returns. *)
  If[streamP && !$Notebooks, stBenchmarkStreamHeader[]];

  startTime = AbsoluteTime[];

  (* Run every case serially in the main kernel.  stBenchmarkClearCaches[]
     inside stBenchmarkRunOneInKernel resets $LinearFactorsCache and
     related HyperIntica state between cases so that one case's symbolic
     state can't poison the next. *)
  results = Monitor[
    Table[
      outcome = stBenchmarkRunOneInKernel[records[[i]]];
      If[streamP && !$Notebooks,
        stBenchmarkStreamRow[outcome, baselineCases]];
      outcome,
      {i, Length[records]}],
    Style["  running diagram " <> ToString[i] <> "/" <>
      ToString[Length[records]] <> " \[Ellipsis]",
      Italic, GrayLevel[0.4]]];

  endTime = AbsoluteTime[];
  totalDuration = endTime - startTime;
  If[streamP && !$Notebooks, stBenchmarkStreamFooter[]];
  If[streamP && $Notebooks, stBenchmarkPrintGrid[results, baselineCases]];

  summary = stBenchmarkSummary[results, totalDuration];

  (* Regressions vs baseline.  Only prints when the baseline has an
     entry for a case whose status dropped, time > 2x, or hash changed. *)
  If[Length[baselineCases] > 0 &&
     (AssociationQ[baselineData] || MatchQ[baselineData, {__Rule}]),
    stBenchmarkPrintRegressions[results, Association[baselineData]]];

  (* Failures / warnings \[LongDash] only surface when non-empty.  For "pass"
     runs (the common case), nothing is printed between the table and
     the final one-line summary. *)
  failures = Select[results, #["status"] === "fail" &];
  warnings = Select[results, #["status"] === "warning" &];
  If[Length[failures] > 0,
    Print[];
    Print[Style["Failures:", Bold, Red]];
    Do[Print["  ", f["id"], "  ", f["label"],
      If[Length[f["messages"]] > 0,
        "\n    messages: " <> ToString[Short[First[f["messages"]], 2]], ""]],
      {f, failures}]];
  If[Length[warnings] > 0,
    Print[];
    Print[Style["Warnings:", Bold, RGBColor[0.8, 0.6, 0]]];
    Do[Print["  ", w["id"], "  ", w["label"],
      If[Length[w["messages"]] > 0,
        "\n    messages: " <> StringRiffle[w["messages"], ", "], ""]],
      {w, warnings}]];

  (* Write/update baseline *)
  If[updateBaseline === True ||
      (updateBaseline === Automatic && baselineData === None),
    stBenchmarkWriteBaseline[results, summary, suite, baselinePath]];

  (* Optional Markdown report *)
  If[StringQ[reportPath],
    stBenchmarkWriteReport[results, summary, reportPath];
    Print["Report written to ", reportPath]];

  Print[];
  Print[Style["STBenchmark (" <> suite <> "): " <>
    ToString[summary["pass"]] <> "/" <> ToString[summary["total"]] <>
    " pass (" <> ToString[PaddedForm[100. summary["pass"] / Max[1, summary["total"]], {4, 1}]] <>
    "%), " <> ToString[summary["warn"]] <> " warn, " <>
    ToString[summary["fail"]] <> " fail, " <>
    ToString[PaddedForm[N[totalDuration], {6, 1}]] <> " s, v" <> $SubTropicaVersion,
    Bold]];

  (* Expose the run's per-case details for programmatic access without
     echoing a giant Association at the REPL/script top level. *)
  $STLastBenchmarkResults = results;
  Null
];

(* Roll-up summary across categories *)
stBenchmarkSummary[results_List, totalDuration_] := Module[
  {byCat, cats, row, totals},
  cats = DeleteDuplicates[#["category"] & /@ results];
  byCat = Association @ Table[
    Module[{sub = Select[results, #["category"] === cat &]},
      cat -> <|
        "n"     -> Length[sub],
        "pass"  -> Count[sub, KeyValuePattern["status" -> "pass"]],
        "warn"  -> Count[sub, KeyValuePattern["status" -> "warning"]],
        "fail"  -> Count[sub, KeyValuePattern["status" -> "fail"]],
        "time"  -> Total[#["time"] & /@ sub]|>],
    {cat, cats}];
  totals = <|
    "total" -> Length[results],
    "pass"  -> Count[results, KeyValuePattern["status" -> "pass"]],
    "warn"  -> Count[results, KeyValuePattern["status" -> "warning"]],
    "fail"  -> Count[results, KeyValuePattern["status" -> "fail"]],
    "time"  -> totalDuration|>;
  Join[<|"byCategory" -> byCat|>, totals]
];

stBenchmarkPrintSummary[summary_Association, results_List] := Module[
  {rows, header, byCat, fmtTime},
  byCat = summary["byCategory"];
  fmtTime[t_] := ToString[PaddedForm[N[t], {7, 1}]];
  rows = Table[
    {cat, byCat[cat]["n"], byCat[cat]["pass"], byCat[cat]["warn"],
     byCat[cat]["fail"], fmtTime[byCat[cat]["time"]]},
    {cat, Keys[byCat]}];
  AppendTo[rows, {If[$Notebooks, Style["TOTAL", Bold], "TOTAL"],
    summary["total"], summary["pass"], summary["warn"], summary["fail"],
    fmtTime[summary["time"]]}];
  header = {"category", "n", "pass", "warn", "fail", "time (s)"};
  If[$Notebooks,
    Print[Grid[Prepend[rows, Style[#, Bold] & /@ header],
      Alignment -> {{Left, Right, Right, Right, Right, Right}},
      Dividers -> {None, {2 -> Gray, -2 -> Gray}},
      Spacings -> {2, 0.4}]],
    (* Terminal: fixed-width columns, no decorations *)
    Module[{widths, fmtRow},
      widths = {18, 5, 5, 5, 5, 10};
      fmtRow[r_] := StringJoin[
        StringPadRight[ToString[r[[1]]], widths[[1]]],
        StringPadLeft[ToString[r[[2]]], widths[[2]]],
        StringPadLeft[ToString[r[[3]]], widths[[3]]],
        StringPadLeft[ToString[r[[4]]], widths[[4]]],
        StringPadLeft[ToString[r[[5]]], widths[[5]]],
        StringPadLeft[ToString[r[[6]]], widths[[6]]]];
      Print[fmtRow[header]];
      Print[StringJoin @@ Table["-", {Total[widths]}]];
      Print[fmtRow[#]] & /@ rows;
    ]]
];

stBenchmarkPrintRegressions[results_List, baselineData_Association] := Module[
  {cases, prev, regressions, now, delta},
  cases = Lookup[baselineData, "cases", <||>];
  If[!AssociationQ[cases] && !MatchQ[cases, {__Rule}], Return[]];
  cases = Association[cases];
  regressions = {};
  Do[
    prev = Lookup[cases, r["id"], None];
    If[AssociationQ[prev] || MatchQ[prev, {__Rule}],
      prev = Association[prev];
      Which[
        Lookup[prev, "status", ""] === "pass" && r["status"] =!= "pass",
          AppendTo[regressions, {r["id"], r["label"],
            "newly " <> r["status"]}],
        r["status"] === "pass" && NumericQ[Lookup[prev, "time", 0]] &&
            prev["time"] > 0 && r["time"] > 2 prev["time"] && r["time"] > 1.,
          AppendTo[regressions, {r["id"], r["label"],
            ToString[NumberForm[N[prev["time"]],  {Infinity, 2}]] <> " s \[Rule] " <>
            ToString[NumberForm[N[r["time"]],     {Infinity, 2}]] <> " s (" <>
            ToString[NumberForm[N[r["time"] / prev["time"]], {Infinity, 1}]] <> "\[Times])"}],
        r["status"] === "pass" && StringQ[Lookup[prev, "hash", ""]] &&
            prev["hash"] =!= "" && prev["hash"] =!= r["hash"],
          AppendTo[regressions, {r["id"], r["label"], "result hash changed"}]
      ]];
  , {r, results}];
  If[Length[regressions] > 0,
    Print[];
    Print[Style["Regressions vs baseline (v" <>
      ToString[Lookup[baselineData, "version", "?"]] <> "):",
      Bold, RGBColor[0.7, 0.3, 0.1]]];
    Do[Print["  ", reg[[1]], "  ", reg[[3]],
      If[reg[[2]] =!= "", "   (" <> reg[[2]] <> ")", ""]], {reg, regressions}]];
];

stBenchmarkWriteBaseline[results_List, summary_Association, suite_String,
  path_String] := Module[
  {payload, dir},
  dir = DirectoryName[path];
  Quiet[CreateDirectory[dir, CreateIntermediateDirectories -> True]];
  payload = <|
    "version" -> $SubTropicaVersion,
    "suite"   -> suite,
    "date"    -> DateString[],
    "summary" -> <|
      "total" -> summary["total"], "pass" -> summary["pass"],
      "warn"  -> summary["warn"],  "fail" -> summary["fail"],
      "time"  -> N[summary["time"]]|>,
    "cases" -> Association[#["id"] -> <|
      "status" -> #["status"],
      "time"   -> N[#["time"]],
      "hash"   -> #["hash"]|> & /@ results]|>;
  Quiet[Check[Export[path, payload, "JSON"], $Failed]];
];

stBenchmarkWriteReport[results_List, summary_Association, path_String] := Module[
  {lines, byCat},
  byCat = summary["byCategory"];
  lines = {
    "# STBenchmark report",
    "",
    "SubTropica v" <> $SubTropicaVersion <> " \[LongDash] " <> DateString[],
    "",
    "| category | n | pass | warn | fail | time (s) |",
    "|---|---:|---:|---:|---:|---:|"};
  Do[AppendTo[lines,
    "| " <> cat <> " | " <> ToString[byCat[cat]["n"]] <>
    " | " <> ToString[byCat[cat]["pass"]] <>
    " | " <> ToString[byCat[cat]["warn"]] <>
    " | " <> ToString[byCat[cat]["fail"]] <>
    " | " <> ToString[NumberForm[N[byCat[cat]["time"]], {Infinity, 1}]] <> " |"],
    {cat, Keys[byCat]}];
  AppendTo[lines,
    "| **TOTAL** | " <> ToString[summary["total"]] <>
    " | " <> ToString[summary["pass"]] <>
    " | " <> ToString[summary["warn"]] <>
    " | " <> ToString[summary["fail"]] <>
    " | " <> ToString[NumberForm[N[summary["time"]], {Infinity, 1}]] <> " |"];
  AppendTo[lines, ""];
  AppendTo[lines, "## Failures"];
  Module[{f = Select[results, #["status"] === "fail" &]},
    If[f === {},
      AppendTo[lines, "_none_"],
      Do[AppendTo[lines, "- `" <> r["id"] <> "` " <> r["label"]], {r, f}]]];
  AppendTo[lines, ""];
  AppendTo[lines, "## Slowest"];
  Module[{top = Take[SortBy[results, -#["time"] &], UpTo[10]]},
    Do[AppendTo[lines, "- `" <> r["id"] <> "` " <> r["label"] <>
      "  \[LongDash] " <> ToString[NumberForm[N[r["time"]], {Infinity, 2}]] <> " s"], {r, top}]];
  Quiet[Export[path, StringRiffle[lines, "\n"], "Text"]];
];


