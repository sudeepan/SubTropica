(* Apply NP once on an integrand along a ray *)

Clear[STcontinueRay];
STcontinueRay[integrand_,xvars_,ray_]:=Module[{smallParam,coeff,mons,pols,exps,newExps,trop,newPref,newPol,continued},
{coeff,mons,{pols,exps}}=STtoCoeffMonPols[integrand/.Table[xvars[[i]]-> xvars[[i]] smallParam^(-ray[[i]]),{i,1,xvars//Length}]//STFactor,Join[{smallParam},xvars]];
(*{coeff,mons,{pols,exps}}//Return;*)
newPref=-1/mons[[1]];
continued=Table[
newPol=D[pols[[i]],smallParam];
newExps=exps;
newExps[[i]]-=1;
coeff*newPref *exps[[i]](Times@@(xvars^mons[[2;;]]))(Times@@(pols^newExps))newPol/.smallParam->1
,{i,1,pols//Length}]//DeleteCases[#,0]&;
STextractCoefficient[#,xvars]&/@continued
]


(* Apply NP multiple times on a combination of Euler integrands presented as {prefactor, integrand} *)
Clear[STContinueRays];
(* takes as input a collection of pairs {prefactor,integrand}*)
STContinueRays[prefsInts_,xvars_,{}]:=prefsInts;
STContinueRays[prefsInts_,xvars_,rays_]:=Module[{continued,newPrefsInts},
newPrefsInts=Join@@Table[
continued={ FullSimplify[pri[[1]]#[[1]] ] ,#[[2]]}&/@ STcontinueRay[pri[[2]],xvars,rays[[1]]]
,{pri,prefsInts}];
STContinueRays[newPrefsInts,xvars,rays[[2;;]]]
]

