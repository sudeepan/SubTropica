Clear[STReadResults];
Options[STReadResults]={"NumericsQ"->False};
STReadResults[id_:"NP",OptionsPattern[]]:=Module[
	{
	result,results,
NPfilenames,polysAndPairs,xvars,linearlyReducibleOrders,
epspower,prefactor,successQ,failed={},backSubRules},

	(* names of all face/order directories that contribute to this NP-id *)
	NPfilenames=FileNames["integrands/"<>id<>"*"<>"/*"];

	Print["---------------------------------"];
	Print["Combining results from "<> ToString[NPfilenames//Length] <> " face integrands"];
	NPfilenames//Print;
	results=Table[
		epspower=Get[file<>"/epsorder.m"];
		If[Not[OptionValue["NumericsQ"]===False],
			prefactor=Get[file<>"/prefactor.m"]/.OptionValue["NumericsQ"],
			prefactor=Get[file<>"/prefactor.m"]
		];
		If[FileExistsQ[file<>"/successQ.m"] && Get[file<>"/successQ.m"],
			result=Get[file<>"/result.m"]//Total,
			result=STwrapError[file<>" not yet integrated!"]
		];
		prefactor result epspower
		,
		{file,NPfilenames}
	];
	results = stStageTime["STReadResults:Mpl/mzv-rewrite",
		results//.Mpl->MplAsHlog/.mzv->zeta];

	(* FindRoots algebraic letters pipeline:
	   - SimplifyWithVieta is INTENTIONALLY SKIPPED.  Its `FixedPoint[Expand[# //.
	     powerRules] &, Expand[e], 10]` step is an exponential hazard on non-trivial
	     inputs (see the pentagon 2-massive-props case: 5 Wm/Wp pairs, 220 KB
	     results, >> 2h hang with no progress).  The algebraic letters stay as
	     atomic Wm[i]/Wp[i] in the output; symbol-level cancellations are
	     performed on demand by `stCombineWmWpRatios` during symbol computation.
	     Callers who want the Vieta-simplified form can invoke
	     `SimplifyWithVieta[result]` manually afterwards.
	   - CanonicalizeAlgebraicLetters[results]: prune indices no longer
	     appearing in results, dedupe surviving indices up to the mirror swap,
	     renumber 1..k, mutate $HyperAlgebraicLetterTable.
	   - GetAlgebraicBackSubRules[] feeds $stRootSubstitutions for STVerify. *)
	If[Length[$HyperAlgebraicLetterTable] > 0,
		Module[{renameRules = stStageTime["STReadResults:CanonicalizeAlgebraicLetters",
				CanonicalizeAlgebraicLetters[results]]},
			If[renameRules =!= {},
				results = stStageTime["STReadResults:rename-apply",
					results /. renameRules]]];
		$stRootSubstitutions = stStageTime["STReadResults:GetAlgebraicBackSubRules",
			GetAlgebraicBackSubRules[]]];
	results
]


