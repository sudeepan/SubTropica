                            topo_dir = os.path.dirname(cfg_dir)
                            if os.path.isdir(topo_dir):
                                remaining = [x for x in os.listdir(topo_dir) if x != 'topology.json']
                                if not remaining:
                                    tj = os.path.join(topo_dir, 'topology.json')
                                    if os.path.isfile(tj):
                                        os.remove(tj)
                                    if not os.listdir(topo_dir):
                                        os.rmdir(topo_dir)
                    else:
                        old_data['Records'] = staying_records
                        staying_refs = []
                        seen = set()
                        for r in staying_records:
                            ref = r.get('reference', '')
                            if ref and ref not in seen:
                                staying_refs.append(ref)
                                seen.add(ref)
                        old_data['References'] = staying_refs
                        review_atomic_write(old_full, review_serialize(old_data, old_raw))
                # Waitlist transfer: if the old entry was on the waitlist,
                # carry the review debt to the new location \[LongDash] but only if
                # the new location is a fresh directory (not a merge into
