Cell[CellGroupData[{

Cell["Loop-by-loop Baikov", "Subsection",
 CellChangeTimes->{{3.986672709641376*^9, 3.986672710916088*^9}, {
  3.986729239053918*^9, 
  3.986729245016883*^9}},ExpressionUUID->"99480d0c-5d2c-4691-82d9-\
49bd5b7c5c80"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"n", "-", 
    RowBox[{"point", " ", 
     RowBox[{"kinematic", ":"}]}]}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", "GenerateKinematics", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"GenerateKinematics", "[", "nParticles_", "]"}], ":=", "\n", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"nParticles", "==", "2"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Subscript", "[", 
           RowBox[{"p", ",", " ", "1"}], "]"}], "\[CenterDot]", 
          RowBox[{"Subscript", "[", 
           RowBox[{"p", ",", " ", "1"}], "]"}]}], "->", "s"}], "}"}], ",", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", "out", "}"}], ",", "\n", 
         RowBox[{
          RowBox[{"n", "=", "nParticles"}], ";", "\n", 
          RowBox[{"ppMatrix", "=", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"i", "==", "j"}], ",", 
               RowBox[{
                RowBox[{"Subscript", "[", 
                 RowBox[{"M", ",", " ", "i"}], "]"}], "^", "2"}], ",", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"Subscript", "[", 
                   RowBox[{"s", ",", " ", 
                    RowBox[{"Sequence", "@@", 
                    RowBox[{"Sort", "[", 
                    RowBox[{"{", 
                    RowBox[{"i", ",", "j"}], "}"}], "]"}]}]}], "]"}], "-", 
                  RowBox[{
                   RowBox[{"Subscript", "[", 
                    RowBox[{"M", ",", " ", "i"}], "]"}], "^", "2"}], "-", 
                  RowBox[{
                   RowBox[{"Subscript", "[", 
                    RowBox[{"M", ",", " ", "j"}], "]"}], "^", "2"}]}], ")"}], 
                "/", "2"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "n"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "n"}], "}"}]}], "]"}]}], ";", "\n", 
          RowBox[{"cyclicBasis", "=", 
           RowBox[{"Flatten", "[", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Subscript", "[", 
               RowBox[{"s", ",", " ", 
                RowBox[{"Sequence", "@@", 
                 RowBox[{"Sort", "[", 
                  RowBox[{"Mod", "[", 
                   RowBox[{
                    RowBox[{"Range", "[", 
                    RowBox[{"a", ",", 
                    RowBox[{"a", "+", "l"}]}], "]"}], ",", "n", ",", "1"}], 
                   "]"}], "]"}]}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"l", ",", "1", ",", 
                RowBox[{
                 RowBox[{"n", "/", "2"}], "-", "1"}]}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"a", ",", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"l", "==", 
                   RowBox[{
                    RowBox[{"n", "/", "2"}], "-", "1"}]}], ",", 
                  RowBox[{"n", "/", "2"}], ",", "n"}], "]"}]}], "}"}]}], 
             "]"}], "]"}]}], ";", "\n", 
          RowBox[{"sRelations", "=", 
           RowBox[{"Flatten", "[", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Subscript", "[", 
                RowBox[{"s", ",", " ", 
                 RowBox[{"Sequence", "@@", 
                  RowBox[{"Sort", "[", 
                   RowBox[{"Mod", "[", 
                    RowBox[{
                    RowBox[{"Range", "[", 
                    RowBox[{"a", ",", 
                    RowBox[{"a", "+", "l"}]}], "]"}], ",", "n", ",", "1"}], 
                    "]"}], "]"}]}]}], "]"}], "==", 
               RowBox[{"Sum", "[", 
                RowBox[{
                 RowBox[{"ppMatrix", "[", 
                  RowBox[{"[", 
                   RowBox[{"b", ",", "c"}], "]"}], "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"b", ",", 
                   RowBox[{"Mod", "[", 
                    RowBox[{
                    RowBox[{"Range", "[", 
                    RowBox[{"a", ",", 
                    RowBox[{"a", "+", "l"}]}], "]"}], ",", "n", ",", "1"}], 
                    "]"}]}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"c", ",", 
                   RowBox[{"Mod", "[", 
                    RowBox[{
                    RowBox[{"Range", "[", 
                    RowBox[{"a", ",", 
                    RowBox[{"a", "+", "l"}]}], "]"}], ",", "n", ",", "1"}], 
                    "]"}]}], "}"}]}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"l", ",", "1", ",", 
                RowBox[{
                 RowBox[{"n", "/", "2"}], "-", "1"}]}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"a", ",", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"l", "==", 
                   RowBox[{
                    RowBox[{"n", "/", "2"}], "-", "1"}]}], ",", 
                  RowBox[{"n", "/", "2"}], ",", "n"}], "]"}]}], "}"}]}], 
             "]"}], "]"}]}], ";", "\n", 
          RowBox[{"momentumConservation", "=", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Sum", "[", 
               RowBox[{
                RowBox[{"ppMatrix", "[", 
                 RowBox[{"[", 
                  RowBox[{"i", ",", "j"}], "]"}], "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"j", ",", "n"}], "}"}]}], "]"}], "==", "0"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "n"}], "}"}]}], "]"}]}], ";", "\n", 
          RowBox[{"solution", "=", 
           RowBox[{
            RowBox[{"Solve", "[", "\n", 
             RowBox[{
              RowBox[{"Join", "[", 
               RowBox[{"momentumConservation", ",", "sRelations"}], "]"}], 
              "\n", ",", 
              RowBox[{"Complement", "[", 
               RowBox[{
                RowBox[{"Variables", "[", "ppMatrix", "]"}], ",", 
                "cyclicBasis", ",", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"Subscript", "[", 
                   RowBox[{"M", ",", " ", "i"}], "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", "n"}], "}"}]}], "]"}]}], "]"}]}], "]"}], 
            "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", 
          RowBox[{"substitutions", "=", 
           RowBox[{"Flatten", "[", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"Subscript", "[", 
                   RowBox[{"p", ",", " ", "i"}], "]"}], "\[CenterDot]", 
                  RowBox[{"Subscript", "[", 
                   RowBox[{"p", ",", " ", "j"}], "]"}]}], "->", 
                 RowBox[{"ppMatrix", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", ",", "j"}], "]"}], "]"}]}], "/.", 
                "solution"}], "//", "Factor"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "n"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", "n"}], "}"}]}], "]"}], "]"}]}], ";", "\n", 
          RowBox[{"out", "=", "substitutions"}]}]}], "\n", "]"}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{"FixingLoopEdges", " ", "and", " ", "helper", " ", 
     RowBox[{"functions", ":"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"normalizeEdge", "[", 
      RowBox[{"UndirectedEdge", "[", 
       RowBox[{"a_", ",", "b_", ",", "w_"}], "]"}], "]"}], ":=", 
     RowBox[{"UndirectedEdge", "[", 
      RowBox[{
       RowBox[{"Min", "[", 
        RowBox[{"a", ",", "b"}], "]"}], ",", 
       RowBox[{"Max", "[", 
        RowBox[{"a", ",", "b"}], "]"}], ",", "w"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"RemoveZeroRowMatrices", "[", "list_", "]"}], ":=", 
    RowBox[{"Select", "[", 
     RowBox[{"list", ",", 
      RowBox[{
       RowBox[{"FreeQ", "[", 
        RowBox[{"#", ",", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"0", ",", 
           RowBox[{"Length", "[", 
            RowBox[{"First", "[", "#", "]"}], "]"}]}], "]"}]}], "]"}], 
       "&"}]}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"FirstUniqueOnePositions", "[", "matrix_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"trimmed", ",", "zeroCols", ",", "positions"}], "}"}], ",", 
       "\n", 
       RowBox[{
        RowBox[{"trimmed", "=", 
         RowBox[{"matrix", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", 
            RowBox[{"1", ";;", 
             RowBox[{"-", "2"}]}]}], "]"}], "]"}]}], ";", "\n", 
        RowBox[{"zeroCols", "=", 
         RowBox[{
          RowBox[{"Position", "[", 
           RowBox[{
            RowBox[{"Total", "[", 
             RowBox[{"trimmed", ",", 
              RowBox[{"{", "1", "}"}]}], "]"}], ",", "1"}], "]"}], "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", "\n", 
        RowBox[{"positions", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"SelectFirst", "[", 
            RowBox[{
             RowBox[{"Range", "[", 
              RowBox[{"Length", "[", 
               RowBox[{"trimmed", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"MemberQ", "[", 
                RowBox[{"zeroCols", ",", "#"}], "]"}], "&&", 
               RowBox[{
                RowBox[{"trimmed", "[", 
                 RowBox[{"[", 
                  RowBox[{"i", ",", "#"}], "]"}], "]"}], "==", "1"}]}], 
              "&"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", 
             RowBox[{"Length", "[", "trimmed", "]"}]}], "}"}]}], "]"}]}], ";",
         "\n", "positions"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"CycleToIndicator", "[", 
      RowBox[{"cycle_", ",", "edgelist_"}], "]"}], ":=", 
     RowBox[{"Boole", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"MemberQ", "[", 
         RowBox[{"cycle", ",", "#"}], "]"}], "&"}], "/@", "edgelist"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"addedges", "[", "edges_", "]"}], ":=", 
     RowBox[{"Cases", "[", 
      RowBox[{
       RowBox[{"Tally", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", "edges", "]"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"Sort", "[", "#1", "]"}], "===", 
           RowBox[{"Sort", "[", "#2", "]"}]}], "&"}]}], "]"}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"e_", ",", 
          RowBox[{"_", "?", "OddQ"}]}], "}"}], ":>", "e"}]}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"keepFirstNSingletons", "[", 
      RowBox[{"list_", ",", "n_"}], "]"}], ":=", 
     RowBox[{"Delete", "[", 
      RowBox[{"list", ",", 
       RowBox[{"List", "/@", 
        RowBox[{"Drop", "[", 
         RowBox[{
          RowBox[{"Flatten", "@", 
           RowBox[{"Position", "[", 
            RowBox[{"list", ",", 
             RowBox[{"{", "_", "}"}]}], "]"}]}], ",", "n"}], "]"}]}]}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
