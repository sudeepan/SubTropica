Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"here", " ", "i", " ", "setup", " ", "the", " ", "diagram"}], " ",
     "+", " ", 
    RowBox[{"Baikov", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"edgesMomenta", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["l", "1"], ",", 
      SubscriptBox["l", "2"], ",", 
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["l", "1"]}], "-", 
       SubscriptBox["l", "2"], "+", 
       SubscriptBox["p", "1"]}]}], "}"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"standardBaikov", "=", 
     RowBox[{"Echo", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"edgesMomenta", "[", 
          RowBox[{"[", "ii", "]"}], "]"}], "\[CenterDot]", 
         RowBox[{"edgesMomenta", "[", 
          RowBox[{"[", "jj", "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"ii", ",", 
          RowBox[{"Length", "[", "edgesMomenta", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"jj", ",", 
          RowBox[{"Length", "[", "edgesMomenta", "]"}]}], "}"}]}], "]"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"xToLoop", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Thread", "[", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"ToExpression", "[", 
             RowBox[{"\"\<x\>\"", "<>", 
              RowBox[{"ToString", "[", "#", "]"}]}], "]"}], "&"}], ",", 
           RowBox[{"Range", "[", 
            RowBox[{"Length", "[", "#", "]"}], "]"}]}], "]"}], "->", "#1"}], 
        "]"}], "&"}], "[", 
      RowBox[{
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"#1", "\[CenterDot]", "#1"}], "&"}], ",", "edgesMomenta"}], 
        "]"}], "-", 
       RowBox[{"{", 
        RowBox[{
         SubsuperscriptBox["m", "1", "2"], ",", 
         SubsuperscriptBox["m", "2", "2"], ",", 
         SubsuperscriptBox["m", "3", "2"]}], "}"}]}], "]"}], "~", "Join", "~", 
     RowBox[{"(*", "ISPs", "*)"}], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x4", "->", 
        RowBox[{
         SubscriptBox["l", "1"], "\[CenterDot]", 
         SubscriptBox["l", "2"]}]}], ",", 
       RowBox[{"x5", "->", 
        RowBox[{
         SubscriptBox["l", "1"], "\[CenterDot]", 
         SubscriptBox["p", "1"]}]}]}], "}"}]}]}], "\[IndentingNewLine]", 
   RowBox[{"loopToX", "=", 
    RowBox[{"Flatten", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"#", "==", "0"}], ",", 
         RowBox[{"DeleteDuplicates", "[", 
          RowBox[{"Cases", "[", 
           RowBox[{"#", ",", 
            RowBox[{
             SubscriptBox["l", "_"], "\[CenterDot]", "_"}], ",", "Infinity"}],
            "]"}], "]"}]}], "]"}], "&"}], "[", 
      RowBox[{"xToLoop", "/.", 
       RowBox[{
        RowBox[{"Rule", "[", 
         RowBox[{"a_", ",", "b_"}], "]"}], ":>", 
        RowBox[{"a", "-", "b"}]}]}], "]"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"BH", "=", 
     RowBox[{
      RowBox[{"standardBaikov", "//.", "loopToX"}], "/.", "xhom"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"%", "//", "MatrixForm"}], "\[IndentingNewLine]", 
   RowBox[{"polyBH", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"Expand", "[", 
       RowBox[{"Numerator", "[", 
        RowBox[{"Factor", "[", 
         RowBox[{"Det", "[", "BH", "]"}], "]"}], "]"}], "]"}], "/.", 
      RowBox[{
       SubscriptBox["m", "i_"], ":>", 
       SqrtBox[
        RowBox[{"ToExpression", "[", 
         RowBox[{"\"\<mm\>\"", "<>", 
          RowBox[{"ToString", "[", "i", "]"}]}], "]"}]]}]}], "/.", 
     RowBox[{"GenerateKinematics", "[", "2", "]"}]}]}], "\[IndentingNewLine]", 
   RowBox[{"%", "//", "Length"}]}]}]], "Input",
