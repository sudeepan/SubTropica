Cell[BoxData[{
 RowBox[{"polyG2", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Numerator", "[", 
      RowBox[{"Factor", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "1"}], "}"}], ".", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"U2", ",", "F2"}], "}"}], "=", 
          RowBox[{"Echo", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"UF", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"l", "[", "1", "]"}], ",", 
                   RowBox[{"l", "[", "2", "]"}]}], "}"}], ",", 
                 RowBox[{
                  RowBox[{"props", "//.", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"GenerateKinematics", "[", "2", "]"}], "/.", 
                    RowBox[{
                    SubscriptBox["p", "i_"], ":>", 
                    RowBox[{"p", "[", "i", "]"}]}]}], ")"}]}], "/.", 
                  RowBox[{
                   RowBox[{"a_", "\[CenterDot]", "b_"}], ":>", 
                   RowBox[{"a", "*", "b"}]}]}], ",", 
                 RowBox[{"{", "}"}]}], "]"}], "[", 
               RowBox[{"[", 
                RowBox[{"1", ";;", 
                 RowBox[{"-", "2"}]}], "]"}], "]"}], ")"}], "/.", 
             RowBox[{
              SubscriptBox["m", "i_"], ":>", 
              SqrtBox[
               RowBox[{"ToExpression", "[", 
                RowBox[{"\"\<mm\>\"", "<>", 
                 RowBox[{"ToString", "[", "i", "]"}]}], "]"}]]}]}], "/.", 
            RowBox[{
             RowBox[{"\[Alpha]", "[", "i_", "]"}], ":>", 
             FractionBox[
              RowBox[{"ToExpression", "[", 
               RowBox[{"\"\<\[Alpha]\>\"", "<>", 
                RowBox[{"ToString", "[", "i", "]"}]}], "]"}], 
              "\[Alpha]0"]}]}], "]"}]}], ")"}]}], "]"}], "]"}], "//.", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"homogeneizeKin", "[", "MySubstitutions", "]"}], "/.", 
        RowBox[{
         SubscriptBox["p", "i_"], ":>", 
