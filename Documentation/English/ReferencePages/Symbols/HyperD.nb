Notebook[{

Cell[CellGroupData[{
Cell["HyperD", "ObjectName",ExpressionUUID->"a954e0e3-328b-4a1d-92e6-1ec7040e3eb1"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["HyperD", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"fb974c00-b558-44e3-9211-0e30bd3035b4"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"74de0090-9b67-4706-845d-0b1707cf127c"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"563c114f-9f27-40da-9e19-c2fb0ce6bf15"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"7af40c4d-6d8b-464d-bc7b-177305a46313"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"3678c81a-d3ac-4c64-bb6f-4ec5c2e5e4a4"],

Cell["Derivatives", "Subsection",ExpressionUUID->"45ad6ea3-db2b-4b55-9d1f-1e899b0f0986"],

Cell["\<\
HyperD[expr, var] computes the derivative of expr with respect to var, \
correctly implementing differentiation rules for Hlog and Mpl that the \
built-in Mathematica D[] does not handle. expr may contain Hlog, Mpl, \
PolyLog, logarithms, and algebraic functions, while var can appear in both \
the upper limit and the letters of hyperlogarithms. Some examples are: (see \
example below)\
\>", "Text",ExpressionUUID->"212b7613-1342-452d-a270-43232af5d785"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Differentiate", " ", 
    RowBox[{"Li", "\\", "textcolor"}], 
    RowBox[{"{", "gray", "}"}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "}"}], "_", "2"}], "}"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"x", "/", "u"}]}], ")"}], " ", "with", " ", "respect", " ", 
    "to", " ", "x"}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], ",", " ", "x"}], "]"}], 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Mpl", "[", 
         RowBox[{
          RowBox[{"{", "1", "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"u", 
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"x", "/", "u"}]}], ")"}]}], ")"}]}], ")"}]}]}], " ", 
    "*)"}], "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Differentiate", " ", "Hlog", " ", "with", " ", "var"}], "-", 
     RowBox[{"dependent", " ", "letters"}]}], " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"z", ",", " ", 
       RowBox[{"{", 
        RowBox[{"a", ",", " ", "b"}], "}"}]}], "]"}], ",", " ", "a"}], "]"}], 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Hlog", "[", 
          RowBox[{"z", ",", " ", 
           RowBox[{"{", "a", "}"}]}], "]"}], " ", "-", " ", 
         RowBox[{"Hlog", "[", 
          RowBox[{"z", ",", " ", 
           RowBox[{"{", "b", "}"}]}], "]"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"a", " ", "-", " ", "b"}], ")"}]}], " ", "-", " ", 
      RowBox[{
       RowBox[{"Hlog", "[", 
        RowBox[{"z", ",", " ", 
         RowBox[{"{", "b", "}"}]}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"z", "-", "a"}], ")"}]}]}]}], " ", "*)"}], "\n", "\t", "\n", 
   "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Product", " ", "involving", " ", "Mpl"}], " ", "*)"}], "\n", 
   "\t", 
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Log", "[", "x", "]"}], " ", 
      RowBox[{"Mpl", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}]}], ",", " ", "x"}], 
    "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", "\n", "    ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", "x", "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"x", "-", "1"}], ")"}]}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Mpl", "[", 
           RowBox[{
            RowBox[{"{", "2", "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"x", " ", "y"}], "}"}]}], "]"}], "/", "x"}], "-", 
         RowBox[{"(", 
          RowBox[{"Mpl", "[", 
           RowBox[{
            RowBox[{"{", "2", "}"}], ",", 
            RowBox[{"{", "y", "}"}]}], "]"}], ")"}]}], ")"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"Mpl", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "2"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}], "]"}], "/", "x"}]}]}], " ", 
    "*)"}]}]}]], "Input",ExpressionUUID->"dc1ffcb7-6117-4547-939e-\
012c35edad1e"]
}, Open  ]],

