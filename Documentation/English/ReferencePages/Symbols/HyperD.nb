Notebook[{

Cell[CellGroupData[{
Cell["HyperD", "ObjectName",ExpressionUUID->"a9a661f5-3f5e-46af-b837-371f3bf2a9d8"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["HyperD", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"39291687-b4e4-41eb-b0ed-21084a79165b"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"8e46cfc1-0c3b-4fe3-b885-64f05e1be61a"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"b6e748ec-c368-416e-b951-c4c40c5455dd"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"f1526a4d-c514-4e60-904c-042edb34c331"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"08bb3f35-7a6b-44a3-b2a5-2f96c076b984"],

Cell["Derivatives", "Subsection",ExpressionUUID->"062040d1-eb9b-43ec-a060-86c88933e34f"],

Cell["\<\
HyperD[expr, var] computes the derivative of expr with respect to var, \
correctly implementing differentiation rules for Hlog and Mpl that the \
built-in Mathematica D[] does not handle. expr may contain Hlog, Mpl, \
PolyLog, logarithms, and algebraic functions, while var can appear in both \
the upper limit and the letters of hyperlogarithms. Some examples are: (see \
example below)\
\>", "Text",ExpressionUUID->"664f0ed4-6773-4ca6-81a3-55255bc0401a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Differentiate", " ", 
    RowBox[{"Li", "\\", "textcolor"}], 
    RowBox[{"{", "gray", "}"}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "}"}], "_", "2"}], "}"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"x", "/", "u"}]}], ")"}], " ", "with", " ", "respect", " ", 
    "to", " ", "x"}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], ",", " ", "x"}], "]"}], 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Mpl", "[", 
         RowBox[{
          RowBox[{"{", "1", "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"u", 
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"x", "/", "u"}]}], ")"}]}], ")"}]}], ")"}]}]}], " ", 
    "*)"}], "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Differentiate", " ", "Hlog", " ", "with", " ", "var"}], "-", 
     RowBox[{"dependent", " ", "letters"}]}], " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"z", ",", " ", 
       RowBox[{"{", 
        RowBox[{"a", ",", " ", "b"}], "}"}]}], "]"}], ",", " ", "a"}], "]"}], 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Hlog", "[", 
          RowBox[{"z", ",", " ", 
           RowBox[{"{", "a", "}"}]}], "]"}], " ", "-", " ", 
         RowBox[{"Hlog", "[", 
          RowBox[{"z", ",", " ", 
           RowBox[{"{", "b", "}"}]}], "]"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"a", " ", "-", " ", "b"}], ")"}]}], " ", "-", " ", 
      RowBox[{
       RowBox[{"Hlog", "[", 
        RowBox[{"z", ",", " ", 
         RowBox[{"{", "b", "}"}]}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"z", "-", "a"}], ")"}]}]}]}], " ", "*)"}], "\n", "\t", "\n", 
   "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Product", " ", "involving", " ", "Mpl"}], " ", "*)"}], "\n", 
   "\t", 
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Log", "[", "x", "]"}], " ", 
      RowBox[{"Mpl", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}]}], ",", " ", "x"}], 
    "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", "\n", "    ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", "x", "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"x", "-", "1"}], ")"}]}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Mpl", "[", 
           RowBox[{
            RowBox[{"{", "2", "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"x", " ", "y"}], "}"}]}], "]"}], "/", "x"}], "-", 
         RowBox[{"(", 
          RowBox[{"Mpl", "[", 
           RowBox[{
            RowBox[{"{", "2", "}"}], ",", 
            RowBox[{"{", "y", "}"}]}], "]"}], ")"}]}], ")"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"Mpl", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "2"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}], "]"}], "/", "x"}]}]}], " ", 
    "*)"}]}]}]], "Input",ExpressionUUID->"4f84bd59-2fce-41fd-a5a6-\
a57a50b193d7"]
}, Open  ]],

