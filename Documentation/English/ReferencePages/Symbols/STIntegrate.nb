Cell[CellGroupData[{

Cell["Exponents", "ExampleSubsection",ExpressionUUID->"1e127906-f502-4219-b30b-2a8bbdf8541b"],

Cell["Squared propagators and numerator insertions:", "ExampleText",ExpressionUUID->"2fb79b49-6fb7-476e-932e-d90763bfcb4c"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], " ", "-", " ", 
      RowBox[{"m", "^", "2"}]}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{"q", " ", 
      RowBox[{"l", "[", "1", "]"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", "1", ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}]}], "]"}]], "Input",Expression\
UUID->"c4690573-a620-4dfb-8f82-8033d967698c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Gauge", "ExampleSubsection",ExpressionUUID->"2eb1df98-42d7-4b98-a5fb-9936f54d0679"],

Cell["Fix a specific gauge instead of scanning:", "ExampleText",ExpressionUUID->"3951935d-ba45-4d48-a20d-b814128b9833"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", "\n",
    "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "2", "]"}], " ", "->", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "3", "]"}], " ", "->", " ", 
       RowBox[{"Sqrt", "[", "s", "]"}]}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Gauge\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"x3", " ", "->", " ", "1"}], "}"}]}]}], "]"}]], "Input",Expressio\
nUUID->"c4ec7ea2-35db-47e7-a1d7-0a7dd9708931"]
}, Open  ]],

Cell[CellGroupData[{

Cell["StopAt and StartAt", "ExampleSubsection",ExpressionUUID->"31b81b26-42cf-4c84-8b70-2d0bf06519ed"],

Cell["Pause the pipeline after building the integrand:", "ExampleText",ExpressionUUID->"9cc73e3c-f1d0-40ff-864a-af5d76577080"],

Cell[BoxData[
 RowBox[{"result", " ", "=", " ", 
  RowBox[{"STIntegrate", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"l", "[", "1", "]"}], "-", 
         RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", 
    "\n", "  ", 
    RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
       RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", "\n", "  ", 
    RowBox[{"\"\<StopAt\>\"", " ", "->", 
     " ", "\"\<AfterBuildingIntegrand\>\""}]}], "]"}]}]], "Input",ExpressionUU\
ID->"ace8a23d-7f79-4a07-90c0-29b5d5d1080a"],

Cell["Resume from a checkpoint:", "ExampleText",ExpressionUUID->"8bb762a4-b73f-44a9-8659-850894b77fb6"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", "\n",
    "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<StartAt\>\"", " ", "->", " ", 
    RowBox[{"result", "[", "\"\<CheckpointID\>\"", "]"}]}]}], "]"}]], "Input",\
ExpressionUUID->"a08b874a-48dd-4568-aa18-03899ada3ad6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["SelectFaces", "ExampleSubsection",ExpressionUUID->"17fb79bd-5967-473e-9ff1-1eb97a1606bb"],

Cell["Integrate only specific tropical faces:", "ExampleText",ExpressionUUID->"c17b1a8b-4e64-4af1-8f08-af92dc73844f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"First", " ", "obtain", " ", "a", " ", "checkpoint"}], " ", "*)"}],
   "\n", 
  RowBox[{
   RowBox[{"stage", " ", "=", " ", 
    RowBox[{"STIntegrate", "[", 
     RowBox[{"diag", ",", " ", 
      RowBox[{"\"\<StopAt\>\"", " ", "->", 
       " ", "\"\<AfterLinearOrder\>\""}]}], "]"}]}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Integrate", " ", "faces", " ", "1", " ", "and", " ", "4", " ", "only"}], 
    " ", "*)"}], "\n", 
   RowBox[{"STIntegrate", "[", 
    RowBox[{"diag", ",", " ", 
     RowBox[{"\"\<StartAt\>\"", " ", "->", " ", 
      RowBox[{"stage", "[", "\"\<CheckpointID\>\"", "]"}]}], ",", "\n", "  ", 
     
     RowBox[{"\"\<SelectFaces\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "4"}], "}"}]}]}], "]"}]}]}]], "Input",Expression\
UUID->"d1a30235-2c66-4b78-a261-33ed0cea003b"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Applications", "ExampleSection",ExpressionUUID->"959def6d-3187-4d37-8b64-6547727a0df7"],

Cell["\<\
Compute the one-loop contribution to the electron anomalous magnetic moment. \
The triangle diagram has two massive propagators (electron mass m) and one \
massless propagator (photon), with a numerator from the QED vertex:\
\>", "ExampleText",ExpressionUUID->"39139bb0-e846-4b09-828e-c9a8d3a6cb6f"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}], ",", "\n", "   ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"m", "^", "2"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"l", "[", "1", "]"}]}], " ", "+", " ", 
         RowBox[{"p", "[", "1", "]"}], " ", "+", " ", 
         RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}]}], ",", "\n", 
     "   ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"m", "^", "2"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}]}], ",", "\n", "   ", 
     RowBox[{"q", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "1", ",", " ", "1", ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", "m"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "2", "]"}], " ", "->", " ", "m"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "3", "]"}], " ", "->", " ", "0"}]}], "}"}]}], ",", 
   "\n", "  ", 
   RowBox[{"\"\<CleanOutput\>\"", " ", "->", " ", "True"}]}], "]"}]], "Input",\
ExpressionUUID->"7795bd73-b3a4-4656-aaa9-46c9fe6bb5dd"]
}, Open  ]]
}, Open  ]],

