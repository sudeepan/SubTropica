Cell["Scope", "ExampleSection",ExpressionUUID->"3cea0f62-c858-4499-a410-add9218f7d8c"],

Cell["\<\
Linearized (eikonal) propagators are supported alongside quadratic ones:\
\>", "ExampleText",ExpressionUUID->"d93c273b-ccb0-4be3-8bef-49b861ff6f9f"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"k", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"k", "[", "2", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"k", "[", "1", "]"}], "+", 
        RowBox[{"k", "[", "2", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"v", "[", "1", "]"}], " ", 
       RowBox[{"k", "[", "1", "]"}]}], "-", "1"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"v", "[", "2", "]"}], " ", 
       RowBox[{"k", "[", "2", "]"}]}], "-", "1"}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<LoopMomenta\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"k", "[", "1", "]"}], ",", " ", 
      RowBox[{"k", "[", "2", "]"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"v", "[", "1", "]"}], "^", "2"}], " ", "->", " ", "1"}], ",", 
      " ", 
      RowBox[{
       RowBox[{
        RowBox[{"v", "[", "2", "]"}], "^", "2"}], " ", "->", " ", "1"}]}], 
     "}"}]}]}], "]"}]], "Input",ExpressionUUID->"9ec8295e-02ba-4d52-84f4-\
9a2b08299322"]
}, Open  ]],

