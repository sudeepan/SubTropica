Cell[CellGroupData[{

Cell["Exponents", "ExampleSubsection",ExpressionUUID->"287c5c1b-ac1b-43cb-b923-80acb72ef121"],

Cell["Squared propagators and numerator insertions:", "ExampleText",ExpressionUUID->"cbcd988c-7b02-4060-8a76-e31771a9630b"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], " ", "-", " ", 
      RowBox[{"m", "^", "2"}]}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{"q", " ", 
      RowBox[{"l", "[", "1", "]"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", "1", ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}]}], "]"}]], "Input",Expression\
UUID->"9087c903-ff97-4767-b918-e909aa0e3a60"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Gauge", "ExampleSubsection",ExpressionUUID->"624b625b-020f-4426-844b-454812999719"],

Cell["Fix a specific gauge instead of scanning:", "ExampleText",ExpressionUUID->"703e7297-d051-42b6-b07c-2fbcb54d47be"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", "\n",
    "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "2", "]"}], " ", "->", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "3", "]"}], " ", "->", " ", 
       RowBox[{"Sqrt", "[", "s", "]"}]}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Gauge\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"x3", " ", "->", " ", "1"}], "}"}]}]}], "]"}]], "Input",Expressio\
nUUID->"7cdd6fbb-fb39-4abd-8250-a907e12b425f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["StopAt and StartAt", "ExampleSubsection",ExpressionUUID->"c8b2921e-822e-46dd-88bf-c2dda4a459e9"],

Cell["Pause the pipeline after building the integrand:", "ExampleText",ExpressionUUID->"4044c898-fc07-4745-9c9e-7d01f44a2413"],

Cell[BoxData[
 RowBox[{"result", " ", "=", " ", 
  RowBox[{"STIntegrate", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"l", "[", "1", "]"}], "-", 
         RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", 
    "\n", "  ", 
    RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
       RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", "\n", "  ", 
    RowBox[{"\"\<StopAt\>\"", " ", "->", 
     " ", "\"\<AfterBuildingIntegrand\>\""}]}], "]"}]}]], "Input",ExpressionUU\
ID->"39ee1f2d-d9e6-4de5-b884-8d30f03d4fbe"],

Cell["Resume from a checkpoint:", "ExampleText",ExpressionUUID->"c248a4d9-613f-485c-9775-234776b2f39f"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", "\n",
    "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<StartAt\>\"", " ", "->", " ", 
    RowBox[{"result", "[", "\"\<CheckpointID\>\"", "]"}]}]}], "]"}]], "Input",\
ExpressionUUID->"8593db0e-d24a-4b9a-af56-b94fb01bb293"]
}, Open  ]],

Cell[CellGroupData[{

Cell["SelectFaces", "ExampleSubsection",ExpressionUUID->"06b0b020-5dc1-433d-84c5-2c3acd7d8a4c"],

Cell["Integrate only specific tropical faces:", "ExampleText",ExpressionUUID->"d7be300f-379f-4310-a21d-a52de69a4fb5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"First", " ", "obtain", " ", "a", " ", "checkpoint"}], " ", "*)"}],
   "\n", 
  RowBox[{
   RowBox[{"stage", " ", "=", " ", 
    RowBox[{"STIntegrate", "[", 
     RowBox[{"diag", ",", " ", 
      RowBox[{"\"\<StopAt\>\"", " ", "->", 
       " ", "\"\<AfterLinearOrder\>\""}]}], "]"}]}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Integrate", " ", "faces", " ", "1", " ", "and", " ", "4", " ", "only"}], 
    " ", "*)"}], "\n", 
   RowBox[{"STIntegrate", "[", 
    RowBox[{"diag", ",", " ", 
     RowBox[{"\"\<StartAt\>\"", " ", "->", " ", 
      RowBox[{"stage", "[", "\"\<CheckpointID\>\"", "]"}]}], ",", "\n", "  ", 
     
     RowBox[{"\"\<SelectFaces\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "4"}], "}"}]}]}], "]"}]}]}]], "Input",Expression\
UUID->"2bd4cba6-eeea-4087-a151-b310961ba33c"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Applications", "ExampleSection",ExpressionUUID->"94aa4617-fd88-4ebc-bea4-f6f6b227d563"],

Cell["\<\
Compute the one-loop contribution to the electron anomalous magnetic moment. \
The triangle diagram has two massive propagators (electron mass m) and one \
massless propagator (photon), with a numerator from the QED vertex:\
\>", "ExampleText",ExpressionUUID->"a3ee0316-609b-4af1-8d0a-13386674784f"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}], ",", "\n", "   ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"m", "^", "2"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"l", "[", "1", "]"}]}], " ", "+", " ", 
         RowBox[{"p", "[", "1", "]"}], " ", "+", " ", 
         RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}]}], ",", "\n", 
     "   ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"m", "^", "2"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}]}], ",", "\n", "   ", 
     RowBox[{"q", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "1", ",", " ", "1", ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", "m"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "2", "]"}], " ", "->", " ", "m"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "3", "]"}], " ", "->", " ", "0"}]}], "}"}]}], ",", 
   "\n", "  ", 
   RowBox[{"\"\<CleanOutput\>\"", " ", "->", " ", "True"}]}], "]"}]], "Input",\
ExpressionUUID->"605a36fc-4a78-4ac7-ab08-52a43b5d35a5"]
}, Open  ]]
}, Open  ]],

