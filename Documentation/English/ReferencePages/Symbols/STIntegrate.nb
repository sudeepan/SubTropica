Cell[CellGroupData[{

Cell["Scope", "ExampleSection",ExpressionUUID->"c861c68c-4450-4764-b512-5a86deb69efc"],

Cell["\<\
Linearized (eikonal) propagators are supported alongside quadratic ones:\
\>", "ExampleText",ExpressionUUID->"b2eb7ed8-ce84-407d-bbac-8c64271b4c9a"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"k", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"k", "[", "2", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"k", "[", "1", "]"}], "+", 
        RowBox[{"k", "[", "2", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"v", "[", "1", "]"}], " ", 
       RowBox[{"k", "[", "1", "]"}]}], "-", "1"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"v", "[", "2", "]"}], " ", 
       RowBox[{"k", "[", "2", "]"}]}], "-", "1"}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<LoopMomenta\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"k", "[", "1", "]"}], ",", " ", 
      RowBox[{"k", "[", "2", "]"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"v", "[", "1", "]"}], "^", "2"}], " ", "->", " ", "1"}], ",", 
      " ", 
      RowBox[{
       RowBox[{
        RowBox[{"v", "[", "2", "]"}], "^", "2"}], " ", "->", " ", "1"}]}], 
     "}"}]}]}], "]"}]], "Input",ExpressionUUID->"06ad390c-92b8-41a5-8f2d-\
6b91b143ec19"]
}, Open  ]],

