e382328d4dc6"],

Cell["Include a numerator insertion using negative exponents:", "ExampleText",ExpressionUUID->"515e680a-d528-421f-97f9-ddd95a7cd1e1"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], " ", "-", " ", "mm"}], ",", 
     " ", 
     RowBox[{
      RowBox[{"q", "[", "1", "]"}], " ", 
      RowBox[{"l", "[", "1", "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"q", "[", "2", "]"}], " ", 
      RowBox[{"l", "[", "1", "]"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", 
      RowBox[{"-", "1"}], ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}]}], "]"}]], "Input",ExpressionUUID->\
"cff6ee2f-cd0e-441a-90f1-fc8f5180bb67"]
}, Open  ]],

