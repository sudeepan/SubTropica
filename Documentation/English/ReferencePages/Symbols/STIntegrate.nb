Notebook[{

Cell[CellGroupData[{
Cell["STIntegrate", "ObjectName",ExpressionUUID->"e0f18cc5-6f07-467f-9dfd-d2d1f0456f9d"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STIntegrate[]", "TI"],
     " \[LineSeparator]opens the interactive Feynman diagram GUI."
    }], "TableText",ExpressionUUID->"e8f7a518-837f-43ac-9393-a318704b63cc"]},
   {Cell[TextData[{
     StyleBox["STIntegrate[{edges, nodes}, opts]", "TI"],
     " \[LineSeparator]evaluates a Feynman integral specified by a graph \
topology."
    }], "TableText",ExpressionUUID->"dbdc3fc5-6ac7-4540-8f09-54f60669f639"]},
   {Cell[TextData[{
     StyleBox["STIntegrate[{propagators}, opts]", "TI"],
     " \[LineSeparator]evaluates a Feynman integral from a list of inverse \
propagators."
    }], "TableText",ExpressionUUID->"0f2e35bb-183a-4e1e-85ca-6c11b275b1b3"]},
   {Cell[TextData[{
     StyleBox[
     "STIntegrate[integrand, {x,0,1}, {y,0,\[Infinity]}, \[Ellipsis], opts]", 
      "TI"],
     " \[LineSeparator]evaluates a generic Euler integral with \
Mathematica-style limits."
    }], "TableText",ExpressionUUID->"5bd811a4-b019-4b15-b851-5cf634a6caed"]},
   {Cell[TextData[{
     StyleBox["STIntegrate[{pref, integrand, xvars, coeffs}, opts]", "TI"],
     " \[LineSeparator]evaluates from a pre-built integrand tuple."
    }], "TableText",ExpressionUUID->"5ed2eeaf-0b7d-46b4-ae69-7f1bbbb05264"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"bebc7465-e94f-45eb-8a35-fe6d0aec380e"],

Cell["\<\
STIntegrate is the main entry point of the SubTropica package. It automates \
the full pipeline: Symanzik polynomial construction, GL(1) gauge fixing, \
tropical subtraction, linear reducibility analysis, and integration via \
HyperIntica.\
\>", "Notes",ExpressionUUID->"dbebc2ca-2163-4011-95ee-313641666375"],

Cell["\<\
In the propagator-list form, each entry is an inverse propagator in the \
convention \[ScriptCapitalD]\[ThinSpace]=\[ThinSpace]q^2\[ThinSpace]-\
\[ThinSpace]m^2. Loop momenta l[i] are auto-detected; external momenta p[i] \
are identified as everything else.\
\>", "Notes",ExpressionUUID->"4ce20b0e-87c6-41c0-a6fd-2494f5f37cf9"],

Cell["\<\
In the graph-topology form, edges are tuples {{i, j}, mass} and nodes are \
tuples {vertex, Sqrt[p^2]}. SOFIASymanzik squares the node mass internally.\
\>", "Notes",ExpressionUUID->"39cd0e76-4bb3-4d2a-bb89-fd74b060d31f"],

Cell["\<\
The \"Exponents\" option controls which entries are propagators (positive \
exponents) vs numerators (negative exponents). Exponent 0 means the entry is \
ignored.\
\>", "Notes",ExpressionUUID->"014fa5d4-bde4-484f-b7e2-4a858d190f57"],

Cell["\<\
External masses are specified via \"Substitutions\" \[Rule] {M[1] \[Rule] m, \
\[Ellipsis]}, where M[i] is the mass (not mass squared) of external leg i.\
\>", "Notes",ExpressionUUID->"994a4a28-92a2-4911-bdbc-35e93a56b995"],

Cell["\<\
The default normalization includes a factor of Exp[L \[CurlyEpsilon] \
\[Gamma]] for an L-loop integral, where \[Gamma] is the \
Euler\[Dash]Mascheroni constant.\
\>", "Notes",ExpressionUUID->"82019809-b7e1-4879-bb72-66febb3e9d29"],

Cell["\<\
For bare-symbol inputs like STIntegrate[f, x, y, \[Ellipsis]], integration \
bounds default to {0, \[Infinity]}.\
\>", "Notes",ExpressionUUID->"50c1b9dc-1cb3-40c7-91d4-f91445d5162c"],

Cell["Valid integration bounds are 0, 1, and \[Infinity].", "Notes",ExpressionUUID->"0602b1f7-c08e-471c-a3fa-ef64769e9701"],

Cell["\<\
The full list of options and their allowed values can be queried with \
STOptionValues[].\
\>", "Notes",ExpressionUUID->"8c414927-e63f-49c9-a735-be246551c2a9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Options", "OptionsSection",ExpressionUUID->"dc2a9423-2b33-4e44-a4e5-47add331ad03"],

Cell[BoxData[GridBox[{
   {"\"\<Order\>\"", "Automatic", 
    RowBox[{"expansion", " ", "order", " ", "in", " ", "\[CurlyEpsilon]", " ", 
     RowBox[{"(", 
      RowBox[{"Automatic", " ", "=", " ", 
       RowBox[{
        RowBox[{"through", " ", 
         RowBox[{"\[CurlyEpsilon]", "^", "2"}]}], "=", "0"}]}], ")"}]}]},
   {"\"\<Dimension\>\"", 
    RowBox[{"4", " ", "-", " ", 
     RowBox[{"2", " ", "eps"}]}], 
    RowBox[{"spacetime", " ", "dimension"}]},
   {"\"\<Normalization\>\"", "Automatic", 
    RowBox[{"overall", " ", "prefactor", " ", 
     RowBox[{"(", 
      RowBox[{"Automatic", " ", "=", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{"L", " ", "\[CurlyEpsilon]", " ", "\[Gamma]"}], "]"}]}], 
      ")"}]}]},
   {"\"\<Substitutions\>\"", 
    RowBox[{"{", "}"}], 
    RowBox[{"kinematic", " ", "replacement", " ", "rules"}]},
   {"\"\<Representation\>\"", "\"\<Schwinger\>\"", 
    RowBox[{"\"\<Schwinger\>\"", " ", "or", " ", "\"\<LeePomeransky\>\""}]},
   {"\"\<Exponents\>\"", "Automatic", 
    RowBox[{
     RowBox[{"propagator", "/", "numerator"}], " ", "exponents"}]},
   {"\"\<LoopMomenta\>\"", "Automatic", 
    RowBox[{"loop", " ", "momenta", " ", 
     RowBox[{"(", 
      RowBox[{"auto", "-", 
       RowBox[{"detected", " ", "as", " ", 
        RowBox[{"l", "[", "i", "]"}]}]}], ")"}]}]},
   {"\"\<Gauge\>\"", "Automatic", 
    RowBox[{"gauge", " ", "choice", " ", 
     RowBox[{"(", 
      RowBox[{"Automatic", " ", "scans", " ", "all"}], ")"}]}]},
   {"\"\<IncludeGauges\>\"", "All", 
    RowBox[{
    "restrict", " ", "gauge", " ", "scan", " ", "to", " ", "specific", " ", 
     "indices"}]},
   {"\"\<Heuristic\>\"", "\"\<LeafCountLinear\>\"", 
    RowBox[{"scoring", " ", "metric", " ", "for", " ", 
     RowBox[{"gauge", "/", "LR"}], " ", "ranking"}]},
   {"\"\<CleanOutput\>\"", "False", 
    RowBox[{
    "apply", " ", "MZV", " ", "simplification", " ", "to", " ", "result"}]},
   {"\"\<SimplifyOutput\>\"", "Simplify", 
    RowBox[{
    "simplification", " ", "function", " ", "applied", " ", "to", " ", 
     "result"}]},
   {"\"\<Verbose\>\"", "False", 
    RowBox[{"print", " ", "progress", " ", "messages"}]},
   {"\"\<ShowTimings\>\"", "True", 
    RowBox[{"print", " ", "timing", " ", "for", " ", "each", " ", "stage"}]},
   {"\"\<KernelsAvailable\>\"", 
    RowBox[{"$ProcessorCount", "-", "1"}], 
    RowBox[{
     RowBox[{"number", " ", "of", " ", "parallel", " ", "sub"}], "-", 
     "kernels"}]},
   {"\"\<Parallelization\>\"", "All", 
    RowBox[{"integration", " ", "distribution", " ", "strategy"}]},
   {"\"\<StopAt\>\"", "Automatic", 
    RowBox[{
    "pause", " ", "pipeline", " ", "at", " ", "intermediate", " ", 
     "stage"}]},
   {"\"\<StartAt\>\"", "None", 
    RowBox[{
    "resume", " ", "from", " ", "a", " ", "saved", " ", "checkpoint"}]},
   {"\"\<SelectFaces\>\"", "All", 
    RowBox[{"target", " ", "specific", " ", "tropical", " ", "faces"}]},
   {"\"\<ReuseExistingResults\>\"", "True", 
    RowBox[{
    "skip", " ", "faces", " ", "with", " ", "results", " ", "on", " ", 
     "disk"}]},
   {"\"\<FindRoots\>\"", "False", 
    RowBox[{
    "factor", " ", "univariate", " ", "polynomials", " ", "in", " ", "LR", " ",
      "search"}]},
   {"\"\<MethodLR\>\"", "\"\<Espresso\>\"", 
    RowBox[{"LR", " ", 
     RowBox[{"algorithm", ":", " ", 
      RowBox[{"\"\<Espresso\>\"", " ", "or", " ", "\"\<Lungo\>\""}]}]}]},
   {"\"\<ContourHandling\>\"", "\"\<Abort\>\"", 
    RowBox[{
    "response", " ", "to", " ", "ambiguous", " ", "contour", " ", 
     "direction"}]}
  },
  GridBoxAlignment->{"Columns" -> {Left, Left, Left}},
  GridBoxDividers->{"Rows" -> {True, {False}, True}}]], "OptionsTable",Express\
ionUUID->"7142d786-a82e-460a-b798-c524f527a9bc"]
}, Open  ]],

