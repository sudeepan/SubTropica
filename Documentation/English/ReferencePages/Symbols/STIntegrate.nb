Cell["Evaluate a one-loop massless bubble:", "ExampleText",ExpressionUUID->"4bd3aa2e-6544-460b-9d32-dd93dd0d90e8"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", " ", 
   "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", " ", "\n", "  ", 
   RowBox[{"\"\<CleanOutput\>\"", " ", "->", " ", "True"}]}], "]"}]], "Input",\
ExpressionUUID->"7558d3aa-3d9f-4605-bebe-954f038cf0ea"],

