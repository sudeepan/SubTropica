Notebook[{

Cell[CellGroupData[{
Cell["ConvertToSymbol", "ObjectName",ExpressionUUID->"6b8f7e1f-6f6f-417c-a48f-edb20fbc880b"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["ConvertToSymbol", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"363d25af-1244-4ef9-aedf-d78b6dae48d9"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"0f90a7ed-23bb-4ea6-b90a-93464769f709"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"17965074-99f7-4b1b-87da-ce7757f4a8a9"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"eb0253f7-fd1b-4524-b6c3-11ec5f46a477"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"6b955f1d-8dc0-424a-9a4a-abe25a1c5a7b"],

Cell["Symbol", "Subsection",ExpressionUUID->"3289bfa5-105c-4b0a-8be7-49d52fc5f773"],

Cell["\<\
ConvertToSymbol[expr] converts an expression containing hyperlogarithms and \
multiple polylogarithms to its ``symbol'' . The available options are: (see \
example below) \"Expand\" -> True (default) factors each symbol letter into \
irreducible polynomials via FactorList, revealing the so-called ``symbol \
alphabet.''\
\>", "Text",ExpressionUUID->"686c42f9-63dd-4ed3-a634-588633c682c0"],

Cell[BoxData[
 RowBox[{"ConvertToSymbol", "[", 
  RowBox[{"expr", ",", " ", 
   RowBox[{"\"\<Expand\>\"", " ", "->", " ", "True"}], ",", "\n", 
   "\t               ", 
   RowBox[{"\"\<DropConstants\>\"", " ", "->", " ", "False"}]}], 
  "]"}]], "Input",ExpressionUUID->"33314194-2bf1-4212-9388-f2b97535946c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Symbol", " ", "of", " ", 
    RowBox[{"Li", "\\", "textcolor"}], 
    RowBox[{"{", "gray", "}"}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "}"}], "_", "2"}], "}"}], 
    RowBox[{"(", "z", ")"}]}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{"PolyLog", "[", 
     RowBox[{"2", ",", " ", "z"}], "]"}], "]"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"Sym", "[", 
      RowBox[{"{", 
       RowBox[{"z", ",", " ", 
        RowBox[{"1", "-", "z"}]}], "}"}], "]"}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", "Symbol", " ", "*)"}], "\n", "\t", 
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{
     RowBox[{"Log", "[", "x", "]"}], " ", 
     RowBox[{"Log", "[", 
      RowBox[{"1", "-", "x"}], "]"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"Sym", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", " ", "-", " ", "x"}], ",", " ", "x"}], "}"}], "]"}], 
      " ", "+", " ", 
      RowBox[{"Sym", "[", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", 
         RowBox[{"1", " ", "-", " ", "x"}]}], "}"}], "]"}]}]}], " ", "*)"}], 
   "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Without", " ", "factoring", " ", "letters"}], " ", "*)"}], "\n", 
   "\t", 
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"1", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"1", "-", "x"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"\"\<Expand\>\"", " ", "->", " ", "False"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"Sym", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{"x", " ", "-", " ", "1"}], ")"}]}], ",", " ", 
        RowBox[{"x", "/", 
         RowBox[{"(", 
          RowBox[{"1", " ", "-", " ", "x"}], ")"}]}]}], "}"}], "]"}]}], " ", 
    "*)"}]}]}]], "Input",ExpressionUUID->"a7f21494-a53c-4163-8839-\
7478e7b64c79"]
}, Open  ]],

