Notebook[{

Cell[CellGroupData[{
Cell["ConvertToSymbol", "ObjectName",ExpressionUUID->"3d621556-67f4-494f-b4aa-cbbf3c0d1621"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["ConvertToSymbol", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"9248194c-79ff-4f33-93d1-dc89db36ac89"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"190b5d96-4225-4275-b478-df46be01b7a6"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"6ef9f44f-72de-4d3a-a6d9-3ed1de94f39c"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"d6bdead5-5143-481b-945c-2da1124a1829"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"91fdee54-0494-46d9-9328-2d1bc83f3768"],

Cell["Symbol", "Subsection",ExpressionUUID->"8f04078a-bd7c-484b-a862-6e2572c8bc70"],

Cell["\<\
ConvertToSymbol[expr] converts an expression containing hyperlogarithms and \
multiple polylogarithms to its ``symbol'' . The available options are: (see \
example below) \"Expand\" -> True (default) factors each symbol letter into \
irreducible polynomials via FactorList, revealing the so-called ``symbol \
alphabet.''\
\>", "Text",ExpressionUUID->"98e29bf3-3f48-4494-bfce-73c253e57427"],

Cell[BoxData[
 RowBox[{"ConvertToSymbol", "[", 
  RowBox[{"expr", ",", " ", 
   RowBox[{"\"\<Expand\>\"", " ", "->", " ", "True"}], ",", "\n", 
   "\t               ", 
   RowBox[{"\"\<DropConstants\>\"", " ", "->", " ", "False"}]}], 
  "]"}]], "Input",ExpressionUUID->"39ae4946-37cd-415e-89b5-1ed42269a2cd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Symbol", " ", "of", " ", 
    RowBox[{"Li", "\\", "textcolor"}], 
    RowBox[{"{", "gray", "}"}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "}"}], "_", "2"}], "}"}], 
    RowBox[{"(", "z", ")"}]}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{"PolyLog", "[", 
     RowBox[{"2", ",", " ", "z"}], "]"}], "]"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"Sym", "[", 
      RowBox[{"{", 
       RowBox[{"z", ",", " ", 
        RowBox[{"1", "-", "z"}]}], "}"}], "]"}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", "Symbol", " ", "*)"}], "\n", "\t", 
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{
     RowBox[{"Log", "[", "x", "]"}], " ", 
     RowBox[{"Log", "[", 
      RowBox[{"1", "-", "x"}], "]"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"Sym", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", " ", "-", " ", "x"}], ",", " ", "x"}], "}"}], "]"}], 
      " ", "+", " ", 
      RowBox[{"Sym", "[", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", 
         RowBox[{"1", " ", "-", " ", "x"}]}], "}"}], "]"}]}]}], " ", "*)"}], 
   "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Without", " ", "factoring", " ", "letters"}], " ", "*)"}], "\n", 
   "\t", 
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"1", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"1", "-", "x"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"\"\<Expand\>\"", " ", "->", " ", "False"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"Sym", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{"x", " ", "-", " ", "1"}], ")"}]}], ",", " ", 
        RowBox[{"x", "/", 
         RowBox[{"(", 
          RowBox[{"1", " ", "-", " ", "x"}], ")"}]}]}], "}"}], "]"}]}], " ", 
    "*)"}]}]}]], "Input",ExpressionUUID->"9f896ae7-5921-4c98-9c0c-\
b54af2af70e3"]
}, Open  ]],

