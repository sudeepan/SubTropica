Notebook[{

Cell[CellGroupData[{
Cell["HyperSeries", "ObjectName",ExpressionUUID->"dfcb1f23-5e9f-42e0-9e4a-489fea5f2f51"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["HyperSeries", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"c29061a9-e194-45c4-a832-b08aec80b6b1"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"61223a2c-5615-47fa-9754-151ef768b1d7"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"d289c578-17e2-49be-9126-b5d4b1c46341"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"39ea1a1d-a765-4c96-a916-e9e4f0e33a33"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"527d5196-24a8-467c-a0da-154d143b96d2"],

Cell["Series", "Subsection",ExpressionUUID->"b915d72a-03e7-40fc-a422-62759f6da1ae"],

Cell["\<\
HyperSeries[expr, {var, point, order}] expands expr around var = point \
through O((var-point)^{order}), handling Hlog and Mpl when their arguments \
depend on the expansion variable (unlike the built-in Series). Some examples \
are: (see example below)\
\>", "Text",ExpressionUUID->"cd472033-39f4-40fb-9a69-db95cf3744aa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Expand", " ", 
     RowBox[{"Li", "\\", "textcolor"}], 
     RowBox[{"{", "gray", "}"}], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", "}"}], "_", "2"}], "}"}], 
     RowBox[{"(", "z", ")"}], " ", "around", " ", "z"}], " ", "=", " ", "0"}],
    " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", "z", "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"z", ",", " ", "0", ",", " ", "5"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"z", " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "2"}], "/", "4"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "3"}], "/", "9"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "4"}], "/", "16"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "5"}], "/", "25"}]}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Expand", " ", "with", " ", "parametric", " ", "dependence"}], 
    " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Pi", "^", "2"}], "/", "6"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x", "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"Log", "[", 
            RowBox[{"x", "/", "u"}], "]"}]}], ")"}]}], ")"}], "/", "u"}], " ",
       "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "2"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"2", "*", 
            RowBox[{"Log", "[", 
             RowBox[{"x", "/", "u"}], "]"}]}]}], ")"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", "*", 
         RowBox[{"u", "^", "2"}]}], ")"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "3"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"3", "*", 
            RowBox[{"Log", "[", 
             RowBox[{"x", "/", "u"}], "]"}]}]}], ")"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"9", "*", 
         RowBox[{"u", "^", "3"}]}], ")"}]}]}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Expand", " ", "Hlog", " ", "with", " ", "argument", " ", "approaching", " ",
      "0"}], " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}], "/", "z"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"z", ",", " ", "0", ",", " ", "4"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"-", "1"}], " ", "-", " ", 
      RowBox[{"z", "/", "4"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"z", "^", "2"}], "/", "9"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"z", "^", "3"}], "/", "16"}]}]}], " ", "*)"}]}]}]], "Input",Exp\
ressionUUID->"2ceb5a4c-73cf-4efb-b580-6514c5ed3910"]
}, Open  ]],

