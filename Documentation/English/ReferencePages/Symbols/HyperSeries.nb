Notebook[{

Cell[CellGroupData[{
Cell["HyperSeries", "ObjectName",ExpressionUUID->"4fd972b0-f943-493e-a5fa-525c7baa377a"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["HyperSeries", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"fe18ac80-b895-4106-819a-bd2608b4baa2"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"04213cea-85f7-4bc2-8129-47b1c2fc7542"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"0a78e77a-8d28-43d7-95e7-257400aa8fd3"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"daeb4de5-55c4-4d28-afd6-b2e1162a7d05"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"7a6ed209-c7cc-472c-97b9-3e150375bb6f"],

Cell["Series", "Subsection",ExpressionUUID->"0e2628bb-fd75-4fb6-890a-c44881114776"],

Cell["\<\
HyperSeries[expr, {var, point, order}] expands expr around var = point \
through O((var-point)^{order}), handling Hlog and Mpl when their arguments \
depend on the expansion variable (unlike the built-in Series). Some examples \
are: (see example below)\
\>", "Text",ExpressionUUID->"21dc2260-7a4b-4f3a-a799-90aeac582bf7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Expand", " ", 
     RowBox[{"Li", "\\", "textcolor"}], 
     RowBox[{"{", "gray", "}"}], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", "}"}], "_", "2"}], "}"}], 
     RowBox[{"(", "z", ")"}], " ", "around", " ", "z"}], " ", "=", " ", "0"}],
    " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", "z", "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"z", ",", " ", "0", ",", " ", "5"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"z", " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "2"}], "/", "4"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "3"}], "/", "9"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "4"}], "/", "16"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "5"}], "/", "25"}]}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Expand", " ", "with", " ", "parametric", " ", "dependence"}], 
    " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Pi", "^", "2"}], "/", "6"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x", "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"Log", "[", 
            RowBox[{"x", "/", "u"}], "]"}]}], ")"}]}], ")"}], "/", "u"}], " ",
       "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "2"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"2", "*", 
            RowBox[{"Log", "[", 
             RowBox[{"x", "/", "u"}], "]"}]}]}], ")"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", "*", 
         RowBox[{"u", "^", "2"}]}], ")"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "3"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"3", "*", 
            RowBox[{"Log", "[", 
             RowBox[{"x", "/", "u"}], "]"}]}]}], ")"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"9", "*", 
         RowBox[{"u", "^", "3"}]}], ")"}]}]}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Expand", " ", "Hlog", " ", "with", " ", "argument", " ", "approaching", " ",
      "0"}], " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}], "/", "z"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"z", ",", " ", "0", ",", " ", "4"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"-", "1"}], " ", "-", " ", 
      RowBox[{"z", "/", "4"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"z", "^", "2"}], "/", "9"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"z", "^", "3"}], "/", "16"}]}]}], " ", "*)"}]}]}]], "Input",Exp\
ressionUUID->"78fd4f63-3983-4e23-ab97-c113ba60127b"]
}, Open  ]],

