Notebook[{

Cell[CellGroupData[{
Cell["FibrationBasis", "ObjectName",ExpressionUUID->"0b0274a1-6fac-4d16-8297-061059d8d552"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["FibrationBasis", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"3286bb5f-0b72-4bc3-98c0-5f7ed692deac"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"56925d7a-6cb7-4199-a99c-2edaeb697926"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"a8a35783-811d-4e08-bab4-773d3d7e937e"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"17c6a375-7cc9-4479-a8fd-5cb09f34ab22"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"3a0199c1-e29d-4f3f-afc7-73d3449e3348"],

Cell["Fibration basis", "Subsection",ExpressionUUID->"363a5afa-5b7f-48d3-a3ca-9bada5a49ffa"],

Cell["\<\
FibrationBasis[expr, variables] rewrites an expression in a fibration basis, \
often making non-trivial functional identities between hyperlogarithms \
manifest. The argument expr accepts a symbolic expression (e.g., PolyLog or \
Hlog). The variables argument defines the fibration order x_1 \[Precedes] x_2 \
\[Precedes] \[Ellipsis] \[Precedes] x_n, where w_j = \
w_j(x_1,\[Ellipsis],x_n). The output can vary significantly with this \
ordering. The decomposition is based on the shuffle identity introduced \
earlier in ,\
\>", "Text",ExpressionUUID->"97c10edc-e667-48a4-82f7-a5128e04791b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Single", "-", 
    RowBox[{"variable", ":", " ", 
     RowBox[{
      RowBox[{"Li", "\\", "textcolor"}], 
      RowBox[{"{", "gray", "}"}], 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", "}"}], "_", "5"}], "}"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "z"}], ")"}], " ", "expressed", " ", "as", " ",
       "sum", " ", "of", "  ", "c_w", " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", "w"}], "]"}], "  ", "with", " ", "MZV", " ", 
      "coefficient", " ", "c_w"}]}]}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"FibrationBasis", "[", 
    RowBox[{
     RowBox[{"PolyLog", "[", 
      RowBox[{"5", ",", " ", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "z"}]}], "]"}], ",", " ", 
     RowBox[{"{", "z", "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0", ",", " ", "0", ",", " ", "0", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"z", ",", " ", 
       RowBox[{"{", 
        RowBox[{
        "0", ",", " ", "0", ",", " ", "0", ",", " ", "0", ",", " ", "0"}], 
        "}"}]}], "]"}], " ", "+", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}], "*", 
      RowBox[{"mzv", "[", "2", "]"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"7", "*", 
        RowBox[{"Hlog", "[", 
         RowBox[{"z", ",", " ", 
          RowBox[{"{", "0", "}"}]}], "]"}], "*", 
        RowBox[{
         RowBox[{"mzv", "[", "2", "]"}], "^", "2"}]}], ")"}], "/", "10"}]}], 
    "*)"}], "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Two", "-", 
     RowBox[{"variable", ":"}]}], " ", "*)"}], "\n", "\t", 
   RowBox[{"FibrationBasis", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"1", ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", " ", "+", " ", "x"}], ",", " ", 
         RowBox[{"1", " ", "+", " ", "y"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", 
         RowBox[{"y", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"x", ",", " ", 
       RowBox[{"{", 
        RowBox[{"y", ",", " ", "0"}], "}"}]}], "]"}], " ", "-", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"-", "1"}], "}"}]}], "]"}]}], " ", "+", "\n", "\t", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "y", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"-", "1"}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}]}], " ", "-", "\n", "\t", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "y", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"y", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"-", "1"}]}], "}"}]}], "]"}], " ", "-", " ", 
     RowBox[{"Hlog", "[", 
