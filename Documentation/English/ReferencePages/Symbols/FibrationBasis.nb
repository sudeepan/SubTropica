Notebook[{

Cell[CellGroupData[{
Cell["FibrationBasis", "ObjectName",ExpressionUUID->"5919f28c-ba4c-43b5-ad5b-bd5af2755a3f"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["FibrationBasis", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"b18c1273-f599-4717-ad89-fac1af36080b"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"f96af79e-4cf5-47cd-894e-d3669b0d8213"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"3b29e1d2-f43c-4a01-bc9a-79b2322a2eb2"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"c4961e11-278f-4937-ba84-b813cd4e4824"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"0c262a80-73e3-4492-b62a-90901a496774"],

Cell["Fibration basis", "Subsection",ExpressionUUID->"1c07803f-c496-4bee-9d6f-e4fed8d3eb68"],

Cell["\<\
FibrationBasis[expr, variables] rewrites an expression in a fibration basis, \
often making non-trivial functional identities between hyperlogarithms \
manifest. The argument expr accepts a symbolic expression (e.g., PolyLog or \
Hlog). The variables argument defines the fibration order x_1 \[Precedes] x_2 \
\[Precedes] \[Ellipsis] \[Precedes] x_n, where w_j = \
w_j(x_1,\[Ellipsis],x_n). The output can vary significantly with this \
ordering. The decomposition is based on the shuffle identity introduced \
earlier in ,\
\>", "Text",ExpressionUUID->"3218a4b4-9494-4258-9265-efbd839b3c7c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Single", "-", 
    RowBox[{"variable", ":", " ", 
     RowBox[{
      RowBox[{"Li", "\\", "textcolor"}], 
      RowBox[{"{", "gray", "}"}], 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", "}"}], "_", "5"}], "}"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "z"}], ")"}], " ", "expressed", " ", "as", " ",
       "sum", " ", "of", "  ", "c_w", " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", "w"}], "]"}], "  ", "with", " ", "MZV", " ", 
      "coefficient", " ", "c_w"}]}]}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"FibrationBasis", "[", 
    RowBox[{
     RowBox[{"PolyLog", "[", 
      RowBox[{"5", ",", " ", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "z"}]}], "]"}], ",", " ", 
     RowBox[{"{", "z", "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0", ",", " ", "0", ",", " ", "0", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"z", ",", " ", 
       RowBox[{"{", 
        RowBox[{
        "0", ",", " ", "0", ",", " ", "0", ",", " ", "0", ",", " ", "0"}], 
        "}"}]}], "]"}], " ", "+", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}], "*", 
      RowBox[{"mzv", "[", "2", "]"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"7", "*", 
        RowBox[{"Hlog", "[", 
         RowBox[{"z", ",", " ", 
          RowBox[{"{", "0", "}"}]}], "]"}], "*", 
        RowBox[{
         RowBox[{"mzv", "[", "2", "]"}], "^", "2"}]}], ")"}], "/", "10"}]}], 
    "*)"}], "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Two", "-", 
     RowBox[{"variable", ":"}]}], " ", "*)"}], "\n", "\t", 
   RowBox[{"FibrationBasis", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"1", ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", " ", "+", " ", "x"}], ",", " ", 
         RowBox[{"1", " ", "+", " ", "y"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", 
         RowBox[{"y", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"x", ",", " ", 
       RowBox[{"{", 
        RowBox[{"y", ",", " ", "0"}], "}"}]}], "]"}], " ", "-", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"-", "1"}], "}"}]}], "]"}]}], " ", "+", "\n", "\t", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "y", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"-", "1"}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}]}], " ", "-", "\n", "\t", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "y", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"y", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"-", "1"}]}], "}"}]}], "]"}], " ", "-", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"y", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0"}], "}"}]}], "]"}], " ", "-", "\n", "\t", 
     RowBox[{"mzv", "[", "2", "]"}]}], "*)"}]}]}]], "Input",ExpressionUUID->\
"4527a284-f814-4401-87a4-c444655c5aad"]
}, Open  ]],

