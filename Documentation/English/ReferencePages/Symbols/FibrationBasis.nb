       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0"}], "}"}]}], "]"}], " ", "-", "\n", "\t", 
     RowBox[{"mzv", "[", "2", "]"}]}], "*)"}]}]}]], "Input",ExpressionUUID->\
"3db26f44-3e5f-45df-8353-2f0d1d261068"]
