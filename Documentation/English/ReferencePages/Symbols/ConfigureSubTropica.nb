Notebook[{

Cell[CellGroupData[{
Cell["ConfigureSubTropica", "ObjectName",ExpressionUUID->"1c400f4e-75b6-42ef-ac1c-f7d4f198f87a"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["ConfigureSubTropica[opt -> val, ...]", "TI"],
     " \[LineSeparator]sets external-tool paths (PolymakePath, GinshPath, \
MaplePath, HyperIntPath, HyperFlintPath, PythonPath, FiniteFlowPath, \
SPQRPath, FIESTAPath, AMFlowPath, LiteRedPath, LiteIBPPath, FIREPath, \
FeyntropPath, IterIntPath, SymbolicEvaluator, KiraPath, NeatIBPPath, \
SingularPath, PolyLogToolsPath, LibraPath, DiffExpPath, FermatPath, FormPath, \
MsolvePath, PolymakeConcurrencyFraction). IterIntPath points at the \
iterint_mpfr driver (or IterInt repo dir); SymbolicEvaluator is \"ginsh\" \
(default) or \"iterint\" and selects which evaluator STVerify uses for the \
symbolic Hlog/Log/zeta result. Only options that are explicitly named are \
updated; omitted options leave the current global state unchanged (no silent \
reset to package defaults). The configuration is auto-persisted to \
$STConfigFile and reapplied on the next Get[\"SubTropica`\"], so you only \
need to call this once per machine."
    }], "TableText",ExpressionUUID->"e8498193-c35a-44f1-b209-523830941b16"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"639ca7be-f1aa-4ebd-81a0-ec345bbe3413"]
}, Open  ]],

