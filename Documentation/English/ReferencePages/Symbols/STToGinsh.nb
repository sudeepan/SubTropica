Notebook[{

Cell[CellGroupData[{
Cell["STToGinsh", "ObjectName",ExpressionUUID->"3c8918b0-b34a-4e6a-a4e6-8a0c438dfd0e"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STToGinsh", "TI"],
     " \[LineSeparator]STNIntegrate numerically evaluates integrals."
    }], "TableText",ExpressionUUID->"6a2ae3b2-671f-4d73-8f77-7b6b583f9ac1"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"b4f5f785-9bb0-42db-8c44-8f136ef8c6b6"],

Cell["\<\
STNIntegrate numerically evaluates integrals. It accepts all the same input \
formats as STIntegrate (Forms~1--3), including generic parametric \
representations.\
\>", "Notes",ExpressionUUID->"21ffc488-9e94-48dd-8c51-cd194d9017c2"],

Cell[BoxData[
 RowBox[{"STNIntegrate", "[", 
  RowBox[{"input", "\n", "    ", ",", " ", 
   RowBox[{"\"\<Method\>\"", "             ", "->", " ", "\"\<pySecDec\>\""}],
    "\n", "    ", ",", " ", 
   RowBox[{"\"\<Substitutions\>\"", "     ", "->", " ", 
    RowBox[{"{", "}"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Order\>\"", "              ", "->", " ", "0"}], "\n", "    ", 
   ",", " ", 
   RowBox[{"\"\<MaxEval\>\"", "            ", "->", " ", 
    RowBox[{"10", "^", "7"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Accuracy\>\"", "           ", "->", " ", 
    RowBox[{"10", "^", 
     RowBox[{"-", "4"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Integrator\>\"", "         ", "->", " ", "\"\<Qmc\>\""}], 
   "\n", "    ", ",", " ", 
   RowBox[{"\"\<ContourDeformation\>\"", " ", "->", " ", "True"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Verbose\>\"", "            ", "->", " ", "False"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Dimension\>\"", "          ", "->", " ", 
    RowBox[{"4", " ", "-", " ", 
     RowBox[{"2", " ", "eps"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Normalization\>\"", "      ", "->", " ", "Automatic"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Exponents\>\"", "          ", "->", " ", "Automatic"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Substitutions\>\"", "      ", "->", " ", 
    RowBox[{"{", "}"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<CacheDirectory\>\"", "     ", "->", " ", "Automatic"}]}], 
  "]"}]], "Input",ExpressionUUID->"c2c82783-8b17-474a-a76c-fe6c505fe7e1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"784dee6a-0dc0-4c8f-9ec3-309e5caae470"],

Cell["Numerical evaluation of hyperlogarithms: STToGinsh", "Subsection",ExpressionUUID->"0751db56-2c97-47a6-a8bb-d9843d6c614b"],

Cell["\<\
STToGinsh[expr] numerically evaluates hyperlogarithm expressions via ginsh, \
the GiNaC interactive shell (requires ginsh installed and on the system \
path). It accepts Hlog, Mpl, mzv/zeta, and Log objects, converts them to \
GiNaC format internally, and returns a floating-point approximation. \
Expressions containing none of these are returned unchanged. A simple example \
of usage is:  (see example below)\
\>", "Text",ExpressionUUID->"fcc14ec5-214b-4ba5-9e7c-0f1ce96178db"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Evaluate", " ", "an", " ", "expression", " ", "with", " ", "Hlogs", " ", 
    "and", " ", "MZVs"}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"result", " ", "=", " ", 
    RowBox[{"STToGinsh", "[", 
     RowBox[{
      RowBox[{"3", " ", 
       RowBox[{"Hlog", "[", 
        RowBox[{"2", ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}], " ", "+", " ", 
      RowBox[{"mzv", "[", "3", "]"}]}], "]"}]}], "\n", "    ", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"-", "6.20015"}], " ", "+", " ", 
      RowBox[{"6.53276", " ", "I"}]}]}], " ", "*)"}]}]}]], "Input",ExpressionU\
UID->"6df1af99-717d-4af7-a1a5-13bb87c4b9a2"]
}, Open  ]],

