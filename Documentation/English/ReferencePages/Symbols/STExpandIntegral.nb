Notebook[{

Cell[CellGroupData[{
Cell["STExpandIntegral", "ObjectName",ExpressionUUID->"7d717b68-8f94-4081-af9f-681da5234ebe"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STExpandIntegral", "TI"],
     " \[LineSeparator]~."
    }], "TableText",ExpressionUUID->"1f31ac7e-5879-4ded-860b-5d882a1a433a"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"39f20da3-016c-4bc3-a57c-bb425a85537b"],

Cell["\<\
STExpandIntegral is the core routine that reduces a (potentially divergent) \
Euler integral to a sum of locally finite integrals, applying the \
Nilsson--Passare procedure followed by tropical subtractions as described in \
Sec.~. It takes three required and three optional positional arguments: (see \
example below)\
\>", "Notes",ExpressionUUID->"c265269c-8ee7-4280-9faa-a258c04d0392"],

Cell[BoxData[
 RowBox[{
  RowBox[{"STExpandIntegral", "[", 
   RowBox[{
   "integrand", ",", " ", "variables", ",", " ", "coeffs", "\n", "\t", ",", 
    " ", 
    RowBox[{"{", "eps", "}"}], "  ", 
    RowBox[{"(*", " ", 
     RowBox[{"regulators", ",", " ", "optional"}], " ", "*)"}], "\n", "\t", ",",
     " ", 
    RowBox[{"{", "}"}], "     ", 
    RowBox[{"(*", " ", 
     RowBox[{"trDataGiven", ",", " ", "optional"}], " ", "*)"}], "\n", "\t", ",",
     " ", 
    RowBox[{"{", "}"}]}], "   ", "]"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"forceUs", ",", " ", "optional"}], " ", "*)"}]}]], "Input",Expressi\
onUUID->"5797bc3c-1b45-4af0-8985-1ec680c1567e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"4aa4bf8c-cec1-4269-b969-7cbac440b019"],

Cell["Required arguments", "Subsection",ExpressionUUID->"53ae6491-eb4a-4eb3-a359-b542108a15df"],

Cell["\<\
integrand is an Euler-type integrand, expressed as a product of polynomials \
raised to powers that depend on the dimensional regulator (see ). variables \
is the list of integration variables (Feynman or Schwinger parameters, \
denoted x_j=xj), and coeffs lists the kinematic coefficients appearing in \
those polynomials.\
\>", "Text",ExpressionUUID->"64d0b5ef-36ad-48a2-9e63-09af208cb5cc"],

Cell["Return value", "Subsection",ExpressionUUID->"e7e9396a-a000-413e-8040-864b45ba92f7"],

Cell["\<\
The function returns a list {{prefactor, subtraction}, ...}, one entry per \
Nilsson--Passare continuation term. Each subtraction is itself a list \
{{faceIntegrand, faceVariables}, ...} indexed by the divergent faces of the \
Newton polytope. Here faceIntegrand is a list of additive terms whose sum is \
locally finite and ready to be passed to HyperIntica.\
\>", "Text",ExpressionUUID->"9d9c718e-1899-4e90-aa5b-eb88980cc095"],

Cell["Optional arguments", "Subsection",ExpressionUUID->"d10871b2-8d95-4523-bc99-c7922e760346"],

Cell["\<\
regulators (default {eps}) lists the dimensional regulators used to identify \
which rays of the Newton polytope correspond to divergences. trDataGiven \
(default {}) accepts pre-computed tropical data, skipping the Polymake call. \
When STIntegrate is used, tropical data for all gauge candidates is computed \
concurrently upfront and passed through this argument. forceUs (default {}) \
pins specific u-variables for both the NP continuation and the subtraction \
formula.\
\>", "Text",ExpressionUUID->"976b675b-1ce4-4564-b502-707d7859cd94"]
}, Open  ]],

