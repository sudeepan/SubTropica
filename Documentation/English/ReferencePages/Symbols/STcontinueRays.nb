Notebook[{

Cell[CellGroupData[{
Cell["STcontinueRays", "ObjectName",ExpressionUUID->"d6b593d9-40b2-430f-a12d-9ea06feff651"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STcontinueRays", "TI"],
     " \[LineSeparator]STcontinueRays performs the Nilsson--Passare \
analytical continuation along a specified set of rays of the Newton polytope, \
extracting pole contributions before the subtraction formula is applied."
    }], "TableText",ExpressionUUID->"63029324-fd4c-4162-85c8-91ac1b984e4e"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"17886eee-2e1a-4f7d-b221-20b287c8922a"],

Cell["\<\
STcontinueRays performs the Nilsson--Passare analytical continuation along a \
specified set of rays of the Newton polytope, extracting pole contributions \
before the subtraction formula is applied. It is called internally by \
STExpandIntegral, but can also be invoked directly when finer control over \
the continuation is needed (see the small-x example in Sec.~ for a worked \
illustration).  (see example below)\
\>", "Notes",ExpressionUUID->"4f31cbc3-f7ea-4abb-b93e-5803034a3af9"],

Cell[BoxData[
 RowBox[{"STcontinueRays", "[", 
  RowBox[{"prefsInts", ",", " ", "variables", ",", " ", "rays"}], 
  "]"}]], "Input",ExpressionUUID->"cffd4b4e-730e-42a5-bc82-2ced93ae2e9e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"a756b4e4-88f5-4523-93af-4cd6956217fb"],

Cell["Arguments", "Subsection",ExpressionUUID->"2aebf8ca-68fb-4e73-b12b-8d14decf40ca"],

Cell["\<\
prefsInts is a list of pairs {prefactor, integrand}, where each pair \
represents a term in the Euler integral. variables is the list of integration \
variables. rays is a list of rays (integer vectors) along which the \
continuation is to be performed. Inputing an empty list {} returns the input \
unchanged. The function processes the rays recursively, one at a time.\
\>", "Text",ExpressionUUID->"ae23a5c8-3c81-4445-b66f-55abf68fb01d"],

Cell["Return value", "Subsection",ExpressionUUID->"24dfd7de-2240-497e-9a3a-5efe0b2cb6ec"],

Cell["\<\
A list of pairs {prefactor, integrand} after the continuation has been \
performed. Each resulting term can then be passed to STExpandIntegral for \
tropical subtraction.\
\>", "Text",ExpressionUUID->"80fb5485-0dc7-49cf-b1e7-7b3bb3f0522d"]
}, Open  ]],

